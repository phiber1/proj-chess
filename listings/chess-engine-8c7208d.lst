   2314   8c                GLO 12
   2315   fb 08             XRI $08
   2317   ac                PLO 12              ; C = color restored
                        
                            ; Restore R9 (move list pointer) from ply-indexed memory
   2318   68 ca 64 48       RLDI 10, CURRENT_PLY
   231c   0a                LDN 10              ; D = ply
   231d   fe                SHL                 ; D = ply * 2
   231e   fc db             ADI LOW(LOOP_MOVE_PTR)
   2320   aa                PLO 10
   2321   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   2323   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   2324   4a                LDA 10
   2325   b9                PHI 9               ; R9.hi
   2326   0a                LDN 10
   2327   a9                PLO 9               ; R9 = move list pointer restored
                        
                            ; Load score from SCORE memory into R13 (R9 is move list pointer!)
                            ; Big-endian: high byte at lower address (SCORE_HI)
   2328   68 ca 64 46       RLDI 10, SCORE_HI
   232c   4a                LDA 10              ; SCORE_HI -> high byte
   232d   bd                PHI 13
   232e   0a                LDN 10              ; SCORE_LO -> low byte
   232f   ad                PLO 13              ; R13 = negated score from memory
                        
                            ; -----------------------------------------------
                            ; Beta Cutoff Check: if (score >= beta) return beta
                            ; -----------------------------------------------
