   0bf2   d4 58 22          CALL HASH_XOR_SIDE
                        
   0bf5   f8 00             LDI 0               ; Return success
   0bf7   d5                SEP 5
                        
                        ; ------------------------------------------------------------------------------
                        ; MM_ROOK_HOME_CHECK - Check if square is a rook home square
                        ; ------------------------------------------------------------------------------
                        ; If so, clear the corresponding castling right.
                        ; Input: D = square to check
                        ; Clobbers: R10, R13 (via CLEAR_CASTLING_RIGHT)
                        ; Note: Called from MAKE_MOVE for both FROM and TO squares.
                        ;       FROM handles rook moving away; TO handles rook being captured.
                        ; ------------------------------------------------------------------------------
   0bf8                 MM_ROOK_HOME_CHECK:
   0bf8   c2 0c 0b          LBZ MMRHC_A1         ; $00 = a1 → white queenside
   0bfb   fb 07             XRI $07
   0bfd   c2 0c 10          LBZ MMRHC_H1         ; $07 = h1 → white kingside
   0c00   fb 77             XRI $77
   0c02   c2 0c 15          LBZ MMRHC_A8         ; $70 = a8 → black queenside
   0c05   fb 07             XRI $07
   0c07   c2 0c 1a          LBZ MMRHC_H8         ; $77 = h8 → black kingside
   0c0a   d5                RETN                 ; No match, return
                        
   0c0b                 MMRHC_A1:
   0c0b   f8 02             LDI CASTLE_WQ        ; $02
   0c0d   c0 0c 1c          LBR MMRHC_CLEAR
                        
   0c10                 MMRHC_H1:
   0c10   f8 01             LDI CASTLE_WK        ; $01
   0c12   c0 0c 1c          LBR MMRHC_CLEAR
                        
   0c15                 MMRHC_A8:
   0c15   f8 08             LDI CASTLE_BQ        ; $08
   0c17   c0 0c 1c          LBR MMRHC_CLEAR
                        
   0c1a                 MMRHC_H8:
   0c1a   f8 04             LDI CASTLE_BK        ; $04
                        
   0c1c                 MMRHC_CLEAR:
   0c1c   d4 01 5c          CALL CLEAR_CASTLING_RIGHT
   0c1f   d5                RETN
                        
                        ; ==============================================================================
                        ; UNMAKE_MOVE - Reverse the last move
                        ; Input: Undo info from previous MAKE_MOVE
                        ; Output: Board restored to previous state
                        ; ==============================================================================
   0c20                 UNMAKE_MOVE:
                            ; Get moving piece from to square
   0c20   68 c9 64 0a       RLDI 9, UNDO_TO
   0c24   09                LDN 9               ; D = to square
