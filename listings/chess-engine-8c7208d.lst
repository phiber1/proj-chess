   1294   0b                LDN 11
   1295   ff 02             SMI 2
   1297   cb 12 a2          LBNF EVAL_NO_BBP
   129a   89                GLO 9
   129b   ff 1e             SMI 30
   129d   a9                PLO 9
   129e   99                GHI 9
   129f   7f 00             SMBI 0
   12a1   b9                PHI 9                       ; R9 -= 30 (black bishop pair)
   12a2                 EVAL_NO_BBP:
                        
                            ; ==================================================================
                            ; Rook on Open/Semi-Open File
                            ; +20cp open (no friendly pawns, no enemy pawns on file)
                            ; +10cp semi-open (no friendly pawns, enemy pawns present)
                            ; ==================================================================
                        
