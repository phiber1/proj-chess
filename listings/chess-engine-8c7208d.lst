   0af4   fc 01             ADI 1                ; D = to + 1
   0af6   a8                PLO 8
   0af7   f8 60             LDI HIGH(BOARD)
   0af9   b8                PHI 8               ; R8 = &BOARD[to+1]
   0afa   9d                GHI 13              ; D = rook piece
   0afb   58                STR 8               ; Place rook at d1/d8
                        
                            ; Hash: XOR out [rook, to-2]
   0afc   9d                GHI 13              ; D = rook piece
   0afd   a8                PLO 8               ; R8.0 = rook piece
   0afe   09                LDN 9               ; D = to square
   0aff   ff 02             SMI 2                ; D = to - 2 (rook's old square)
   0b01   b8                PHI 8               ; R8.1 = old rook square
   0b02   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
