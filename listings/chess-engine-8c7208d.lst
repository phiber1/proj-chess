   08b0   c2 08 c5          LBZ GEN_SLIDE_W_RET
   08b3   9b                GHI 11
   08b4   bd                PHI 13
   08b5   87                GLO 7
   08b6   ad                PLO 13
   08b7   f8 00             LDI MOVE_NORMAL
   08b9   d4 03 e9          CALL ADD_MOVE_ENCODED
   08bc   8b                GLO 11              ; Get result from R11.0
   08bd   fb 02             XRI 2
   08bf   c2 08 c5          LBZ GEN_SLIDE_W_RET
   08c2   c0 08 a1          LBR GEN_SLIDE_W_LOOP
   08c5                 GEN_SLIDE_W_RET:
