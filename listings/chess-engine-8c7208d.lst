   12a2   68 cb 64 b1       RLDI 11, EVAL_W_ROOK_F1
   12a6   0b                LDN 11
   12a7   fb ff             XRI $FF
   12a9   c2 13 18          LBZ EVAL_WR_DONE            ; no white rook 1
                            ; Check white pawn count on this file
   12ac   0b                LDN 11                      ; D = file (reload, XRI changed D)
   12ad   fc 10             ADI LOW(W_PAWN_FILE_CT)
   12af   ab                PLO 11
   12b0   f8 67             LDI HIGH(W_PAWN_FILE_CT)
   12b2   7c 00             ADCI 0
   12b4   bb                PHI 11                      ; R11 = &W_PAWN_FILE_CT[file]
   12b5   0b                LDN 11
   12b6   ca 12 dd          LBNZ EVAL_WR1_CLOSED        ; friendly pawns on file, no bonus
                            ; No friendly pawns. Check enemy pawns for open vs semi-open.
   12b9   68 cb 64 b1       RLDI 11, EVAL_W_ROOK_F1
   12bd   0b                LDN 11                      ; D = file
