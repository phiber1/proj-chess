   0c56   c2 0c 67          LBZ UM_NOT_PROMOTION ; EMPTY piece = nothing to un-promote
   0c59   68 c9 64 04       RLDI 9, UNDO_PROMOTION
   0c5d   09                LDN 9               ; D = promotion type (0 if none)
   0c5e   c2 0c 67          LBZ UM_NOT_PROMOTION
                        
