   2334   4a                LDA 10              ; D = beta_hi
   2335   b7                PHI 7
   2336   0a                LDN 10              ; D = beta_lo
   2337   a7                PLO 7               ; R7 = beta (loaded from memory)
                        
                            ; SIGNED comparison: score (R13) vs beta (R7)
                            ; Use COMPARE_TEMP for scratch (NEVER use STR 2 for scratch!)
   2338   68 ca 64 49       RLDI 10, COMPARE_TEMP
   233c   ea                SEX 10              ; X = R10 for comparisons
                        
