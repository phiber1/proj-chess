   0b62   09                LDN 9
   0b63   fc f0             ADI DIR_N           ; to - $10 (square pawn passed through)
   0b65   58                STR 8               ; STATE_EP_SQUARE = EP target
   0b66   c0 0b 77          LBR MM_EP_DONE
                        
   0b69                 MM_EP_BLACK:
                            ; EP square = to + DIR_S ($10) = one rank below destination
   0b69   68 c9 64 0a       RLDI 9, UNDO_TO
   0b6d   09                LDN 9
   0b6e   fc 10             ADI DIR_S           ; to + $10 (square pawn passed through)
   0b70   58                STR 8               ; STATE_EP_SQUARE = EP target
   0b71   c0 0b 77          LBR MM_EP_DONE
                        
   0b74                 MM_EP_CLEAR:
   0b74   f8 ff             LDI NO_EP
   0b76   58                STR 8
                        
   0b77                 MM_EP_DONE:
                        
                            ; ===========================================
                            ; FIFTY-MOVE RULE: Update halfmove clock
                            ; ===========================================
