   0c2f   09                LDN 9               ; D = cap_sq
   0c30   a8                PLO 8
   0c31   f8 60             LDI HIGH(BOARD)
   0c33   b8                PHI 8               ; R8 = &BOARD[cap_sq]
   0c34   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0c38   09                LDN 9
   0c39   58                STR 8               ; BOARD[cap_sq] = captured piece
                        
