   0bd0   68 ca 64 08       RLDI 10, UNDO_CAPTURED
   0bd4   0a                LDN 10              ; D = captured piece
   0bd5   a8                PLO 8               ; R8.0 = captured piece
   0bd6   68 ca 64 ff       RLDI 10, UNDO_CAP_SQ
   0bda   0a                LDN 10              ; D = capture square
   0bdb   b8                PHI 8               ; R8.1 = capture square
