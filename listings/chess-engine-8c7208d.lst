   0b58   c2 0b 69          LBZ MM_EP_BLACK     ; Black pawn double push
   0b5b   c0 0b 74          LBR MM_EP_CLEAR     ; Not a double push
                        
   0b5e                 MM_EP_WHITE:
                            ; EP square = to + DIR_N ($F0) = one rank above destination
