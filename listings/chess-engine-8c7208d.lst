                            ; -----------------------------------------------
   2498   68 ca 64 48       RLDI 10, CURRENT_PLY
   249c   0a                LDN 10             ; D = ply
   249d   fc ef             ADI LOW(LOOP_MOVE_CNT)
   249f   aa                PLO 10
   24a0   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   24a2   ba                PHI 10             ; R10 = &LOOP_MOVE_CNT[ply]
   24a3   0a                LDN 10             ; D = move count
   24a4   ff 01             SMI 1              ; Decrement
   24a6   5a                STR 10             ; LOOP_MOVE_CNT[ply]-- (D still holds new value)
   24a7   c2 24 ad          LBZ NEGAMAX_LOOP_DONE ; If count == 0, exit loop (long branch)
   24aa   c0 1f 66          LBR NEGAMAX_MOVE_LOOP
                        
   24ad                 NEGAMAX_LOOP_DONE:
                            ; Count (now in LOOP_MOVE_CNT[ply], not the stack) reached 0.
                            ; R2 was never perturbed by count management — no stack re-sync needed.
                        
                            ; Check if any legal move updated BEST_SCORE.
                            ; If BEST_SCORE is still $8001 (initial sentinel), no legal move
                            ; was found - all pseudo-legal moves left king in check.
                            ; This is checkmate or stalemate; handle via NEGAMAX_NO_MOVES.
                            ; (R2 is at the function-entry position; count is in LOOP_MOVE_CNT, not stack)
   24ad   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   24b1   4a                LDA 10              ; D = BEST_SCORE_HI
   24b2   fb 80             XRI $80
   24b4   ca 24 c0          LBNZ NEGAMAX_RETURN ; BEST_SCORE_HI != $80 → a legal move was scored
   24b7   0a                LDN 10              ; D = BEST_SCORE_LO
   24b8   fb 01             XRI $01
   24ba   ca 24 c0          LBNZ NEGAMAX_RETURN ; BEST_SCORE_LO != $01 → a legal move was scored
                        
                            ; BEST_SCORE == $8001: no legal move improved the sentinel.
                            ; All pseudo-legal moves were illegal → checkmate or stalemate.
   24bd   c0 25 0a          LBR NEGAMAX_NO_MOVES
                        
   24c0                 NEGAMAX_RETURN:
                            ; -----------------------------------------------
                            ; Return best score (from BEST_SCORE memory) via R9
                            ; -----------------------------------------------
                            ; Move count now lives in LOOP_MOVE_CNT[ply], never on the stack, so R2
                            ; is already at the function-entry position here — no count byte to pop.
                            ; (Was: IRX to skip a stack-resident move count. See LOOP_MOVE_CNT.)
                        
                            ; Copy BEST_SCORE to SCORE memory BEFORE restore (RESTORE clobbers R9!)
                            ; Best score is in BEST_SCORE_HI/LO, copy to SCORE_HI/LO for return
   24c0   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   24c4   4a                LDA 10              ; BEST_SCORE_HI
   24c5   b8                PHI 8               ; Temp in R8.1
   24c6   0a                LDN 10              ; BEST_SCORE_LO
   24c7   a8                PLO 8               ; Temp in R8.0
                        
   24c8   68 ca 64 46       RLDI 10, SCORE_HI
   24cc   98                GHI 8               ; Best score high byte
   24cd   5a                STR 10
   24ce   1a                INC 10
   24cf   88                GLO 8               ; Best score low byte
   24d0   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Store result in Transposition Table
                            ; -----------------------------------------------
                            ; Hash is updated incrementally in MAKE/UNMAKE_MOVE,
                            ; so TT works correctly at all nodes.
                        
                            ; TT_STORE expects: D = depth, R8.0 = flag, SCORE_HI/LO and BEST_MOVE set
                            ; -- Load TT node flag for current ply --
   24d1   68 ca 64 48       RLDI 10, CURRENT_PLY
   24d5   0a                LDN 10
   24d6   fc d2             ADI LOW(NODE_TT_FLAGS)
   24d8   aa                PLO 10
   24d9   f8 64             LDI HIGH(NODE_TT_FLAGS)
   24db   ba                PHI 10
   24dc   0a                LDN 10              ; D = flag
   24dd   a8                PLO 8               ; R8.0 = flag
   24de   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   24e2   0a                LDN 10              ; D = depth (low byte = actual depth)
   24e3   d4 57 5f          CALL TT_STORE
                        
                            ; Restore caller's context (clobbers R7, R8, R9, R11, R12)
   24e6   d4 00 54          CALL RESTORE_PLY_STATE
                        
                            ; Load return value back into R9 AFTER restore
                            ; Big-endian: load high byte from lower address first
   24e9   68 ca 64 46       RLDI 10, SCORE_HI
   24ed   4a                LDA 10              ; SCORE_HI -> high byte
   24ee   b9                PHI 9
   24ef   0a                LDN 10              ; SCORE_LO -> low byte
   24f0   a9                PLO 9
                        
   24f1   d5                RETN
                        
   24f2                 NEGAMAX_LEAF:
                            ; -----------------------------------------------
                            ; Leaf node - do quiescence search
                            ; -----------------------------------------------
   24f2   d4 25 59          CALL QUIESCENCE_SEARCH
                            ; Returns score in R9 (already from side-to-move's perspective)
                        
                            ; Save return value to SCORE memory BEFORE restore (RESTORE clobbers R9!)
                            ; Big-endian: store high byte at lower address (SCORE_HI), low at SCORE_LO
   24f5   68 ca 64 46       RLDI 10, SCORE_HI
   24f9   99                GHI 9               ; Score high byte first
   24fa   5a                STR 10
   24fb   1a                INC 10
   24fc   89                GLO 9               ; Score low byte second
   24fd   5a                STR 10
                        
                            ; Restore caller's context (clobbers R7, R8, R9, R11, R12)
   24fe   d4 00 54          CALL RESTORE_PLY_STATE
                        
                            ; Load return value back into R9 AFTER restore
                            ; Big-endian: load high byte from lower address first
   2501   68 ca 64 46       RLDI 10, SCORE_HI
   2505   4a                LDA 10              ; SCORE_HI -> high byte
   2506   b9                PHI 9
   2507   0a                LDN 10              ; SCORE_LO -> low byte
   2508   a9                PLO 9
                        
   2509   d5                RETN
                        
   250a                 NEGAMAX_NO_MOVES:
                            ; -----------------------------------------------
                            ; No legal moves - checkmate or stalemate
                            ; -----------------------------------------------
                            ; Check if in check
   250a   d4 01 8e          CALL IS_IN_CHECK
                            ; Returns: D = 1 if in check, 0 if not
                        
   250d   c2 25 3f          LBZ NEGAMAX_STALEMATE   ; Long branch - may cross page
                        
                            ; Checkmate - return mate-score adjusted by ply so shorter mates score higher.
                            ; Formula: score = -MATE_VAL + ply  (standard negamax mate convention)
                            ; The mated side's score is "less negative" the farther from root we are,
                            ; so after the negation chain back to root, the side delivering the mate
                            ; sees a HIGHER score for SHORTER mate sequences (mate-in-1 > mate-in-2 > ...).
                            ;
                            ; FIXED 2026-04-27: previously used SEARCH_DEPTH+1 (depth_remaining), which
                            ; INVERTED the preference — engine consistently picked longer mates over
                            ; shorter ones at d>=3. Manifested visibly only after 2271af2 enabled real
                            ; promotions (positions with multiple forced-mate sequences became reachable).
                            ;
                            ; NOTE: Use $8001 (-32767) not $8000 (-32768) to avoid overflow when negating!
                            ; -(-32768) = -32768 due to two's complement overflow, breaking score propagation!
   2510   f8 80             LDI $80
   2512   b9                PHI 9
   2513   f8 01             LDI $01
   2515   a9                PLO 9              ; R9 = -32767 (R6 is SCRT linkage - off limits!)
                        
                            ; Add ply (distance from root) so shorter mates score higher
   2516   68 cd 64 48       RLDI 13, CURRENT_PLY
   251a   0d                LDN 13              ; D = current ply (0 at root, increases with depth)
                            ; Use COMPARE_TEMP for ADD scratch (NEVER use STR 2!)
   251b   68 ca 64 49       RLDI 10, COMPARE_TEMP
   251f   ea                SEX 10
   2520   5a                STR 10
   2521   89                GLO 9
   2522   f4                ADD
   2523   e2                SEX 2
   2524   a9                PLO 9
                            ; High byte stays same (adding small depth won't overflow)
                        
                            ; Store checkmate score to BEST_SCORE memory for return
   2525   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   2529   99                GHI 9               ; Score high byte
   252a   5a                STR 10
   252b   1a                INC 10
   252c   89                GLO 9               ; Score low byte
   252d   5a                STR 10
                        
                            ; -- TT node flag: EXACT (checkmate) --
   252e   68 ca 64 48       RLDI 10, CURRENT_PLY
   2532   0a                LDN 10
   2533   fc d2             ADI LOW(NODE_TT_FLAGS)
   2535   aa                PLO 10
   2536   f8 64             LDI HIGH(NODE_TT_FLAGS)
   2538   ba                PHI 10
   2539   f8 01             LDI TT_FLAG_EXACT
   253b   5a                STR 10
                        
   253c   c0 24 c0          LBR NEGAMAX_RETURN
                        
   253f                 NEGAMAX_STALEMATE:
                            ; Stalemate - return 0 (draw)
                            ; Store 0 to BEST_SCORE memory for return
   253f   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   2543   f8 00             LDI 0
   2545   5a                STR 10              ; BEST_SCORE_HI = 0
   2546   1a                INC 10
   2547   5a                STR 10              ; BEST_SCORE_LO = 0
                        
                            ; -- TT node flag: EXACT (stalemate) --
   2548   68 ca 64 48       RLDI 10, CURRENT_PLY
   254c   0a                LDN 10
   254d   fc d2             ADI LOW(NODE_TT_FLAGS)
   254f   aa                PLO 10
   2550   f8 64             LDI HIGH(NODE_TT_FLAGS)
   2552   ba                PHI 10
   2553   f8 01             LDI TT_FLAG_EXACT
   2555   5a                STR 10
                        
   2556   c0 24 c0          LBR NEGAMAX_RETURN
                        
                        ; ==============================================================================
                        ; QUIESCENCE_SEARCH - Search captures at leaf nodes
                        ; ==============================================================================
                        ; Avoids horizon effect by extending search for captures
                        ; Input:  C = color (0 for white, 8 for black - matches COLOR_MASK)
                        ;         A = board pointer
                        ; Output: R9 = best score (from side-to-move's perspective)
                        ; NOTE:   R6 is SCRT linkage register - off limits for application data!
                        ; ==============================================================================
   2559                 QUIESCENCE_SEARCH:
                            ; Ensure X=2 for stack operations
   2559   e2                SEX 2
                        
   255a   68 ca 64 1d       RLDI 10, TRACE_WHERE
   255e   f8 c1             LDI $C1
   2560   5a                STR 10              ; tracer: in QSEARCH
                        
                            ; Stack overflow detection (see NEGAMAX comment).
   2561   d4 00 87          CALL CHECK_STACK_OVERFLOW
                        
                            ; Stand-pat: evaluate current position
   2564   d4 0e 92          CALL EVALUATE
                            ; Returns score in R9 (from white's perspective)
                        
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   2567   8c                GLO 12
   2568   fa 08             ANI $08
   256a   c2 25 75          LBZ QS_SAVE_STANDPAT
   256d   89                GLO 9               ; low byte
   256e   fd 00             SDI 0               ; negate low
   2570   a9                PLO 9
   2571   99                GHI 9               ; high byte
   2572   7d 00             SDBI 0              ; negate high with borrow
   2574   b9                PHI 9
                        
   2575                 QS_SAVE_STANDPAT:
                            ; Save stand-pat score to QS_BEST_HI/LO
   2575   68 ca 64 18       RLDI 10, QS_BEST_HI
   2579   99                GHI 9               ; high byte → QS_BEST_HI (lower address)
   257a   5a                STR 10
   257b   1a                INC 10
   257c   89                GLO 9               ; low byte → QS_BEST_LO (higher address)
   257d   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Stand-pat beta cutoff: if stand-pat >= beta, return
                            ; (Position is already good enough, no need to search captures)
                            ; -----------------------------------------------
                            ; Load beta from memory (big-endian: HI at lower address)
   257e   68 ca 64 44       RLDI 10, BETA_HI
   2582   4a                LDA 10              ; beta high
   2583   b7                PHI 7
   2584   0a                LDN 10              ; beta low
   2585   a7                PLO 7               ; R7 = beta
                        
                            ; Compare: stand-pat (R9) >= beta (R7)?
                            ; Signed comparison using COMPARE_TEMP
   2586   68 ca 64 49       RLDI 10, COMPARE_TEMP
   258a   ea                SEX 10
   258b   99                GHI 9               ; stand-pat high
   258c   5a                STR 10
   258d   97                GHI 7               ; beta high
   258e   f3                XOR
   258f   fa 80             ANI $80             ; Check if different signs
   2591   e2                SEX 2
   2592   ca 25 a5          LBNZ QS_BETA_DIFF_SIGN
                        
                            ; Same sign - compare magnitudes
                            ; stand-pat >= beta means stand-pat - beta >= 0, i.e., no borrow
   2595   ea                SEX 10
   2596   87                GLO 7               ; beta low
   2597   5a                STR 10
   2598   89                GLO 9               ; stand-pat low
   2599   f7                SM                  ; D = stand-pat_lo - beta_lo
   259a   97                GHI 7               ; beta high
   259b   5a                STR 10
   259c   99                GHI 9               ; stand-pat high
   259d   77                SMB                 ; D = stand-pat_hi - beta_hi - borrow
   259e   e2                SEX 2
   259f   c3 28 00          LBDF QS_RETURN      ; No borrow = stand-pat >= beta, cutoff!
   25a2   c0 25 ab          LBR QS_NO_BETA_CUTOFF
                        
   25a5                 QS_BETA_DIFF_SIGN:
                            ; Different signs: positive >= negative always
                            ; stand-pat positive (bit 7 = 0) means stand-pat >= beta
   25a5   99                GHI 9
   25a6   fa 80             ANI $80
   25a8   c2 28 00          LBZ QS_RETURN       ; stand-pat positive, beta negative -> cutoff
                        
   25ab                 QS_NO_BETA_CUTOFF:
                            ; -----------------------------------------------
                            ; Alpha update: if stand-pat > alpha, alpha = stand-pat
                            ; (Tightens window, makes beta cutoffs more likely)
                            ; -----------------------------------------------
                            ; Load alpha (R9 still has stand-pat)
   25ab   68 ca 64 42       RLDI 10, ALPHA_HI
   25af   4a                LDA 10              ; alpha high
   25b0   b7                PHI 7
   25b1   0a                LDN 10              ; alpha low
   25b2   a7                PLO 7               ; R7 = alpha
                        
                            ; Compare: stand-pat (R9) > alpha (R7)?
   25b3   68 ca 64 49       RLDI 10, COMPARE_TEMP
   25b7   ea                SEX 10
   25b8   99                GHI 9
   25b9   5a                STR 10
   25ba   97                GHI 7
   25bb   f3                XOR
   25bc   fa 80             ANI $80
   25be   e2                SEX 2
   25bf   ca 25 da          LBNZ QS_ALPHA_DIFF_SIGN
                        
                            ; Same sign - R9 > R7 means R9 - R7 > 0 (positive, no borrow, not zero)
   25c2   ea                SEX 10
   25c3   87                GLO 7
   25c4   5a                STR 10
   25c5   89                GLO 9
   25c6   f7                SM                  ; D = stand-pat_lo - alpha_lo
   25c7   b8                PHI 8               ; Save low result
   25c8   97                GHI 7
   25c9   5a                STR 10
   25ca   99                GHI 9
   25cb   77                SMB                 ; D = stand-pat_hi - alpha_hi - borrow
   25cc   e2                SEX 2
   25cd   cb 25 e9          LBNF QS_NO_ALPHA_UPDATE  ; Borrow = stand-pat <= alpha
   25d0   ca 25 e0          LBNZ QS_UPDATE_ALPHA     ; High diff non-zero and positive
   25d3   98                GHI 8                    ; Check low diff
   25d4   c2 25 e9          LBZ QS_NO_ALPHA_UPDATE   ; Both zero = equal, don't update
   25d7   c0 25 e0          LBR QS_UPDATE_ALPHA
                        
   25da                 QS_ALPHA_DIFF_SIGN:
                            ; Different signs: positive > negative
   25da   99                GHI 9
   25db   fa 80             ANI $80
   25dd   ca 25 e9          LBNZ QS_NO_ALPHA_UPDATE  ; stand-pat negative, alpha positive
                            ; stand-pat positive, alpha negative -> update
                        
   25e0                 QS_UPDATE_ALPHA:
                            ; alpha = stand-pat
   25e0   68 ca 64 42       RLDI 10, ALPHA_HI
   25e4   99                GHI 9
   25e5   5a                STR 10
   25e6   1a                INC 10
   25e7   89                GLO 9
   25e8   5a                STR 10
                        
   25e9                 QS_NO_ALPHA_UPDATE:
                            ; -----------------------------------------------
                            ; Delta pruning: if stand-pat + QUEEN_VALUE < alpha, return alpha
                            ; (Even capturing a queen can't raise alpha - futile to search)
                            ; -----------------------------------------------
                            ; Load alpha from memory (big-endian: HI at lower address)
   25e9   68 ca 64 42       RLDI 10, ALPHA_HI
   25ed   4a                LDA 10              ; alpha high
   25ee   b7                PHI 7
   25ef   0a                LDN 10              ; alpha low
   25f0   a7                PLO 7               ; R7 = alpha
                        
                            ; Calculate stand-pat + QUEEN_VALUE (900 = $0384)
                            ; R9 = stand-pat, add 900
   25f1   89                GLO 9
   25f2   fc 84             ADI LOW(900)        ; Add low byte of 900 ($84)
   25f4   a8                PLO 8
   25f5   99                GHI 9
   25f6   7c 03             ADCI HIGH(900)      ; Add high byte of 900 ($03) + carry
   25f8   b8                PHI 8               ; R8 = stand-pat + 900
                        
                            ; Compare: (stand-pat + 900) < alpha?
                            ; If R8 < R7, then delta prune
   25f9   68 ca 64 49       RLDI 10, COMPARE_TEMP
   25fd   ea                SEX 10
   25fe   98                GHI 8               ; (stand-pat + 900) high
   25ff   5a                STR 10
   2600   97                GHI 7               ; alpha high
   2601   f3                XOR
   2602   fa 80             ANI $80             ; Check if different signs
   2604   e2                SEX 2
   2605   ca 26 18          LBNZ QS_DELTA_DIFF_SIGN
                        
                            ; Same sign - compare: R8 < R7 means R8 - R7 has borrow
   2608   ea                SEX 10
   2609   87                GLO 7               ; alpha low
   260a   5a                STR 10
   260b   88                GLO 8               ; (stand-pat + 900) low
   260c   f7                SM                  ; D = (sp+900)_lo - alpha_lo
   260d   97                GHI 7               ; alpha high
   260e   5a                STR 10
   260f   98                GHI 8               ; (stand-pat + 900) high
   2610   77                SMB                 ; D = (sp+900)_hi - alpha_hi - borrow
   2611   e2                SEX 2
   2612   cb 26 1e          LBNF QS_DELTA_PRUNE ; Borrow = (stand-pat + 900) < alpha, prune!
   2615   c0 26 23          LBR QS_NO_DELTA_PRUNE
                        
   2618                 QS_DELTA_DIFF_SIGN:
                            ; Different signs: negative < positive always
                            ; (stand-pat + 900) negative means it's < alpha (if alpha positive)
   2618   98                GHI 8
   2619   fa 80             ANI $80
   261b   c2 26 23          LBZ QS_NO_DELTA_PRUNE ; (stand-pat + 900) positive -> no prune
                        
   261e                 QS_DELTA_PRUNE:
                            ; Return alpha (in R7) - we're too far behind
   261e   97                GHI 7
   261f   b9                PHI 9
   2620   87                GLO 7
   2621   a9                PLO 9               ; R9 = alpha
   2622   d5                RETN
                        
   2623                 QS_NO_DELTA_PRUNE:
                            ; Generate all moves (use QS_MOVE_LIST to avoid clobbering parent's move list!)
   2623   68 c9 67 80       RLDI 9, QS_MOVE_LIST
   2627   d4 04 d7          CALL GENERATE_MOVES
                            ; D = move count
                        
                            ; Save move count to temp (must clear R15.1 to avoid DEC underflow!)
   262a   af                PLO 15              ; R15.0 = move count (temp)
   262b   f8 00             LDI 0
   262d   bf                PHI 15              ; R15.1 = 0 (prevents underflow when DEC 15)
                        
                            ; Save move list start pointer (big-endian: high byte first)
   262e   68 ca 64 1a       RLDI 10, QS_MOVE_PTR_HI
   2632   f8 67             LDI HIGH(QS_MOVE_LIST)
   2634   5a                STR 10
   2635   1a                INC 10
   2636   f8 80             LDI LOW(QS_MOVE_LIST)
   2638   5a                STR 10
                        
                            ; Initialize capture limit counter
   2639   f8 08             LDI 8                   ; QS_CAPTURE_LIMIT = 8 captures max
   263b   bb                PHI 11                  ; R11.1 = captures remaining
                        
   263c                 QS_LOOP:
   263c   3f 40             BN4  BRK_QS_LOOP      ; /EF4 break trap (DEBUG)
   263e   79                MARK
   263f   d1                SEP  1
   2640                 BRK_QS_LOOP:
                            ; Check if any moves left
   2640   8f                GLO 15
   2641   c2 28 00          LBZ QS_RETURN
                        
                            ; Load move list pointer (big-endian: high byte first)
   2644   68 ca 64 1a       RLDI 10, QS_MOVE_PTR_HI
   2648   4a                LDA 10              ; High byte
   2649   b9                PHI 9
   264a   0a                LDN 10              ; Low byte
   264b   a9                PLO 9               ; R9 = move pointer
                        
                            ; Load encoded move (big-endian: high byte first)
   264c   49                LDA 9
   264d   b8                PHI 8
   264e   49                LDA 9
   264f   a8                PLO 8               ; R8 = encoded move
                        
                            ; Save updated pointer (big-endian: high byte first)
   2650   68 ca 64 1a       RLDI 10, QS_MOVE_PTR_HI
   2654   99                GHI 9
   2655   5a                STR 10
   2656   1a                INC 10
   2657   89                GLO 9
   2658   5a                STR 10
                        
                            ; Decrement move count
   2659   2f                DEC 15
                        
                            ; Decode move to get from/to squares
   265a   d4 03 c7          CALL DECODE_MOVE_16BIT
                            ; R13.1 = from, R13.0 = to (R14.0 = flags - but we don't use it)
                        
                            ; Check if this is a capture: target square must have enemy piece
   265d   f8 60             LDI HIGH(BOARD)
   265f   ba                PHI 10
   2660   8d                GLO 13              ; to square
   2661   aa                PLO 10
   2662   0a                LDN 10              ; piece at target
   2663   c2 26 3c          LBZ QS_LOOP         ; Empty = not a capture, skip
                        
                            ; Has piece - check if enemy color
   2666   fa 08             ANI COLOR_MASK      ; D = target piece color (0 or 8)
                            ; Use COMPARE_TEMP for XOR scratch (NEVER use STR 2!)
   2668   68 ca 64 49       RLDI 10, COMPARE_TEMP
   266c   ea                SEX 10
   266d   5a                STR 10              ; Store target color to COMPARE_TEMP
   266e   8c                GLO 12              ; D = our color (0 or 8, per COLOR_MASK)
   266f   fa 08             ANI COLOR_MASK      ; D = our color masked (0 or 8)
   2671   f3                XOR                 ; D = our_color XOR target_color
   2672   e2                SEX 2
   2673   c2 26 3c          LBZ QS_LOOP         ; Same color (result 0) = own piece, skip
                        
                            ; -------------------------------------------------
                            ; Per-capture delta pruning:
                            ; If stand_pat + victim_value < alpha, skip capture
                            ; (Even capturing this piece won't raise score above alpha)
                            ; -------------------------------------------------
                            ; Reload victim piece and extract type
   2676   f8 60             LDI HIGH(BOARD)
   2678   ba                PHI 10
   2679   8d                GLO 13              ; to square (preserved in R13.0)
   267a   aa                PLO 10
   267b   0a                LDN 10              ; piece at target
   267c   fa 07             ANI $07             ; D = piece type (1-6)
                        
                            ; Look up value: PIECE_VALUES + type*2
   267e   fe                SHL                 ; D = type * 2
   267f   fc de             ADI LOW(PIECE_VALUES)
   2681   aa                PLO 10
   2682   f8 0d             LDI HIGH(PIECE_VALUES)
   2684   7c 00             ADCI 0
   2686   ba                PHI 10              ; R10 = &PIECE_VALUES[type]
                        
   2687   4a                LDA 10              ; victim value high
   2688   b8                PHI 8
   2689   0a                LDN 10              ; victim value low
   268a   a8                PLO 8               ; R8 = victim_value
                        
                            ; Load stand_pat from QS_BEST
   268b   68 ca 64 18       RLDI 10, QS_BEST_HI
   268f   4a                LDA 10
   2690   b7                PHI 7
   2691   0a                LDN 10
   2692   a7                PLO 7               ; R7 = stand_pat
                        
                            ; R7 = stand_pat + victim_value
   2693   88                GLO 8
   2694   52                STR 2               ; Use stack top as temp
   2695   87                GLO 7
   2696   f4                ADD
   2697   a7                PLO 7
   2698   98                GHI 8
   2699   52                STR 2
   269a   97                GHI 7
   269b   74                ADC
   269c   b7                PHI 7               ; R7 = stand_pat + victim_value
                        
                            ; Load alpha
   269d   68 ca 64 42       RLDI 10, ALPHA_HI
   26a1   4a                LDA 10
   26a2   b8                PHI 8
   26a3   0a                LDN 10
   26a4   a8                PLO 8               ; R8 = alpha
                        
                            ; Compare: (stand_pat + victim) < alpha?
                            ; If R7 < R8, skip this capture
   26a5   68 ca 64 49       RLDI 10, COMPARE_TEMP
   26a9   ea                SEX 10
   26aa   97                GHI 7               ; (stand_pat + victim) high
   26ab   5a                STR 10
   26ac   98                GHI 8               ; alpha high
   26ad   f3                XOR
   26ae   fa 80             ANI $80             ; Check if different signs
   26b0   e2                SEX 2
   26b1   ca 26 c4          LBNZ QS_DELTA_DIFF_SIGN2
                        
                            ; Same sign: R7 < R8 means R7 - R8 has borrow
   26b4   ea                SEX 10
   26b5   88                GLO 8               ; alpha low
   26b6   5a                STR 10
   26b7   87                GLO 7               ; (stand_pat + victim) low
   26b8   f7                SM                  ; D = (sp+v)_lo - alpha_lo
   26b9   98                GHI 8               ; alpha high
   26ba   5a                STR 10
   26bb   97                GHI 7               ; (stand_pat + victim) high
   26bc   77                SMB                 ; D = (sp+v)_hi - alpha_hi - borrow
   26bd   e2                SEX 2
   26be   cb 26 3c          LBNF QS_LOOP        ; Borrow = (stand_pat + victim) < alpha, skip!
   26c1   c0 26 ca          LBR QS_DELTA_NO_PRUNE
                        
   26c4                 QS_DELTA_DIFF_SIGN2:
                            ; Different signs: negative < positive always
                            ; (stand_pat + victim) negative means it's < alpha (if alpha positive)
   26c4   97                GHI 7
   26c5   fa 80             ANI $80
   26c7   ca 26 3c          LBNZ QS_LOOP        ; (stand_pat + victim) negative -> skip capture
                        
   26ca                 QS_DELTA_NO_PRUNE:
                            ; -------------------------------------------------
                            ; End per-capture delta pruning
                            ; -------------------------------------------------
                        
                            ; It's a capture! Process it.
                            ; Save move count to stack (BOTH bytes! IS_IN_CHECK clobbers R15.1)
   26ca   9f                GHI 15
   26cb   73                STXD
   26cc   8f                GLO 15
   26cd   73                STXD
                        
                            ; ===============================================================
                            ; QSEARCH defender-check pre-filter (added 2026-05-07)
                            ; ===============================================================
                            ; QSEARCH lacks recursion: each capture is evaluated as if its
                            ; recapture won't happen. This causes phantom material wins when
                            ; we capture a defended piece with a more valuable attacker.
                            ;
                            ; Filter: if captor_value > victim_value AND target is defended
                            ; by enemy, skip this capture entirely. Single-level defender
                            ; check; doesn't see exchange chains, but catches the dominant
                            ; bug class (e.g., Bxg6 when h7-pawn defends).
                            ;
                            ; Empirical motivation (2026-05-07): post-Kxf7 d=1 returned +220cp
                            ; bestmove d3g6 (Bxg6) despite h7 pawn obviously recapturing —
                            ; QSEARCH saw bishop "win" but not the recapture.
                            ; ===============================================================
                        
                            ; Load victim_value from board[to_square]
   26ce   f8 60             LDI HIGH(BOARD)
   26d0   ba                PHI 10
   26d1   8d                GLO 13                          ; to square
   26d2   aa                PLO 10
   26d3   0a                LDN 10
   26d4   fa 07             ANI $07                         ; victim piece type 1-6
   26d6   fe                SHL                             ; * 2 for 16-bit table
   26d7   fc de             ADI LOW(PIECE_VALUES)
   26d9   aa                PLO 10
   26da   f8 0d             LDI HIGH(PIECE_VALUES)
   26dc   7c 00             ADCI 0
   26de   ba                PHI 10
   26df   4a                LDA 10                          ; victim_value hi
   26e0   b8                PHI 8
   26e1   0a                LDN 10                          ; victim_value lo
   26e2   a8                PLO 8                           ; R8 = victim_value
                        
                            ; Load captor_value from board[from_square]
   26e3   f8 60             LDI HIGH(BOARD)
   26e5   ba                PHI 10
   26e6   9d                GHI 13                          ; from square
   26e7   aa                PLO 10
   26e8   0a                LDN 10
   26e9   fa 07             ANI $07                         ; captor piece type 1-6
   26eb   fe                SHL
   26ec   fc de             ADI LOW(PIECE_VALUES)
   26ee   aa                PLO 10
   26ef   f8 0d             LDI HIGH(PIECE_VALUES)
   26f1   7c 00             ADCI 0
   26f3   ba                PHI 10
   26f4   4a                LDA 10                          ; captor_value hi
   26f5   b7                PHI 7
   26f6   0a                LDN 10                          ; captor_value lo
   26f7   a7                PLO 7                           ; R7 = captor_value
                        
                            ; Compare: victim - captor (16-bit signed). DF=1 if victim >= captor.
   26f8   87                GLO 7
   26f9   52                STR 2                           ; M(R2) = captor_lo
   26fa   88                GLO 8
   26fb   f7                SM                              ; D = victim_lo - captor_lo
   26fc   97                GHI 7
   26fd   52                STR 2                           ; M(R2) = captor_hi
   26fe   98                GHI 8
   26ff   77                SMB                             ; D = victim_hi - captor_hi - borrow
   2700   c3 27 1b          LBDF QS_DEF_OK                  ; victim >= captor: no filter
                        
                            ; Captor > victim. Check if target square is defended by enemy.
                            ; Save R11.1 (capture limit) and R13 (from/to) — IS_SQUARE_ATTACKED
                            ; restores R11.0 and R12.0 but clobbers everything else including
                            ; R13 and R15.0.
   2703   9b                GHI 11
   2704   73                STXD                            ; push capture limit
   2705   9d                GHI 13
   2706   73                STXD                            ; push from
   2707   8d                GLO 13
   2708   73                STXD                            ; push to
                        
                            ; Set R11.0 = target square, R12.0 already = our color
   2709   8d                GLO 13
   270a   ab                PLO 11
   270b   d4 01 a4          CALL IS_SQUARE_ATTACKED
   270e   a7                PLO 7                           ; R7.0 = result (0=safe, 1=attacked)
   270f   e2                SEX 2                           ; Defensive: ensure X=2 for following pop
                        
                            ; Restore saved state
   2710   60                IRX
   2711   72                LDXA                            ; pop to → R13.0
   2712   ad                PLO 13
   2713   72                LDXA                            ; pop from → R13.1
   2714   bd                PHI 13
   2715   f0                LDX                             ; pop capture limit → R11.1
   2716   bb                PHI 11
                        
   2717   87                GLO 7
   2718   ca 27 4e          LBNZ QS_DEF_SKIP                ; defended: filter fires, skip capture
                        
   271b                 QS_DEF_OK:
                            ; ===============================================================
                            ; End QSEARCH defender-check pre-filter
                            ; ===============================================================
                        
                            ; Store from/to for MAKE_MOVE
   271b   68 ca 64 02       RLDI 10, MOVE_FROM
   271f   9d                GHI 13              ; from
   2720   5a                STR 10
   2721   1a                INC 10
   2722   8d                GLO 13              ; to
   2723   5a                STR 10
                        
                            ; Set UNDO_PROMOTION based on move flags (capture-promotions)
   2724   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   2728   68 cd 64 05       RLDI 13, DECODED_FLAGS
   272c   0d                LDN 13              ; D = flags
   272d   fb 03             XRI MOVE_PROMOTION  ; == $03?
   272f   ca 27 37          LBNZ QS_NOT_PROMO
   2732   f8 05             LDI QUEEN_TYPE      ; Promote to queen ($05)
   2734   c0 27 39          LBR QS_SET_PROMO
   2737                 QS_NOT_PROMO:
   2737   f8 00             LDI 0               ; Not a promotion
   2739                 QS_SET_PROMO:
   2739   5a                STR 10              ; UNDO_PROMOTION = QUEEN_TYPE or 0
                        
                            ; Make move
   273a   d4 09 b4          CALL MAKE_MOVE
                        
                            ; -----------------------------------------------
                            ; LEGALITY CHECK: Does this capture leave our king in check?
                            ; MAKE_MOVE does NOT toggle R12 - only SIDE in memory.
                            ; R12 still contains our color (the side that just moved).
                            ; -----------------------------------------------
   273d   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if our king is in check (illegal), 0 if safe
                        
   2740   c2 27 56          LBZ QS_CAPTURE_LEGAL  ; D=0 means not in check, capture is legal
                        
                            ; ILLEGAL CAPTURE: Unmake and skip to next capture
   2743   d4 0c 20          CALL UNMAKE_MOVE
                        
                            ; R12 stays as our color (UNMAKE_MOVE doesn't toggle R12)
                        
                            ; Restore move count from stack and continue loop (both bytes)
   2746   60                IRX
   2747   72                LDXA
   2748   af                PLO 15              ; R15.0 = move count low
   2749   f0                LDX
   274a   bf                PHI 15              ; R15.1 = move count high (0)
   274b   c0 26 3c          LBR QS_LOOP         ; Skip this illegal capture, try next
                        
   274e                 QS_DEF_SKIP:
                            ; Defender-check filter fired: skip capture WITHOUT make/unmake.
                            ; Pop R15 (saved before our filter ran) and continue.
   274e   60                IRX
   274f   72                LDXA
   2750   af                PLO 15              ; R15.0 = move count low
   2751   f0                LDX
   2752   bf                PHI 15              ; R15.1 = move count high (0)
   2753   c0 26 3c          LBR QS_LOOP
                        
   2756                 QS_CAPTURE_LEGAL:
                            ; Check capture limit - decrement and bail if exhausted
   2756   9b                GHI 11                  ; D = captures remaining
   2757   c2 27 f8          LBZ QS_CAPTURE_LIMIT_HIT ; Already at 0, don't process more
   275a   ff 01             SMI 1
   275c   bb                PHI 11                  ; R11.1 = captures remaining - 1
                        
                            ; Evaluate position after capture
   275d   d4 0e 92          CALL EVALUATE
                            ; Score in R9 (from white's perspective)
                        
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   2760   8c                GLO 12
   2761   fa 08             ANI $08
   2763   c2 27 6e          LBZ QS_NO_NEG
   2766   89                GLO 9               ; low byte
   2767   fd 00             SDI 0               ; negate low
   2769   a9                PLO 9
   276a   99                GHI 9               ; high byte
   276b   7d 00             SDBI 0              ; negate high with borrow
   276d   b9                PHI 9
   276e                 QS_NO_NEG:
                            ; Save score (R9) before UNMAKE_MOVE clobbers it
   276e   99                GHI 9
   276f   73                STXD
   2770   89                GLO 9
   2771   73                STXD
                        
                            ; Unmake move
   2772   d4 0c 20          CALL UNMAKE_MOVE
                        
                            ; Restore score (R9)
   2775   60                IRX
   2776   72                LDXA
   2777   a9                PLO 9
   2778   f0                LDX
   2779   b9                PHI 9
                        
                            ; Restore move count (both bytes)
   277a   60                IRX
   277b   72                LDXA
   277c   af                PLO 15              ; R15.0 = move count low
   277d   f0                LDX
   277e   bf                PHI 15              ; R15.1 = move count high (0)
                        
                            ; Compare: if score (R9) > best (QS_BEST), update best
                            ; Load QS_BEST into R7 for comparison (big-endian: HI first)
   277f   68 ca 64 18       RLDI 10, QS_BEST_HI
   2783   4a                LDA 10              ; High byte
   2784   b7                PHI 7
   2785   0a                LDN 10              ; Low byte
   2786   a7                PLO 7               ; R7 = QS_BEST
                        
                            ; Signed comparison: R9 > R7?
                            ; Use COMPARE_TEMP for scratch (NEVER use STR 2!)
   2787   68 ca 64 49       RLDI 10, COMPARE_TEMP
   278b   ea                SEX 10
   278c   99                GHI 9
   278d   5a                STR 10
   278e   97                GHI 7
   278f   f3                XOR
   2790   fa 80             ANI $80
   2792   e2                SEX 2
   2793   ca 27 b4          LBNZ QS_DIFF_SIGN
                        
                            ; Same sign - compare normally
   2796   ea                SEX 10
   2797   97                GHI 7
   2798   5a                STR 10
   2799   99                GHI 9
   279a   f5                SD
   279b   e2                SEX 2
   279c   ca 27 ae          LBNZ QS_HI_DIFF
                            ; High bytes equal, compare low
   279f   ea                SEX 10
   27a0   87                GLO 7
   27a1   5a                STR 10
   27a2   89                GLO 9
   27a3   f5                SD
   27a4   e2                SEX 2
   27a5   c2 26 3c          LBZ QS_LOOP         ; Equal, don't update
   27a8   cb 27 ba          LBNF QS_UPDATE      ; Score > best
   27ab   c0 26 3c          LBR QS_LOOP         ; Score < best
                        
   27ae                 QS_HI_DIFF:
   27ae   cb 27 ba          LBNF QS_UPDATE      ; Score > best
   27b1   c0 26 3c          LBR QS_LOOP         ; Score < best
                        
   27b4                 QS_DIFF_SIGN:
                            ; Different signs - positive is greater
   27b4   99                GHI 9
   27b5   fa 80             ANI $80
   27b7   ca 26 3c          LBNZ QS_LOOP        ; Score negative, best positive - don't update
                            ; Score positive, best negative - update
                        
   27ba                 QS_UPDATE:
                            ; Update best = score (big-endian: HI first)
   27ba   68 ca 64 18       RLDI 10, QS_BEST_HI
   27be   99                GHI 9               ; High byte first
   27bf   5a                STR 10
   27c0   1a                INC 10
   27c1   89                GLO 9               ; Low byte second
   27c2   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Beta cutoff check: if best >= beta, return beta
                            ; -----------------------------------------------
                            ; Load beta (big-endian: HI first)
   27c3   68 ca 64 44       RLDI 10, BETA_HI
   27c7   4a                LDA 10              ; beta high
   27c8   b7                PHI 7
   27c9   0a                LDN 10              ; beta low
   27ca   a7                PLO 7               ; R7 = beta
                        
                            ; Compare: best (R9) >= beta (R7)?
   27cb   68 ca 64 49       RLDI 10, COMPARE_TEMP
   27cf   ea                SEX 10
   27d0   99                GHI 9               ; best high
   27d1   5a                STR 10
   27d2   97                GHI 7               ; beta high
   27d3   f3                XOR
   27d4   fa 80             ANI $80
   27d6   e2                SEX 2
   27d7   ca 27 ea          LBNZ QS_BETA_CUT_DIFF
                        
                            ; Same sign: best >= beta means best - beta >= 0 (no borrow)
   27da   ea                SEX 10
   27db   87                GLO 7               ; beta low
   27dc   5a                STR 10
   27dd   89                GLO 9               ; best low
   27de   f7                SM
   27df   97                GHI 7               ; beta high
   27e0   5a                STR 10
   27e1   99                GHI 9               ; best high
   27e2   77                SMB
   27e3   e2                SEX 2
   27e4   c3 27 f3          LBDF QS_BETA_CUTOFF ; No borrow = best >= beta, cutoff!
   27e7   c0 26 3c          LBR QS_LOOP
                        
   27ea                 QS_BETA_CUT_DIFF:
                            ; Different signs: positive >= negative
   27ea   99                GHI 9               ; best high
   27eb   fa 80             ANI $80
   27ed   c2 27 f3          LBZ QS_BETA_CUTOFF  ; best positive, beta negative -> cutoff
   27f0   c0 26 3c          LBR QS_LOOP
                        
   27f3                 QS_BETA_CUTOFF:
                            ; Return beta (fail-high)
   27f3   97                GHI 7
   27f4   b9                PHI 9
   27f5   87                GLO 7
   27f6   a9                PLO 9               ; R9 = beta
   27f7   d5                RETN
                        
   27f8                 QS_CAPTURE_LIMIT_HIT:
                            ; Hit capture limit - unmake the move and return best so far
   27f8   d4 0c 20          CALL UNMAKE_MOVE
                            ; Restore move count from stack (was pushed at capture processing start)
   27fb   60                IRX
   27fc   72                LDXA
   27fd   af                PLO 15              ; R15.0 = move count low
   27fe   f0                LDX
   27ff   bf                PHI 15              ; R15.1 = move count high (0)
                            ; Fall through to QS_RETURN
                        
   2800                 QS_RETURN:
                            ; Return best score in R9 (big-endian: HI first)
   2800   68 ca 64 18       RLDI 10, QS_BEST_HI
   2804   4a                LDA 10              ; High byte
   2805   b9                PHI 9
   2806   0a                LDN 10              ; Low byte
   2807   a9                PLO 9
   2808   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; Helper Functions - STUBS REMOVED (functions now in other modules)
                        ; ------------------------------------------------------------------------------
                        ; GENERATE_MOVES - implemented in movegen.asm
                        ; MAKE_MOVE - implemented in makemove.asm
                        ; UNMAKE_MOVE - implemented in makemove.asm
                        ; EVALUATE - implemented in evaluate.asm
                        ; IS_IN_CHECK - implemented in check.asm
                        
                        ; Only these helper functions remain here:
                        
                        ; ------------------------------------------------------------------------------
                        ; STORE_KILLER_MOVE - Store killer move for move ordering
                        ; ------------------------------------------------------------------------------
                        ; Input:  R11 = move that caused beta cutoff
                        ;         CURRENT_PLY = current ply (in memory)
                        ; Output: Killer move stored in table
                        ; Uses:   R10, R13, D
                        ; ------------------------------------------------------------------------------
   2809                 STORE_KILLER_MOVE:
                            ; Calculate killer table offset from CURRENT_PLY
                            ; (Use ply, not depth, so killers work across different search depths)
   2809   68 cd 64 48       RLDI 13, CURRENT_PLY
   280d   0d                LDN 13              ; D = current ply
   280e   fa 0f             ANI $0F             ; Limit to 16 plies
   2810   fe                SHL
   2811   fe                SHL                 ; × 4 (2 moves × 2 bytes each)
   2812   ad                PLO 13
                        
                            ; Point to killer table (offset in R13.0 is 0-60, won't overflow with ADI)
   2813   f8 64             LDI HIGH(KILLER_MOVES)
   2815   ba                PHI 10
   2816   8d                GLO 13              ; Get offset (0, 4, 8, ... 60)
   2817   fc 20             ADI LOW(KILLER_MOVES)  ; Add base address low byte
   2819   aa                PLO 10              ; R10 = KILLER_MOVES + offset
                        
                            ; Shift killers: killer2 = killer1
   281a   4a                LDA 10              ; Load killer1 low
   281b   ad                PLO 13
   281c   4a                LDA 10              ; Load killer1 high
   281d   bd                PHI 13              ; D = old killer1
                        
                            ; Store old killer1 as new killer2
   281e   8d                GLO 13
   281f   5a                STR 10
   2820   1a                INC 10
   2821   9d                GHI 13
   2822   5a                STR 10
                        
                            ; Reset pointer to killer1 position (R10 is at killer2_high, need killer1_low)
   2823   2a                DEC 10              ; killer2_low
   2824   2a                DEC 10              ; killer1_high
   2825   2a                DEC 10              ; killer1_low
                        
                            ; Store new killer1 (R11 = move that caused cutoff)
   2826   8b                GLO 11
   2827   5a                STR 10
   2828   1a                INC 10
   2829   9b                GHI 11
   282a   5a                STR 10
                        
   282b   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ORDER_TT_MOVE - Promote TT best move to front of move list
                        ; ------------------------------------------------------------------------------
                        ; Input:  R9 = start of move list
                        ;         D = move count
                        ; Output: Move list reordered with TT move at front (if found)
                        ; Uses:   R7, R8, R10, R11, R13
                        ; Note:   TT_MOVE_HI/LO must be populated by TT_PROBE before calling
                        ; ------------------------------------------------------------------------------
   282c                 ORDER_TT_MOVE:
   282c   a7                PLO 7               ; R7.0 = move count
   282d   c2 28 97          LBZ OTM_DONE        ; No moves, return
                        
                            ; Load TT move (raw from/to squares)
   2830   68 ca 64 c0       RLDI 10, TT_MOVE_HI
   2834   4a                LDA 10              ; D = from
   2835   bd                PHI 13              ; R13.1 = from
   2836   0a                LDN 10              ; D = to
   2837   ad                PLO 13              ; R13.0 = to
                        
                            ; Check validity: both zero = no TT move
   2838   9d                GHI 13
   2839   ca 28 40          LBNZ OTM_VALID
   283c   8d                GLO 13
   283d   c2 28 97          LBZ OTM_DONE
   2840                 OTM_VALID:
                        
                            ; Save move count (ENCODE clobbers R7)
   2840   87                GLO 7
   2841   73                STXD
                        
                            ; Set flags = 0 for encoding
   2842   68 ca 64 06       RLDI 10, MOVE_FLAGS_TEMP
   2846   f8 00             LDI 0
   2848   5a                STR 10
                        
                            ; Encode TT move to 16-bit format
   2849   d4 03 8d          CALL ENCODE_MOVE_16BIT
                            ; R8 = encoded TT move (flags=0 in top 2 bits)
                        
                            ; Save to R11 for comparison
   284c   98                GHI 8
   284d   bb                PHI 11
   284e   88                GLO 8
   284f   ab                PLO 11              ; R11 = encoded TT move
                        
                            ; Restore move count
   2850   60                IRX
   2851   f0                LDX                 ; D = move count
   2852   b7                PHI 7               ; R7.1 = loop counter
                        
                            ; Set up scan pointer
   2853   99                GHI 9
   2854   b8                PHI 8
   2855   89                GLO 9
   2856   a8                PLO 8               ; R8 = list start
                        
   2857                 OTM_SCAN:
   2857   97                GHI 7
   2858   c2 28 97          LBZ OTM_DONE        ; Scanned all, no match
                        
                            ; MOVE_LIST entries are stored HIGH byte first (ADD_MOVE_ENCODED
                            ; movegen-helpers.asm:221). Fixed 2026-05-13 — old code mistakenly
                            ; called LDA 8's read "low byte". Compare HIGH (mask flag bits 6-7)
                            ; first, then LOW.
   285b   48                LDA 8               ; list move HIGH byte; R8 advances
   285c   fa 3f             ANI $3F             ; mask off flag bits 6-7
   285e   52                STR 2
   285f   9b                GHI 11              ; TT encoded HIGH byte (flags=0)
   2860   f3                XOR
   2861   ca 28 6b          LBNZ OTM_NEXT       ; HIGH bytes differ
                        
                            ; HIGH match — compare LOW byte (no mask)
   2864   08                LDN 8               ; list move LOW byte; R8 stays
   2865   52                STR 2
   2866   8b                GLO 11              ; TT encoded LOW byte
   2867   f3                XOR
   2868   c2 28 73          LBZ OTM_FOUND       ; Match!
                        
   286b                 OTM_NEXT:
   286b   18                INC 8               ; skip past LOW byte to next entry
   286c   97                GHI 7
   286d   ff 01             SMI 1
   286f   b7                PHI 7
   2870   c0 28 57          LBR OTM_SCAN
                        
   2873                 OTM_FOUND:
                            ; Match at R8-1 (LDA advanced). Swap with front (R9).
   2873   28                DEC 8               ; R8 → matched move low byte
                        
                            ; Skip if already at front
   2874   98                GHI 8
   2875   52                STR 2
   2876   99                GHI 9
   2877   f3                XOR
   2878   ca 28 82          LBNZ OTM_SWAP
   287b   88                GLO 8
   287c   52                STR 2
   287d   89                GLO 9
   287e   f3                XOR
   287f   c2 28 97          LBZ OTM_DONE        ; Already first
                        
   2882                 OTM_SWAP:
                            ; Save front (R9) to stack
   2882   49                LDA 9               ; front low, R9++
   2883   73                STXD
   2884   09                LDN 9               ; front high
   2885   73                STXD
                        
                            ; Copy matched (R8) to front
   2886   29                DEC 9               ; R9 back to front low
   2887   48                LDA 8               ; src low, R8++
   2888   59                STR 9
   2889   19                INC 9
   288a   08                LDN 8               ; src high
   288b   59                STR 9
   288c   19                INC 9               ; R9 = front + 2
                        
                            ; Copy saved front to matched position
   288d   28                DEC 8               ; R8 back to src low
   288e   60                IRX
   288f   72                LDXA                ; saved high
   2890   18                INC 8
   2891   58                STR 8               ; R8+1 = saved high
   2892   28                DEC 8
   2893   f0                LDX                 ; saved low
   2894   58                STR 8               ; R8 = saved low
                        
                            ; Reset R9 to front
   2895   29                DEC 9
   2896   29                DEC 9
                        
   2897                 OTM_DONE:
   2897   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ORDER_KILLER_MOVES - Promote killer moves to front of move list
                        ; ------------------------------------------------------------------------------
                        ; Input:  R9 = start of move list
                        ;         D = move count
                        ;         CURRENT_PLY = current ply (for killer table index)
                        ; Output: Move list reordered with killers at front
                        ; Uses:   R7, R8, R10, R11, R13
                        ; Note:   Call this right after GENERATE_MOVES, before move loop
                        ; ------------------------------------------------------------------------------
   2898                 ORDER_KILLER_MOVES:
                            ; Save move count
   2898   a7                PLO 7               ; R7.0 = move count
   2899   c2 29 62          LBZ OKM_DONE        ; No moves, nothing to order
                        
                            ; Calculate killer table offset from CURRENT_PLY
   289c   68 ca 64 48       RLDI 10, CURRENT_PLY
   28a0   0a                LDN 10              ; D = ply
   28a1   fa 0f             ANI $0F             ; Limit to 16 plies
   28a3   fe                SHL
   28a4   fe                SHL                 ; × 4 (2 moves × 2 bytes each)
   28a5   ad                PLO 13              ; R13.0 = offset
                        
                            ; Point to killer table entry
   28a6   f8 64             LDI HIGH(KILLER_MOVES)
   28a8   ba                PHI 10
   28a9   8d                GLO 13
   28aa   fc 20             ADI LOW(KILLER_MOVES)
   28ac   aa                PLO 10              ; R10 = &killer1 for this ply
                        
                            ; Load killer1 (16-bit) into R11
   28ad   4a                LDA 10              ; killer1 low
   28ae   ab                PLO 11
   28af   4a                LDA 10              ; killer1 high
   28b0   bb                PHI 11              ; R11 = killer1
                        
                            ; Load killer2 (16-bit) into R13
   28b1   4a                LDA 10              ; killer2 low
   28b2   ad                PLO 13
   28b3   0a                LDN 10              ; killer2 high
   28b4   bd                PHI 13              ; R13 = killer2
                        
                            ; Check if killers are zero (uninitialized)
   28b5   8b                GLO 11
   28b6   f1                OR
   28b7   9b                GHI 11
   28b8   c2 29 01          LBZ OKM_TRY_KILLER2 ; killer1 is zero, skip
                        
                            ; === Search for killer1 in move list ===
                            ; R8 = scan pointer, start from R9
   28bb   99                GHI 9
   28bc   b8                PHI 8
   28bd   89                GLO 9
   28be   a8                PLO 8               ; R8 = move list start
                        
   28bf   87                GLO 7               ; D = move count
   28c0   b7                PHI 7               ; R7.1 = loop counter
                        
   28c1                 OKM_SCAN_K1:
   28c1   97                GHI 7
   28c2   c2 29 01          LBZ OKM_TRY_KILLER2 ; No more moves to scan
                        
                            ; MOVE_LIST entries stored HIGH first (ADD_MOVE_ENCODED:221). Killer is
                            ; stored with flags=0 (see beta-cutoff store at line ~2042). Compare
                            ; HIGH (mask flag bits 6-7 from list entry), then LOW. Fixed 2026-05-13
                            ; — old code had reversed byte order, so the optimization never matched.
   28c5   48                LDA 8               ; list move HIGH byte; R8 advances
   28c6   fa 3f             ANI $3F             ; mask off flag bits
   28c8   52                STR 2
   28c9   9b                GHI 11              ; killer1 HIGH (flags=0)
   28ca   f3                XOR
   28cb   ca 28 d5          LBNZ OKM_K1_NEXT    ; HIGH bytes don't match
                        
   28ce   08                LDN 8               ; list move LOW byte; R8 stays
   28cf   52                STR 2
   28d0   8b                GLO 11              ; killer1 LOW
   28d1   f3                XOR
   28d2   c2 28 dd          LBZ OKM_K1_FOUND    ; Match! Swap to front
                        
   28d5                 OKM_K1_NEXT:
   28d5   18                INC 8               ; skip past LOW byte to next entry
   28d6   97                GHI 7
   28d7   ff 01             SMI 1
   28d9   b7                PHI 7               ; Decrement counter
   28da   c0 28 c1          LBR OKM_SCAN_K1
                        
   28dd                 OKM_K1_FOUND:
                            ; Killer1 found at R8-1 (we did LDA). Swap with first move.
   28dd   28                DEC 8               ; R8 points to killer1_low in list
                        
                            ; Only swap if not already at front
   28de   98                GHI 8
   28df   52                STR 2
   28e0   99                GHI 9
   28e1   f3                XOR
   28e2   ca 28 ec          LBNZ OKM_K1_SWAP
   28e5   88                GLO 8
   28e6   52                STR 2
   28e7   89                GLO 9
   28e8   f3                XOR
   28e9   c2 29 01          LBZ OKM_TRY_KILLER2 ; Already at front, no swap needed
                        
   28ec                 OKM_K1_SWAP:
                            ; Swap 2-byte entry at R8 with entry at R9
                            ; Save move at R9 to stack
   28ec   49                LDA 9
   28ed   73                STXD
   28ee   09                LDN 9
   28ef   73                STXD
                        
                            ; Copy killer from R8 to R9 (LDA advanced R9 by 1, undo it)
   28f0   29                DEC 9
   28f1   48                LDA 8               ; killer low
   28f2   59                STR 9
   28f3   19                INC 9
   28f4   08                LDN 8               ; killer high
   28f5   59                STR 9
   28f6   19                INC 9               ; R9 back to +2
                        
                            ; Copy saved move from stack to R8
   28f7   28                DEC 8               ; Back to low byte position
   28f8   60                IRX
   28f9   72                LDXA                ; Saved high byte
   28fa   18                INC 8
   28fb   58                STR 8               ; Store at R8+1
   28fc   28                DEC 8
   28fd   f0                LDX                 ; Saved low byte
   28fe   58                STR 8               ; Store at R8
                        
                            ; Reset R9 to list start
   28ff   29                DEC 9
   2900   29                DEC 9
                        
   2901                 OKM_TRY_KILLER2:
                            ; Check if killer2 is zero
   2901   8d                GLO 13
   2902   f1                OR
   2903   9d                GHI 13
   2904   c2 29 62          LBZ OKM_DONE        ; killer2 is zero, skip
                        
                            ; Check if we have at least 2 moves
   2907   87                GLO 7               ; Original move count
   2908   ff 02             SMI 2
   290a   cb 29 62          LBNF OKM_DONE       ; Less than 2 moves
                        
                            ; === Search for killer2 in move list (skip first entry) ===
   290d   99                GHI 9
   290e   b8                PHI 8
   290f   89                GLO 9
   2910   fc 02             ADI 2               ; Skip first entry
   2912   a8                PLO 8
   2913   99                GHI 9
   2914   7c 00             ADCI 0
   2916   b8                PHI 8               ; R8 = second entry
                        
   2917   87                GLO 7               ; move count
   2918   ff 01             SMI 1               ; Skip first
   291a   b7                PHI 7               ; R7.1 = counter
                        
   291b                 OKM_SCAN_K2:
   291b   97                GHI 7
   291c   c2 29 62          LBZ OKM_DONE        ; No more moves
                        
                            ; Byte-order fix (2026-05-13) — HIGH first with mask, then LOW.
   291f   48                LDA 8               ; list move HIGH byte; R8 advances
   2920   fa 3f             ANI $3F             ; mask off flag bits 6-7
   2922   52                STR 2
   2923   9d                GHI 13              ; killer2 HIGH (flags=0)
   2924   f3                XOR
   2925   ca 29 2f          LBNZ OKM_K2_NEXT    ; HIGH bytes don't match
                        
   2928   08                LDN 8               ; list move LOW byte; R8 stays
   2929   52                STR 2
   292a   8d                GLO 13              ; killer2 LOW
   292b   f3                XOR
   292c   c2 29 37          LBZ OKM_K2_FOUND    ; Match!
                        
   292f                 OKM_K2_NEXT:
   292f   18                INC 8               ; skip past LOW byte to next entry
   2930   97                GHI 7
   2931   ff 01             SMI 1
   2933   b7                PHI 7
   2934   c0 29 1b          LBR OKM_SCAN_K2
                        
   2937                 OKM_K2_FOUND:
                            ; Killer2 found at R8-1. Swap with second move (R9+2).
   2937   28                DEC 8               ; R8 points to killer2_low
                        
                            ; Calculate second entry position
   2938   99                GHI 9
   2939   ba                PHI 10
   293a   89                GLO 9
   293b   fc 02             ADI 2
   293d   aa                PLO 10
   293e   99                GHI 9
   293f   7c 00             ADCI 0
   2941   ba                PHI 10              ; R10 = second entry
                        
                            ; Only swap if not already there
   2942   98                GHI 8
   2943   52                STR 2
   2944   9a                GHI 10
   2945   f3                XOR
   2946   ca 29 50          LBNZ OKM_K2_SWAP
   2949   88                GLO 8
   294a   52                STR 2
   294b   8a                GLO 10
   294c   f3                XOR
   294d   c2 29 62          LBZ OKM_DONE        ; Already in position
                        
   2950                 OKM_K2_SWAP:
                            ; Swap 2-byte entry at R8 with entry at R10
   2950   4a                LDA 10              ; second entry low
   2951   73                STXD
   2952   0a                LDN 10              ; second entry high
   2953   73                STXD
                        
                            ; Copy killer to second position
   2954   2a                DEC 10
   2955   48                LDA 8               ; killer low
   2956   5a                STR 10
   2957   1a                INC 10
   2958   08                LDN 8               ; killer high
   2959   5a                STR 10
                        
                            ; Copy saved to R8
   295a   28                DEC 8
   295b   60                IRX
   295c   72                LDXA                ; high byte
   295d   18                INC 8
   295e   58                STR 8
   295f   28                DEC 8
   2960   f0                LDX                 ; low byte
   2961   58                STR 8
                        
   2962                 OKM_DONE:
   2962   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ORDER_CAPTURES_FIRST - Move captures to front of move list, sorted by
                        ;                        victim piece-type value (queen first, pawn last).
                        ; ------------------------------------------------------------------------------
                        ; Input:  R9 = start of move list
                        ;         D = move count
                        ; Output: Move list reordered with captures at front, victim-value descending
                        ;         (Q-takes, R-takes, B-takes, N-takes, P-takes, then non-captures).
                        ; Uses:   R7, R8, R10, R11, R13
                        ; Note:   Call after GENERATE_MOVES, before move loop. Implements simplified
                        ;         victim-only sort (no attacker analysis): 5 passes filtering by
                        ;         piece-type value 5..1. Front pointer R8 persists across passes.
                        ; ------------------------------------------------------------------------------
   2963                 ORDER_CAPTURES_FIRST:
                            ; Save move count
   2963   a7                PLO 7               ; R7.0 = move count
   2964   c2 29 da          LBZ OCF_DONE        ; No moves
                        
                            ; R8 = front pointer (where to put next capture; persists across passes)
   2967   99                GHI 9
   2968   b8                PHI 8
   2969   89                GLO 9
   296a   a8                PLO 8               ; R8 = front = list start
                        
                            ; Initialize filter: start with QUEEN piece type (5), decrement each pass
   296b   68 cd 64 49       RLDI 13, COMPARE_TEMP
   296f   f8 05             LDI 5
   2971   5d                STR 13              ; M(COMPARE_TEMP) = filter type
                        
   2972                 OCF_PASS_LOOP:
                            ; R10 = scan pointer (re-init each pass)
   2972   99                GHI 9
   2973   ba                PHI 10
   2974   89                GLO 9
   2975   aa                PLO 10              ; R10 = scan = list start
                        
                            ; R7.1 = remaining count to scan (re-init each pass)
   2976   87                GLO 7
   2977   b7                PHI 7
                        
   2978                 OCF_SCAN_LOOP:
   2978   97                GHI 7
   2979   c2 29 cf          LBZ OCF_PASS_DONE   ; No more moves to scan in this pass
                        
                            ; Decode move at R10 to get target square
                            ; Move format: [flags:2][to:7][from:7]
                            ; Move list is big-endian: high byte first, low byte second
   297c   4a                LDA 10              ; High byte (first in big-endian)
   297d   bb                PHI 11              ; R11.1 = high byte
   297e   0a                LDN 10              ; Low byte (second in big-endian)
   297f   ab                PLO 11              ; R11.0 = low byte
                        
                            ; Extract 'to' square: (high & $3F) << 1 | (low >> 7)
   2980   9b                GHI 11              ; D = high byte (LDN left D with low byte)
   2981   fa 3f             ANI $3F
   2983   fe                SHL
   2984   ad                PLO 13              ; R13.0 = to bits 1-6
   2985   8b                GLO 11              ; Low byte
   2986   fa 80             ANI $80             ; Bit 7
   2988   c2 29 8f          LBZ OCF_TO_BIT0_CLR
   298b   8d                GLO 13
   298c   f9 01             ORI $01
   298e   ad                PLO 13
   298f                 OCF_TO_BIT0_CLR:
                            ; R13.0 = to square, R11 = encoded move
                        
                            ; Check if target square has a piece (any piece = potential capture)
                            ; Calculate BOARD + to_square
                            ; BOARD is at $6000, so high byte is $60, low byte is to_square
   298f   f8 60             LDI HIGH(BOARD)
   2991   bd                PHI 13
                            ; R13 now = $60xx where xx = to_square (already in R13.0)
                        
                            ; Load piece at target square
   2992   0d                LDN 13              ; D = piece at target
   2993   2a                DEC 10              ; Reset R10 to low byte position
                        
                            ; If piece is 0 (empty), not a capture
   2994   c2 29 c6          LBZ OCF_NEXT_MOVE   ; Empty square, skip
                        
                            ; Check victim type against current pass filter.
                            ; D still holds piece byte; mask off color to get type (1-6).
   2997   fa 07             ANI PIECE_MASK      ; D = victim type (1-5; king=6 can't actually be captured)
   2999   52                STR 2               ; M(R2) = victim type (temp)
   299a   68 cd 64 49       RLDI 13, COMPARE_TEMP
   299e   0d                LDN 13              ; D = current pass filter type
   299f   f3                XOR                 ; D = filter ^ victim (0 if match, since SEX 2 set globally)
   29a0   ca 29 c6          LBNZ OCF_NEXT_MOVE  ; victim type doesn't match this pass — skip
                        
                            ; Match: capture with current filter type. Fall through to swap.
                        
   29a3                 OCF_IS_CAPTURE:
                            ; Move is a capture - swap to front if not already there
                            ; R10 points to current move, R8 points to front
   29a3   9a                GHI 10
   29a4   52                STR 2
   29a5   98                GHI 8
   29a6   f3                XOR
   29a7   ca 29 b1          LBNZ OCF_DO_SWAP
   29aa   8a                GLO 10
   29ab   52                STR 2
   29ac   88                GLO 8
   29ad   f3                XOR
   29ae   c2 29 c4          LBZ OCF_ADVANCE_FRONT  ; Already at front
                        
   29b1                 OCF_DO_SWAP:
                            ; Swap 2-byte entries at R8 and R10
                            ; Save R8 entry to stack
   29b1   48                LDA 8
   29b2   73                STXD
   29b3   08                LDN 8
   29b4   73                STXD
   29b5   28                DEC 8               ; Reset R8
                        
                            ; Copy R10 to R8
   29b6   4a                LDA 10
   29b7   58                STR 8
   29b8   18                INC 8
   29b9   0a                LDN 10
   29ba   58                STR 8
   29bb   28                DEC 8
   29bc   2a                DEC 10              ; Reset both
                        
                            ; Copy stack to R10
   29bd   60                IRX
   29be   72                LDXA                ; High byte
   29bf   1a                INC 10
   29c0   5a                STR 10
   29c1   2a                DEC 10
   29c2   f0                LDX                 ; Low byte
   29c3   5a                STR 10
                        
   29c4                 OCF_ADVANCE_FRONT:
                            ; Advance front pointer
   29c4   18                INC 8
   29c5   18                INC 8
                        
   29c6                 OCF_NEXT_MOVE:
                            ; Advance scan pointer
   29c6   1a                INC 10
   29c7   1a                INC 10
                            ; Decrement counter
   29c8   97                GHI 7
   29c9   ff 01             SMI 1
   29cb   b7                PHI 7
   29cc   c0 29 78          LBR OCF_SCAN_LOOP
                        
   29cf                 OCF_PASS_DONE:
                            ; Decrement filter type for next pass; loop until filter reaches 0.
   29cf   68 cd 64 49       RLDI 13, COMPARE_TEMP
   29d3   0d                LDN 13
   29d4   ff 01             SMI 1
   29d6   5d                STR 13              ; filter--
   29d7   ca 29 72          LBNZ OCF_PASS_LOOP  ; continue if filter > 0
                        
   29da                 OCF_DONE:
   29da   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; INC_NODE_COUNT - Increment 32-bit node counter (FULL VERSION)
                        ; ------------------------------------------------------------------------------
                        ; Input:  None
                        ; Output: NODES_SEARCHED incremented
                        ; Uses:   A, D
                        ; ------------------------------------------------------------------------------
   29db                 INC_NODE_COUNT:
   29db   68 ca 64 12       RLDI 10, NODES_SEARCHED
                        
                            ; Increment byte 0 (LSB)
   29df   0a                LDN 10
   29e0   fc 01             ADI 1
   29e2   5a                STR 10
   29e3   ca 29 fb          LBNZ INC_NODE_DONE   ; No carry
                        
                            ; Carry to byte 1
   29e6   1a                INC 10
   29e7   0a                LDN 10
   29e8   7c 00             ADCI 0
   29ea   5a                STR 10
   29eb   ca 29 fb          LBNZ INC_NODE_DONE
                        
                            ; Carry to byte 2
   29ee   1a                INC 10
   29ef   0a                LDN 10
   29f0   7c 00             ADCI 0
   29f2   5a                STR 10
   29f3   ca 29 fb          LBNZ INC_NODE_DONE
                        
                            ; Carry to byte 3 (MSB)
   29f6   1a                INC 10
   29f7   0a                LDN 10
   29f8   7c 00             ADCI 0
   29fa   5a                STR 10
                        
   29fb                 INC_NODE_DONE:
   29fb   d5                RETN
                        
                        ; ==============================================================================
                        ; SEARCH_POSITION - Iterative Deepening Entry Point
                        ; ==============================================================================
                        ; Input:  SEARCH_DEPTH = target depth (stored in memory by UCI handler)
                        ; Output: R9 = best score (R6 is SCRT linkage - off limits!)
                        ;         BEST_MOVE = best move found
                        ; Searches depth 1, 2, ..., TARGET_DEPTH. If depth N exceeds node budget,
                        ; aborts and returns depth N-1's bestmove.
                        ; ==============================================================================
   29fc                 SEARCH_POSITION:
   29fc   e2                SEX 2
                        
                            ; --- Save TARGET_DEPTH from SEARCH_DEPTH (set by UCI handler) ---
   29fd   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   2a01   0a                LDN 10                      ; D = target depth (low byte)
   2a02   73                STXD                        ; Save depth on stack (LDI clobbers D!)
   2a03   68 ca 64 c6       RLDI 10, TARGET_DEPTH
   2a07   60                IRX
   2a08   f0                LDX                         ; D = target depth (restored from stack)
   2a09   5a                STR 10                      ; TARGET_DEPTH = original depth
                        
                            ; --- Clear SEARCH_ABORTED flag ---
   2a0a   68 ca 64 c4       RLDI 10, SEARCH_ABORTED
   2a0e   f8 00             LDI 0
   2a10   5a                STR 10
                        
                            ; --- Clear ITER_BEST (no bestmove yet) ---
   2a11   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   2a15   f8 ff             LDI $FF
   2a17   5a                STR 10
   2a18   1a                INC 10
   2a19   5a                STR 10                      ; ITER_BEST_TO = $FF
                        
                            ; --- Set starting depth = 1 ---
   2a1a   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2a1e   f8 01             LDI 1
   2a20   5a                STR 10
                        
                            ; --- Initialize RTC elapsed timer ---
                            ; Read current seconds from DS12887 RTC (binary mode)
                            ; Protocol: OUT port 2 = register select, INP port 3 = read data
   2a21   f8 80             LDI $80                     ; $80 = seconds register
   2a23   52                STR 2                       ; Store at M(R2) for OUT
   2a24   62                OUT 2                       ; Send to port 2 (selects seconds), R2++
   2a25   22                DEC 2                       ; Restore stack pointer
   2a26   6b                INP 3                       ; D = seconds (binary 0-59), also M(R2)
   2a27   73                STXD                        ; Save seconds on stack (LDI clobbers D!)
   2a28   68 ca 64 ca       RLDI 10, SEARCH_PREV_SECS
   2a2c   60                IRX
   2a2d   f0                LDX                         ; D = seconds (restored)
   2a2e   5a                STR 10                      ; SEARCH_PREV_SECS = current seconds
                        
                            ; Clear elapsed counter
   2a2f   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2a33   f8 00             LDI 0
   2a35   5a                STR 10                      ; SEARCH_ELAPSED = 0
                        
                            ; --- Canary check (ported 2026-07-13): CANARY_ZONE $64F7-$64FC must be all
                            ; zero (no code owns it; the 7/3 v3-build crash dump found stray writes
                            ; there). Sticky-OR into CANARY_HIT once per search — a nonzero CANARY_HIT
                            ; in any post-crash dump = the stray writer struck this game.
   2a36   68 ca 64 f7       RLDI 10, CANARY_ZONE
   2a3a   f8 00             LDI 0
   2a3c   52                STR 2                       ; M(2) = accumulator = 0
   2a3d   f8 06             LDI 6
   2a3f   ab                PLO 11                      ; R11.0 = byte counter (R11 reloaded below)
   2a40                 SP_CANARY_LP:
   2a40   4a                LDA 10
   2a41   f1                OR                          ; D = zone byte | acc
   2a42   52                STR 2                       ; acc back to M(2)
   2a43   2b                DEC 11
   2a44   8b                GLO 11
   2a45   ca 2a 40          LBNZ SP_CANARY_LP
   2a48   68 ca 64 1e       RLDI 10, CANARY_HIT
   2a4c   0a                LDN 10
   2a4d   f1                OR                          ; D = CANARY_HIT | acc
   2a4e   5a                STR 10                      ; sticky
                        
                            ; --- Clear node counter (once for entire search) ---
   2a4f   68 cb 64 12       RLDI 11, NODES_SEARCHED
   2a53   f8 00             LDI 0
   2a55   5b                STR 11
   2a56   1b                INC 11
   2a57   5b                STR 11
   2a58   1b                INC 11
   2a59   5b                STR 11
   2a5a   1b                INC 11
   2a5b   5b                STR 11
                        
                            ; --- Zobrist hash: use the incremental hash from UCI parsing ---
                            ; Do NOT call HASH_INIT here! HASH_INIT includes castling/EP Zobrist
                            ; keys, but MAKE_MOVE doesn't XOR castling/EP changes. This creates a
                            ; mismatch between search hashes (from-scratch) and HASH_HIST entries
                            ; (incremental), which breaks repetition detection completely.
                            ; The hash left by UCI parsing is already correct and consistent.
                        
                        ; ======================================================================
                        ; ITERATIVE DEEPENING LOOP
                        ; ======================================================================
   2a5c                 ITER_LOOP:
                            ; --- Set SEARCH_DEPTH = CURRENT_MAX_DEPTH for this iteration ---
   2a5c   68 ca 64 16       RLDI 10, SEARCH_DEPTH
   2a60   f8 00             LDI 0
   2a62   5a                STR 10                      ; SEARCH_DEPTH high = 0
   2a63   1a                INC 10
                            ; Load CURRENT_MAX_DEPTH
   2a64   68 cd 64 c5       RLDI 13, CURRENT_MAX_DEPTH
   2a68   0d                LDN 13                      ; D = current depth
   2a69   5a                STR 10                      ; SEARCH_DEPTH low = current depth
                        
                            ; --- Reset SEARCH_ABORTED for this iteration ---
   2a6a   68 ca 64 c4       RLDI 10, SEARCH_ABORTED
   2a6e   f8 00             LDI 0
   2a70   5a                STR 10
                        
                            ; --- Capture iteration start time for iteration-time gate ---
   2a71   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2a75   0a                LDN 10
   2a76   68 ca 64 ed       RLDI 10, ITER_START_ELAPSED
   2a7a   5a                STR 10
                        
                            ; --- Standard search init ---
                            ; Alpha = -32767
   2a7b   68 ca 64 42       RLDI 10, ALPHA_HI
   2a7f   f8 80             LDI $80
   2a81   5a                STR 10                      ; ALPHA_HI = $80
   2a82   1a                INC 10
   2a83   f8 01             LDI $01
   2a85   5a                STR 10                      ; ALPHA_LO = $01
                        
                            ; Beta = +32767
   2a86   68 ca 64 44       RLDI 10, BETA_HI
   2a8a   f8 7f             LDI $7F
   2a8c   5a                STR 10                      ; BETA_HI = $7F
   2a8d   1a                INC 10
   2a8e   f8 ff             LDI $FF
   2a90   5a                STR 10                      ; BETA_LO = $FF
                        
                            ; CURRENT_PLY = 0
   2a91   68 ca 64 48       RLDI 10, CURRENT_PLY
   2a95   f8 00             LDI 0
   2a97   5a                STR 10
                        
                            ; NULL_MOVE_OK = 1
   2a98   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   2a9c   f8 01             LDI 1
   2a9e   5a                STR 10
                        
                            ; Get side to move
   2a9f   d4 01 3e          CALL GET_SIDE_TO_MOVE
   2aa2   ac                PLO 12                      ; C.0 = color
                        
                            ; Board pointer
   2aa3   68 ca 60 00       RLDI 10, BOARD
                        
                            ; Clear best move for this iteration
   2aa7   68 cb 64 10       RLDI 11, BEST_MOVE
   2aab   f8 ff             LDI $FF
   2aad   5b                STR 11
   2aae   1b                INC 11
   2aaf   5b                STR 11
                        
                            ; --- Run search for this depth ---
   2ab0   d4 1b 35          CALL NEGAMAX
                        
                            ; --- Check if search was aborted ---
   2ab3   68 ca 64 c4       RLDI 10, SEARCH_ABORTED
   2ab7   0a                LDN 10
   2ab8   ca 2b 2d          LBNZ ITER_ABORTED           ; Aborted: use previous depth's bestmove
                        
                            ; --- Depth completed: save bestmove ---
                            ; Set up BOTH pointers first, then copy (LDI clobbers D!)
   2abb   68 ca 64 10       RLDI 10, BEST_MOVE
   2abf   68 cb 64 c2       RLDI 11, ITER_BEST_FROM
                            ; Now copy: R10→BEST_MOVE, R11→ITER_BEST
   2ac3   4a                LDA 10                      ; D = from square
   2ac4   5b                STR 11                      ; ITER_BEST_FROM = from
   2ac5   1b                INC 11
   2ac6   0a                LDN 10                      ; D = to square (BEST_MOVE+1)
   2ac7   5b                STR 11                      ; ITER_BEST_TO = to
                        
                            ; --- Save score from this depth ---
   2ac8   68 ca 64 c8       RLDI 10, ITER_SCORE_HI
   2acc   99                GHI 9
   2acd   5a                STR 10                      ; ITER_SCORE_HI = R9.hi
   2ace   1a                INC 10
   2acf   89                GLO 9
   2ad0   5a                STR 10                      ; ITER_SCORE_LO = R9.lo
                        
                            ; --- Send UCI "info" for this depth ---
   2ad1   d4 2b 3b          CALL SEND_UCI_INFO
                        
                            ; Stack-overflow handling moved to CHECK_STACK_OVERFLOW (2026-05-16):
                            ; it now traps via MARK/SEP 1 immediately on detection, so this
                            ; IDS-boundary report path is unreachable. STACK_OVERFLOW_FLAG remains
                            ; written by the guard for post-trap memory dump inspection.
   2ad4                 ITER_NO_SOVF:
                        
                            ; --- Iterative deepening termination decision ---
                            ; UCI semantics: TARGET_DEPTH is treated as a CAP (max depth we may reach),
                            ; not a fixed target. The engine self-decides whether to attempt the next
                            ; deeper iteration based on iteration-time prediction and a hard safety cap.
                            ;
                            ; Termination rules (stop if any are true; else continue to current+1):
                            ;   1. current >= TARGET_DEPTH   — respect UCI cap
                            ;   2. current >= 5              — hard safety cap (MOVE_LIST sized for 5 plies)
                            ;   3. current >= 3 AND predicted_next > remaining_budget — iter-time gate
                            ;
                            ; Iter-time gate (rule 3, replaces 60s/90s cumulative thresholds 2026-05-06):
                            ;   predicted_next = 3 * last_iter_seconds  (BF=3, conservative)
                            ;   remaining      = 180 - SEARCH_ELAPSED
                            ;   stop if predicted_next >= remaining
                            ; Rationale: closed positions branch ~3x at d>=4 (vs ~1.8x in open). Old
                            ; cumulative gate let d=5 start with insufficient budget in Hippo-class
                            ; positions, wasting 80-110s/move on incomplete d=5 (lost match 2026-05-06
                            ; move 5-9, all d=4 timeouts). Iteration-time gate uses the actual measured
                            ; iteration time so it adapts to position. RTC is 1s resolution; gate only
                            ; applies at d>=3 where iteration times are reliably multi-second.
                        
                            ; Rule 1: current >= TARGET_DEPTH?
   2ad4   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2ad8   0a                LDN 10
   2ad9   52                STR 2                       ; M(R2) = current
   2ada   68 ca 64 c6       RLDI 10, TARGET_DEPTH
   2ade   0a                LDN 10                      ; D = target
   2adf   f7                SM                          ; D = target - current; DF=1 if target >= current
   2ae0   cb 2b 3a          LBNF ITER_DONE              ; target < current — defensive (shouldn't happen)
   2ae3   c2 2b 3a          LBZ ITER_DONE               ; target == current — UCI cap reached
                        
                            ; Rule 2: current >= 5?
   2ae6   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2aea   0a                LDN 10
   2aeb   ff 05             SMI 5
   2aed   c3 2b 3a          LBDF ITER_DONE              ; current >= 5 — hard safety cap
                        
                            ; Rule 3: iteration-time gate. Apply only at depth >= 3.
   2af0   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2af4   0a                LDN 10
   2af5   ff 03             SMI 3
   2af7   cb 2b 22          LBNF ITER_INCREMENT         ; current < 3 — always continue (RTC granularity)
                        
                            ; last_iter_seconds = SEARCH_ELAPSED - ITER_START_ELAPSED
   2afa   68 ca 64 ed       RLDI 10, ITER_START_ELAPSED
   2afe   0a                LDN 10
   2aff   52                STR 2                       ; M(R2) = iter_start
   2b00   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2b04   0a                LDN 10                      ; D = elapsed
   2b05   f7                SM                          ; D = elapsed - iter_start = last_iter
   2b06   ad                PLO 13                      ; R13.0 = last_iter
                        
                            ; Fast path: last_iter > 60 → 3*last_iter overflows AND exceeds remaining
   2b07   ff 3d             SMI 61
   2b09   c3 2b 3a          LBDF ITER_DONE              ; last_iter >= 61 — stop
                        
                            ; predicted = 3 * last_iter (no overflow: last_iter <= 60, so 3x <= 180)
   2b0c   8d                GLO 13                      ; D = last_iter
   2b0d   fe                SHL                         ; D = 2 * last_iter
   2b0e   52                STR 2                       ; M(R2) = 2 * last_iter
   2b0f   8d                GLO 13                      ; D = last_iter
   2b10   f4                ADD                         ; D = 3 * last_iter
   2b11   ad                PLO 13                      ; R13.0 = predicted
                        
                            ; remaining = 180 - SEARCH_ELAPSED
   2b12   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2b16   0a                LDN 10
   2b17   fd b4             SDI 180                     ; D = 180 - elapsed
   2b19   cb 2b 3a          LBNF ITER_DONE              ; elapsed > 180 (defensive; budget abort handles too)
                        
                            ; if predicted >= remaining: stop, else continue
   2b1c   52                STR 2                       ; M(R2) = remaining
   2b1d   8d                GLO 13                      ; D = predicted
   2b1e   f7                SM                          ; D = predicted - remaining
   2b1f   c3 2b 3a          LBDF ITER_DONE              ; predicted >= remaining — stop
                        
   2b22                 ITER_INCREMENT:
                            ; --- Increment depth and loop ---
   2b22   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2b26   0a                LDN 10
   2b27   fc 01             ADI 1
   2b29   5a                STR 10                      ; CURRENT_MAX_DEPTH++
   2b2a   c0 2a 5c          LBR ITER_LOOP
                        
   2b2d                 ITER_ABORTED:
                            ; Search at this depth was aborted — fall back to ITER_BEST
                            ; Set up BOTH pointers first, then copy (LDI clobbers D!)
   2b2d   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   2b31   68 cb 64 10       RLDI 11, BEST_MOVE
                            ; Now copy: R10→ITER_BEST, R11→BEST_MOVE
   2b35   4a                LDA 10                      ; D = ITER_BEST_FROM
   2b36   5b                STR 11                      ; BEST_MOVE[0] = from
   2b37   1b                INC 11
   2b38   0a                LDN 10                      ; D = ITER_BEST_TO
   2b39   5b                STR 11                      ; BEST_MOVE[1] = to
                        
   2b3a                 ITER_DONE:
   2b3a   d5                RETN
                        
                        ; ==============================================================================
                        ; SEND_UCI_INFO - Send "info depth N score cp S nodes NNNNN" after each iteration
                        ; ==============================================================================
                        ; Sends: "info depth N score cp S nodes NNNNN\r\n"
                        ;   N = CURRENT_MAX_DEPTH (ASCII digit)
                        ;   S = ITER_SCORE as signed decimal (centipawns)
                        ;   NNNNN = NODES_SEARCHED as decimal via F_UINTOUT (lower 16 bits)
                        ; ==============================================================================
   2b3b                 SEND_UCI_INFO:
                            ; Send "info depth "
   2b3b   68 cf 2c 69       RLDI 15, STR_INFO_DEPTH
   2b3f   d4                SEP 4
   2b40   ff 09             DW F_MSG
                        
                            ; Send depth digit (1-9)
   2b42   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2b46   0a                LDN 10                      ; D = depth (1-9)
   2b47   fc 30             ADI '0'                     ; Convert to ASCII
   2b49   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
                            ; Send " score cp "
   2b4c   68 cf 2c 75       RLDI 15, STR_SCORE_CP
   2b50   d4                SEP 4
   2b51   ff 09             DW F_MSG
                        
                            ; Load score into R13 (big-endian: HI at $64C8, LO at $64C9)
   2b53   68 ca 64 c8       RLDI 10, ITER_SCORE_HI
   2b57   4a                LDA 10                      ; D = score high byte, R10 -> LO
   2b58   bd                PHI 13
   2b59   0a                LDN 10                      ; D = score low byte
   2b5a   ad                PLO 13                      ; R13 = signed 16-bit score
                        
                            ; Check if negative
   2b5b   9d                GHI 13
   2b5c   fa 80             ANI $80
   2b5e   c2 2b 6e          LBZ SUCI_POSITIVE
                        
                            ; Negative: print '-' and negate R13 to get absolute value
   2b61   f8 2d             LDI '-'
   2b63   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2b66   8d                GLO 13                      ; low byte
   2b67   fd 00             SDI 0                       ; negate low
   2b69   ad                PLO 13
   2b6a   9d                GHI 13                      ; high byte
   2b6b   7d 00             SDBI 0                      ; negate high with borrow
   2b6d   bd                PHI 13
                        
   2b6e                 SUCI_POSITIVE:
                            ; Convert R13 (now unsigned magnitude) to ASCII decimal
   2b6e   68 cf 64 cc       RLDI 15, UINT_BUFFER
   2b72   d4                SEP 4
   2b73   ff 60             DW F_UINTOUT
                        
                            ; Null-terminate (R15 points past last digit)
   2b75   f8 00             LDI 0
   2b77   5f                STR 15
                        
                            ; Print the score string
   2b78   68 cf 64 cc       RLDI 15, UINT_BUFFER
   2b7c   d4                SEP 4
   2b7d   ff 09             DW F_MSG
                        
                            ; Send " nodes "
   2b7f   68 cf 2c 80       RLDI 15, STR_NODES
   2b83   d4                SEP 4
   2b84   ff 09             DW F_MSG
                        
                            ; Load NODES_SEARCHED (16-bit) into R13: high byte first, then low
   2b86   68 ca 64 13       RLDI 10, NODES_SEARCHED + 1
   2b8a   0a                LDN 10                      ; D = high byte of node count
   2b8b   bd                PHI 13                      ; R13.1 = high byte
   2b8c   68 ca 64 12       RLDI 10, NODES_SEARCHED
   2b90   0a                LDN 10                      ; D = low byte of node count
   2b91   ad                PLO 13                      ; R13.0 = low byte
                        
                            ; Point R15 at ASCII scratch buffer
   2b92   68 cf 64 cc       RLDI 15, UINT_BUFFER
                        
                            ; Convert R13 to ASCII decimal at R15
   2b96   d4                SEP 4
   2b97   ff 60             DW F_UINTOUT
                        
                            ; Null-terminate (R15 points past last digit)
   2b99   f8 00             LDI 0
   2b9b   5f                STR 15
                        
                            ; Print the decimal string
   2b9c   68 cf 64 cc       RLDI 15, UINT_BUFFER
   2ba0   d4                SEP 4
   2ba1   ff 09             DW F_MSG
                        
                            ; Send CR+LF
   2ba3   f8 0d             LDI 13
   2ba5   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2ba8   f8 0a             LDI 10
   2baa   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   2bad   d5                RETN
                        
                        ; ==============================================================================
                        ; End of Negamax Core
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - UCI Protocol Implementation
                        ; ==============================================================================
                        ; Universal Chess Interface for communication with GUI
                        ; Implements minimal UCI subset for playability
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI Command Buffer - defined in board.asm
                        ; ------------------------------------------------------------------------------
                        ; UCI_BUFFER ($7000, 2048 bytes) and UCI_STATE ($64B8) defined in board.asm
   07ff                 UCI_BUFFER_LEN  EQU 2047    ; Max chars (16-bit counter, 2048-byte buffer)
   0001                 UCI_READY       EQU 1       ; Ready state
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI String Constants
                        ; ------------------------------------------------------------------------------
                        ; These would be defined as byte arrays in actual implementation
                        
   2bae   75 63 69 00   STR_UCI         DB "uci", 0
   2bb2   69 73 72 65   STR_ISREADY     DB "isready", 0
   2bb6   61 64 79 00   
   2bba   70 6f 73 69   STR_POSITION    DB "position", 0
   2bbe   74 69 6f 6e   
   2bc2   00            
   2bc3   67 6f 00      STR_GO          DB "go", 0
   2bc6   71 75 69 74   STR_QUIT        DB "quit", 0
   2bca   00            
   2bcb   75 63 69 6e   STR_UCINEWGAME  DB "ucinewgame", 0
   2bcf   65 77 67 61   
   2bd3   6d 65 00      
   2bd6   73 74 6f 70   STR_STOP        DB "stop", 0
   2bda   00            
                        
                        ; Response strings (CR+LF for terminal display)
   2bdb   69 64 20 6e   STR_ID_NAME     DB "id name RCA-Chess-1806", 13, 10, 0
   2bdf   61 6d 65 20   
   2be3   52 43 41 2d   
   2be7   43 68 65 73   
   2beb   73 2d 31 38   
   2bef   30 36 0d 0a   
   2bf3   00            
   2bf4   69 64 20 61   STR_ID_AUTHOR   DB "id author Mark Abene & Claude Code", 13, 10, 0
   2bf8   75 74 68 6f   
   2bfc   72 20 4d 61   
   2c00   72 6b 20 41   
   2c04   62 65 6e 65   
   2c08   20 26 20 43   
   2c0c   6c 61 75 64   
   2c10   65 20 43 6f   
   2c14   64 65 0d 0a   
   2c18   00            
   2c19   6f 70 74 69   STR_OPTION_DEPTH DB "option name Depth type spin default 4 min 1 max 6", 13, 10, 0
   2c1d   6f 6e 20 6e   
   2c21   61 6d 65 20   
   2c25   44 65 70 74   
   2c29   68 20 74 79   
   2c2d   70 65 20 73   
   2c31   70 69 6e 20   
   2c35   64 65 66 61   
   2c39   75 6c 74 20   
   2c3d   34 20 6d 69   
   2c41   6e 20 31 20   
   2c45   6d 61 78 20   
   2c49   36 0d 0a 00   
   2c4d   75 63 69 6f   STR_UCIOK       DB "uciok", 13, 10, 0
   2c51   6b 0d 0a 00   
   2c55   72 65 61 64   STR_READYOK     DB "readyok", 13, 10, 0
   2c59   79 6f 6b 0d   
   2c5d   0a 00         
   2c5f   62 65 73 74   STR_BESTMOVE    DB "bestmove ", 0
   2c63   6d 6f 76 65   
   2c67   20 00         
   2c69   69 6e 66 6f   STR_INFO_DEPTH  DB "info depth ", 0
   2c6d   20 64 65 70   
   2c71   74 68 20 00   
   2c75   20 73 63 6f   STR_SCORE_CP    DB " score cp ", 0
   2c79   72 65 20 63   
   2c7d   70 20 00      
   2c80   20 6e 6f 64   STR_NODES       DB " nodes ", 0
   2c84   65 73 20 00   
                        ; STR_INFO_SOVF removed 2026-05-16 — CHECK_STACK_OVERFLOW now hard-traps
                        ; via MARK/SEP 1 instead of emitting an info string via a corrupted stack.
   2c88   69 6e 66 6f   STR_INFO_RMV    DB "info string ROOT_MOVE_INVALID_SUBSTITUTED", 13, 10, 0
   2c8c   20 73 74 72   
   2c90   69 6e 67 20   
   2c94   52 4f 4f 54   
   2c98   5f 4d 4f 56   
   2c9c   45 5f 49 4e   
   2ca0   56 41 4c 49   
   2ca4   44 5f 53 55   
   2ca8   42 53 54 49   
   2cac   54 55 54 45   
   2cb0   44 0d 0a 00   
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_INIT - Initialize UCI interface
                        ; ------------------------------------------------------------------------------
   2cb4                 UCI_INIT:
                            ; Set up serial I/O (if needed)
                            ; TODO: Hardware-specific initialization
                        
                            ; Set initial state
   2cb4   f8 01             LDI UCI_READY
   2cb6   ad                PLO 13
                        
   2cb7   68 ca 64 b8       RLDI 10, UCI_STATE
                        
   2cbb   8d                GLO 13
   2cbc   5a                STR 10
                        
   2cbd   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_READ_LINE - Read a line of input
                        ; ------------------------------------------------------------------------------
                        ; Input:  None
                        ; Output: Line in UCI_BUFFER, null-terminated
                        ;         D = length
                        ; Uses:   A, D
                        ;
                        ; Reads characters until newline or max length
                        ; ------------------------------------------------------------------------------
   2cbe                 UCI_READ_LINE:
   2cbe   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2cc2   f8 00             LDI 0
   2cc4   bd                PHI 13              ; R13.1 = count high byte = 0
   2cc5   ad                PLO 13              ; R13.0 = count low byte = 0
                        
   2cc6                 UCI_READ_LOOP:
                            ; Read character from serial input
   2cc6   d4 00 07          CALL SERIAL_READ_CHAR
                            ; Returns character in D
                        
                            ; Check for carriage return (CR = 13)
   2cc9   ff 0d             SMI 13
   2ccb   c2 2c e6          LBZ UCI_READ_DONE
                        
                            ; Check for newline (LF = 10) - restore D first
   2cce   fc 0d             ADI 13              ; Restore: (D-13)+13 = D
   2cd0   ff 0a             SMI 10              ; Check for LF
   2cd2   c2 2c e6          LBZ UCI_READ_DONE
   2cd5   fc 0a             ADI 10              ; Restore D
                        
                            ; Store character
   2cd7   5a                STR 10
   2cd8   1a                INC 10
                        
                            ; Increment 16-bit count
   2cd9   1d                INC 13
                        
                            ; Check buffer limit (16-bit: UCI_BUFFER_LEN = 2047 = $07FF)
   2cda   8d                GLO 13
   2cdb   fb ff             XRI LOW(UCI_BUFFER_LEN)
   2cdd   ca 2c c6          LBNZ UCI_READ_LOOP
   2ce0   9d                GHI 13
   2ce1   fb 07             XRI HIGH(UCI_BUFFER_LEN)
   2ce3   ca 2c c6          LBNZ UCI_READ_LOOP
                            ; Count == UCI_BUFFER_LEN, buffer full
                        
                        
                        
   2ce6                 UCI_READ_DONE:
                            ; Null-terminate string
   2ce6   f8 00             LDI 0
   2ce8   5a                STR 10
                        
                            ; Echo CR+LF
   2ce9   f8 0d             LDI 13
   2ceb   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2cee   f8 0a             LDI 10
   2cf0   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
                            ; Return length
   2cf3   8d                GLO 13
   2cf4   d5                RETN
                        
                        ; NOTE: UCI_WRITE_STRING removed - use F_MSG with R15 directly
                        ; The old UCI_WRITE_STRING used R10, which clobbered the negamax loop counter!
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_PROCESS_COMMAND - Process UCI command from buffer
                        ; ------------------------------------------------------------------------------
                        ; Input:  Command in UCI_BUFFER
                        ; Output: Appropriate action taken
                        ; ------------------------------------------------------------------------------
   2cf5                 UCI_PROCESS_COMMAND:
                            ; Compare command with known commands
                        
                            ; Check "uci"
   2cf5   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2cf9   68 cb 2b ae       RLDI 11, STR_UCI
                        
   2cfd   d4 30 11          CALL STRCMP
   2d00   c2 2d 58          LBZ UCI_CMD_UCI
                        
                            ; Check "isready"
   2d03   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d07   68 cb 2b b2       RLDI 11, STR_ISREADY
                        
   2d0b   d4 30 11          CALL STRCMP
   2d0e   c2 2d 75          LBZ UCI_CMD_ISREADY
                        
                            ; Check "position"
   2d11   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d15   68 cb 2b ba       RLDI 11, STR_POSITION
                        
   2d19   d4 30 27          CALL STRNCMP        ; Compare first 8 chars
   2d1c   c2 2d 7d          LBZ UCI_CMD_POSITION
                        
                            ; Check "go"
   2d1f   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d23   68 cb 2b c3       RLDI 11, STR_GO
                        
   2d27   d4 30 27          CALL STRNCMP
   2d2a   c2 2e ac          LBZ UCI_CMD_GO
                        
                            ; Check "quit"
   2d2d   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d31   68 cb 2b c6       RLDI 11, STR_QUIT
                        
   2d35   d4 30 11          CALL STRCMP
   2d38   c2 2f 94          LBZ UCI_CMD_QUIT
                        
                            ; Check "ucinewgame"
   2d3b   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d3f   68 cb 2b cb       RLDI 11, STR_UCINEWGAME
                        
   2d43   d4 30 11          CALL STRCMP
   2d46   c2 2f 97          LBZ UCI_CMD_UCINEWGAME
                        
                            ; Check "stop"
   2d49   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d4d   68 cb 2b d6       RLDI 11, STR_STOP
                        
   2d51   d4 30 11          CALL STRCMP
   2d54   c2 2f c2          LBZ UCI_CMD_STOP
                        
                            ; Unknown command - ignore
   2d57   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI Command Handlers
                        ; ------------------------------------------------------------------------------
                        
   2d58                 UCI_CMD_UCI:
                            ; Send identification
   2d58   68 cf 2b db       RLDI 15, STR_ID_NAME
   2d5c   d4                SEP 4
   2d5d   ff 09             DW F_MSG
                        
   2d5f   68 cf 2b f4       RLDI 15, STR_ID_AUTHOR
   2d63   d4                SEP 4
   2d64   ff 09             DW F_MSG
                        
                            ; Send options
   2d66   68 cf 2c 19       RLDI 15, STR_OPTION_DEPTH
   2d6a   d4                SEP 4
   2d6b   ff 09             DW F_MSG
                        
                            ; Send uciok
   2d6d   68 cf 2c 4d       RLDI 15, STR_UCIOK
   2d71   d4                SEP 4
   2d72   ff 09             DW F_MSG
                        
   2d74   d5                RETN
                        
   2d75                 UCI_CMD_ISREADY:
                            ; Send readyok
   2d75   68 cf 2c 55       RLDI 15, STR_READYOK
   2d79   d4                SEP 4
   2d7a   ff 09             DW F_MSG
                        
   2d7c   d5                RETN
                        
   2d7d                 UCI_CMD_POSITION:
                            ; Parse position command
                            ; Format: "position startpos" or "position startpos moves e2e4 ..."
                        
                            ; Check if "startpos"
   2d7d   68 ca 70 09       RLDI 10, UCI_BUFFER + 9
                        
                            ; Check for "startpos"
   2d81   0a                LDN 10
   2d82   fb 73             XRI 's'
   2d84   ca 2e 86          LBNZ UCI_POS_DONE   ; Not startpos (FEN not supported yet)
                        
                            ; Initialize to starting position
   2d87   d4 00 a6          CALL INIT_BOARD
   2d8a   d4 01 76          CALL INIT_MOVE_HISTORY
                        
                            ; --- Compute and store starting position hash for repetition detection ---
   2d8d   d4 55 9a          CALL HASH_INIT          ; Compute hash for starting position
   2d90   68 ca 65 00       RLDI 10, HASH_HIST      ; R10 → first hash history entry
   2d94   68 cd 64 b9       RLDI 13, HASH_HI
   2d98   4d                LDA 13                  ; D = HASH_HI, R13 → HASH_LO
   2d99   5a                STR 10
   2d9a   1a                INC 10
   2d9b   0d                LDN 13                  ; D = HASH_LO
   2d9c   5a                STR 10
   2d9d   68 ca 64 eb       RLDI 10, HASH_HIST_COUNT
   2da1   f8 01             LDI 1
   2da3   5a                STR 10                  ; count = 1 (starting position stored)
                        
                            ; Skip past "startpos" (8 chars) to check for " moves"
                            ; Buffer now at "startpos..." - need to find " moves "
   2da4   68 ca 70 11       RLDI 10, UCI_BUFFER + 17
                        
                            ; Check if there's more (should be space or null)
   2da8   0a                LDN 10
   2da9   c2 2e 86          LBZ UCI_POS_DONE    ; End of string, no moves
   2dac   fb 20             XRI ' '
   2dae   ca 2e 86          LBNZ UCI_POS_DONE   ; Not a space, unexpected
                        
                            ; Skip the space
   2db1   1a                INC 10
                        
                            ; Check for "moves" (5 chars)
   2db2   0a                LDN 10
   2db3   fb 6d             XRI 'm'
   2db5   ca 2e 86          LBNZ UCI_POS_DONE
   2db8   1a                INC 10
   2db9   0a                LDN 10
   2dba   fb 6f             XRI 'o'
   2dbc   ca 2e 86          LBNZ UCI_POS_DONE
   2dbf   1a                INC 10
   2dc0   0a                LDN 10
   2dc1   fb 76             XRI 'v'
   2dc3   ca 2e 86          LBNZ UCI_POS_DONE
   2dc6   1a                INC 10
   2dc7   0a                LDN 10
   2dc8   fb 65             XRI 'e'
   2dca   ca 2e 86          LBNZ UCI_POS_DONE
   2dcd   1a                INC 10
   2dce   0a                LDN 10
   2dcf   fb 73             XRI 's'
   2dd1   ca 2e 86          LBNZ UCI_POS_DONE
   2dd4   1a                INC 10              ; R10 now past "moves"
                        
                            ; Now parse move list: " e2e4 e7e5 ..."
   2dd5                 UCI_POS_MOVE_LOOP:
                            ; Skip spaces
   2dd5   0a                LDN 10
   2dd6   c2 2e 86          LBZ UCI_POS_DONE    ; End of string
   2dd9   fb 20             XRI ' '
   2ddb   ca 2d e2          LBNZ UCI_POS_PARSE_MOVE  ; Not a space, should be move
   2dde   1a                INC 10
   2ddf   c0 2d d5          LBR UCI_POS_MOVE_LOOP
                        
   2de2                 UCI_POS_PARSE_MOVE:
                            ; R10 points to start of move (e.g., "e2e4")
                            ; Parse from square (2 chars)
   2de2   d4 2e 87          CALL ALGEBRAIC_TO_SQUARE
   2de5   fb ff             XRI $FF
   2de7   c2 2e 86          LBZ UCI_POS_DONE    ; Invalid square, abort
                        
                            ; Save from square
   2dea   fb ff             XRI $FF             ; Restore value (XRI is self-inverse)
   2dec   b7                PHI 7               ; R7.1 = from square
                        
                            ; Parse to square (2 chars)
   2ded   d4 2e 87          CALL ALGEBRAIC_TO_SQUARE
   2df0   fb ff             XRI $FF
   2df2   c2 2e 86          LBZ UCI_POS_DONE    ; Invalid square, abort
   2df5   fb ff             XRI $FF             ; Restore value
                        
                            ; Store from and to in MOVE_FROM/MOVE_TO
   2df7   a7                PLO 7               ; R7.0 = to square
                        
   2df8   68 c8 64 02       RLDI 8, MOVE_FROM
   2dfc   97                GHI 7
   2dfd   58                STR 8               ; MOVE_FROM = from
   2dfe   18                INC 8
   2dff   87                GLO 7
   2e00   58                STR 8               ; MOVE_TO = to
                        
                            ; ---- Check for promotion suffix (5th char: q/r/b/n) ----
                            ; Clear UNDO_PROMOTION first (default: no promotion)
   2e01   68 c8 64 04       RLDI 8, UNDO_PROMOTION
   2e05   f8 00             LDI 0
   2e07   58                STR 8               ; UNDO_PROMOTION = 0
                        
                            ; Check next char for promotion piece
   2e08   0a                LDN 10              ; Peek next char
   2e09   fb 71             XRI 'q'
   2e0b   c2 2e 20          LBZ UCI_PROMO_QUEEN
   2e0e   fb 03             XRI $03             ; 'q'^'r' = $71^$72 = $03
   2e10   c2 2e 25          LBZ UCI_PROMO_ROOK
   2e13   fb 10             XRI $10             ; 'r'^'b' = $72^$62 = $10
   2e15   c2 2e 2a          LBZ UCI_PROMO_BISHOP
   2e18   fb 0c             XRI $0C             ; 'b'^'n' = $62^$6E = $0C
   2e1a   c2 2e 2f          LBZ UCI_PROMO_KNIGHT
   2e1d   c0 2e 33          LBR UCI_PROMO_DONE  ; Not a promotion char, don't advance
                        
   2e20                 UCI_PROMO_QUEEN:
   2e20   f8 05             LDI QUEEN_TYPE      ; $05
   2e22   c0 2e 31          LBR UCI_PROMO_STORE
   2e25                 UCI_PROMO_ROOK:
   2e25   f8 04             LDI ROOK_TYPE       ; $04
   2e27   c0 2e 31          LBR UCI_PROMO_STORE
   2e2a                 UCI_PROMO_BISHOP:
   2e2a   f8 03             LDI BISHOP_TYPE     ; $03
   2e2c   c0 2e 31          LBR UCI_PROMO_STORE
   2e2f                 UCI_PROMO_KNIGHT:
   2e2f   f8 02             LDI KNIGHT_TYPE     ; $02
                        
   2e31                 UCI_PROMO_STORE:
   2e31   58                STR 8               ; UNDO_PROMOTION = piece type
   2e32   1a                INC 10              ; Advance past promotion char
                        
   2e33                 UCI_PROMO_DONE:
                        
                            ; ---- Record move in MOVE_HIST for opening book ----
                            ; Skip recording past book depth (prevents 8-bit GAME_PLY overflow)
   2e33   68 c8 64 4d       RLDI 8, GAME_PLY
   2e37   08                LDN 8               ; D = GAME_PLY
   2e38   ff 0f             SMI BOOK_PLY_LIMIT  ; past book depth?
   2e3a   c3 2e 58          LBDF UCI_HIST_DONE  ; skip recording + increment
                            ; Calculate offset: GAME_PLY * 2
   2e3d   08                LDN 8               ; reload GAME_PLY (SMI clobbered D)
   2e3e   fe                SHL                 ; D = GAME_PLY * 2
   2e3f   a9                PLO 9               ; R9.0 = offset
                        
                            ; R9 = MOVE_HIST + offset
   2e40   f8 60             LDI HIGH(MOVE_HIST)
   2e42   b9                PHI 9
   2e43   f8 90             LDI LOW(MOVE_HIST)
   2e45   e2                SEX 2
   2e46   52                STR 2
   2e47   89                GLO 9               ; D = offset
   2e48   f4                ADD                 ; D = LOW(MOVE_HIST) + offset
   2e49   a9                PLO 9
   2e4a   f8 60             LDI HIGH(MOVE_HIST)
   2e4c   7c 00             ADCI 0              ; Add carry to high byte
   2e4e   b9                PHI 9
                        
                            ; Store from square
   2e4f   97                GHI 7               ; from square
   2e50   59                STR 9
   2e51   19                INC 9
                            ; Store to square
   2e52   87                GLO 7               ; to square
   2e53   59                STR 9
                        
                            ; Increment GAME_PLY
   2e54   08                LDN 8               ; R8 still points to GAME_PLY
   2e55   fc 01             ADI 1
   2e57   58                STR 8
   2e58                 UCI_HIST_DONE:
                            ; ---- End of MOVE_HIST recording ----
                        
                            ; Apply the move (save R10 - MAKE_MOVE clobbers it!)
   2e58   9a                GHI 10
   2e59   73                STXD
   2e5a   8a                GLO 10
   2e5b   73                STXD
   2e5c   d4 09 b4          CALL MAKE_MOVE
   2e5f   60                IRX
   2e60   72                LDXA
   2e61   aa                PLO 10
   2e62   f0                LDX
   2e63   ba                PHI 10
                        
                            ; ---- Record hash for repetition detection ----
   2e64   68 cd 64 eb       RLDI 13, HASH_HIST_COUNT
   2e68   0d                LDN 13              ; D = count
   2e69   fb ff             XRI 255             ; Zero if count == 255 (table full)
   2e6b   c2 2d d5          LBZ UCI_POS_MOVE_LOOP   ; Full, skip recording
   2e6e   0d                LDN 13              ; D = count (reload)
   2e6f   fe                SHL                 ; D = (count*2) & $FF, DF = carry for counts >= 128
   2e70   a8                PLO 8               ; R8.0 = offset low byte
   2e71   f8 65             LDI HIGH(HASH_HIST) ; DF preserved (LDI doesn't affect DF)
   2e73   7c 00             ADCI 0              ; D = HIGH(HASH_HIST) + carry from SHL
   2e75   b8                PHI 8               ; R8 = &HASH_HIST[count] (correct for all counts)
   2e76   68 c9 64 b9       RLDI 9, HASH_HI
   2e7a   49                LDA 9               ; D = HASH_HI
   2e7b   58                STR 8
   2e7c   18                INC 8
   2e7d   09                LDN 9               ; D = HASH_LO
   2e7e   58                STR 8
   2e7f   0d                LDN 13              ; count (R13 still at HASH_HIST_COUNT)
   2e80   fc 01             ADI 1
   2e82   5d                STR 13              ; count++
   2e83   c0 2d d5          LBR UCI_POS_MOVE_LOOP
                        
   2e86                 UCI_POS_DONE:
   2e86   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ALGEBRAIC_TO_SQUARE - Convert algebraic notation to 0x88 square
                        ; ------------------------------------------------------------------------------
                        ; Input:  R10 = pointer to 2-char string (e.g., "e2"), advanced by 2
                        ; Output: D = 0x88 square index, or $FF if invalid
                        ; Uses:   R7.0 for file temp
                        ; ------------------------------------------------------------------------------
   2e87                 ALGEBRAIC_TO_SQUARE:
                            ; Get file character (a-h)
   2e87   4a                LDA 10              ; Load file char, advance R10
   2e88   ff 61             SMI 'a'             ; Convert to 0-7
   2e8a   cb 2e a8          LBNF ATS_INVALID    ; If DF=0 (borrow), char < 'a', invalid
   2e8d   a7                PLO 7               ; Save potential file in R7.0
   2e8e   ff 08             SMI 8               ; Check if >= 8
   2e90   c3 2e a8          LBDF ATS_INVALID    ; If >= 8, invalid
                        
                            ; Get rank character (1-8)
   2e93   4a                LDA 10              ; Load rank char, advance R10
   2e94   ff 31             SMI '1'             ; Convert to 0-7
   2e96   cb 2e a8          LBNF ATS_INVALID    ; If DF=0 (borrow), char < '1', invalid
   2e99   ff 08             SMI 8               ; Check if >= 8
   2e9b   c3 2e a8          LBDF ATS_INVALID    ; If >= 8, invalid
   2e9e   fc 08             ADI 8               ; Restore 0-7 value
                        
                            ; Calculate 0x88 square = rank * 16 + file
                            ; rank is in D (0-7), file in R7.0
   2ea0   fe                SHL                 ; D = rank * 2
   2ea1   fe                SHL                 ; D = rank * 4
   2ea2   fe                SHL                 ; D = rank * 8
   2ea3   fe                SHL                 ; D = rank * 16
   2ea4   52                STR 2               ; Save rank*16 on stack
   2ea5   87                GLO 7               ; Get file (0-7)
   2ea6   f4                ADD                 ; D = rank*16 + file
   2ea7   d5                RETN
                        
   2ea8                 ATS_INVALID:
   2ea8   1a                INC 10              ; Skip second char even on error (keep R10 consistent)
   2ea9   f8 ff             LDI $FF
   2eab   d5                RETN
                        
   2eac                 UCI_CMD_GO:
                            ; Parse go command
                            ; Format: "go depth 6" or "go infinite", etc.
                            ; Default to depth 1, parse "depth N" if present
                            ; Store in memory (R5 is SRET in BIOS mode!)
                        
                            ; Default depth = 1
   2eac   f8 01             LDI 1
   2eae   a7                PLO 7               ; R7.0 = depth (default 1)
                        
                            ; Check for "depth " after "go "
                            ; Buffer: "go depth 3" or "go" or "go infinite"
   2eaf   68 ca 70 03       RLDI 10, UCI_BUFFER + 3
                        
                            ; Check if we have "depth"
   2eb3   0a                LDN 10
   2eb4   fb 64             XRI 'd'
   2eb6   ca 2e ee          LBNZ UCI_GO_SET_DEPTH   ; Not "depth", use default
   2eb9   1a                INC 10
   2eba   0a                LDN 10
   2ebb   fb 65             XRI 'e'
   2ebd   ca 2e ee          LBNZ UCI_GO_SET_DEPTH
   2ec0   1a                INC 10
   2ec1   0a                LDN 10
   2ec2   fb 70             XRI 'p'
   2ec4   ca 2e ee          LBNZ UCI_GO_SET_DEPTH
   2ec7   1a                INC 10
   2ec8   0a                LDN 10
   2ec9   fb 74             XRI 't'
   2ecb   ca 2e ee          LBNZ UCI_GO_SET_DEPTH
   2ece   1a                INC 10
   2ecf   0a                LDN 10
   2ed0   fb 68             XRI 'h'
   2ed2   ca 2e ee          LBNZ UCI_GO_SET_DEPTH
   2ed5   1a                INC 10
   2ed6   0a                LDN 10
   2ed7   fb 20             XRI ' '
   2ed9   ca 2e ee          LBNZ UCI_GO_SET_DEPTH
   2edc   1a                INC 10              ; R10 now at the number
                        
                            ; Parse the depth number (1-9, single digit only)
                            ; Depths > 9 would take impractically long on the 1802 anyway
   2edd   0a                LDN 10
   2ede   ff 30             SMI '0'             ; Convert ASCII to value
   2ee0   cb 2e ee          LBNF UCI_GO_SET_DEPTH ; Invalid (< '0'), use default
   2ee3   ff 0a             SMI 10              ; Check if >= 10
   2ee5   c3 2e ee          LBDF UCI_GO_SET_DEPTH ; >= 10, use default
   2ee8   fc 0a             ADI 10              ; Restore 0-9 value
   2eea   c2 2e ee          LBZ UCI_GO_SET_DEPTH ; Depth 0 invalid, use default
   2eed   a7                PLO 7               ; R7.0 = parsed depth (1-9)
                        
   2eee                 UCI_GO_SET_DEPTH:
                            ; Set SEARCH_DEPTH from R7.0
   2eee   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   2ef2   f8 00             LDI 0
   2ef4   5d                STR 13              ; SEARCH_DEPTH high = 0
   2ef5   1d                INC 13
   2ef6   87                GLO 7
   2ef7   5d                STR 13              ; SEARCH_DEPTH low = depth
                        
                            ; ---- Check opening book first ----
   2ef8   d4 30 4a          CALL BOOK_LOOKUP
   2efb   c2 2f 0e          LBZ UCI_GO_SEARCH   ; D=0: no book hit, do normal search
                        
                            ; Book hit! Copy BOOK_MOVE to BEST_MOVE
   2efe   68 c8 64 4e       RLDI 8, BOOK_MOVE_FROM
   2f02   68 c9 64 10       RLDI 9, BEST_MOVE
                        
                            ; Store book move in BEST_MOVE (from in high, to in low)
   2f06   48                LDA 8               ; BOOK_MOVE_FROM
   2f07   59                STR 9               ; BEST_MOVE high = from
   2f08   19                INC 9
   2f09   08                LDN 8               ; BOOK_MOVE_TO
   2f0a   59                STR 9               ; BEST_MOVE low = to
   2f0b   c0 2f 18          LBR UCI_GO_SEND_MOVE
                        
   2f0e                 UCI_GO_SEARCH:
                            ; Clear stale promotion flag before search
                            ; (opponent's promotion move leaves UNDO_PROMOTION set, which would
                            ; corrupt every MAKE_MOVE during search)
   2f0e   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   2f12   f8 00             LDI 0
   2f14   5a                STR 10              ; UNDO_PROMOTION = 0
                        
                            ; Run search
   2f15   d4 29 fc          CALL SEARCH_POSITION
                        
   2f18                 UCI_GO_SEND_MOVE:
                            ; Best move now at BEST_MOVE.
                            ;
                            ; --- Root-move validation (added 2026-05-12) ---
                            ; Defense against MOVE_LIST corruption causing illegal-move output.
                            ; Regenerate moves from current board; verify BEST_MOVE appears in
                            ; the regenerated list. If not, emit info string + substitute first
                            ; legal move. Catches the symptom of any state corruption affecting
                            ; root MOVE_LIST regardless of underlying cause.
                        
                            ; Encode BEST_MOVE for byte-by-byte comparison (mirrors ORDER_TT_MOVE)
   2f18   68 ca 64 10       RLDI 10, BEST_MOVE
   2f1c   4a                LDA 10
   2f1d   bd                PHI 13                      ; R13.1 = BEST_MOVE from (0x88)
   2f1e   0a                LDN 10
   2f1f   ad                PLO 13                      ; R13.0 = BEST_MOVE to (0x88)
                        
   2f20   68 ca 64 06       RLDI 10, MOVE_FLAGS_TEMP
   2f24   f8 00             LDI 0
   2f26   5a                STR 10                      ; flags=0 for the comparison encoding
                        
   2f27   d4 03 8d          CALL ENCODE_MOVE_16BIT
                            ; R8 = encoded BEST_MOVE (flags=0)
                        
                            ; Save encoded BEST_MOVE on stack across GENERATE_MOVES
                            ; (GENERATE_MOVES clobbers R11 — uses R11.1 as current-from-square)
   2f2a   98                GHI 8
   2f2b   73                STXD
   2f2c   88                GLO 8
   2f2d   73                STXD
                        
                            ; Regenerate legal moves into MOVE_LIST
   2f2e   68 c9 78 00       RLDI 9, MOVE_LIST
   2f32   d4 04 d7          CALL GENERATE_MOVES
                            ; D = move count
                        
   2f35   a7                PLO 7                       ; R7.0 = move count
   2f36   b7                PHI 7                       ; R7.1 = loop counter (D unchanged by PLO)
                        
                            ; Restore encoded BEST_MOVE to R11
   2f37   60                IRX
   2f38   72                LDXA
   2f39   ab                PLO 11                      ; R11.0 = LOW
   2f3a   f0                LDX
   2f3b   bb                PHI 11                      ; R11.1 = HIGH
                        
   2f3c   97                GHI 7                       ; check count
   2f3d   c2 2f 7f          LBZ RMV_DONE                ; 0 moves (mate/stalemate) — leave as-is
                        
   2f40   68 c8 78 00       RLDI 8, MOVE_LIST           ; R8 = scan pointer
                        
   2f44                 RMV_SCAN_LOOP:
   2f44   97                GHI 7
   2f45   c2 2f 60          LBZ RMV_NOT_FOUND
                        
                            ; MOVE_LIST stores HIGH byte first (per ADD_MOVE_ENCODED line 221):
                            ; entry layout in memory is [HIGH][LOW] for each 2-byte move.
                            ; Compare HIGH byte (with flag bits 6-7 masked off)
   2f48   48                LDA 8                       ; list move HIGH byte; R8++
   2f49   fa 3f             ANI $3F                     ; mask off flag bits
   2f4b   52                STR 2
   2f4c   9b                GHI 11                      ; encoded BEST_MOVE HIGH byte (flags=0)
   2f4d   f3                XOR
   2f4e   ca 2f 58          LBNZ RMV_NEXT
                        
                            ; HIGH bytes match — compare LOW byte (no masking needed)
   2f51   08                LDN 8                       ; list move LOW byte; R8 stays
   2f52   52                STR 2
   2f53   8b                GLO 11                      ; encoded BEST_MOVE LOW byte
   2f54   f3                XOR
   2f55   c2 2f 7f          LBZ RMV_DONE                ; Match — BEST_MOVE is legal, emit normally
                        
   2f58                 RMV_NEXT:
   2f58   18                INC 8                       ; skip past LOW byte to next entry
   2f59   97                GHI 7
   2f5a   ff 01             SMI 1
   2f5c   b7                PHI 7
   2f5d   c0 2f 44          LBR RMV_SCAN_LOOP
                        
   2f60                 RMV_NOT_FOUND:
                            ; BEST_MOVE not in regenerated legal list — corruption symptom.
   2f60   68 cf 2c 88       RLDI 15, STR_INFO_RMV
   2f64   d4                SEP 4
   2f65   ff 09             DW F_MSG
                        
                            ; Substitute first legal move from regenerated list
                            ; (memory order is [HIGH][LOW]; DECODE_MOVE_16BIT wants R8.0=LOW, R8.1=HIGH)
   2f67   68 c8 78 00       RLDI 8, MOVE_LIST
   2f6b   48                LDA 8                       ; HIGH byte from memory
   2f6c   bb                PHI 11                      ; R11.1 = HIGH
   2f6d   08                LDN 8                       ; LOW byte from memory
   2f6e   ab                PLO 11                      ; R11.0 = LOW
                        
                            ; Now build R8 = [HIGH in .1, LOW in .0] for DECODE
   2f6f   9b                GHI 11
   2f70   b8                PHI 8
   2f71   8b                GLO 11
   2f72   a8                PLO 8
   2f73   d4 03 c7          CALL DECODE_MOVE_16BIT
                            ; R13.1 = from, R13.0 = to
                        
                            ; Write back to BEST_MOVE
   2f76   68 ca 64 10       RLDI 10, BEST_MOVE
   2f7a   9d                GHI 13
   2f7b   5a                STR 10
   2f7c   1a                INC 10
   2f7d   8d                GLO 13
   2f7e   5a                STR 10
                        
   2f7f                 RMV_DONE:
                            ; Send best move (validated or substituted)
   2f7f   68 cf 2c 5f       RLDI 15, STR_BESTMOVE
   2f83   d4                SEP 4
   2f84   ff 09             DW F_MSG
                        
                            ; Convert best move to algebraic and send
                            ; TODO: Load best move and convert
   2f86   d4 2f c3          CALL UCI_SEND_BEST_MOVE
                        
                            ; Send CR+LF
   2f89   f8 0d             LDI 13
   2f8b   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2f8e   f8 0a             LDI 10
   2f90   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   2f93   d5                RETN
                        
   2f94                 UCI_CMD_QUIT:
                            ; Return to monitor at $8000
   2f94   c0 80 03          LBR $8003
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_CMD_UCINEWGAME - Prepare for a new game
                        ; ------------------------------------------------------------------------------
                        ; Clears transposition table and resets game state
                        ; ------------------------------------------------------------------------------
   2f97                 UCI_CMD_UCINEWGAME:
                            ; Clear workspace RAM to prevent stale variable bugs
   2f97   d4 5e 83          CALL WORKSPACE_CLEAR
                        
                            ; Clear transposition table
   2f9a   d4 56 a9          CALL TT_CLEAR
                        
                            ; Reset game ply counter
   2f9d   68 ca 64 4d       RLDI 10, GAME_PLY
   2fa1   f8 00             LDI 0
   2fa3   5a                STR 10
                        
                            ; Clear move history
   2fa4   d4 01 76          CALL INIT_MOVE_HISTORY
                        
                            ; Initialize board to starting position
   2fa7   d4 00 a6          CALL INIT_BOARD
                        
                            ; Compute and store starting-position Zobrist hash + first HASH_HIST entry.
                            ; UCI_CMD_POSITION normally does this when parsing "position startpos",
                            ; but the first such command after ucinewgame is frequently dropped at
                            ; the start of every match since 2026-04-30 ("PARTIAL_ECHO 'sition
                            ; startpos'"). The bridge sends ucinewgame and position back-to-back,
                            ; and BIOS serial RX drops the first 1-2 bytes during the long
                            ; WORKSPACE_CLEAR/TT_CLEAR processing window. Without hash init here,
                            ; the first search runs with hash=0 and pollutes TT with mis-keyed
                            ; entries that persist for the entire match.
   2faa   d4 55 9a          CALL HASH_INIT
   2fad   68 ca 65 00       RLDI 10, HASH_HIST
   2fb1   68 cd 64 b9       RLDI 13, HASH_HI
   2fb5   4d                LDA 13                  ; D = HASH_HI, R13 → HASH_LO
   2fb6   5a                STR 10
   2fb7   1a                INC 10
   2fb8   0d                LDN 13                  ; D = HASH_LO
   2fb9   5a                STR 10
   2fba   68 ca 64 eb       RLDI 10, HASH_HIST_COUNT
   2fbe   f8 01             LDI 1
   2fc0   5a                STR 10                  ; HASH_HIST_COUNT = 1 (startpos stored)
                        
   2fc1   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_CMD_STOP - Stop calculating (no-op for now)
                        ; ------------------------------------------------------------------------------
                        ; On a single-threaded system we cannot interrupt search.
                        ; GUI should wait for bestmove response.
                        ; This is here for protocol compatibility.
                        ; ------------------------------------------------------------------------------
   2fc2                 UCI_CMD_STOP:
                            ; No-op - search completes naturally
                            ; GUI will receive bestmove when search finishes
   2fc2   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_SEND_BEST_MOVE - Send best move in algebraic notation
                        ; ------------------------------------------------------------------------------
   2fc3                 UCI_SEND_BEST_MOVE:
                            ; BEST_MOVE contains raw from/to squares (not encoded)
                            ; BEST_MOVE[0] = from square (0x88), BEST_MOVE[1] = to square (0x88)
   2fc3   68 ca 64 10       RLDI 10, BEST_MOVE
                        
   2fc7   4a                LDA 10              ; from square (raw 0x88)
   2fc8   bd                PHI 13              ; R13.1 = from
   2fc9   0a                LDN 10              ; to square (raw 0x88)
   2fca   ad                PLO 13              ; R13.0 = to
                        
                            ; Convert to algebraic notation (e.g., "e2e4")
                            ; From square
   2fcb   9d                GHI 13              ; From square
   2fcc   d4 2f fe          CALL SQUARE_TO_ALGEBRAIC
                            ; Sends two characters (file, rank)
                        
                            ; To square
   2fcf   8d                GLO 13              ; To square
   2fd0   d4 2f fe          CALL SQUARE_TO_ALGEBRAIC
                        
                            ; Check if this is a promotion move (pawn reaching last rank)
                            ; Load piece at from square
   2fd3   f8 60             LDI HIGH(BOARD)
   2fd5   ba                PHI 10
   2fd6   9d                GHI 13              ; from square
   2fd7   aa                PLO 10
   2fd8   f8 00             LDI LOW(BOARD)
   2fda   52                STR 2
   2fdb   8a                GLO 10
   2fdc   f4                ADD
   2fdd   aa                PLO 10
   2fde   9a                GHI 10
   2fdf   7c 00             ADCI 0
   2fe1   ba                PHI 10              ; R10 = &BOARD[from]
   2fe2   0a                LDN 10              ; D = piece at from
   2fe3   fa 07             ANI PIECE_MASK      ; Get piece type
   2fe5   fb 01             XRI PAWN_TYPE       ; Is it a pawn?
   2fe7   ca 2f fd          LBNZ UCI_BM_NO_PROMO
                        
                            ; It's a pawn - check if to square is on last rank
   2fea   8d                GLO 13              ; to square
   2feb   fa 70             ANI $70             ; Isolate rank
   2fed   c2 2f f8          LBZ UCI_BM_IS_PROMO ; Rank 0 = promotion for black
   2ff0   fb 70             XRI $70
   2ff2   c2 2f f8          LBZ UCI_BM_IS_PROMO ; Rank 7 = promotion for white
   2ff5   c0 2f fd          LBR UCI_BM_NO_PROMO
                        
   2ff8                 UCI_BM_IS_PROMO:
                            ; Append 'q' for queen promotion
   2ff8   f8 71             LDI 'q'
   2ffa   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   2ffd                 UCI_BM_NO_PROMO:
   2ffd   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; SQUARE_TO_ALGEBRAIC - Convert 0x88 square to algebraic notation
                        ; ------------------------------------------------------------------------------
                        ; Input:  D = square (0x88 format)
                        ; Output: Two characters sent (file letter, rank number)
                        ; ------------------------------------------------------------------------------
   2ffe                 SQUARE_TO_ALGEBRAIC:
   2ffe   a7                PLO 7               ; Save square in R7.0 (R13 used by caller!)
                        
                            ; Get file (0-7 → 'a'-'h')
   2fff   fa 07             ANI $07             ; File bits
   3001   fc 61             ADI 'a'             ; Convert to ASCII
   3003   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
                            ; Get rank (0-7 → '1'-'8')
   3006   87                GLO 7               ; Get square from R7.0
   3007   f6                SHR
   3008   f6                SHR
   3009   f6                SHR
   300a   f6                SHR                 ; Rank bits
   300b   fc 31             ADI '1'             ; Convert to ASCII
   300d   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   3010   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; String Comparison Functions
                        ; ------------------------------------------------------------------------------
                        
                        ; STRCMP - Compare two null-terminated strings
                        ; Input:  A = string 1, B = string 2
                        ; Output: D = 0 if equal, non-zero if different
   3011                 STRCMP:
   3011   0a                LDN 10              ; D = char from string 1
   3012   52                STR 2               ; Save to stack
   3013   0b                LDN 11              ; D = char from string 2
   3014   f3                XOR                 ; D = char1 XOR char2 (0 if equal)
   3015   ca 30 24          LBNZ STRCMP_DIFF     ; If XOR != 0, characters differ
                        
                            ; Characters are equal, check if end of both strings
   3018   0a                LDN 10
   3019   c2 30 21          LBZ STRCMP_EQUAL     ; If null terminator, both ended - equal
                        
                            ; Continue comparing
   301c   1a                INC 10
   301d   1b                INC 11
   301e   c0 30 11          LBR STRCMP
                        
   3021                 STRCMP_EQUAL:
   3021   f8 00             LDI 0
   3023   d5                RETN
                        
   3024                 STRCMP_DIFF:
   3024   f8 01             LDI 1
   3026   d5                RETN
                        
                        ; STRNCMP - Compare until space or null in string 1
                        ; Input:  R10 = string 1 (command buffer), R11 = string 2 (command name)
                        ; Output: D = 0 if equal, non-zero if different
   3027                 STRNCMP:
                            ; Check if string 1 hit space (end of command word)
   3027   0a                LDN 10
   3028   fb 20             XRI ' '
   302a   c2 30 3d          LBZ STRNCMP_CHECK_END
                        
                            ; Check if string 1 hit null
   302d   0a                LDN 10
   302e   c2 30 3d          LBZ STRNCMP_CHECK_END
                        
                            ; Compare characters
   3031   0a                LDN 10              ; D = char from string 1
   3032   52                STR 2               ; Save to stack
   3033   0b                LDN 11              ; D = char from string 2
   3034   f3                XOR                 ; D = char1 XOR char2 (0 if equal)
   3035   ca 30 47          LBNZ STRNCMP_DIFF   ; If different, not equal
                        
   3038   1a                INC 10
   3039   1b                INC 11
   303a   c0 30 27          LBR STRNCMP
                        
   303d                 STRNCMP_CHECK_END:
                            ; String 1 ended (space or null) - check if string 2 also ended
   303d   0b                LDN 11
   303e   c2 30 44          LBZ STRNCMP_EQUAL   ; String 2 is null - match!
   3041   c0 30 47          LBR STRNCMP_DIFF    ; String 2 has more chars - no match
                        
   3044                 STRNCMP_EQUAL:
   3044   f8 00             LDI 0
   3046   d5                RETN
                        
   3047                 STRNCMP_DIFF:
   3047   f8 01             LDI 1
   3049   d5                RETN
                        
                        ; ==============================================================================
                        ; End of UCI Implementation
                        ; ==============================================================================
                        ; NOTE: SERIAL_READ_CHAR and SERIAL_WRITE_CHAR are provided by serial-io-9600.asm
                        ; ==============================================================================
                        ; ==============================================================================
                        ; Opening Book Lookup - Check if current position is in opening book
                        ; ==============================================================================
                        ;
                        ; Book format (from opening-book.asm):
                        ;   Each entry: [ply] [move1_from] [move1_to] ... [response_from] [response_to]
                        ;   Terminated with $FF
                        ;   Entries sorted by ply
                        ;
                        ; Uses: GAME_PLY - number of moves played since start
                        ;       MOVE_HIST - array of (from, to) pairs for game moves
                        ;       BOOK_MOVE_FROM/TO - output for book response
                        ;
                        ; ==============================================================================
                        
                        ; ==============================================================================
                        ; BOOK_LOOKUP - Search opening book for current position
                        ; ==============================================================================
                        ; Input:  GAME_PLY = number of moves played
                        ;         MOVE_HIST = game move history (2 bytes per move)
                        ; Output: D = 1 if book hit, 0 if no match
                        ;         BOOK_MOVE_FROM/TO = response move (if hit)
                        ; Uses:   R7, R8, R9, R10
                        ; ==============================================================================
   304a                 BOOK_LOOKUP:
                            ; R8 = pointer to current book entry
   304a   68 c8 30 b8       RLDI 8, OPENING_BOOK
                        
                            ; Load GAME_PLY into R7.1 for quick comparison
   304e   68 ca 64 4d       RLDI 10, GAME_PLY
   3052   0a                LDN 10
   3053   b7                PHI 7               ; R7.1 = GAME_PLY
                        
   3054                 BL_ENTRY_LOOP:
                            ; Read entry ply byte
   3054   08                LDN 8               ; D = entry ply
   3055   fb ff             XRI $FF             ; Check for end marker
   3057   c2 30 b5          LBZ BL_NO_MATCH     ; End of book, no match
                        
                            ; Restore ply value
   305a   fb ff             XRI $FF
   305c   a7                PLO 7               ; R7.0 = entry_ply
                        
                            ; Check if entry_ply > GAME_PLY (early exit - book sorted by ply)
   305d   97                GHI 7               ; D = GAME_PLY
   305e   52                STR 2               ; Store on stack
   305f   87                GLO 7               ; D = entry_ply
   3060   f5                SD                  ; D = GAME_PLY - entry_ply
   3061   cb 30 b5          LBNF BL_NO_MATCH    ; If borrow (entry_ply > GAME_PLY), no match possible
                        
                            ; Check if entry_ply == GAME_PLY
   3064   c2 30 76          LBZ BL_CHECK_MOVES  ; If equal, check the moves
                        
                            ; entry_ply < GAME_PLY, skip to next entry
                            ; Entry length = 1 + entry_ply*2 + 2 = 3 + entry_ply*2
   3067   87                GLO 7               ; D = entry_ply
   3068   fe                SHL                 ; D = entry_ply * 2
   3069   fc 03             ADI 3               ; D = 3 + entry_ply * 2
   306b   52                STR 2               ; Save skip amount
   306c   88                GLO 8
   306d   f4                ADD
   306e   a8                PLO 8
   306f   98                GHI 8
   3070   7c 00             ADCI 0
   3072   b8                PHI 8
   3073   c0 30 54          LBR BL_ENTRY_LOOP
                        
   3076                 BL_CHECK_MOVES:
                            ; entry_ply == GAME_PLY, compare all moves
                            ; R8 points to ply byte, moves start at R8+1
                            ; R9 = pointer to MOVE_HIST
   3076   68 c9 60 90       RLDI 9, MOVE_HIST
                        
                            ; R10.0 = move counter (number of move pairs to compare)
   307a   87                GLO 7               ; entry_ply = number of moves to compare
   307b   aa                PLO 10
                        
                            ; Move past ply byte
   307c   18                INC 8
                        
                            ; If ply == 0, no moves to compare - direct match!
   307d   8a                GLO 10
   307e   c2 30 98          LBZ BL_MATCH_FOUND
                        
   3081                 BL_COMPARE_LOOP:
                            ; Compare from square
   3081   08                LDN 8               ; Book from
   3082   52                STR 2
   3083   09                LDN 9               ; History from
   3084   f3                XOR                 ; Compare
   3085   ca 30 a6          LBNZ BL_SKIP_ENTRY  ; Mismatch
                        
                            ; Compare to square
   3088   18                INC 8
   3089   19                INC 9
   308a   08                LDN 8               ; Book to
   308b   52                STR 2
   308c   09                LDN 9               ; History to
   308d   f3                XOR                 ; Compare
   308e   ca 30 a4          LBNZ BL_SKIP_TO     ; TO mismatch - different skip path
                        
                            ; Move to next pair
   3091   18                INC 8
   3092   19                INC 9
   3093   2a                DEC 10
   3094   8a                GLO 10
   3095   ca 30 81          LBNZ BL_COMPARE_LOOP
                        
   3098                 BL_MATCH_FOUND:
                            ; All moves matched! R8 now points to response
                            ; Store response in BOOK_MOVE_FROM/TO
   3098   68 c9 64 4e       RLDI 9, BOOK_MOVE_FROM
                        
   309c   48                LDA 8               ; Response from
   309d   59                STR 9
   309e   19                INC 9
   309f   08                LDN 8               ; Response to
   30a0   59                STR 9
                        
                            ; Return success
   30a1   f8 01             LDI 1
   30a3   d5                RETN
                        
   30a4                 BL_SKIP_TO:
                            ; TO byte mismatch: R8 points to TO byte (already past FROM via INC 8)
                            ; Advance past TO and count this pair as consumed, then fall through
   30a4   18                INC 8               ; Past TO byte -> R8 at start of next pair
   30a5   2a                DEC 10              ; This pair consumed
                            ; Fall through to BL_SKIP_ENTRY
                        
   30a6                 BL_SKIP_ENTRY:
                            ; FROM byte mismatch: R8 points to FROM byte of mismatched pair
                            ; R10.0 = remaining move pairs to skip (not yet compared)
                            ; Skip: remaining_moves*2 + 2 (response bytes)
   30a6   8a                GLO 10              ; Remaining moves
   30a7   fe                SHL                 ; * 2
   30a8   fc 02             ADI 2               ; + response
   30aa   52                STR 2
   30ab   88                GLO 8
   30ac   f4                ADD
   30ad   a8                PLO 8
   30ae   98                GHI 8
   30af   7c 00             ADCI 0
   30b1   b8                PHI 8
                        
                            ; Reset book pointer past ply (we compared some moves already)
   30b2   c0 30 54          LBR BL_ENTRY_LOOP
                        
   30b5                 BL_NO_MATCH:
                            ; No book match found
   30b5   f8 00             LDI 0
   30b7   d5                RETN
                        
                        ; ==============================================================================
                        ; End of Opening Book Lookup
                        ; ==============================================================================
