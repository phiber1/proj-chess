   12c6   0b                LDN 11                      ; D = black pawn count on this file
   12c7   ca 12 d5          LBNZ EVAL_WR1_SEMI
                            ; Fully open file: +20
   12ca   89                GLO 9
   12cb   fc 14             ADI 20
   12cd   a9                PLO 9
   12ce   99                GHI 9
   12cf   7c 00             ADCI 0
   12d1   b9                PHI 9
   12d2   c0 12 dd          LBR EVAL_WR1_CLOSED
   12d5                 EVAL_WR1_SEMI:
                            ; Semi-open: +10
   12d5   89                GLO 9
