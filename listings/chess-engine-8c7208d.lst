   0a9d   e9                SEX 9
   0a9e   59                STR 9               ; M(COMPARE_TEMP) = from
   0a9f   68 c8 64 0a       RLDI 8, UNDO_TO
   0aa3   08                LDN 8               ; D = to square
   0aa4   f7                SM                   ; D = to - from
   0aa5   e2                SEX 2
                        
