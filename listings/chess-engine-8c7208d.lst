   0851                 GEN_SLIDE_S:
   0851   9b                GHI 11
   0852   a7                PLO 7
   0853                 GEN_SLIDE_S_LOOP:
   0853   87                GLO 7
   0854   fc f0             ADI $F0
   0856   a7                PLO 7
   0857   fa 88             ANI $88
   0859   ca 08 77          LBNZ GEN_SLIDE_S_RET
   085c   87                GLO 7
