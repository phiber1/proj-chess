   0ac7   f8 60             LDI HIGH(BOARD)
   0ac9   b8                PHI 8               ; R8 = &BOARD[to-1]
   0aca   9d                GHI 13              ; D = rook piece
   0acb   58                STR 8               ; Place rook at f1/f8
                        
