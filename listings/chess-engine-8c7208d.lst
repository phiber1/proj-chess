                        ; Total size: 8610 bytes
                        ; ==============================================================================
                        ; TRANSPOSITION TABLE FUNCTIONS
                        ; ==============================================================================
                        ; Provides Zobrist hashing and transposition table lookup/store.
                        ;
                        ; Functions:
                        ;   HASH_INIT   - Compute full hash from current board position
                        ;   TT_CLEAR    - Clear all TT entries
                        ;   TT_PROBE    - Look up position in TT
                        ;   TT_STORE    - Store position result in TT
                        ;
                        ; Hash is updated incrementally by MAKE_MOVE/UNMAKE_MOVE (in makemove.asm)
                        ; ==============================================================================
                        
                        ; ==============================================================================
                        ; HASH_INIT - Compute Zobrist hash from current board position
                        ; ==============================================================================
                        ; Scans the board and XORs all piece-square keys, plus side/castling/EP.
                        ; Result stored in HASH_HI/HASH_LO.
                        ;
                        ; Uses: R7 (hash accumulator), R8 (temp), R9 (square counter), R10 (pointer)
                        ; ==============================================================================
   559a                 HASH_INIT:
                            ; Initialize hash to zero
   559a   f8 00             LDI 0
   559c   b7                PHI 7
   559d   a7                PLO 7               ; R7 = 0 (hash accumulator)
                        
                            ; Scan all 64 valid squares (0x88 format)
   559e   f8 00             LDI 0
   55a0   a9                PLO 9               ; R9.0 = square index (0x88 format)
                        
   55a1                 HASH_INIT_LOOP:
                            ; Check if square is valid (not off-board)
   55a1   89                GLO 9
   55a2   fa 88             ANI $88
   55a4   ca 56 06          LBNZ HASH_INIT_NEXT_SQ  ; Off-board, skip
                        
                            ; Get piece at this square
   55a7   f8 60             LDI HIGH(BOARD)
   55a9   ba                PHI 10
   55aa   89                GLO 9
   55ab   aa                PLO 10              ; R10 = BOARD + square
   55ac   0a                LDN 10              ; D = piece at square
   55ad   c2 56 06          LBZ HASH_INIT_NEXT_SQ   ; Empty square, skip
                        
                            ; Have a piece - compute Zobrist key offset
                            ; piece_index = (piece & 7) - 1 for white, + 6 for black
                            ; Piece encoding: 1-6 = white P/N/B/R/Q/K, 9-14 = black
   55b0   a8                PLO 8               ; R8.0 = piece
   55b1   fa 07             ANI $07             ; D = piece type (1-6)
   55b3   ff 01             SMI 1               ; D = piece_type - 1 (0-5)
   55b5   ad                PLO 13              ; R13.0 = piece index base
                        
   55b6   88                GLO 8               ; Get piece again
   55b7   fa 08             ANI $08             ; Check color bit
   55b9   c2 55 c0          LBZ HASH_INIT_WHITE
                            ; Black piece - add 6 to index
   55bc   8d                GLO 13
   55bd   fc 06             ADI 6
   55bf   ad                PLO 13
   55c0                 HASH_INIT_WHITE:
                        
                            ; Now compute square index (0-63 from 0x88)
                            ; sq64 = (sq88 >> 4) * 8 + (sq88 & 7) = rank*8 + file
   55c0   89                GLO 9               ; 0x88 square
   55c1   fa 07             ANI $07             ; D = file (0-7)
   55c3   a8                PLO 8               ; R8.0 = file
   55c4   89                GLO 9
   55c5   fa 70             ANI $70             ; D = rank * 16 (masked)
   55c7   f6                SHR                 ; D = rank * 8
   55c8   52                STR 2               ; Save rank*8
   55c9   88                GLO 8               ; D = file
   55ca   f4                ADD                 ; D = rank*8 + file = sq64
   55cb   a8                PLO 8               ; R8.0 = sq64 (0-63)
                        
                            ; Compute Zobrist table offset:
                            ; offset = piece_index * 128 + sq64 * 2
                            ; R13.0 = piece_index (0-11)
                            ; R8.0 = sq64 (0-63)
                        
                            ; First: piece_index * 128 = piece_index << 7
                            ; Since piece_index is 0-11, result fits in 16 bits
   55cc   8d                GLO 13              ; piece_index (0-11)
   55cd   fe                SHL                 ; x2
   55ce   fe                SHL                 ; x4
   55cf   fe                SHL                 ; x8
   55d0   fe                SHL                 ; x16
   55d1   fe                SHL                 ; x32
   55d2   fe                SHL                 ; x64
   55d3   b8                PHI 8               ; R8.1 = (piece_index * 64) = high part of offset
   55d4   f8 00             LDI 0
   55d6   c7                LSNF                ; Skip if no carry from last SHL
   55d7   f8 01             LDI 1               ; Carry into high byte
                            ; Actually, piece_index * 128: need one more shift
                            ; Let me reconsider: piece * 128 = piece << 7
                            ; For piece=11: 11 << 7 = 1408 = $580
                            ; High byte = piece >> 1, low byte = (piece & 1) << 7
                        
                            ; Restart: piece_index * 128
   55d9   8d                GLO 13              ; piece_index (0-11)
   55da   f6                SHR                 ; D = piece_index >> 1
   55db   b8                PHI 8               ; R8.1 = high byte of piece*128
   55dc   8d                GLO 13
   55dd   fa 01             ANI $01             ; D = piece_index & 1
   55df   c2 55 e7          LBZ HASH_INIT_EVEN_PIECE
   55e2   f8 80             LDI $80
   55e4   c0 55 e9          LBR HASH_INIT_ADD_SQ
   55e7                 HASH_INIT_EVEN_PIECE:
   55e7   f8 00             LDI 0
   55e9                 HASH_INIT_ADD_SQ:
                            ; D = low byte of piece*128 (0 or $80)
                            ; Now add sq64 * 2
   55e9   ad                PLO 13              ; R13.0 = temp low
   55ea   88                GLO 8               ; sq64
   55eb   fe                SHL                 ; sq64 * 2
   55ec   52                STR 2
   55ed   8d                GLO 13
   55ee   f4                ADD                 ; D = low + sq*2
   55ef   ad                PLO 13              ; R13.0 = offset low
   55f0   98                GHI 8               ; high byte of piece*128
   55f1   7c 00             ADCI 0              ; add carry
   55f3   bd                PHI 13              ; R13.1 = offset high
                        
                            ; Now add ZOBRIST_PIECE_SQ base address
   55f4   8d                GLO 13
   55f5   fc 42             ADI LOW(ZOBRIST_PIECE_SQ)
   55f7   aa                PLO 10
   55f8   9d                GHI 13
   55f9   7c 58             ADCI HIGH(ZOBRIST_PIECE_SQ)
   55fb   ba                PHI 10              ; R10 = address of Zobrist key
                        
                            ; XOR the 16-bit key into hash (R7)
   55fc   4a                LDA 10              ; High byte of key
   55fd   52                STR 2
   55fe   97                GHI 7
   55ff   f3                XOR
   5600   b7                PHI 7               ; hash_hi ^= key_hi
   5601   0a                LDN 10              ; Low byte of key
   5602   52                STR 2
   5603   87                GLO 7
   5604   f3                XOR
   5605   a7                PLO 7               ; hash_lo ^= key_lo
                        
   5606                 HASH_INIT_NEXT_SQ:
                            ; Next square
   5606   19                INC 9               ; R9.0++
   5607   89                GLO 9
   5608   fb 80             XRI $80             ; Check if we've passed square $7F
   560a   ca 55 a1          LBNZ HASH_INIT_LOOP
                        
                            ; Done with pieces. Now XOR side to move.
   560d   68 ca 60 80       RLDI 10, GAME_STATE
   5611   0a                LDN 10              ; D = side to move (0=white, 8=black)
   5612   c2 56 23          LBZ HASH_SIDE_DONE
                            ; Black to move - XOR side key
   5615   68 ca 5e 42       RLDI 10, ZOBRIST_SIDE
   5619   4a                LDA 10
   561a   52                STR 2
   561b   97                GHI 7
   561c   f3                XOR
   561d   b7                PHI 7
   561e   0a                LDN 10
   561f   52                STR 2
   5620   87                GLO 7
   5621   f3                XOR
   5622   a7                PLO 7
   5623                 HASH_SIDE_DONE:
                        
                            ; XOR castling rights
                            ; Castling is at GAME_STATE + STATE_CASTLING ($6081)
   5623   68 ca 60 81       RLDI 10, GAME_STATE + STATE_CASTLING
   5627   0a                LDN 10              ; D = castling rights
   5628   a9                PLO 9               ; R9.0 = castling bits
                        
                            ; Check each castling bit
                            ; White kingside (bit 0)
   5629   89                GLO 9
   562a   fa 01             ANI CASTLE_WK
   562c   c2 56 32          LBZ HASH_NO_WK
   562f   d4 56 79          CALL HASH_XOR_CASTLE_0
   5632                 HASH_NO_WK:
                            ; White queenside (bit 1)
   5632   89                GLO 9
   5633   fa 02             ANI CASTLE_WQ
   5635   c2 56 3b          LBZ HASH_NO_WQ
   5638   d4 56 80          CALL HASH_XOR_CASTLE_1
   563b                 HASH_NO_WQ:
                            ; Black kingside (bit 2)
   563b   89                GLO 9
   563c   fa 04             ANI CASTLE_BK
   563e   c2 56 44          LBZ HASH_NO_BK
   5641   d4 56 89          CALL HASH_XOR_CASTLE_2
   5644                 HASH_NO_BK:
                            ; Black queenside (bit 3)
   5644   89                GLO 9
   5645   fa 08             ANI CASTLE_BQ
   5647   c2 56 4d          LBZ HASH_NO_BQ
   564a   d4 56 94          CALL HASH_XOR_CASTLE_3
   564d                 HASH_NO_BQ:
                        
                            ; XOR en passant file if set
   564d   68 ca 60 80       RLDI 10, GAME_STATE
   5651   1a                INC 10
   5652   1a                INC 10              ; Point to EP square
   5653   0a                LDN 10              ; D = EP square ($FF if none)
   5654   fb ff             XRI $FF
   5656   c2 56 6f          LBZ HASH_NO_EP      ; No EP square
                            ; Have EP - get file (bits 0-2 of 0x88 square)
   5659   0a                LDN 10
   565a   fa 07             ANI $07             ; D = file (0-7)
   565c   fe                SHL                 ; D = file * 2 (offset into ZOBRIST_EP)
   565d   fc 4c             ADI LOW(ZOBRIST_EP)
   565f   aa                PLO 10
   5660   f8 5e             LDI HIGH(ZOBRIST_EP)
   5662   7c 00             ADCI 0
   5664   ba                PHI 10              ; R10 = address of EP file key
   5665   4a                LDA 10
   5666   52                STR 2
   5667   97                GHI 7
   5668   f3                XOR
   5669   b7                PHI 7
   566a   0a                LDN 10
   566b   52                STR 2
   566c   87                GLO 7
   566d   f3                XOR
   566e   a7                PLO 7
   566f                 HASH_NO_EP:
                        
                            ; Store final hash
   566f   68 ca 64 b9       RLDI 10, HASH_HI
   5673   97                GHI 7
   5674   5a                STR 10
   5675   1a                INC 10
   5676   87                GLO 7
   5677   5a                STR 10
                        
   5678   d5                RETN
                        
                        ; Helper functions to XOR castling keys (avoids code duplication)
   5679                 HASH_XOR_CASTLE_0:
   5679   68 ca 5e 44       RLDI 10, ZOBRIST_CASTLE
   567d   c0 56 9e          LBR HASH_XOR_CASTLE_DO
   5680                 HASH_XOR_CASTLE_1:
   5680   68 ca 5e 44       RLDI 10, ZOBRIST_CASTLE
   5684   1a                INC 10
   5685   1a                INC 10
   5686   c0 56 9e          LBR HASH_XOR_CASTLE_DO
   5689                 HASH_XOR_CASTLE_2:
   5689   68 ca 5e 44       RLDI 10, ZOBRIST_CASTLE
   568d   1a                INC 10
   568e   1a                INC 10
   568f   1a                INC 10
   5690   1a                INC 10
   5691   c0 56 9e          LBR HASH_XOR_CASTLE_DO
   5694                 HASH_XOR_CASTLE_3:
   5694   68 ca 5e 44       RLDI 10, ZOBRIST_CASTLE
   5698   1a                INC 10
   5699   1a                INC 10
   569a   1a                INC 10
   569b   1a                INC 10
   569c   1a                INC 10
   569d   1a                INC 10
   569e                 HASH_XOR_CASTLE_DO:
   569e   4a                LDA 10
   569f   52                STR 2
   56a0   97                GHI 7
   56a1   f3                XOR
   56a2   b7                PHI 7
   56a3   0a                LDN 10
   56a4   52                STR 2
   56a5   87                GLO 7
   56a6   f3                XOR
   56a7   a7                PLO 7
   56a8   d5                RETN
                        
                        ; ==============================================================================
                        ; TT_CLEAR - Clear all transposition table entries
                        ; ==============================================================================
                        ; Sets all TT entries to flag=TT_FLAG_NONE (0)
                        ; Should be called at start of new game or new position.
                        ;
                        ; Uses: R9 (counter), R10 (pointer)
                        ; ==============================================================================
   56a9                 TT_CLEAR:
   56a9   68 ca 68 00       RLDI 10, TT_TABLE
                        
                            ; Clear 256 entries × 8 bytes = 2048 bytes
                            ; Use R9 as 16-bit counter
   56ad   68 c9 08 00       RLDI 9, TT_ENTRIES * TT_ENTRY_SIZE
                        
   56b1   f8 00             LDI 0               ; Value to write
   56b3                 TT_CLEAR_LOOP:
   56b3   5a                STR 10
   56b4   1a                INC 10
   56b5   29                DEC 9
   56b6   99                GHI 9
   56b7   ca 56 b3          LBNZ TT_CLEAR_LOOP
   56ba   89                GLO 9
   56bb   ca 56 b3          LBNZ TT_CLEAR_LOOP
                        
   56be   d5                RETN
                        
                        ; ==============================================================================
                        ; TT_PROBE - Look up current position in transposition table
                        ; ==============================================================================
                        ; Checks if current position (HASH_HI/LO) exists in TT.
                        ; If found and depth >= required, copies entry data to TT_* variables.
                        ;
                        ; Input:  D = required depth
                        ; Output: D = 1 if usable hit, 0 if miss
                        ;         If hit: TT_SCORE, TT_DEPTH, TT_FLAG, TT_MOVE populated
                        ;
                        ; Uses: R7 (hash), R8 (required depth), R10 (pointer)
                        ; ==============================================================================
   56bf                 TT_PROBE:
   56bf   a8                PLO 8               ; R8.0 = required depth
                        
   56c0   68 c9 64 1d       RLDI 9, TRACE_WHERE
   56c4   f8 b1             LDI $B1
   56c6   59                STR 9              ; tracer: in TT_PROBE
                        
                            ; Clear TT_MOVE (prevents stale data if hash misses)
   56c7   68 c9 64 c0       RLDI 9, TT_MOVE_HI
   56cb   f8 00             LDI 0
   56cd   59                STR 9
   56ce   19                INC 9
   56cf   59                STR 9               ; TT_MOVE_HI/LO = 0
                        
                            ; Load current hash
   56d0   68 ca 64 b9       RLDI 10, HASH_HI
   56d4   4a                LDA 10
   56d5   b7                PHI 7
   56d6   0a                LDN 10
   56d7   a7                PLO 7               ; R7 = current hash
                        
                            ; Calculate TT entry address: TT_TABLE + (index * 8)
                            ; XOR-fold indexing (2026-05-15): index = (hash_hi XOR hash_lo) & $FF.
   56d8   97                GHI 7               ; hash_hi
   56d9   52                STR 2
   56da   87                GLO 7               ; hash_lo
   56db   f3                XOR                 ; D = hash_hi XOR hash_lo
   56dc   fa ff             ANI TT_INDEX_MASK   ; Mask to table size
   56de   fe                SHL                 ; x2, carry into DF
   56df   aa                PLO 10
   56e0   f8 00             LDI 0
   56e2   7e                SHLC                ; carry into D
   56e3   ba                PHI 10              ; R10.1 = high so far
   56e4   8a                GLO 10
   56e5   fe                SHL                 ; x4
   56e6   aa                PLO 10
   56e7   9a                GHI 10
   56e8   7e                SHLC
   56e9   ba                PHI 10
   56ea   8a                GLO 10
   56eb   fe                SHL                 ; x8
   56ec   aa                PLO 10
   56ed   9a                GHI 10
   56ee   7e                SHLC
   56ef   ba                PHI 10              ; R10 = index * 8
                        
                            ; Add TT_TABLE base
   56f0   8a                GLO 10
   56f1   fc 00             ADI LOW(TT_TABLE)
   56f3   aa                PLO 10
   56f4   9a                GHI 10
   56f5   7c 68             ADCI HIGH(TT_TABLE)
   56f7   ba                PHI 10              ; R10 = TT entry address
                        
                            ; Check if entry matches (compare stored hash with current)
   56f8   4a                LDA 10              ; Entry hash_hi
   56f9   52                STR 2
   56fa   97                GHI 7
   56fb   f3                XOR
   56fc   ca 57 55          LBNZ TT_PROBE_MISS
   56ff   4a                LDA 10              ; Entry hash_lo
   5700   52                STR 2
   5701   87                GLO 7
   5702   f3                XOR
   5703   ca 57 55          LBNZ TT_PROBE_MISS
                        
                            ; Hash matches! Save move for ordering (even if depth insufficient)
                            ; R10 at offset 2 (score_hi). Move is at offset 6-7.
   5706   1a                INC 10              ; → 3
   5707   1a                INC 10              ; → 4 (depth)
   5708   1a                INC 10              ; → 5 (flag)
   5709   1a                INC 10              ; → 6 (move_hi)
   570a   4a                LDA 10              ; D = move_hi, R10 → 7
   570b   73                STXD                ; push move_hi
   570c   0a                LDN 10              ; D = move_lo
   570d   73                STXD                ; push move_lo
                        
                            ; Write to TT_MOVE_HI/LO
   570e   68 c9 64 c0       RLDI 9, TT_MOVE_HI
   5712   60                IRX
   5713   72                LDXA                ; D = move_lo
   5714   19                INC 9
   5715   59                STR 9               ; TT_MOVE_LO = move_lo
   5716   29                DEC 9
   5717   f0                LDX                 ; D = move_hi
   5718   59                STR 9               ; TT_MOVE_HI = move_hi
                        
                            ; Navigate back to depth (offset 4)
   5719   2a                DEC 10              ; → 6
   571a   2a                DEC 10              ; → 5
   571b   2a                DEC 10              ; → 4 (depth)
                        
                            ; Check depth
   571c   0a                LDN 10              ; Entry depth
   571d   52                STR 2
   571e   88                GLO 8               ; Required depth
   571f   f5                SD                  ; D = entry_depth - required_depth
   5720   cb 57 55          LBNF TT_PROBE_MISS  ; Borrow → depth insufficient (but TT_MOVE saved!)
                        
                            ; --- side-bit verification (2026-07-15): a 16-bit hash match can be a
                            ; DIFFERENT position (proven: loss8's +2341 = a white-to-move entry
                            ; served to a black-to-move node = sign inversion). Reject the SCORE on
                            ; side mismatch; the ordering move above is already saved (benign — a
                            ; wrong-position move matches nothing in the generated list).
   5723   1a                INC 10              ; → 5 (flag)
   5724   0a                LDN 10              ; D = entry flag (bit 3 = storing side)
   5725   52                STR 2
   5726   8c                GLO 12              ; current side to move ($00/$08)
   5727   f3                XOR
   5728   fa 08             ANI $08
   572a   ca 57 55          LBNZ TT_PROBE_MISS  ; cross-side entry -> treat as miss
   572d   2a                DEC 10              ; → 4 (depth), as the flow below expects
                        
                            ; Usable hit! Copy entry data to TT_* variables
                            ; Back up to start of entry
   572e   2a                DEC 10
   572f   2a                DEC 10
   5730   2a                DEC 10
   5731   2a                DEC 10              ; R10 at entry start
                        
                            ; Copy to TT result variables
   5732   68 c9 64 bc       RLDI 9, TT_SCORE_HI
                        
   5736   1a                INC 10
   5737   1a                INC 10              ; Skip hash verification bytes
   5738   4a                LDA 10              ; score_hi
   5739   59                STR 9
   573a   19                INC 9
   573b   4a                LDA 10              ; score_lo
   573c   59                STR 9
   573d   19                INC 9
   573e   4a                LDA 10              ; depth
   573f   59                STR 9
   5740   19                INC 9
   5741   4a                LDA 10              ; flag
   5742   fa 07             ANI $07             ; strip the side bit — consumers compare bound types
   5744   59                STR 9
   5745   19                INC 9
   5746   4a                LDA 10              ; move_hi
   5747   59                STR 9
   5748   19                INC 9
   5749   0a                LDN 10              ; move_lo
   574a   59                STR 9
                        
                            ; Set TT_HIT = 1
   574b   68 ca 64 bb       RLDI 10, TT_HIT
   574f   f8 01             LDI 1
   5751   5a                STR 10
                        
   5752   f8 01             LDI 1               ; Return hit
   5754   d5                RETN
                        
   5755                 TT_PROBE_MISS:
                            ; Set TT_HIT = 0
   5755   68 ca 64 bb       RLDI 10, TT_HIT
   5759   f8 00             LDI 0
   575b   5a                STR 10
                        
   575c   f8 00             LDI 0               ; Return miss
   575e   d5                RETN
                        
                        ; ==============================================================================
                        ; TT_STORE - Store position result in transposition table
                        ; ==============================================================================
                        ; Stores current position with score, depth, flag, and best move.
                        ; Always replaces existing entry (replace-always scheme).
                        ;
                        ; Input:  Stack contains (push order): score_hi, score_lo, depth, flag
                        ;         BEST_MOVE contains best move
                        ; Actually, let's use memory variables for simplicity:
                        ;         SCORE_HI/LO = score to store
                        ;         D = depth
                        ;         R8.0 = flag
                        ;
                        ; Uses: R7 (hash), R9 (temp), R10 (pointer)
                        ; ==============================================================================
   575f                 TT_STORE:
                            ; Save depth and flag
   575f   73                STXD                ; Push depth
   5760   88                GLO 8
   5761   73                STXD                ; Push flag
                        
   5762   68 ca 64 1d       RLDI 10, TRACE_WHERE
   5766   f8 b2             LDI $B2
   5768   5a                STR 10              ; tracer: in TT_STORE
                        
                            ; Load current hash
   5769   68 ca 64 b9       RLDI 10, HASH_HI
   576d   4a                LDA 10
   576e   b7                PHI 7
   576f   0a                LDN 10
   5770   a7                PLO 7               ; R7 = current hash
                        
                            ; Calculate TT entry address: TT_TABLE + (index * 8) — XOR-fold (must match TT_PROBE)
   5771   97                GHI 7               ; hash_hi
   5772   52                STR 2
   5773   87                GLO 7               ; hash_lo
   5774   f3                XOR                 ; D = hash_hi XOR hash_lo
   5775   fa ff             ANI TT_INDEX_MASK
   5777   fe                SHL                 ; x2, carry into DF
   5778   aa                PLO 10
   5779   f8 00             LDI 0
   577b   7e                SHLC
   577c   ba                PHI 10
   577d   8a                GLO 10
   577e   fe                SHL                 ; x4
   577f   aa                PLO 10
   5780   9a                GHI 10
   5781   7e                SHLC
   5782   ba                PHI 10
   5783   8a                GLO 10
   5784   fe                SHL                 ; x8
   5785   aa                PLO 10
   5786   9a                GHI 10
   5787   7e                SHLC
   5788   ba                PHI 10              ; R10 = index * 8
                        
                            ; Add TT_TABLE base
   5789   8a                GLO 10
   578a   fc 00             ADI LOW(TT_TABLE)
   578c   aa                PLO 10
   578d   9a                GHI 10
   578e   7c 68             ADCI HIGH(TT_TABLE)
   5790   ba                PHI 10              ; R10 = TT entry address
                        
                            ; Write entry
   5791   97                GHI 7               ; hash_hi
   5792   5a                STR 10
   5793   1a                INC 10
   5794   87                GLO 7               ; hash_lo
   5795   5a                STR 10
   5796   1a                INC 10
                        
                            ; Score from SCORE_HI/LO
   5797   68 c9 64 46       RLDI 9, SCORE_HI
   579b   49                LDA 9               ; score_hi
   579c   5a                STR 10
   579d   1a                INC 10
   579e   09                LDN 9               ; score_lo
   579f   5a                STR 10
   57a0   1a                INC 10
                        
                            ; Depth and flag from stack
   57a1   60                IRX
   57a2   72                LDXA                ; flag
   57a3   a8                PLO 8               ; Save temporarily
   57a4   f0                LDX                 ; depth
   57a5   5a                STR 10
   57a6   1a                INC 10
                            ; --- side-bit (2026-07-15, the $1B81 collision fix): fold the storing
                            ; side into flag bit 3 so a 16-bit false hit can't cross perspectives.
   57a7   8c                GLO 12
   57a8   fa 08             ANI $08
   57aa   52                STR 2               ; M(2) = side bit (spent stack slot, safe scratch)
   57ab   88                GLO 8               ; flag
   57ac   f1                OR                  ; flag | side
   57ad   5a                STR 10
   57ae   1a                INC 10
                        
                            ; Best move from NODE_BEST_MOVE[ply]
   57af   68 c9 64 48       RLDI 9, CURRENT_PLY
   57b3   09                LDN 9               ; D = ply
   57b4   fe                SHL                 ; D = ply * 2
   57b5   a9                PLO 9               ; R9.0 = offset (NODE_BEST_MOVE base = $6700, low = $00)
   57b6   f8 67             LDI HIGH(NODE_BEST_MOVE)
   57b8   b9                PHI 9               ; R9 = $6700 + ply*2
   57b9   49                LDA 9               ; from
   57ba   5a                STR 10
   57bb   1a                INC 10
   57bc   09                LDN 9               ; to
   57bd   5a                STR 10
                        
   57be   d5                RETN
                        
                        ; ==============================================================================
                        ; HASH_XOR_PIECE_SQ - XOR piece-square key into current hash
                        ; ==============================================================================
                        ; Used for incremental hash updates in MAKE_MOVE/UNMAKE_MOVE.
                        ;
                        ; Input:  R8.0 = piece (1-6 white, 9-14 black, or EMPTY=0 for no-op)
                        ;         R8.1 = square (0x88 format)
                        ; Output: HASH_HI/LO updated
                        ; Uses:   R7, R9, R10, R11, R13
                        ; ==============================================================================
   57bf                 HASH_XOR_PIECE_SQ:
                            ; Skip if piece is EMPTY
   57bf   88                GLO 8
   57c0   c2 58 21          LBZ HXPS_DONE
                        
                            ; Load current hash into R7
   57c3   68 ca 64 b9       RLDI 10, HASH_HI
   57c7   4a                LDA 10
   57c8   b7                PHI 7
   57c9   0a                LDN 10
   57ca   a7                PLO 7               ; R7 = current hash
                        
                            ; Compute piece index (0-11)
                            ; piece_index = (piece & 7) - 1 for white, + 6 for black
   57cb   88                GLO 8               ; piece
   57cc   fa 07             ANI $07             ; piece type (1-6)
   57ce   ff 01             SMI 1               ; piece_type - 1 (0-5)
   57d0   ad                PLO 13              ; R13.0 = base index
                        
   57d1   88                GLO 8               ; piece again
   57d2   fa 08             ANI $08             ; color bit
   57d4   c2 57 db          LBZ HXPS_WHITE
                            ; Black - add 6
   57d7   8d                GLO 13
   57d8   fc 06             ADI 6
   57da   ad                PLO 13
   57db                 HXPS_WHITE:
                        
                            ; Compute square index (0-63 from 0x88)
                            ; sq64 = (sq88 >> 4) * 8 + (sq88 & 7)
   57db   98                GHI 8               ; 0x88 square
   57dc   fa 07             ANI $07             ; file
   57de   a9                PLO 9               ; R9.0 = file
   57df   98                GHI 8
   57e0   fa 70             ANI $70             ; rank * 16
   57e2   f6                SHR                 ; rank * 8
   57e3   ab                PLO 11              ; R11.0 = rank*8 (use R11, NOT R7 - R7 has hash!)
   57e4   89                GLO 9               ; file
   57e5   52                STR 2               ; temp store on stack
   57e6   8b                GLO 11              ; rank*8
   57e7   f4                ADD                 ; rank*8 + file = sq64
   57e8   a9                PLO 9               ; R9.0 = sq64
                        
                            ; Compute Zobrist offset: piece_index * 128 + sq64 * 2
                            ; piece * 128: high = piece >> 1, low = (piece & 1) << 7
   57e9   8d                GLO 13              ; piece_index
   57ea   f6                SHR                 ; piece >> 1
   57eb   bd                PHI 13              ; R13.1 = high byte of piece*128
   57ec   8d                GLO 13
   57ed   fe                SHL                 ; Restore, then check bit 0
   57ee   f6                SHR                 ; Back to original
   57ef   fa 01             ANI $01
   57f1   c2 57 f9          LBZ HXPS_EVEN
   57f4   f8 80             LDI $80
   57f6   c0 57 fb          LBR HXPS_ADD_SQ
   57f9                 HXPS_EVEN:
   57f9   f8 00             LDI 0
   57fb                 HXPS_ADD_SQ:
                            ; D = low byte of piece*128 (0 or $80)
   57fb   aa                PLO 10              ; R10.0 = temp low
   57fc   89                GLO 9               ; sq64
   57fd   fe                SHL                 ; sq64 * 2
   57fe   52                STR 2
   57ff   8a                GLO 10
   5800   f4                ADD                 ; low + sq*2
   5801   aa                PLO 10
   5802   9d                GHI 13              ; high of piece*128
   5803   7c 00             ADCI 0
   5805   ba                PHI 10              ; R10 = offset
                        
                            ; Add ZOBRIST_PIECE_SQ base
   5806   8a                GLO 10
   5807   fc 42             ADI LOW(ZOBRIST_PIECE_SQ)
   5809   aa                PLO 10
   580a   9a                GHI 10
   580b   7c 58             ADCI HIGH(ZOBRIST_PIECE_SQ)
   580d   ba                PHI 10              ; R10 = key address
                        
                            ; XOR key into hash
   580e   4a                LDA 10              ; key_hi
   580f   52                STR 2
   5810   97                GHI 7
   5811   f3                XOR
   5812   b7                PHI 7
   5813   0a                LDN 10              ; key_lo
   5814   52                STR 2
   5815   87                GLO 7
   5816   f3                XOR
   5817   a7                PLO 7
                        
                            ; Store updated hash
   5818   68 ca 64 b9       RLDI 10, HASH_HI
   581c   97                GHI 7
   581d   5a                STR 10
   581e   1a                INC 10
   581f   87                GLO 7
   5820   5a                STR 10
                        
   5821                 HXPS_DONE:
   5821   d5                RETN
                        
                        ; ==============================================================================
                        ; HASH_XOR_SIDE - Toggle side-to-move in hash
                        ; ==============================================================================
                        ; Called after every move to flip the side-to-move bit in the hash.
                        ;
                        ; Uses: R7, R10
                        ; ==============================================================================
   5822                 HASH_XOR_SIDE:
                            ; Load current hash
   5822   68 ca 64 b9       RLDI 10, HASH_HI
   5826   4a                LDA 10
   5827   b7                PHI 7
   5828   0a                LDN 10
   5829   a7                PLO 7               ; R7 = current hash
                        
                            ; XOR with side key
   582a   68 ca 5e 42       RLDI 10, ZOBRIST_SIDE
   582e   4a                LDA 10              ; key_hi
   582f   52                STR 2
   5830   97                GHI 7
   5831   f3                XOR
   5832   b7                PHI 7
   5833   0a                LDN 10              ; key_lo
   5834   52                STR 2
   5835   87                GLO 7
   5836   f3                XOR
   5837   a7                PLO 7
                        
                            ; Store updated hash
   5838   68 ca 64 b9       RLDI 10, HASH_HI
   583c   97                GHI 7
   583d   5a                STR 10
   583e   1a                INC 10
   583f   87                GLO 7
   5840   5a                STR 10
                        
   5841   d5                RETN
                        ; Zobrist hash keys for transposition table
                        ; Generated by gen_zobrist.py
                        ; Seed: 0x1802CAFE
                        ;
                        ; Piece indices:
                        ;   0-5:  White P, N, B, R, Q, K
                        ;   6-11: Black P, N, B, R, Q, K
                        ;
                        ; Square indices: 0-63 (rank*8 + file)
                        ;
                        
                        ; ===========================================
                        ; Piece-Square Keys (768 x 2 bytes = 1536 bytes)
                        ; Access: ZOBRIST_PIECE_SQ + (piece_index * 128) + (square * 2)
                        ; ===========================================
   5842                 ZOBRIST_PIECE_SQ:
                        ; Piece 0: WhiteP
   5842   63 c3 c7 79       DW $63C3, $C779, $3A3C, $7599  ; d1
   5846   3a 3c 75 99   
   584a   31 41 c2 d6       DW $3141, $C2D6, $D891, $CEC4  ; h1
   584e   d8 91 ce c4   
   5852   83 de 5b 37       DW $83DE, $5B37, $5799, $E158  ; d2
   5856   57 99 e1 58   
   585a   89 d7 ca 58       DW $89D7, $CA58, $6328, $A9A0  ; h2
   585e   63 28 a9 a0   
   5862   bd 96 94 19       DW $BD96, $9419, $14B7, $2BBB  ; d3
   5866   14 b7 2b bb   
   586a   ca 09 ec 60       DW $CA09, $EC60, $3309, $E193  ; h3
   586e   33 09 e1 93   
   5872   c7 db a4 87       DW $C7DB, $A487, $9161, $CDA0  ; d4
   5876   91 61 cd a0   
   587a   92 ed 7c b2       DW $92ED, $7CB2, $3FED, $76AD  ; h4
   587e   3f ed 76 ad   
   5882   f4 98 dc 8d       DW $F498, $DC8D, $253F, $A4D4  ; d5
   5886   25 3f a4 d4   
   588a   f4 5f 58 d0       DW $F45F, $58D0, $96F8, $D38E  ; h5
   588e   96 f8 d3 8e   
   5892   be 90 b3 88       DW $BE90, $B388, $2956, $4BD7  ; d6
   5896   29 56 4b d7   
   589a   1d a9 8f 74       DW $1DA9, $8F74, $E33E, $B79E  ; h6
   589e   e3 3e b7 9e   
   58a2   65 3a 50 49       DW $653A, $5049, $7A64, $D723  ; d7
   58a6   7a 64 d7 23   
