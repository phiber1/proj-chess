   234c   97                GHI 7
   234d   5a                STR 10              ; M(R10) = beta_hi
   234e   9d                GHI 13              ; D = score_hi
   234f   77                SMB                 ; D = D - M(X) - borrow = score_hi - beta_hi - borrow
   2350   e2                SEX 2               ; X = R2 (restore)
                        
