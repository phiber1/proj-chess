   228c   0a                LDN 10
   228d   73                STXD                ; push LMR_MOVE_INDEX
                        
                            ; Increment ply for recursive call
   228e   68 ca 64 48       RLDI 10, CURRENT_PLY
   2292   0a                LDN 10
   2293   fc 01             ADI 1
   2295   5a                STR 10              ; CURRENT_PLY++
                        
                            ; Call NEGAMAX again (full depth this time)
   2296   d4 1b 35          CALL NEGAMAX
                        
                            ; Restore LMR_MOVE_INDEX (the re-searched child clobbered it)
   2299   60                IRX
   229a   f0                LDX                 ; D = saved LMR_MOVE_INDEX
   229b   a7                PLO 7               ; temp (R7.0 dead here — R9 holds the score)
   229c   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   22a0   87                GLO 7
   22a1   5a                STR 10              ; LMR_MOVE_INDEX restored to this node's value
                        
