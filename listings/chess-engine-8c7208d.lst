   085e   d4 03 65          CALL CHECK_TARGET_SQUARE
   0861   ab                PLO 11              ; Save result to R11.0
   0862   c2 08 77          LBZ GEN_SLIDE_S_RET
   0865   9b                GHI 11
   0866   bd                PHI 13
