   0c26   f8 60             LDI HIGH(BOARD)
   0c28   b8                PHI 8               ; R8 = &BOARD[to]
   0c29   08                LDN 8               ; D = piece at to square
   0c2a   aa                PLO 10              ; Save in R10.0
                        
