   0b05   68 c9 64 0a       RLDI 9, UNDO_TO
   0b09   09                LDN 9               ; D = to square
   0b0a   fc 01             ADI 1                ; D = to + 1 (rook's new square)
   0b0c   b8                PHI 8               ; R8.1 = new rook square
   0b0d   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
   0b10                 MM_CASTLE_DONE:
                            ; Reload R10 (clobbered by HASH_XOR_PIECE_SQ)
   0b10   68 c9 64 0a       RLDI 9, UNDO_TO
   0b14   09                LDN 9               ; D = to square
   0b15   a8                PLO 8
   0b16   f8 60             LDI HIGH(BOARD)
   0b18   b8                PHI 8               ; R8 = &BOARD[to]
   0b19   08                LDN 8               ; D = king piece
   0b1a   aa                PLO 10              ; R10.0 = moving piece
   0b1b   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0b1f   09                LDN 9               ; D = captured piece
   0b20   ba                PHI 10              ; R10.1 = captured piece
