                            ; Check if this was a promotion
   0b9a   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   0b9e   0a                LDN 10              ; D = promotion type (0 if none)
   0b9f   c2 0b b8          LBZ MM_HASH_NOT_PROMO
                        
                            ; Promotion: original piece was a pawn. Get color from BOARD[to].
   0ba2   68 ca 64 0a       RLDI 10, UNDO_TO
   0ba6   0a                LDN 10              ; D = to_square
   0ba7   fc 00             ADI LOW(BOARD)
   0ba9   aa                PLO 10
   0baa   f8 60             LDI HIGH(BOARD)
   0bac   7c 00             ADCI 0
   0bae   ba                PHI 10              ; R10 = &BOARD[to_square]
   0baf   0a                LDN 10              ; D = promoted piece
   0bb0   fa 08             ANI COLOR_MASK      ; Get color (0=white, 8=black)
   0bb2   f9 01             ORI PAWN_TYPE       ; D = pawn of same color
   0bb4   a8                PLO 8               ; R8.0 = pawn
   0bb5   c0 0b c7          LBR MM_HASH_GOT_PIECE
                        
   0bb8                 MM_HASH_NOT_PROMO:
