   22bf   60                IRX
   22c0   72                LDXA                ; BEST_SCORE_LO
   22c1   5a                STR 10
   22c2   2a                DEC 10
   22c3   f0                LDX                 ; BEST_SCORE_HI (R2 stays at this slot)
   22c4   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Restore UNDO_* from stack (7 bytes) before UNMAKE_MOVE
                            ; -----------------------------------------------
                            ; UNDO_CAP_SQ first (it was pushed last - LIFO)
   22c5   68 ca 64 ff       RLDI 10, UNDO_CAP_SQ
   22c9   60                IRX
   22ca   f0                LDX                 ; UNDO_CAP_SQ
   22cb   5a                STR 10
                            ; UNDO_PROMOTION next
   22cc   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   22d0   60                IRX
   22d1   f0                LDX                 ; UNDO_PROMOTION
   22d2   5a                STR 10
                            ; Now restore the contiguous block ($6408-$640D)
   22d3   68 ca 64 0d       RLDI 10, UNDO_HALFMOVE
   22d7   60                IRX
   22d8   72                LDXA                ; UNDO_HALFMOVE
   22d9   5a                STR 10
   22da   2a                DEC 10
   22db   72                LDXA                ; UNDO_EP
   22dc   5a                STR 10
   22dd   2a                DEC 10
   22de   72                LDXA                ; UNDO_CASTLING
   22df   5a                STR 10
   22e0   2a                DEC 10
   22e1   72                LDXA                ; UNDO_TO
   22e2   5a                STR 10
   22e3   2a                DEC 10
   22e4   72                LDXA                ; UNDO_FROM
   22e5   5a                STR 10
   22e6   2a                DEC 10
   22e7   f0                LDX                 ; UNDO_CAPTURED (last, no inc)
   22e8   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Unmake the move
                            ; -----------------------------------------------
   22e9   d4 0c 20          CALL UNMAKE_MOVE
                            ; Board restored to previous state
                        
                            ; -----------------------------------------------
                            ; Restore context (memory-based alpha/beta - R6 is SCRT linkage!)
                            ; -----------------------------------------------
                            ; Stack order (low to high): beta_lo, beta_hi, alpha_lo, alpha_hi, depth_lo, depth_hi, R9
                        
                            ; Pop beta from stack to BETA memory (big-endian)
   22ec   60                IRX                 ; Point to beta_lo
   22ed   72                LDXA                ; D = beta_lo
   22ee   a7                PLO 7               ; R7.0 = beta_lo
   22ef   72                LDXA                ; D = beta_hi
   22f0   b7                PHI 7               ; R7.1 = beta_hi, R7 = beta
   22f1   68 cd 64 44       RLDI 13, BETA_HI
   22f5   97                GHI 7
   22f6   5d                STR 13              ; BETA_HI (high byte at lower addr)
   22f7   1d                INC 13
   22f8   87                GLO 7
   22f9   5d                STR 13              ; BETA_LO (low byte at higher addr)
                        
                            ; Pop alpha from stack to ALPHA memory (NO extra IRX - R2 already at alpha_lo)
   22fa   72                LDXA                ; D = alpha_lo
   22fb   a7                PLO 7               ; R7.0 = alpha_lo
   22fc   72                LDXA                ; D = alpha_hi
   22fd   b7                PHI 7               ; R7.1 = alpha_hi, R7 = alpha
   22fe   68 cd 64 42       RLDI 13, ALPHA_HI
   2302   97                GHI 7
   2303   5d                STR 13              ; ALPHA_HI (high byte at lower addr)
   2304   1d                INC 13
   2305   87                GLO 7
   2306   5d                STR 13              ; ALPHA_LO (low byte at higher addr)
                        
                            ; Pop depth from stack to SEARCH_DEPTH memory
                            ; Stack has: depth_lo, depth_hi (depth_lo at lower addr)
                            ; R9 no longer on stack; move count no longer on stack (LOOP_MOVE_CNT) —
                            ; depth_hi is now the TOP byte of this iteration's search-context frame.
   2307   72                LDXA                ; D = depth_lo, R2 advances to depth_hi
   2308   a7                PLO 7               ; Temp
   2309   f0                LDX                 ; D = depth_hi, R2 stays AT depth_hi (frame top)
   230a   b7                PHI 7               ; R7 = depth (temp: hi.lo)
   230b   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   230f   97                GHI 7
   2310   5d                STR 13              ; SEARCH_DEPTH high
   2311   1d                INC 13
   2312   87                GLO 7
   2313   5d                STR 13              ; SEARCH_DEPTH+1 low
                        
