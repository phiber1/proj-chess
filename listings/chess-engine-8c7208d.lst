                        ; ==============================================================================
                        ; GEN_KING - UNROLLED VERSION with castling (no stack math, no loops)
                        ; ==============================================================================
                        ; R11.1 has from square on entry (set before dispatch, survives CALLs)
                        ; Uses ADI with immediate offsets - no ADD/stack operations
                        ; King offsets: N=$10, NE=$11, E=$01, SE=$F1, S=$F0, SW=$EF, W=$FF, NW=$0F
                        ; ==============================================================================
   08ed                 GEN_KING:
                            ; --- Direction 1: N (+$10) ---
   08ed   9b                GHI 11
   08ee   fc 10             ADI $10
   08f0   ab                PLO 11
   08f1   fa 88             ANI $88
   08f3   ca 09 05          LBNZ GEN_KG_DIR2
   08f6   d4 03 65          CALL CHECK_TARGET_SQUARE
   08f9   c2 09 05          LBZ GEN_KG_DIR2
   08fc   9b                GHI 11
   08fd   bd                PHI 13
   08fe   8b                GLO 11
   08ff   ad                PLO 13
   0900   f8 00             LDI MOVE_NORMAL
   0902   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   0905                 GEN_KG_DIR2:
                            ; --- Direction 2: NE (+$11) ---
   0905   9b                GHI 11
   0906   fc 11             ADI $11
   0908   ab                PLO 11
   0909   fa 88             ANI $88
   090b   ca 09 1d          LBNZ GEN_KG_DIR3
   090e   d4 03 65          CALL CHECK_TARGET_SQUARE
   0911   c2 09 1d          LBZ GEN_KG_DIR3
   0914   9b                GHI 11
   0915   bd                PHI 13
   0916   8b                GLO 11
   0917   ad                PLO 13
   0918   f8 00             LDI MOVE_NORMAL
   091a   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   091d                 GEN_KG_DIR3:
                            ; --- Direction 3: E (+$01) ---
   091d   9b                GHI 11
   091e   fc 01             ADI $01
   0920   ab                PLO 11
   0921   fa 88             ANI $88
   0923   ca 09 35          LBNZ GEN_KG_DIR4
   0926   d4 03 65          CALL CHECK_TARGET_SQUARE
   0929   c2 09 35          LBZ GEN_KG_DIR4
   092c   9b                GHI 11
   092d   bd                PHI 13
   092e   8b                GLO 11
   092f   ad                PLO 13
   0930   f8 00             LDI MOVE_NORMAL
   0932   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   0935                 GEN_KG_DIR4:
                            ; --- Direction 4: SE (+$F1 = -$0F) ---
   0935   9b                GHI 11
   0936   fc f1             ADI $F1
   0938   ab                PLO 11
   0939   fa 88             ANI $88
   093b   ca 09 4d          LBNZ GEN_KG_DIR5
   093e   d4 03 65          CALL CHECK_TARGET_SQUARE
   0941   c2 09 4d          LBZ GEN_KG_DIR5
   0944   9b                GHI 11
   0945   bd                PHI 13
   0946   8b                GLO 11
   0947   ad                PLO 13
   0948   f8 00             LDI MOVE_NORMAL
   094a   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   094d                 GEN_KG_DIR5:
                            ; --- Direction 5: S (+$F0 = -$10) ---
   094d   9b                GHI 11
   094e   fc f0             ADI $F0
   0950   ab                PLO 11
   0951   fa 88             ANI $88
   0953   ca 09 65          LBNZ GEN_KG_DIR6
   0956   d4 03 65          CALL CHECK_TARGET_SQUARE
   0959   c2 09 65          LBZ GEN_KG_DIR6
   095c   9b                GHI 11
   095d   bd                PHI 13
   095e   8b                GLO 11
   095f   ad                PLO 13
   0960   f8 00             LDI MOVE_NORMAL
   0962   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   0965                 GEN_KG_DIR6:
                            ; --- Direction 6: SW (+$EF = -$11) ---
   0965   9b                GHI 11
   0966   fc ef             ADI $EF
   0968   ab                PLO 11
   0969   fa 88             ANI $88
   096b   ca 09 7d          LBNZ GEN_KG_DIR7
   096e   d4 03 65          CALL CHECK_TARGET_SQUARE
   0971   c2 09 7d          LBZ GEN_KG_DIR7
   0974   9b                GHI 11
   0975   bd                PHI 13
   0976   8b                GLO 11
   0977   ad                PLO 13
   0978   f8 00             LDI MOVE_NORMAL
   097a   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   097d                 GEN_KG_DIR7:
                            ; --- Direction 7: W (+$FF = -$01) ---
   097d   9b                GHI 11
   097e   fc ff             ADI $FF
   0980   ab                PLO 11
   0981   fa 88             ANI $88
   0983   ca 09 95          LBNZ GEN_KG_DIR8
   0986   d4 03 65          CALL CHECK_TARGET_SQUARE
   0989   c2 09 95          LBZ GEN_KG_DIR8
   098c   9b                GHI 11
   098d   bd                PHI 13
   098e   8b                GLO 11
   098f   ad                PLO 13
   0990   f8 00             LDI MOVE_NORMAL
   0992   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   0995                 GEN_KG_DIR8:
                            ; --- Direction 8: NW (+$0F) ---
   0995   9b                GHI 11
   0996   fc 0f             ADI $0F
   0998   ab                PLO 11
   0999   fa 88             ANI $88
   099b   ca 09 ad          LBNZ GEN_KG_CASTLING
   099e   d4 03 65          CALL CHECK_TARGET_SQUARE
   09a1   c2 09 ad          LBZ GEN_KG_CASTLING
   09a4   9b                GHI 11
   09a5   bd                PHI 13
   09a6   8b                GLO 11
   09a7   ad                PLO 13
   09a8   f8 00             LDI MOVE_NORMAL
   09aa   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   09ad                 GEN_KG_CASTLING:
                            ; Add castling moves (R11.1 still has king square)
   09ad   9b                GHI 11              ; D = king square for castling check
   09ae   d4 04 29          CALL GEN_CASTLING_MOVES
                        
   09b1   c0 05 24          LBR GEN_SKIP_SQUARE
                        
                        
                        ; ==============================================================================
                        ; End of Move Generation (Fixed)
                        ; ==============================================================================
                        ; ==============================================================================
                        ; MAKE/UNMAKE MOVE MODULE
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; Undo information - defined in board.asm as EQUs in RAM ($6408-$640D)
                        ; UNDO_CAPTURED, UNDO_FROM, UNDO_TO, UNDO_CASTLING, UNDO_EP, UNDO_HALFMOVE
                        ; These MUST be in RAM (not ROM) for read/write access!
                        ; ------------------------------------------------------------------------------
                        
                        ; ==============================================================================
                        ; MAKE_MOVE - Apply move to the board
                        ; Input: MOVE_FROM, MOVE_TO contain the move
                        ; Output: Board updated, undo info saved, hash updated
                        ;         D = 0 if success
                        ; ==============================================================================
   09b4                 MAKE_MOVE:
                            ; Save undo information
   09b4   68 c8 64 09       RLDI 8, UNDO_FROM
                        
                            ; Save from square
   09b8   68 c9 64 02       RLDI 9, MOVE_FROM
   09bc   09                LDN 9
   09bd   58                STR 8
   09be   18                INC 8
                            
                            ; Save to square
   09bf   19                INC 9
   09c0   09                LDN 9               ; MOVE_TO
   09c1   58                STR 8
   09c2   18                INC 8
                            
                            ; Save castling rights from GAME_STATE + STATE_CASTLING
   09c3   68 c9 60 81       RLDI 9, GAME_STATE + STATE_CASTLING
   09c7   09                LDN 9
   09c8   58                STR 8
   09c9   18                INC 8
                        
                            ; Save en passant square from GAME_STATE + STATE_EP_SQUARE
   09ca   19                INC 9
   09cb   09                LDN 9
   09cc   58                STR 8
   09cd   18                INC 8
                        
                            ; Save halfmove clock from GAME_STATE + STATE_HALFMOVE
   09ce   19                INC 9
   09cf   09                LDN 9
   09d0   58                STR 8
                        
                            ; Get the piece being moved
   09d1   68 c9 64 02       RLDI 9, MOVE_FROM
   09d5   09                LDN 9               ; D = from square index
   09d6   a8                PLO 8
   09d7   f8 60             LDI HIGH(BOARD)
   09d9   b8                PHI 8               ; R8 = &BOARD[from]
   09da   08                LDN 8               ; D = piece at from square
   09db   aa                PLO 10              ; Save moving piece in R10.0
                        
                            ; Get captured piece at destination
   09dc   68 c9 64 03       RLDI 9, MOVE_TO
   09e0   09                LDN 9               ; D = to square index
   09e1   a8                PLO 8
   09e2   f8 60             LDI HIGH(BOARD)
   09e4   b8                PHI 8               ; R8 = &BOARD[to]
   09e5   08                LDN 8               ; D = piece at to square (captured)
                            
                            ; Save captured piece
   09e6   ba                PHI 10              ; Save in R10.1
   09e7   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   09eb   9a                GHI 10
   09ec   59                STR 9
                        
                            ; Save capture square (default = to, changed by EP)
   09ed   68 c9 64 ff       RLDI 9, UNDO_CAP_SQ
   09f1   68 cd 64 0a       RLDI 13, UNDO_TO
   09f5   0d                LDN 13
   09f6   59                STR 9               ; UNDO_CAP_SQ = MOVE_TO (default)
                        
                            ; Place moving piece at destination
   09f7   8a                GLO 10              ; Get moving piece
   09f8   58                STR 8               ; Store at to square (R8 still points there)
                        
                            ; =========================================
                            ; EN PASSANT CAPTURE
                            ; =========================================
                            ; Detect: pawn moves to saved EP square, BOARD[to] was empty
                            ; R10.1 = captured piece at BOARD[to], R10.0 = moving piece
   09f9   9a                GHI 10              ; captured piece
   09fa   ca 0a 48          LBNZ MM_NOT_EP_CAP  ; Normal capture (piece at to) -> skip
                        
   09fd   8a                GLO 10              ; moving piece
   09fe   fa 07             ANI PIECE_MASK
   0a00   fb 01             XRI PAWN_TYPE
   0a02   ca 0a 48          LBNZ MM_NOT_EP_CAP  ; Not a pawn -> skip
                        
                            ; Pawn moved to empty square. Check if to == saved EP square.
   0a05   68 c9 64 0c       RLDI 9, UNDO_EP     ; EP square from BEFORE this move
   0a09   09                LDN 9               ; D = saved EP square
   0a0a   fb ff             XRI NO_EP
   0a0c   c2 0a 48          LBZ MM_NOT_EP_CAP   ; No EP was active ($FF) -> skip
   0a0f   68 c9 64 0c       RLDI 9, UNDO_EP
   0a13   09                LDN 9               ; D = EP square
   0a14   52                STR 2
   0a15   68 c9 64 0a       RLDI 9, UNDO_TO
   0a19   09                LDN 9               ; D = to square
   0a1a   f3                XOR
   0a1b   ca 0a 48          LBNZ MM_NOT_EP_CAP  ; to != EP -> not en passant
                        
                            ; EP CAPTURE! Captured pawn at (from_rank | to_file)
   0a1e   68 c9 64 09       RLDI 9, UNDO_FROM
   0a22   09                LDN 9
   0a23   fa 70             ANI $70             ; from rank
   0a25   ad                PLO 13
   0a26   68 c9 64 0a       RLDI 9, UNDO_TO
   0a2a   09                LDN 9
   0a2b   fa 07             ANI $07             ; to file
   0a2d   52                STR 2
   0a2e   8d                GLO 13
   0a2f   f1                OR                  ; D = captured square
   0a30   a8                PLO 8
   0a31   f8 60             LDI HIGH(BOARD)
   0a33   b8                PHI 8               ; R8 = &BOARD[cap_sq]
                        
                            ; Read and save the captured pawn
   0a34   08                LDN 8               ; D = enemy pawn
   0a35   ba                PHI 10              ; R10.1 = captured pawn (update from EMPTY)
   0a36   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0a3a   9a                GHI 10
   0a3b   59                STR 9               ; UNDO_CAPTURED = enemy pawn
                        
                            ; Save EP capture square
   0a3c   88                GLO 8               ; D = cap_sq (low byte of R8)
   0a3d   73                STXD                ; push to stack
   0a3e   68 c9 64 ff       RLDI 9, UNDO_CAP_SQ
   0a42   60                IRX
   0a43   f0                LDX                 ; D = cap_sq
   0a44   59                STR 9               ; UNDO_CAP_SQ = captured square
                        
                            ; Remove captured pawn from board
   0a45   f8 00             LDI EMPTY
   0a47   58                STR 8               ; BOARD[cap_sq] = EMPTY
                        
   0a48                 MM_NOT_EP_CAP:
                        
                            ; =========================================
                            ; PAWN PROMOTION
                            ; =========================================
                            ; Check UNDO_PROMOTION - if non-zero, replace pawn with promoted piece
                            ; R8 still points to BOARD[to], R10.0 = moving piece
   0a48   68 c9 64 04       RLDI 9, UNDO_PROMOTION
   0a4c   09                LDN 9               ; D = promotion piece type (0 if none)
   0a4d   c2 0a 57          LBZ MM_NOT_PROMOTION
                        
                            ; Promotion! Replace pawn with promoted piece
                            ; Get color from moving piece (R10.0), combine with promotion type
   0a50   8a                GLO 10              ; Moving piece (pawn)
   0a51   fa 08             ANI COLOR_MASK      ; Get color (0=white, 8=black)
   0a53   52                STR 2               ; Save color on stack
   0a54   09                LDN 9               ; Get promotion piece type again
   0a55   f4                ADD                 ; D = color + piece_type = promoted piece
   0a56   58                STR 8               ; Store promoted piece at BOARD[to]
                        
   0a57                 MM_NOT_PROMOTION:
                        
                            ; =========================================
                            ; KING POSITION UPDATE
                            ; =========================================
                            ; If moving piece is a king, update GAME_STATE king position
                            ; R10.0 = moving piece
   0a57   8a                GLO 10              ; Get moving piece
   0a58   fa 07             ANI PIECE_MASK      ; Get piece type (0-6)
   0a5a   fb 06             XRI KING_TYPE       ; Is it a king?
   0a5c   ca 0b 21          LBNZ MM_NOT_KING    ; Not a king, skip
                        
