   233d   9d                GHI 13              ; score high byte
   233e   5a                STR 10
   233f   97                GHI 7               ; beta high byte
   2340   f3                XOR                 ; XOR high bytes
   2341   fa 80             ANI $80             ; Check if sign bits differ
   2343   e2                SEX 2               ; X = R2 (restore for branches)
   2344   ca 23 59          LBNZ NEGAMAX_BETA_DIFF_SIGN
                        
                            ; Same sign - use subtraction result
