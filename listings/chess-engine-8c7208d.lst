                        ; --- GEN_SLIDE_NW: Northwest (+$0F) ---
   08c6                 GEN_SLIDE_NW:
   08c6   9b                GHI 11
   08c7   a7                PLO 7
   08c8                 GEN_SLIDE_NW_LOOP:
   08c8   87                GLO 7
   08c9   fc 0f             ADI $0F
   08cb   a7                PLO 7
   08cc   fa 88             ANI $88
   08ce   ca 08 ec          LBNZ GEN_SLIDE_NW_RET
   08d1   87                GLO 7
   08d2   ab                PLO 11
   08d3   d4 03 65          CALL CHECK_TARGET_SQUARE
   08d6   ab                PLO 11              ; Save result to R11.0
   08d7   c2 08 ec          LBZ GEN_SLIDE_NW_RET
   08da   9b                GHI 11
   08db   bd                PHI 13
   08dc   87                GLO 7
   08dd   ad                PLO 13
   08de   f8 00             LDI MOVE_NORMAL
   08e0   d4 03 e9          CALL ADD_MOVE_ENCODED
   08e3   8b                GLO 11              ; Get result from R11.0
   08e4   fb 02             XRI 2
   08e6   c2 08 ec          LBZ GEN_SLIDE_NW_RET
