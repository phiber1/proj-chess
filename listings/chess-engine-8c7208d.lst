   0b25   09                LDN 9               ; D = from square
   0b26   a8                PLO 8
   0b27   f8 60             LDI HIGH(BOARD)
   0b29   b8                PHI 8               ; R8 = &BOARD[from]
   0b2a   f8 00             LDI EMPTY
