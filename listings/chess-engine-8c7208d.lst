                            ; R10.1 = captured piece from UNDO_CAPTURED
   0a8e   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0a92   09                LDN 9               ; D = captured piece
   0a93   ba                PHI 10              ; R10.1 = captured piece
                        
