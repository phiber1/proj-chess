                            ; ==================================================================
                            ; Enemy King Edge Bonus (endgame only, when winning)
                            ; Uses KING_EDGE_TABLE (already in binary, 64 bytes)
                            ; Values: 60 at edges/corners, 0 at center — rewards driving to edge
                            ; Scaled 2x via SHL for effective range 0-120cp
                            ; ==================================================================
                        
                            ; --- King-king proximity (the missing mating ingredient): Chebyshev
                            ; distance between the two kings (R15.0=white index, R15.1=black index,
                            ; both 0-63), look up KING_PROX_BONUS[dist], stash in EVAL_TEMP1. Added for
                            ; the winning side below so its king is pulled toward the enemy king. Mirrors
                            ; the queen-prox distance pattern. Preserves R9/R15. ---
   168c   8f                GLO 15              ; white king 0-63 index
   168d   f6                SHR
   168e   f6                SHR
   168f   f6                SHR                 ; D = white rank (0-7)
   1690   ad                PLO 13              ; R13.0 = w_rank
   1691   9f                GHI 15              ; black king index
   1692   f6                SHR
   1693   f6                SHR
   1694   f6                SHR                 ; D = black rank
   1695   52                STR 2
   1696   8d                GLO 13
   1697   f5                SD                  ; D = b_rank - w_rank
   1698   c3 16 9d          LBDF KP_RANK_OK
   169b   fd 00             SDI 0               ; |rank diff|
   169d                 KP_RANK_OK:
   169d   bd                PHI 13              ; R13.1 = |rank diff|
   169e   8f                GLO 15
   169f   fa 07             ANI $07             ; D = w_file
   16a1   ad                PLO 13              ; R13.0 = w_file
   16a2   9f                GHI 15
   16a3   fa 07             ANI $07             ; D = b_file
   16a5   52                STR 2
   16a6   8d                GLO 13
   16a7   f5                SD                  ; D = b_file - w_file
   16a8   c3 16 ad          LBDF KP_FILE_OK
   16ab   fd 00             SDI 0               ; |file diff|
   16ad                 KP_FILE_OK:
   16ad   ad                PLO 13              ; R13.0 = |file diff|
   16ae   9d                GHI 13              ; |rank diff|
   16af   52                STR 2
   16b0   8d                GLO 13              ; |file diff|
   16b1   f5                SD                  ; D = |rank| - |file|
   16b2   c3 16 b9          LBDF KP_USE_RANK    ; rank >= file -> max = rank
   16b5   8d                GLO 13              ; max = file
   16b6   c0 16 ba          LBR KP_HAVE_DIST
   16b9                 KP_USE_RANK:
   16b9   9d                GHI 13              ; max = rank
   16ba                 KP_HAVE_DIST:
   16ba   fc 2d             ADI LOW(KING_PROX_BONUS)
   16bc   ab                PLO 11
   16bd   f8 00             LDI 0
   16bf   7c 1b             ADCI HIGH(KING_PROX_BONUS)
   16c1   bb                PHI 11
   16c2   0b                LDN 11              ; D = KING_PROX_BONUS[chebyshev dist]
   16c3   68 ca 64 40       RLDI 10, EVAL_TEMP1
   16c7   5a                STR 10              ; EVAL_TEMP1 = king-king proximity bonus
                        
                            ; Check if white is winning significantly (score > 200)
   16c8   99                GHI 9
   16c9   fa 80             ANI $80             ; sign bit
   16cb   ca 17 11          LBNZ EG_CHECK_BLACK ; negative, check if black winning
   16ce   99                GHI 9
   16cf   ca 16 d8          LBNZ EG_DRIVE_BLACK ; high byte > 0 → score > 255
   16d2   89                GLO 9
   16d3   ff c8             SMI 200
   16d5   cb 17 53          LBNF EG_EDGE_DONE   ; score < 200, skip
                        
   16d8                 EG_DRIVE_BLACK:
                            ; MATE-MATERIAL GATE (2026-06-26): only drive if white holds a heavy piece
                            ; (rook or queen). A pawns/minors-only side has no mating material; driving
                            ; its king toward the enemy walks it into danger (the 6/26 phantom-passer king
                            ; march, eval +1080 then -2115 once the king was cornered). Score>200 alone is
                            ; self-referential — the phantom inflates the very score that trips the drive.
   16d8   68 cb 64 b1       RLDI 11, EVAL_W_ROOK_F1
   16dc   0b                LDN 11
   16dd   fb ff             XRI $FF
   16df   ca 16 ea          LBNZ EG_DB_GO       ; white has a rook -> drive ok
   16e2   68 cb 64 b5       RLDI 11, W_QUEEN_CNT
   16e6   0b                LDN 11
   16e7   c2 17 53          LBZ EG_EDGE_DONE    ; no rook AND no queen -> no mate material, skip drive
   16ea                 EG_DB_GO:
                            ; White winning — penalize black king for being in center
                            ; R15.1 = black king index (saved during centralization)
   16ea   9f                GHI 15              ; D = black king 0-63 index
   16eb   52                STR 2               ; save on stack
   16ec   68 cb 1a ed       RLDI 11, KING_EDGE_TABLE
   16f0   8b                GLO 11
   16f1   f4                ADD
   16f2   ab                PLO 11
   16f3   9b                GHI 11
   16f4   7c 00             ADCI 0
   16f6   bb                PHI 11              ; R11 = &KING_EDGE_TABLE[black_king]
   16f7   0b                LDN 11              ; D = edge value (0-60)
   16f8   fe                SHL                 ; D = value * 2 (0-120)
   16f9   52                STR 2               ; save bonus
   16fa   89                GLO 9
   16fb   f4                ADD
   16fc   a9                PLO 9
   16fd   99                GHI 9
   16fe   7c 00             ADCI 0
   1700   b9                PHI 9               ; R9 += edge bonus (always positive, no sign extend)
                            ; + king-king proximity: white king closer to black king = better for white
   1701   68 ca 64 40       RLDI 10, EVAL_TEMP1
   1705   0a                LDN 10
   1706   52                STR 2
   1707   89                GLO 9
   1708   f4                ADD
   1709   a9                PLO 9
   170a   99                GHI 9
   170b   7c 00             ADCI 0
   170d   b9                PHI 9
   170e   c0 17 53          LBR EG_EDGE_DONE
                        
   1711                 EG_CHECK_BLACK:
                            ; Check if black is winning (score < -200)
                            ; Score is negative. Check if <= -201 (i.e., high byte < $FF or low byte <= $37)
   1711   99                GHI 9
   1712   fb ff             XRI $FF
   1714   ca 17 1d          LBNZ EG_DRIVE_WHITE ; high byte < $FF → score < -255
   1717   89                GLO 9
   1718   fc c8             ADI 200             ; if score_lo + 200 overflows, score_lo > 55 → score > -201
   171a   c3 17 53          LBDF EG_EDGE_DONE   ; score > -201, not winning enough
                        
   171d                 EG_DRIVE_WHITE:
                            ; MATE-MATERIAL GATE (2026-06-26): symmetric to EG_DRIVE_BLACK — only drive if
                            ; black holds a heavy piece (rook or queen). No mate material -> don't march.
   171d   68 cb 64 b3       RLDI 11, EVAL_B_ROOK_F1
   1721   0b                LDN 11
   1722   fb ff             XRI $FF
   1724   ca 17 2f          LBNZ EG_DW_GO       ; black has a rook -> drive ok
   1727   68 cb 64 b6       RLDI 11, B_QUEEN_CNT
   172b   0b                LDN 11
   172c   c2 17 53          LBZ EG_EDGE_DONE    ; no rook AND no queen -> no mate material, skip drive
   172f                 EG_DW_GO:
                            ; Black winning — penalize white king for being in center
                            ; R15.0 = white king index (saved during centralization)
   172f   8f                GLO 15              ; D = white king 0-63 index
   1730   52                STR 2
   1731   68 cb 1a ed       RLDI 11, KING_EDGE_TABLE
   1735   8b                GLO 11
   1736   f4                ADD
   1737   ab                PLO 11
   1738   9b                GHI 11
   1739   7c 00             ADCI 0
   173b   bb                PHI 11              ; R11 = &KING_EDGE_TABLE[white_king]
   173c   0b                LDN 11              ; D = edge value (0-60)
   173d   fe                SHL                 ; D = value * 2 (0-120)
   173e   52                STR 2               ; save penalty
   173f   89                GLO 9
   1740   f7                SM                  ; R9.0 - penalty (SM = D - M(R(X)))
   1741   a9                PLO 9
   1742   99                GHI 9
   1743   7f 00             SMBI 0
   1745   b9                PHI 9               ; R9 -= edge penalty
                            ; - king-king proximity: black king closer to white king = better for black
   1746   68 ca 64 40       RLDI 10, EVAL_TEMP1
   174a   0a                LDN 10
   174b   52                STR 2
   174c   89                GLO 9
   174d   f7                SM
   174e   a9                PLO 9
   174f   99                GHI 9
   1750   7f 00             SMBI 0
   1752   b9                PHI 9
                        
   1753                 EG_EDGE_DONE:
                        
                            ; ==================================================================
                            ; Check bonus: if side-to-move is in check, credit the attacker.
                            ; Score is white-relative, so white-in-check → R9 -= CHECK_BONUS;
                            ; black-in-check → R9 += CHECK_BONUS.
                            ; IS_IN_CHECK preserves R11/R12; we save R9 ourselves.
                            ; ==================================================================
   1753   89                GLO 9
   1754   73                STXD
   1755   99                GHI 9
   1756   73                STXD
                        
   1757   d4 01 8e          CALL IS_IN_CHECK        ; uses R12 (side to move); D = 1 if in check
   175a   a8                PLO 8                   ; R8.0 = result
                        
   175b   60                IRX
   175c   72                LDXA
   175d   b9                PHI 9
   175e   f0                LDX
   175f   a9                PLO 9                   ; R9 restored
                        
   1760   88                GLO 8
   1761   c2 17 7f          LBZ CHECK_BONUS_DONE    ; not in check, skip
                        
   1764   8c                GLO 12                  ; side to move: WHITE=0, BLACK=8
   1765   c2 17 75          LBZ CHECK_BONUS_SUB     ; white to move and white in check → penalty
                        
                            ; Black to move and black in check → bonus to white
   1768   f8 28             LDI CHECK_BONUS
   176a   52                STR 2
   176b   89                GLO 9
   176c   f4                ADD
   176d   a9                PLO 9
   176e   99                GHI 9
   176f   7c 00             ADCI 0
   1771   b9                PHI 9
   1772   c0 17 7f          LBR CHECK_BONUS_DONE
                        
   1775                 CHECK_BONUS_SUB:
                            ; White to move and white in check → penalty to white
   1775   f8 28             LDI CHECK_BONUS
   1777   52                STR 2
   1778   89                GLO 9
   1779   f7                SM                      ; SM = D - M(R(X)) → R9.0 - CHECK_BONUS
   177a   a9                PLO 9
   177b   99                GHI 9
   177c   7f 00             SMBI 0
   177e   b9                PHI 9
                        
   177f                 CHECK_BONUS_DONE:
                        
   177f                 BKS_DONE:
   177f   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; EVALUATE_MATERIAL - Material-only evaluation (fast version)
                        ; ------------------------------------------------------------------------------
                        ; Simplified evaluation for leaf nodes where speed is critical
                        ; Input:  A = board pointer
                        ; Output: R9 = material score (NOT R6 - R6 is SCRT linkage, off limits!)
                        ; ------------------------------------------------------------------------------
   1780                 EVALUATE_MATERIAL:
                            ; Alias to main evaluate for now
                            ; Later can optimize this path
   1780   c0 0e 92          LBR EVALUATE
                        
                        ; ------------------------------------------------------------------------------
                        ; KING_SAFETY - shield + enemy-queen-storm danger for one king (2026-06-11)
                        ; In:  R7.0 = king sq (0x88); R7.1 = enemy queen sq ($FF if none)
                        ;      R8.0 = friendly pawn code; R8.1 = shield ahead-offset (+$10 / $F0)
                        ; Out: D = penalty magnitude (0-250). Preserves R9. Uses R10,R11,R13. X=2.
                        ; ------------------------------------------------------------------------------
   1783                 KING_SAFETY:
   1783   e2                SEX 2
                        
   1784   68 ca 64 1d       RLDI 10, TRACE_WHERE
   1788   f8 e2             LDI $E2
   178a   5a                STR 10              ; tracer: in KING_SAFETY (v2)
                            ; No enemy queen -> no king-safety penalty at all. Prevents penalizing an
                            ; actively centralized (shieldless) king in queenless endgames.
   178b   97                GHI 7
   178c   fb ff             XRI $FF
   178e   c2 18 26          LBZ KS_ZERO
                            ; center shield square = king + ahead-offset
   1791   87                GLO 7
   1792   52                STR 2
   1793   98                GHI 8
   1794   f4                ADD
   1795   ad                PLO 13              ; R13.0 = center
   1796   ff 01             SMI 1               ; D = center - 1 (first shield square)
   1798   aa                PLO 10              ; R10.0 = shield square
   1799   f8 00             LDI 0
   179b   bd                PHI 13              ; R13.1 = shield pawn count = 0
   179c   f8 03             LDI 3
   179e   ab                PLO 11              ; loop counter
   179f                 KS_SH_LOOP:
   179f   8a                GLO 10
   17a0   fa 88             ANI $88
   17a2   ca 17 b3          LBNZ KS_SH_NEXT     ; off board
   17a5   f8 60             LDI HIGH(BOARD)
   17a7   ba                PHI 10              ; R10 -> board[sq]
   17a8   0a                LDN 10
   17a9   52                STR 2
   17aa   88                GLO 8               ; friendly pawn code
   17ab   f3                XOR
   17ac   ca 17 b3          LBNZ KS_SH_NEXT     ; not our pawn
   17af   9d                GHI 13
   17b0   fc 01             ADI 1
   17b2   bd                PHI 13              ; count++
   17b3                 KS_SH_NEXT:
   17b3   1a                INC 10              ; next shield square (center-1 -> center -> center+1)
   17b4   2b                DEC 11
   17b5   8b                GLO 11
   17b6   ca 17 9f          LBNZ KS_SH_LOOP
                            ; missing = 3 - count
   17b9   9d                GHI 13
   17ba   52                STR 2
   17bb   f8 03             LDI 3
   17bd   f7                SM                  ; D = 3 - count
   17be   ad                PLO 13              ; R13.0 = missing (0-3)
   17bf   fc d1             ADI LOW(SHIELD_PEN)
   17c1   aa                PLO 10
   17c2   f8 0d             LDI HIGH(SHIELD_PEN)
   17c4   7c 00             ADCI 0
   17c6   ba                PHI 10
   17c7   0a                LDN 10              ; D = SHIELD_PEN[missing]
   17c8   bb                PHI 11              ; R11.1 = penalty
                            ; storm only if shield cracked AND enemy queen within Chebyshev 2
   17c9   8d                GLO 13              ; missing
   17ca   c2 18 24          LBZ KS_RET          ; fully shielded -> no penalty
   17cd   97                GHI 7               ; enemy queen sq
   17ce   fb ff             XRI $FF
   17d0   c2 18 24          LBZ KS_RET          ; no enemy queen
                            ; chebyshev(enemy queen R7.1, our king R7.0)
   17d3   97                GHI 7
   17d4   fa 70             ANI $70
   17d6   f6                SHR
   17d7   f6                SHR
   17d8   f6                SHR
   17d9   f6                SHR                 ; q_rank
   17da   ad                PLO 13
   17db   87                GLO 7
   17dc   fa 70             ANI $70
   17de   f6                SHR
   17df   f6                SHR
   17e0   f6                SHR
   17e1   f6                SHR                 ; k_rank
   17e2   52                STR 2
   17e3   8d                GLO 13
   17e4   f5                SD                  ; k_rank - q_rank
   17e5   c3 17 ea          LBDF KS_RANK_OK
   17e8   fd 00             SDI 0
   17ea                 KS_RANK_OK:
   17ea   bd                PHI 13              ; |rank diff|
   17eb   97                GHI 7
   17ec   fa 07             ANI $07             ; q_file
   17ee   ad                PLO 13
   17ef   87                GLO 7
   17f0   fa 07             ANI $07             ; k_file
   17f2   52                STR 2
   17f3   8d                GLO 13
   17f4   f5                SD                  ; k_file - q_file
   17f5   c3 17 fa          LBDF KS_FILE_OK
   17f8   fd 00             SDI 0
   17fa                 KS_FILE_OK:
   17fa   ad                PLO 13              ; |file diff|
   17fb   9d                GHI 13              ; |rank diff|
   17fc   52                STR 2
   17fd   8d                GLO 13              ; |file diff|
   17fe   f5                SD                  ; |rank| - |file|
   17ff   c3 18 06          LBDF KS_USE_RANK
   1802   8d                GLO 13              ; max = file
   1803   c0 18 07          LBR KS_HAVE_DIST
   1806                 KS_USE_RANK:
   1806   9d                GHI 13              ; max = rank
   1807                 KS_HAVE_DIST:
   1807   52                STR 2               ; M2 = dist
   1808   f8 03             LDI 3
   180a   f7                SM                  ; D = 3 - dist
   180b   c2 18 24          LBZ KS_RET          ; dist == 3 -> no storm
   180e   ad                PLO 13              ; R13.0 = 3 - dist
   180f   fa 80             ANI $80
   1811   ca 18 24          LBNZ KS_RET         ; dist > 3 -> no storm
   1814   8d                GLO 13
   1815   fc d5             ADI LOW(STORM_PEN)
   1817   aa                PLO 10
   1818   f8 0d             LDI HIGH(STORM_PEN)
   181a   7c 00             ADCI 0
   181c   ba                PHI 10
   181d   0a                LDN 10              ; D = STORM_PEN[3-dist]
   181e   ab                PLO 11              ; R11.0 = storm penalty (R11.1 still = shield)
                            ; (v2 defense-credit path REMOVED 2026-07-13 for the staging reclaim:
                            ; DEFENSE_CREDIT was zeroed 2026-06-17, so this block computed and
                            ; subtracted a constant 0 every eval — ~70 B dead by configuration.
                            ; git-revert this commit to restore the queen-home credit machinery.)
   181f                 KS_STORM_FULL:
   181f   8b                GLO 11              ; net (or full) storm
   1820   52                STR 2
   1821   9b                GHI 11              ; shield penalty
   1822   f4                ADD                 ; total = shield + net storm
   1823   bb                PHI 11
   1824                 KS_RET:
   1824   9b                GHI 11              ; D = total penalty
   1825   d5                RETN
   1826                 KS_ZERO:
   1826   f8 00             LDI 0
   1828   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; QUEEN_MOBILITY - count empty squares the queen commands (8-direction ray walk).
                        ; The RIGHT instrument for queen activity (2026-06-17): rewards an active/safe queen
                        ; (high mobility), penalizes an idle OR self-caged queen (low mobility), and never
                        ; pays for a sac (a queen moving where it's captured has the SEARCH reject it, not
                        ; this term). Pure mobility -- no per-square attack check (too costly mid-game); the
                        ; search handles tactics. Symmetric (white adds, black subtracts) so a queen trade is
                        ; ~mobility-neutral UNLESS our queen is the less active one, in which case the term
                        ; correctly nudges us to trade it off.
                        ; In:  R7.0 = queen square (0x88; caller guarantees != $FF). Out: D = mobility 0..27.
                        ; Uses R8,R10,R11,R13. Preserves R9,R12. X=2 (mirrors KING_SAFETY).
                        ; ------------------------------------------------------------------------------
   1829                 QUEEN_MOBILITY:
   1829   e2                SEX 2
                        
   182a   68 ca 64 1d       RLDI 10, TRACE_WHERE
   182e   f8 e3             LDI $E3
   1830   5a                STR 10              ; tracer: in QUEEN_MOBILITY
   1831   f8 00             LDI 0
   1833   a8                PLO 8                   ; R8.0 = mobility = 0
   1834   68 ca 18 5e       RLDI 10, QUEEN_DIRS     ; R10 -> 8-direction delta table
   1838   f8 08             LDI 8
   183a   ad                PLO 13                  ; R13.0 = directions remaining
   183b                 QM_DIR:
   183b   4a                LDA 10                  ; D = delta, R10++
   183c   b8                PHI 8                   ; R8.1 = delta
   183d   f8 60             LDI HIGH(BOARD)
   183f   bb                PHI 11
   1840   87                GLO 7
   1841   ab                PLO 11                  ; R11 = &BOARD[queen sq]
   1842                 QM_STEP:
   1842   8b                GLO 11
   1843   52                STR 2                   ; M(2) = current ray square (low byte)
   1844   98                GHI 8                   ; D = delta
   1845   f4                ADD                     ; D = square + delta
   1846   ab                PLO 11                  ; R11.0 = next ray square
   1847   fa 88             ANI $88
   1849   ca 18 57          LBNZ QM_NEXT            ; off board -> end this ray
   184c   0b                LDN 11                  ; D = BOARD[next square]
   184d   ca 18 57          LBNZ QM_NEXT            ; occupied -> blocked, end this ray
   1850   88                GLO 8
   1851   fc 01             ADI 1
   1853   a8                PLO 8                   ; empty -> mobility++
   1854   c0 18 42          LBR QM_STEP
   1857                 QM_NEXT:
   1857   2d                DEC 13
   1858   8d                GLO 13
   1859   ca 18 3b          LBNZ QM_DIR
   185c   88                GLO 8                   ; D = mobility count
   185d   d5                RETN
   185e                 QUEEN_DIRS:
   185e   f0 10 01 ff       DB DIR_N, DIR_S, DIR_E, DIR_W, DIR_NE, DIR_NW, DIR_SE, DIR_SW
   1862   f1 ef 11 0f   
                        
                        ; ==============================================================================
                        ; End of Evaluation
                        ; (EVAL_WITH_PST/EVAL_PST_SCAN/EVAL_PST_NEXT stub family removed 2026-06-04 —
                        ;  zero call-sites; reclaimed for SEE. EVALUATE_MATERIAL kept, 1 live caller.)
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Piece-Square Tables
                        ; ==============================================================================
                        ; Positional bonuses based on piece placement
                        ; Values in centipawns (signed 8-bit: -128 to +127)
                        ;
                        ; Tables are from White's perspective (flip for Black)
                        ; Total size: 6 tables x 64 squares = 384 bytes
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; PAWN PST - Encourage central pawns and advancement
                        ; ------------------------------------------------------------------------------
                        ; Index 0-7 = Rank 1 (a1-h1), Index 56-63 = Rank 8 (a8-h8)
                        ; For White: index = rank*8 + file (rank 0 = Rank 1)
                        ; For Black: index XOR $38 flips rank (Black's Rank 8 maps to Rank 1 values)
                        ; ------------------------------------------------------------------------------
   1866                 PST_PAWN:
                            ; Rank 1 (index 0-7) - pawns never here
   1866   00 00 00 00       DB  0,  0,  0,  0,  0,  0,  0,  0
   186a   00 00 00 00   
                            ; Rank 2 (index 8-15) - starting position
   186e   05 0a 0a ec       DB  5, 10, 10,-20,-20, 10, 10,  5
   1872   ec 0a 0a 05   
                            ; Rank 3 (index 16-23)
   1876   05 fb f6 00       DB  5, -5,-10,  0,  0,-10, -5,  5
   187a   00 f6 fb 05   
                            ; Rank 4 (index 24-31) - center control
   187e   00 00 00 14       DB  0,  0,  0, 20, 20,  0,  0,  0
   1882   14 00 00 00   
                            ; Rank 5 (index 32-39)
   1886   05 05 0a 19       DB  5,  5, 10, 25, 25, 10,  5,  5
   188a   19 0a 05 05   
                            ; Rank 6 (index 40-47)
   188e   0a 0a 14 1e       DB 10, 10, 20, 30, 30, 20, 10, 10
   1892   1e 14 0a 0a   
                            ; Rank 7 (index 48-55) - about to promote!
   1896   32 32 32 32       DB 50, 50, 50, 50, 50, 50, 50, 50
   189a   32 32 32 32   
                            ; Rank 8 (index 56-63) - promotion rank
   189e   00 00 00 00       DB  0,  0,  0,  0,  0,  0,  0,  0
   18a2   00 00 00 00   
                        
                        ; ------------------------------------------------------------------------------
                        ; KNIGHT PST - Knights love the center, hate the rim
                        ; ------------------------------------------------------------------------------
   18a6                 PST_KNIGHT:
                            ; Rank 1
   18a6   ce d8 e2 e2       DB -50,-40,-30,-30,-30,-30,-40,-50
   18aa   e2 e2 d8 ce   
                            ; Rank 2
   18ae   d8 ec 00 05       DB -40,-20,  0,  5,  5,  0,-20,-40
   18b2   05 00 ec d8   
                            ; Rank 3
   18b6   e2 05 0a 0f       DB -30,  5, 10, 15, 15, 10,  5,-30
   18ba   0f 0a 05 e2   
                            ; Rank 4
   18be   e2 00 0f 14       DB -30,  0, 15, 20, 20, 15,  0,-30
   18c2   14 0f 00 e2   
                            ; Rank 5
   18c6   e2 05 0f 14       DB -30,  5, 15, 20, 20, 15,  5,-30
   18ca   14 0f 05 e2   
                            ; Rank 6
   18ce   e2 00 0a 0f       DB -30,  0, 10, 15, 15, 10,  0,-30
   18d2   0f 0a 00 e2   
                            ; Rank 7
   18d6   d8 ec 00 00       DB -40,-20,  0,  0,  0,  0,-20,-40
   18da   00 00 ec d8   
                            ; Rank 8
   18de   ce d8 e2 e2       DB -50,-40,-30,-30,-30,-30,-40,-50
   18e2   e2 e2 d8 ce   
                        
                        ; ------------------------------------------------------------------------------
                        ; BISHOP PST - Avoid corners, prefer long diagonals
                        ; ------------------------------------------------------------------------------
   18e6                 PST_BISHOP:
                            ; Rank 1 - penalize undeveloped bishops on c1/f1
   18e6   ec f6 f1 f6       DB -20,-10,-15,-10,-10,-15,-10,-20
   18ea   f6 f1 f6 ec   
                            ; Rank 2
   18ee   f6 05 00 00       DB -10,  5,  0,  0,  0,  0,  5,-10
   18f2   00 00 05 f6   
                            ; Rank 3
   18f6   f6 0a 0a 0a       DB -10, 10, 10, 10, 10, 10, 10,-10
   18fa   0a 0a 0a f6   
                            ; Rank 4
   18fe   f6 00 0a 0a       DB -10,  0, 10, 10, 10, 10,  0,-10
   1902   0a 0a 00 f6   
                            ; Rank 5
   1906   f6 05 05 0a       DB -10,  5,  5, 10, 10,  5,  5,-10
   190a   0a 05 05 f6   
                            ; Rank 6
   190e   f6 00 05 0a       DB -10,  0,  5, 10, 10,  5,  0,-10
   1912   0a 05 00 f6   
                            ; Rank 7
   1916   f6 00 00 00       DB -10,  0,  0,  0,  0,  0,  0,-10
   191a   00 00 00 f6   
                            ; Rank 8
   191e   ec f6 f6 f6       DB -20,-10,-10,-10,-10,-10,-10,-20
   1922   f6 f6 f6 ec   
                        
                        ; ------------------------------------------------------------------------------
                        ; ROOK PST - 7th rank is golden, open files later
                        ; ------------------------------------------------------------------------------
   1926                 PST_ROOK:
                            ; Rank 1 - penalize undeveloped corner rooks, prefer central
   1926   f1 00 00 05       DB -15,  0,  0,  5,  5,  0,  0,-15
   192a   05 00 00 f1   
                            ; Rank 2
   192e   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   1932   00 00 00 fb   
                            ; Rank 3
   1936   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   193a   00 00 00 fb   
                            ; Rank 4
   193e   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   1942   00 00 00 fb   
                            ; Rank 5
   1946   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   194a   00 00 00 fb   
                            ; Rank 6
   194e   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   1952   00 00 00 fb   
                            ; Rank 7 - "pig" on 7th rank
   1956   05 0a 0a 0a       DB  5, 10, 10, 10, 10, 10, 10,  5
   195a   0a 0a 0a 05   
                            ; Rank 8
   195e   00 00 00 00       DB  0,  0,  0,  0,  0,  0,  0,  0
   1962   00 00 00 00   
                        
                        ; ------------------------------------------------------------------------------
                        ; QUEEN PST - Slight preference for center, avoid early development
                        ; ------------------------------------------------------------------------------
   1966                 PST_QUEEN:
                            ; Rank 1 - starting position OK
   1966   ec f6 f6 fb       DB -20,-10,-10, -5, -5,-10,-10,-20
   196a   fb f6 f6 ec   
                            ; Rank 2
   196e   f6 00 05 00       DB -10,  0,  5,  0,  0,  0,  0,-10
   1972   00 00 00 f6   
                            ; Rank 3
   1976   f6 05 05 05       DB -10,  5,  5,  5,  5,  5,  0,-10
   197a   05 05 00 f6   
                            ; Rank 4
   197e   00 00 05 05       DB   0,  0,  5,  5,  5,  5,  0, -5
   1982   05 05 00 fb   
                            ; Rank 5
   1986   fb 00 05 05       DB  -5,  0,  5,  5,  5,  5,  0, -5
   198a   05 05 00 fb   
                            ; Rank 6
   198e   f6 00 05 05       DB -10,  0,  5,  5,  5,  5,  0,-10
   1992   05 05 00 f6   
                            ; Rank 7 - penalize edge squares in enemy territory
   1996   ec f6 00 00       DB -20,-10,  0,  0,  0,  0,-10,-20
   199a   00 00 f6 ec   
                            ; Rank 8 - heavy penalty for deep queen raids
   199e   e2 ec ec f6       DB -30,-20,-20,-10,-10,-20,-20,-30
   19a2   f6 ec ec e2   
                        
                        ; ------------------------------------------------------------------------------
                        ; KING PST (Middlegame) - Castle! Stay safe on the side
                        ; ------------------------------------------------------------------------------
   19a6                 PST_KING:
                            ; Rank 1 - castled king is safest (b1/g1 kingside, c1 queenside)
   19a6   14 3c 28 ec       DB  20, 60, 40,-20,-20, 10, 60, 20
   19aa   ec 0a 3c 14   
                            ; Rank 2 - behind pawn shelter OK
   19ae   14 14 f6 e2       DB  20, 20,-10,-30,-30,-10, 20, 20
   19b2   e2 f6 14 14   
                            ; Rank 3
   19b6   f6 ec ec ec       DB -10,-20,-20,-20,-20,-20,-20,-10
   19ba   ec ec ec f6   
                            ; Rank 4
   19be   ec e2 e2 d8       DB -20,-30,-30,-40,-40,-30,-30,-20
   19c2   d8 e2 e2 ec   
                            ; Rank 5
   19c6   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   19ca   ce d8 d8 e2   
                            ; Rank 6
   19ce   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   19d2   ce d8 d8 e2   
                            ; Rank 7
   19d6   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   19da   ce d8 d8 e2   
                            ; Rank 8
   19de   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   19e2   ce d8 d8 e2   
                        
                        ; ==============================================================================
                        ; PST Table Address Lookup
                        ; ==============================================================================
                        ; Index by piece type (1-6) to get table address
   19e6                 PST_TABLE_LO:
   19e6   00                DB 0                    ; 0 = empty (unused)
   19e7   66                DB LOW(PST_PAWN)        ; 1 = pawn
   19e8   a6                DB LOW(PST_KNIGHT)      ; 2 = knight
   19e9   e6                DB LOW(PST_BISHOP)      ; 3 = bishop
   19ea   26                DB LOW(PST_ROOK)        ; 4 = rook
   19eb   66                DB LOW(PST_QUEEN)       ; 5 = queen
   19ec   a6                DB LOW(PST_KING)        ; 6 = king
                        
   19ed                 PST_TABLE_HI:
   19ed   00                DB 0
   19ee   18                DB HIGH(PST_PAWN)
   19ef   18                DB HIGH(PST_KNIGHT)
   19f0   18                DB HIGH(PST_BISHOP)
   19f1   19                DB HIGH(PST_ROOK)
   19f2   19                DB HIGH(PST_QUEEN)
   19f3   19                DB HIGH(PST_KING)
                        
                        ; ==============================================================================
                        ; EVAL_PST - Add piece-square table bonuses to score
                        ; ==============================================================================
                        ; Input:  6 = current score (material)
                        ; Output: 6 = score + PST bonuses
                        ; Uses:   A, D, E, F
                        ;
                        ; Algorithm:
                        ;   For each piece on board:
                        ;     1. Get piece type and color
                        ;     2. Convert 0x88 square to 0-63 index
                        ;     3. For black pieces, flip the rank (mirror vertically)
                        ;     4. Look up PST value
                        ;     5. Add (white) or subtract (black) from score
                        ; ==============================================================================
   19f4                 EVAL_PST:
                            ; Ensure X=2 for all stack operations
   19f4   e2                SEX 2
                        
                            ; Save score (R9 is score accumulator, NOT R6 which is SCRT linkage!)
   19f5   89                GLO 9
   19f6   73                STXD
   19f7   99                GHI 9
   19f8   73                STXD
                        
                            ; Save R15 (used by caller for move count in quiescence search)
   19f9   8f                GLO 15
   19fa   73                STXD
   19fb   9f                GHI 15
   19fc   73                STXD
                        
                            ; Initialize PST accumulator
   19fd   f8 00             LDI 0
   19ff   b7                PHI 7
   1a00   a7                PLO 7               ; 7 = 0
                        
                            ; Point to board
   1a01   68 ca 60 00       RLDI 10, BOARD
                        
                            ; Loop counter in memory (R14 is off-limits - BIOS uses it!)
   1a05   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1a09   f8 00             LDI 0
   1a0b   58                STR 8               ; EVAL_TEMP1 = 0 (square index)
                        
   1a0c                 EVAL_PST_LOOP:
                            ; Check if valid square (load from memory)
   1a0c   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1a10   08                LDN 8               ; D = square index
   1a11   fa 88             ANI $88
   1a13   ca 1a 8a          LBNZ EVAL_PST_NEXT_SQ
                        
                            ; Load piece
   1a16   0a                LDN 10
   1a17   c2 1a 8a          LBZ EVAL_PST_NEXT_SQ ; Empty square
                        
                            ; Save piece
   1a1a   af                PLO 15               ; F.0 = piece
                        
                            ; Get piece type
   1a1b   fa 07             ANI PIECE_MASK
   1a1d   ad                PLO 13               ; D.0 = piece type (1-6)
                        
                            ; Get PST table address for this piece type
   1a1e   68 cb 19 e6       RLDI 11, PST_TABLE_LO
   1a22   8d                GLO 13               ; Piece type
   1a23   52                STR 2
   1a24   8b                GLO 11
   1a25   f4                ADD
   1a26   ab                PLO 11
   1a27   9b                GHI 11
   1a28   7c 00             ADCI 0
   1a2a   bb                PHI 11               ; Propagate carry across page boundary
   1a2b   0b                LDN 11               ; D = low byte of PST address
   1a2c   bd                PHI 13               ; Save in D.1 temporarily
                        
   1a2d   68 cb 19 ed       RLDI 11, PST_TABLE_HI
   1a31   8d                GLO 13               ; Piece type (still in D.0? No, need to reload)
   1a32   8f                GLO 15               ; Get piece back
   1a33   fa 07             ANI PIECE_MASK
   1a35   52                STR 2
   1a36   8b                GLO 11
   1a37   f4                ADD
   1a38   ab                PLO 11
   1a39   0b                LDN 11               ; High byte of PST address
   1a3a   bb                PHI 11
   1a3b   9d                GHI 13               ; Low byte (saved earlier)
   1a3c   ab                PLO 11               ; B = PST table base for this piece
                        
                            ; Convert 0x88 square to 0-63 index
                            ; Index = (rank * 8) + file
                            ; For 0x88: rank = sq >> 4, file = sq & 7
                            ; Load square from memory (R14 is off-limits!)
   1a3d   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1a41   08                LDN 8               ; D = square (0x88 format)
   1a42   73                STXD                ; Save square on stack for reuse
   1a43   fa 07             ANI $07             ; File (0-7)
   1a45   ad                PLO 13               ; D.0 = file
                        
   1a46   60                IRX
   1a47   f0                LDX                 ; D = square again
   1a48   fa 70             ANI $70             ; Rank * 16
   1a4a   f6                SHR                 ; Rank * 8
   1a4b   52                STR 2
   1a4c   8d                GLO 13
   1a4d   f4                ADD                 ; Index = rank*8 + file
   1a4e   ad                PLO 13               ; D.0 = 0-63 index
                        
                            ; For black pieces, flip the index (mirror board)
                            ; New index = 63 - index = (7-rank)*8 + (7-file)
                            ; Simpler: XOR with $38 flips rank (keeps file same within rank)
   1a4f   8f                GLO 15               ; Get piece
   1a50   fa 08             ANI COLOR_MASK
   1a52   c2 1a 59          LBZ EVAL_PST_WHITE   ; long branch: insertion shifted page boundary
                        
                            ; Black piece - flip rank
   1a55   8d                GLO 13
   1a56   fb 38             XRI $38             ; Flip rank bits
   1a58   ad                PLO 13
                        
   1a59                 EVAL_PST_WHITE:
                            ; Look up PST value
   1a59   8d                GLO 13               ; Index
   1a5a   52                STR 2
   1a5b   8b                GLO 11
   1a5c   f4                ADD
   1a5d   ab                PLO 11
   1a5e   9b                GHI 11
   1a5f   7c 00             ADCI 0
   1a61   bb                PHI 11
   1a62   0b                LDN 11               ; D = PST value (signed 8-bit)
                        
                            ; Extend sign to 16-bit
   1a63   ad                PLO 13               ; D.0 = PST value
   1a64   fa 80             ANI $80             ; Check sign bit
   1a66   c2 1a 6f          LBZ EVAL_PST_POSITIVE
   1a69   f8 ff             LDI $FF
   1a6b   bd                PHI 13               ; D = sign-extended negative
   1a6c   c0 1a 72          LBR EVAL_PST_ADD
                        
   1a6f                 EVAL_PST_POSITIVE:
   1a6f   f8 00             LDI 0
   1a71   bd                PHI 13               ; D = sign-extended positive
                        
   1a72                 EVAL_PST_ADD:
                            ; Add or subtract based on color
   1a72   8f                GLO 15               ; Get piece
   1a73   fa 08             ANI COLOR_MASK
   1a75   c2 1a 80          LBZ EVAL_PST_ADD_WHITE
                        
                            ; Black - subtract from accumulator (7 = 7 - D)
                            ; Actually: negate D, then add
   1a78   8d                GLO 13
   1a79   fd 00             SDI 0               ; D.0 = -D.0
   1a7b   ad                PLO 13
   1a7c   9d                GHI 13
   1a7d   7d 00             SDBI 0              ; D.1 = -D.1 - borrow
   1a7f   bd                PHI 13
                        
   1a80                 EVAL_PST_ADD_WHITE:
                            ; Add D to accumulator (7)
   1a80   8d                GLO 13
   1a81   52                STR 2
   1a82   87                GLO 7
   1a83   f4                ADD
   1a84   a7                PLO 7
                        
   1a85   9d                GHI 13
   1a86   52                STR 2
   1a87   97                GHI 7
   1a88   74                ADC
   1a89   b7                PHI 7
                        
   1a8a                 EVAL_PST_NEXT_SQ:
   1a8a   1a                INC 10               ; Next board position
                            ; Increment square index in memory (R14 is off-limits!)
   1a8b   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1a8f   08                LDN 8               ; D = square index
   1a90   fc 01             ADI 1               ; Increment
   1a92   58                STR 8               ; Store back
   1a93   fb 80             XRI $80             ; Done when index = 128
   1a95   ca 1a 0c          LBNZ EVAL_PST_LOOP
                        
                            ; Add PST accumulator to score
                            ; Restore R15 first (LIFO - it was pushed last)
   1a98   60                IRX
   1a99   72                LDXA
   1a9a   bf                PHI 15
   1a9b   f0                LDX
   1a9c   af                PLO 15
                        
                            ; Now restore material score (R9)
   1a9d   60                IRX
   1a9e   72                LDXA
   1a9f   b9                PHI 9
   1aa0   f0                LDX
   1aa1   a9                PLO 9
                        
                            ; R9 = R9 + R7
   1aa2   87                GLO 7
   1aa3   52                STR 2
   1aa4   89                GLO 9
   1aa5   f4                ADD
   1aa6   a9                PLO 9
                        
   1aa7   97                GHI 7
   1aa8   52                STR 2
   1aa9   99                GHI 9
   1aaa   74                ADC
   1aab   b9                PHI 9
                        
   1aac   d5                RETN
                        
                        ; ==============================================================================
                        ; End of Piece-Square Tables
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Endgame Heuristics
                        ; ==============================================================================
                        ; Special evaluation bonuses for endgame positions:
                        ; 1. King centralization when material is low
                        ; 2. Drive enemy king to edge/corner in winning positions
                        ; 3. Passed pawn bonus
                        ; ==============================================================================
                        
                        ; Endgame threshold (in centipawns of total material)
                        ; Below this, we're in the endgame
                        ; Roughly: 2 rooks + 2 minor = 2*500 + 2*325 = 1650
   0068                 ENDGAME_THRESHOLD_LO    EQU $68     ; 1640 = $0668
   0006                 ENDGAME_THRESHOLD_HI    EQU $06
                        
                        ; King centralization table (bonus for king being in center during endgame)
                        ; Higher values in center, lower on edges
   1aad                 KING_CENTER_TABLE:
                            ; Rank 8
   1aad   e2 ec f6 00       DB -30,-20,-10,  0,  0,-10,-20,-30
   1ab1   00 f6 ec e2   
                            ; Rank 7
   1ab5   ec f6 00 0a       DB -20,-10,  0, 10, 10,  0,-10,-20
   1ab9   0a 00 f6 ec   
                            ; Rank 6
   1abd   f6 00 0a 14       DB -10,  0, 10, 20, 20, 10,  0,-10
   1ac1   14 0a 00 f6   
                            ; Rank 5
   1ac5   00 0a 14 1e       DB   0, 10, 20, 30, 30, 20, 10,  0
   1ac9   1e 14 0a 00   
                            ; Rank 4
   1acd   00 0a 14 1e       DB   0, 10, 20, 30, 30, 20, 10,  0
   1ad1   1e 14 0a 00   
                            ; Rank 3
   1ad5   f6 00 0a 14       DB -10,  0, 10, 20, 20, 10,  0,-10
   1ad9   14 0a 00 f6   
                            ; Rank 2
   1add   ec f6 00 0a       DB -20,-10,  0, 10, 10,  0,-10,-20
   1ae1   0a 00 f6 ec   
                            ; Rank 1
   1ae5   e2 ec f6 00       DB -30,-20,-10,  0,  0,-10,-20,-30
   1ae9   00 f6 ec e2   
                        
                        ; King to edge table (bonus for enemy king on edge/corner — drive-to-mate)
                        ; Use this when we're winning to drive enemy king to corner.
                        ; Higher values at edges/corners, lower in center.
                        ; Retuned 2026-06-15: steepened ~1.5x toward corners (proven mate-shuffle:
                        ; R+Q+5P vs lone K dawdled ~22 moves, eval flat — the edge gradient was too
                        ; shallow to actively squeeze the enemy king to a corner). Max 90, SHL'd to
                        ; 180cp at the corner (still <256, no byte overflow). Zero new bytes.
   1aed                 KING_EDGE_TABLE:
                            ; Rank 8
   1aed   5a 4b 3c 2d       DB  90, 75, 60, 45, 45, 60, 75, 90
   1af1   2d 3c 4b 5a   
                            ; Rank 7
   1af5   4b 3c 2d 1e       DB  75, 60, 45, 30, 30, 45, 60, 75
   1af9   1e 2d 3c 4b   
                            ; Rank 6
   1afd   3c 2d 1e 0f       DB  60, 45, 30, 15, 15, 30, 45, 60
   1b01   0f 1e 2d 3c   
                            ; Rank 5
   1b05   2d 1e 0f 00       DB  45, 30, 15,  0,  0, 15, 30, 45
   1b09   00 0f 1e 2d   
                            ; Rank 4
   1b0d   2d 1e 0f 00       DB  45, 30, 15,  0,  0, 15, 30, 45
   1b11   00 0f 1e 2d   
                            ; Rank 3
   1b15   3c 2d 1e 0f       DB  60, 45, 30, 15, 15, 30, 45, 60
   1b19   0f 1e 2d 3c   
                            ; Rank 2
   1b1d   4b 3c 2d 1e       DB  75, 60, 45, 30, 30, 45, 60, 75
   1b21   1e 2d 3c 4b   
                            ; Rank 1
   1b25   5a 4b 3c 2d       DB  90, 75, 60, 45, 45, 60, 75, 90
   1b29   2d 3c 4b 5a   
                        
                        ; ------------------------------------------------------------------------------
                        ; KING_PROX_BONUS - friendly-king-to-enemy-king proximity, indexed by Chebyshev
                        ; distance (0-7). The missing mating ingredient: edging the enemy king alone
                        ; never mates — the winning side's king must march up to support. Small-distance
                        ; = high bonus gives the shallow search a downhill gradient to walk the king in.
                        ; Kings can never be adjacent (dist<2 illegal), so 2 = closest = max pull.
                        ; ------------------------------------------------------------------------------
                        ; Retuned 2026-06-15: ~4x stronger (was 0,0,40,32,24,16,8,0 = 8cp/step).
                        ; PROVEN bottleneck: in the R+Q+5P vs K mate the winning king refused to march
                        ; (g1<->h1<->f1 shuffle for ~11 moves) because closing toward the enemy king
                        ; netted only +8cp — tied with shuffling, so the engine wouldn't commit. The
                        ; mate appeared the instant the king finally reached the enemy. Now ~30-35cp/
                        ; step so each marching step clearly beats a wait move. Max 150 < passer/runner
                        ; bonuses (250-600) so this never pulls the king off a passer in a K+P race.
   1b2d                 KING_PROX_BONUS:
   1b2d   00 00 96 73       DB   0,  0,150,115, 80, 50, 25,  0   ; dist 0..7 (~30-35cp/step march)
   1b31   50 32 19 00   
                        
                        ; ==============================================================================
                        ; EVAL_ENDGAME - Add endgame-specific bonuses
                        ; ==============================================================================
                        ; Input:  6 = current score (material + PST)
                        ;         7 = total material on board (calculated externally, or we calculate)
                        ; Output: 6 = score with endgame bonuses
                        ; Uses:   A, B, D, E, F
                        ;
                        ; Logic:
                        ;   1. Check if we're in endgame (material below threshold)
                        ;   2. If endgame:
                        ;      - Add king centralization bonus for friendly king
                        ;      - If winning significantly, add enemy king edge bonus
                        ; ==============================================================================
                        ; (EVAL_ENDGAME + CALC_TOTAL_MATERIAL REMOVED 2026-07-15 — symmetry audit)
                        ; Both had ZERO call sites (the 'removed king-drive'); the live endgame king
                        ; logic is in evaluate.asm's pc<12 block. The dead code ALSO contained
                        ; side-to-move-relative sign bugs (mover's centralization credited to white;
                        ; winning gate read raw R9) — deleted rather than fixed. git-revert restores.
                        ; KING_CENTER_TABLE / KING_EDGE_TABLE below remain LIVE (evaluate.asm uses them).
                        ; ==============================================================================
                        
                        
                        ; ==============================================================================
                        ; End of Endgame Heuristics
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Negamax Search with Alpha-Beta Pruning
                        ; ==============================================================================
                        ; Core search algorithm
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; Register Usage During Search
                        ; ------------------------------------------------------------------------------
                        ; 0:  Reserved for interrupts/DMA
                        ; 1:  Reserved for interrupt PC
                        ; 2:  Stack pointer (X register) - CRITICAL
                        ; 3:  Program counter (P register) - CRITICAL
                        ; 4:  SCALL routine pointer (BIOS SCRT)
                        ; 5:  SRET routine pointer (BIOS SCRT) - DO NOT USE FOR DATA!
                        ; 6:  SCRT linkage register - DO NOT USE FOR DATA! (corrupted by every CALL)
                        ; 7:  Temp for alpha/beta operations (beta loaded from memory when needed)
                        ; 8:  Best score accumulator
                        ; 9:  Move list pointer / score return value
                        ; A:  Board state pointer (set before search)
                        ; B:  Current move being evaluated
                        ; C:  Color/side to move (0 for white, 8 for black - matches COLOR_MASK)
                        ; D:  Temp/scratch register 1
                        ; E:  Temp/scratch register 2 (move counter)
                        ; F:  Temp/scratch register 3
                        ; NOTE: Alpha/beta stored in memory at ALPHA_HI/LO, BETA_HI/LO (big-endian)
                        ; NOTE: Search depth stored in memory at SEARCH_DEPTH (not in a register)
                        ; ------------------------------------------------------------------------------
                        
                        ; Memory locations for search state - defined in board.asm:
                        ;   BEST_MOVE, NODES_SEARCHED, SEARCH_DEPTH, QS_*, EVAL_SQ_INDEX, KILLER_MOVES
                        ;   ALPHA_HI/LO, BETA_HI/LO, SCORE_HI/LO (big-endian: high byte at lower address)
                        ; All engine variables consolidated at $6400+ region
                        
                        ; ------------------------------------------------------------------------------
                        ; NEGAMAX - Main recursive search function
                        ; ------------------------------------------------------------------------------
                        ; Input:  SEARCH_DEPTH = depth remaining in memory (0 = leaf node, evaluate)
                        ;         ALPHA_HI/LO = alpha (lower bound) in memory (big-endian)
                        ;         BETA_HI/LO = beta (upper bound) in memory (big-endian)
                        ;         C = color (0 for white, 8 for black - matches COLOR_MASK)
                        ;         A = board state pointer
                        ; Output: R9 = score from current position
                        ;         BEST_MOVE = best move found (if at root)
                        ; Uses:   All registers 7-F, stack
                        ; NOTE:   R6 is SCRT linkage register - never used for data!
                        ; ------------------------------------------------------------------------------
   1b35                 NEGAMAX:
                            ; Ensure X=2 for stack operations
   1b35   e2                SEX 2
                        
                            ; Stack overflow detection (added 2026-05-12). MOVE_LIST at $7800-$7A7F
                            ; sits directly below stack guard $7B00. If recursion pushes R2 below
                            ; $7B00, MOVE_LIST gets silently corrupted — the suspected cause of the
                            ; 2026-05-11 g8h7 illegal-move output. Flag is checked + emitted as
                            ; UCI info string at each IDS iteration boundary.
   1b36   d4 00 87          CALL CHECK_STACK_OVERFLOW
                        
                            ; -----------------------------------------------
                            ; PLY LIMIT CHECK: Prevent array overflow
                            ; -----------------------------------------------
                            ; If CURRENT_PLY >= MAX_PLY (8), return static eval
   1b39   68 ca 64 48       RLDI 10, CURRENT_PLY
   1b3d   0a                LDN 10              ; D = current ply
   1b3e   ff 08             SMI 8               ; D = ply - MAX_PLY
   1b40   cb 1b 55          LBNF NEGAMAX_PLY_OK ; ply < 8, continue
                        
                            ; Ply limit reached - return static evaluation
   1b43   d4 0e 92          CALL EVALUATE
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   1b46   8c                GLO 12
   1b47   fa 08             ANI $08
   1b49   c2 1b 54          LBZ NEGAMAX_PLY_RET
   1b4c   89                GLO 9               ; low byte
   1b4d   fd 00             SDI 0               ; negate low
   1b4f   a9                PLO 9
   1b50   99                GHI 9               ; high byte
   1b51   7d 00             SDBI 0              ; negate high with borrow
   1b53   b9                PHI 9
   1b54                 NEGAMAX_PLY_RET:
   1b54   d5                RETN
                        
   1b55                 NEGAMAX_PLY_OK:
                            ; Save context to ply-indexed state array (no stack manipulation!)
   1b55   d4 00 18          CALL SAVE_PLY_STATE
                        
   1b58   68 ca 64 1d       RLDI 10, TRACE_WHERE
   1b5c   f8 a1             LDI $A1
   1b5e   5a                STR 10              ; tracer: in NEGAMAX node
                        
                            ; -- TT node flag: default ALPHA (upper bound) --
   1b5f   68 ca 64 48       RLDI 10, CURRENT_PLY
   1b63   0a                LDN 10
   1b64   fc d2             ADI LOW(NODE_TT_FLAGS)
   1b66   aa                PLO 10
   1b67   f8 64             LDI HIGH(NODE_TT_FLAGS)
   1b69   ba                PHI 10
   1b6a   f8 02             LDI TT_FLAG_ALPHA
   1b6c   5a                STR 10
                        
                            ; Increment node counter (for statistics)
   1b6d   d4 29 db          CALL INC_NODE_COUNT
                        
                            ; -----------------------------------------------
                            ; RTC TIME TRACKING: Always update elapsed time
                            ; -----------------------------------------------
                            ; Read RTC on every node so elapsed time is accurate.
                            ; Only check abort flag and enforce budget during d3+.
                        
                            ; --- RTC elapsed time check ---
                            ; Read current seconds from DS12887 (binary mode)
   1b70   f8 80             LDI $80                     ; Seconds register
   1b72   52                STR 2
   1b73   62                OUT 2                       ; Select register, R2++
   1b74   22                DEC 2                       ; Restore R2
   1b75   6b                INP 3                       ; D = current_secs, M(R2) = current_secs
   1b76   a7                PLO 7                       ; R7.0 = current_secs (R7 saved by SAVE_PLY_STATE)
                        
                            ; Load prev_secs, save for delta computation
   1b77   68 cd 64 ca       RLDI 13, SEARCH_PREV_SECS
   1b7b   0d                LDN 13                      ; D = prev_secs
   1b7c   b7                PHI 7                       ; R7.1 = prev_secs
                        
                            ; Update prev = current
   1b7d   87                GLO 7                       ; D = current_secs
   1b7e   5d                STR 13                      ; SEARCH_PREV_SECS = current_secs
                        
                            ; Compute delta = current - prev
   1b7f   97                GHI 7                       ; D = prev_secs
   1b80   52                STR 2                       ; M(R2) = prev_secs
   1b81   87                GLO 7                       ; D = current_secs
   1b82   f7                SM                          ; D = current - prev (SM = D - M(R(X)))
   1b83   c3 1b 88          LBDF RTC_DELTA_POS          ; DF=1: no borrow, delta >= 0
   1b86   fc 3c             ADI 60                      ; Wrapped past 59→0: add 60
   1b88                 RTC_DELTA_POS:
                            ; D = delta seconds (typically 0 or 1)
                        
                            ; Add delta to elapsed counter
   1b88   52                STR 2                       ; M(R2) = delta
   1b89   68 cd 64 cb       RLDI 13, SEARCH_ELAPSED
   1b8d   0d                LDN 13                      ; D = elapsed so far
   1b8e   f4                ADD                         ; D = elapsed + delta
   1b8f   cb 1b 94          LBNF RTC_NO_SAT             ; DF=0: no carry, fits in 8 bits
   1b92   f8 ff             LDI 255                     ; Saturate at 255
   1b94                 RTC_NO_SAT:
   1b94   5d                STR 13                      ; SEARCH_ELAPSED = updated value
                        
                            ; -----------------------------------------------
                            ; ABORT CHECK: Only enforce budget during d3+
                            ; -----------------------------------------------
                            ; Depth 1-2 always complete; only abort d3+ if over budget
   1b95   68 cd 64 c5       RLDI 13, CURRENT_MAX_DEPTH
   1b99   0d                LDN 13                      ; D = current iteration depth
   1b9a   ff 03             SMI 3
   1b9c   cb 1b c0          LBNF NEGAMAX_BUDGET_OK      ; depth < 3, skip abort check
                        
                            ; --- Abort flag check (propagate up recursion during d3) ---
   1b9f   68 cd 64 c4       RLDI 13, SEARCH_ABORTED
   1ba3   0d                LDN 13
   1ba4   ca 1b b8          LBNZ NEGAMAX_ABORT_RETURN   ; Already aborted, bail out
                        
                            ; Check: elapsed >= 180 seconds?
   1ba7   68 cd 64 cb       RLDI 13, SEARCH_ELAPSED
   1bab   0d                LDN 13                      ; Reload elapsed (clobbered above)
   1bac   ff b4             SMI 180                     ; D = elapsed - 180 (budget bumped 2026-04-23)
   1bae   cb 1b c0          LBNF NEGAMAX_BUDGET_OK      ; DF=0: elapsed < 180, continue
                        
                            ; Time exceeded — set abort flag
   1bb1   68 cd 64 c4       RLDI 13, SEARCH_ABORTED
   1bb5   f8 01             LDI 1
   1bb7   5d                STR 13
                        
   1bb8                 NEGAMAX_ABORT_RETURN:
                            ; Restore ply state and return dummy score
   1bb8   d4 00 54          CALL RESTORE_PLY_STATE
   1bbb   f8 00             LDI 0
   1bbd   b9                PHI 9
   1bbe   a9                PLO 9                       ; R9 = 0 (score irrelevant, will be discarded)
   1bbf   d5                RETN
                        
   1bc0                 NEGAMAX_BUDGET_OK:
                        
                            ; -----------------------------------------------
                            ; FIFTY-MOVE RULE: Check for draw
                            ; -----------------------------------------------
                            ; If halfmove clock >= 100, position is a draw
   1bc0   68 cd 60 83       RLDI 13, GAME_STATE + STATE_HALFMOVE
   1bc4   0d                LDN 13               ; D = halfmove clock
   1bc5   ff 64             SMI 100             ; D = halfmove - 100
   1bc7   cb 1b e3          LBNF NEGAMAX_NOT_FIFTY ; If < 100, continue normally (long branch - crosses page)
                        
                            ; Draw return — shared by fifty-move rule and repetition detection
   1bca                 RETURN_DRAW:
   1bca   f8 00             LDI 0
   1bcc   b9                PHI 9
   1bcd   a9                PLO 9               ; R9 = 0 (draw score) - R6 is SCRT linkage!
                            ; Save score to SCORE_HI/LO BEFORE restore (RESTORE clobbers R9!)
   1bce   68 ca 64 46       RLDI 10, SCORE_HI
   1bd2   99                GHI 9
   1bd3   5a                STR 10
   1bd4   1a                INC 10
   1bd5   89                GLO 9
   1bd6   5a                STR 10              ; SCORE_HI/LO = 0 (draw)
   1bd7   d4 00 54          CALL RESTORE_PLY_STATE
                            ; Reload R9 from SCORE_HI/LO AFTER restore
   1bda   68 ca 64 46       RLDI 10, SCORE_HI
   1bde   4a                LDA 10
   1bdf   b9                PHI 9
   1be0   0a                LDN 10
   1be1   a9                PLO 9               ; R9 = draw score (0)
   1be2   d5                RETN
                        
   1be3                 NEGAMAX_NOT_FIFTY:
                            ; -----------------------------------------------
                            ; REPETITION DETECTION: Check game position history
                            ; -----------------------------------------------
                            ; Skip at root (ply 0) — root position is the last HASH_HIST
                            ; entry and would always match itself.
   1be3   68 ca 64 48       RLDI 10, CURRENT_PLY
   1be7   0a                LDN 10
   1be8   c2 1c 21          LBZ REP_NO_MATCH
                        
                            ; Skip if halfmove clock < 4 — after pawn moves or captures,
                            ; repetition is impossible. Scanning the full hash history with
                            ; 16-bit hashes causes false collisions (~5% with 80+ entries),
                            ; which makes the engine return draw (0) for promotion lines.
   1beb   68 ca 60 83       RLDI 10, GAME_STATE + STATE_HALFMOVE
   1bef   0a                LDN 10              ; D = halfmove clock
   1bf0   ff 04             SMI 4
   1bf2   cb 1c 21          LBNF REP_NO_MATCH   ; halfmove < 4, can't be repetition
                        
                            ; Load current hash into R8
   1bf5   68 ca 64 b9       RLDI 10, HASH_HI
   1bf9   4a                LDA 10              ; D = HASH_HI
   1bfa   b8                PHI 8
   1bfb   0a                LDN 10              ; D = HASH_LO
   1bfc   a8                PLO 8               ; R8 = current position hash
                        
                            ; Load history count
   1bfd   68 cd 64 eb       RLDI 13, HASH_HIST_COUNT
   1c01   0d                LDN 13
   1c02   c2 1c 21          LBZ REP_NO_MATCH    ; Empty history
   1c05   ab                PLO 11              ; R11.0 = loop counter
                        
   1c06   68 c9 65 00       RLDI 9, HASH_HIST   ; R9 → first entry
                        
   1c0a                 REP_CHECK_LOOP:
                            ; Compare hi byte
   1c0a   49                LDA 9               ; D = hist[i].hi, R9→lo byte
   1c0b   52                STR 2               ; temp at M(R2)
   1c0c   98                GHI 8               ; D = current.hi
   1c0d   f3                XOR                 ; compare
   1c0e   ca 1c 1b          LBNZ REP_SKIP_LO   ; Hi mismatch
                        
                            ; Hi matched — compare lo byte
   1c11   49                LDA 9               ; D = hist[i].lo, R9→next entry
   1c12   52                STR 2
   1c13   88                GLO 8               ; D = current.lo
   1c14   f3                XOR
   1c15   c2 1b ca          LBZ RETURN_DRAW     ; MATCH! Return draw (shared code)
   1c18   c0 1c 1c          LBR REP_DEC         ; Mismatch, R9 already past both bytes
                        
   1c1b                 REP_SKIP_LO:
   1c1b   19                INC 9               ; Skip lo byte
                        
   1c1c                 REP_DEC:
   1c1c   2b                DEC 11
   1c1d   8b                GLO 11
   1c1e   ca 1c 0a          LBNZ REP_CHECK_LOOP
                        
   1c21                 REP_NO_MATCH:
                            ; -----------------------------------------------
                            ; Snapshot CHECK_EXT_FLAG → NODE_IN_CHECK[CURRENT_PLY]
                            ; -----------------------------------------------
                            ; CHECK_EXT_FLAG was just set by parent's move-loop iteration to
                            ; indicate "did my (parent's) move give check to opponent (us)". We
                            ; capture it here at NEGAMAX entry — before our own move loop starts
                            ; overwriting it — so downstream pruning code (LMP especially) can
                            ; tell whether THIS node is in check.
                            ;
                            ; Cost: ~10 instructions per node call. Negligible relative to per-
                            ; node search cost (~30K instructions median).
   1c21   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   1c25   0a                LDN 10              ; D = current check flag (from parent)
   1c26   ad                PLO 13              ; R13.0 = check flag (temp)
   1c27   68 ca 64 48       RLDI 10, CURRENT_PLY
   1c2b   0a                LDN 10              ; D = ply
   1c2c   fc 42             ADI LOW(NODE_IN_CHECK)
   1c2e   aa                PLO 10
   1c2f   f8 67             LDI HIGH(NODE_IN_CHECK)
   1c31   7c 00             ADCI 0
   1c33   ba                PHI 10              ; R10 = NODE_IN_CHECK + ply
   1c34   8d                GLO 13              ; D = saved check flag
   1c35   5a                STR 10              ; NODE_IN_CHECK[ply] = check flag
                        
                            ; -----------------------------------------------
                            ; Transposition Table Probe
                            ; -----------------------------------------------
                            ; Hash is updated incrementally in MAKE/UNMAKE_MOVE,
                            ; so TT works correctly at all nodes.
                            ;
                            ; Skip TT at root (ply 0): TT_STORE saves the root's BEST_MOVE
                            ; globally, so non-root TT entries have stale/sentinel move data.
                            ; Root must always search fully to guarantee a valid BEST_MOVE.
   1c36   68 ca 64 48       RLDI 10, CURRENT_PLY
   1c3a   0a                LDN 10              ; D = current ply
   1c3b   c2 1c 7c          LBZ NEGAMAX_TT_MISS ; Root: always search fully
                        
                            ; Load current search depth for comparison
   1c3e   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   1c42   0d                LDN 13              ; D = depth low byte (SEARCH_DEPTH+1 = low byte)
   1c43   d4 56 bf          CALL TT_PROBE       ; D = required depth, returns D = 1 if hit
   1c46   c2 1c 7c          LBZ NEGAMAX_TT_MISS ; No hit, continue with search
                        
                            ; TT hit - check if it's usable (EXACT bound)
   1c49   68 ca 64 bf       RLDI 10, TT_FLAG
   1c4d   0a                LDN 10              ; D = TT flag
   1c4e   fb 01             XRI TT_FLAG_EXACT
   1c50   ca 1c 7c          LBNZ NEGAMAX_TT_MISS    ; Not exact, can't use directly (for now)
                        
                            ; EXACT hit at non-root node - use the stored score
                            ; (Root is excluded above, so no BEST_MOVE copy needed)
                        
                            ; Get the score and save to SCORE_HI/LO BEFORE restore
                            ; (RESTORE_PLY_STATE clobbers R9!)
                            ; CRITICAL: Reject mate scores from TT to prevent hash collision
                            ; causing stalemate/checkmate misidentification (16-bit hash limit)
   1c53   68 ca 64 bc       RLDI 10, TT_SCORE_HI
   1c57   0a                LDN 10              ; D = score_hi
   1c58   fb 7f             XRI $7F
   1c5a   c2 1c 7c          LBZ NEGAMAX_TT_MISS ; Positive mate score → re-search to verify
   1c5d   0a                LDN 10              ; D = score_hi (reload)
   1c5e   fb 80             XRI $80
   1c60   c2 1c 7c          LBZ NEGAMAX_TT_MISS ; Negative mate score → re-search to verify
   1c63   4a                LDA 10              ; D = score_hi, R10 → score_lo
   1c64   b9                PHI 9
   1c65   0a                LDN 10              ; score_lo
   1c66   a9                PLO 9               ; R9 = stored score
                            ; Save to SCORE_HI/LO so it survives RESTORE
   1c67   68 ca 64 46       RLDI 10, SCORE_HI
   1c6b   99                GHI 9
   1c6c   5a                STR 10
   1c6d   1a                INC 10
   1c6e   89                GLO 9
   1c6f   5a                STR 10              ; SCORE_HI/LO = TT score
   1c70   d4 00 54          CALL RESTORE_PLY_STATE
                            ; Reload R9 from SCORE_HI/LO AFTER restore
   1c73   68 ca 64 46       RLDI 10, SCORE_HI
   1c77   4a                LDA 10
   1c78   b9                PHI 9
   1c79   0a                LDN 10
   1c7a   a9                PLO 9               ; R9 = TT score (preserved through restore)
   1c7b   d5                RETN                ; Return TT score
                        
   1c7c                 NEGAMAX_TT_MISS:
                            ; -----------------------------------------------
                            ; Check if we're at a leaf node (depth == 0)
                            ; -----------------------------------------------
                            ; Load depth from memory (SEARCH_DEPTH)
   1c7c   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   1c80   4d                LDA 13              ; D = depth high byte
   1c81   ca 1c 8b          LBNZ NEGAMAX_CONTINUE
   1c84   0d                LDN 13              ; D = depth low byte
   1c85   ca 1c 8b          LBNZ NEGAMAX_CONTINUE
                            ; Depth is 0, evaluate leaf node
   1c88   c0 24 f2          LBR NEGAMAX_LEAF
                        
   1c8b                 NEGAMAX_CONTINUE:
                            ; ===============================================
                            ; NULL MOVE PRUNING CHECK
                            ; ===============================================
                            ; If position is so strong that passing still beats beta, prune.
                            ; Conditions: depth >= 3, not in check, NULL_MOVE_OK, ply > 0
                        
                            ; Condition 1: depth >= 3?
   1c8b   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   1c8f   0a                LDN 10              ; D = depth low byte
   1c90   ff 03             SMI 3               ; D = depth - 3
   1c92   cb 1d a9          LBNF NMP_SKIP       ; depth < 3, skip null move
                        
                            ; Condition 2: ply > 0? (don't do at root)
   1c95   68 ca 64 48       RLDI 10, CURRENT_PLY
   1c99   0a                LDN 10              ; D = current ply
   1c9a   c2 1d a9          LBZ NMP_SKIP        ; ply == 0, skip null move
                        
                            ; Condition 3: NULL_MOVE_OK?
   1c9d   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   1ca1   0a                LDN 10
   1ca2   c2 1d a9          LBZ NMP_SKIP        ; null move not allowed (already did one)
                        
                            ; Condition 4: NOT in check? (already verified above for non-CE path)
   1ca5   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if in check, 0 if safe
   1ca8   ca 1d a9          LBNZ NMP_SKIP       ; in check, can't pass
                        
                            ; --- All conditions met, try null move ---
                        
                            ; Disable null move for child (prevent consecutive)
   1cab   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   1caf   f8 00             LDI 0
   1cb1   5a                STR 10              ; NULL_MOVE_OK = 0
                        
                            ; Save depth to stack
   1cb2   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   1cb6   4d                LDA 13              ; depth_hi
   1cb7   73                STXD
   1cb8   0d                LDN 13              ; depth_lo
   1cb9   73                STXD
                        
                            ; Save alpha/beta to stack
   1cba   68 cd 64 42       RLDI 13, ALPHA_HI
   1cbe   4d                LDA 13              ; alpha_hi
   1cbf   73                STXD
   1cc0   0d                LDN 13              ; alpha_lo
   1cc1   73                STXD
   1cc2   68 cd 64 44       RLDI 13, BETA_HI
   1cc6   4d                LDA 13              ; beta_hi
   1cc7   73                STXD
   1cc8   0d                LDN 13              ; beta_lo
   1cc9   73                STXD
                        
                            ; Make null move (toggle side, update hash, clear EP)
   1cca   d4 0d 92          CALL NULL_MAKE_MOVE
                        
                            ; Set child depth = depth - 3 (R=2 reduction + normal -1)
                            ; Peek depth from stack (at R2+5, R2+6)
   1ccd   82                GLO 2
   1cce   fc 06             ADI 6
   1cd0   aa                PLO 10
   1cd1   92                GHI 2
   1cd2   7c 00             ADCI 0
   1cd4   ba                PHI 10              ; R10 = &depth_hi on stack
   1cd5   0a                LDN 10              ; depth_hi
   1cd6   b7                PHI 7               ; R7.1 = depth_hi
   1cd7   2a                DEC 10
   1cd8   0a                LDN 10              ; depth_lo
   1cd9   ff 03             SMI 3               ; depth_lo - 3
   1cdb   a7                PLO 7
   1cdc   97                GHI 7
   1cdd   7f 00             SMBI 0              ; depth_hi - borrow
   1cdf   b7                PHI 7               ; R7 = depth - 3
                        
                            ; Store child depth to memory
   1ce0   68 ca 64 16       RLDI 10, SEARCH_DEPTH
   1ce4   97                GHI 7
   1ce5   5a                STR 10
   1ce6   1a                INC 10
   1ce7   87                GLO 7
   1ce8   5a                STR 10              ; SEARCH_DEPTH = depth - 3
                        
                            ; Set child alpha = -beta (zero window)
                            ; Peek beta from stack (at R2+1, R2+2)
   1ce9   82                GLO 2
   1cea   fc 02             ADI 2
   1cec   aa                PLO 10
   1ced   92                GHI 2
   1cee   7c 00             ADCI 0
   1cf0   ba                PHI 10              ; R10 = &beta_hi on stack
   1cf1   0a                LDN 10              ; beta_hi
   1cf2   b7                PHI 7
   1cf3   2a                DEC 10
   1cf4   0a                LDN 10              ; beta_lo
   1cf5   a7                PLO 7               ; R7 = beta
                        
                            ; Negate R7 (beta) → R8 = -beta (child alpha)
   1cf6   87                GLO 7               ; low byte
   1cf7   fd 00             SDI 0               ; negate low
   1cf9   a8                PLO 8
   1cfa   97                GHI 7               ; high byte
   1cfb   7d 00             SDBI 0              ; negate high with borrow
   1cfd   b8                PHI 8               ; R8 = -beta
                        
                            ; Store as new alpha
   1cfe   68 ca 64 42       RLDI 10, ALPHA_HI
   1d02   98                GHI 8
   1d03   5a                STR 10
   1d04   1a                INC 10
   1d05   88                GLO 8
   1d06   5a                STR 10              ; ALPHA = -beta
                        
                            ; Set child beta = -beta + 1 (zero window)
   1d07   88                GLO 8
   1d08   fc 01             ADI 1
   1d0a   a8                PLO 8
   1d0b   98                GHI 8
   1d0c   7c 00             ADCI 0
   1d0e   b8                PHI 8               ; R8 = -beta + 1
                        
   1d0f   68 ca 64 44       RLDI 10, BETA_HI
   1d13   98                GHI 8
   1d14   5a                STR 10
   1d15   1a                INC 10
   1d16   88                GLO 8
   1d17   5a                STR 10              ; BETA = -beta + 1
                        
                            ; Toggle color for child
   1d18   8c                GLO 12
   1d19   fb 08             XRI $08
   1d1b   ac                PLO 12
                        
                            ; Increment ply
   1d1c   68 ca 64 48       RLDI 10, CURRENT_PLY
   1d20   0a                LDN 10
   1d21   fc 01             ADI 1
   1d23   5a                STR 10              ; CURRENT_PLY++
                        
                            ; Recursive call
   1d24   d4 1b 35          CALL NEGAMAX
                            ; R9 = score
                        
                            ; Decrement ply
   1d27   68 ca 64 48       RLDI 10, CURRENT_PLY
   1d2b   0a                LDN 10
   1d2c   ff 01             SMI 1
   1d2e   5a                STR 10              ; CURRENT_PLY--
                        
                            ; Toggle color back
   1d2f   8c                GLO 12
   1d30   fb 08             XRI $08
   1d32   ac                PLO 12
                        
                            ; Negate R9 (score = -score)
   1d33   89                GLO 9               ; low byte
   1d34   fd 00             SDI 0               ; negate low
   1d36   a9                PLO 9
   1d37   99                GHI 9               ; high byte
   1d38   7d 00             SDBI 0              ; negate high with borrow
   1d3a   b9                PHI 9
                        
                            ; Unmake null move (toggle side back, restore EP, update hash)
   1d3b   d4 0d b1          CALL NULL_UNMAKE_MOVE
                        
                            ; Re-enable null move for this level
   1d3e   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   1d42   f8 01             LDI 1
   1d44   5a                STR 10              ; NULL_MOVE_OK = 1
                        
                            ; Pop beta from stack into R7
   1d45   60                IRX
   1d46   72                LDXA                ; beta_lo
   1d47   a7                PLO 7
   1d48   f0                LDX                 ; beta_hi (R2 now at beta_hi slot)
   1d49   b7                PHI 7               ; R7 = original beta
                        
                            ; Pop alpha from stack into R8
   1d4a   60                IRX
   1d4b   72                LDXA                ; alpha_lo
   1d4c   a8                PLO 8
   1d4d   f0                LDX                 ; alpha_hi
   1d4e   b8                PHI 8               ; R8 = original alpha
                        
                            ; Pop depth from stack and restore to memory
   1d4f   60                IRX
   1d50   72                LDXA                ; depth_lo
   1d51   ad                PLO 13
   1d52   f0                LDX                 ; depth_hi
   1d53   bd                PHI 13              ; R13 = original depth
                        
   1d54   68 ca 64 16       RLDI 10, SEARCH_DEPTH
   1d58   9d                GHI 13
   1d59   5a                STR 10
   1d5a   1a                INC 10
   1d5b   8d                GLO 13
   1d5c   5a                STR 10              ; SEARCH_DEPTH restored
                            ; R7 = original beta, R8 = original alpha (for NMP_NO_CUTOFF path)
                        
                            ; Compare: score (R9) >= beta (R7)? If so, prune!
                            ; Signed 16-bit comparison
                        
   1d5d   68 ca 64 49       RLDI 10, COMPARE_TEMP
   1d61   ea                SEX 10
                        
                            ; Check if signs differ
   1d62   99                GHI 9               ; score_hi
   1d63   5a                STR 10
   1d64   97                GHI 7               ; beta_hi
   1d65   f3                XOR
   1d66   fa 80             ANI $80             ; Check sign bit difference
   1d68   e2                SEX 2
   1d69   ca 1d 7c          LBNZ NMP_CHECK_SIGN
                        
                            ; Same sign: score >= beta if (score - beta) has no borrow
   1d6c   ea                SEX 10
   1d6d   87                GLO 7               ; beta_lo
   1d6e   5a                STR 10
   1d6f   89                GLO 9               ; score_lo
   1d70   f7                SM                  ; score_lo - beta_lo
   1d71   97                GHI 7               ; beta_hi
   1d72   5a                STR 10
   1d73   99                GHI 9               ; score_hi
   1d74   77                SMB                 ; score_hi - beta_hi - borrow
   1d75   e2                SEX 2
   1d76   cb 1d 97          LBNF NMP_NO_CUTOFF  ; Borrow set = score < beta
   1d79   c0 1d 82          LBR NMP_CUTOFF      ; No borrow = score >= beta
                        
   1d7c                 NMP_CHECK_SIGN:
                            ; Different signs: positive >= negative always
                            ; If score positive (hi bit 0) and beta negative (hi bit 1): score >= beta
   1d7c   99                GHI 9               ; score_hi
   1d7d   fa 80             ANI $80
   1d7f   ca 1d 97          LBNZ NMP_NO_CUTOFF  ; score negative, beta positive: score < beta
                            ; score positive, beta negative: score >= beta
                            ; Fall through to cutoff
                        
   1d82                 NMP_CUTOFF:
                            ; Null move cutoff! Return beta
                            ; Save beta to SCORE memory (same pattern as NEGAMAX_RETURN)
   1d82   68 ca 64 46       RLDI 10, SCORE_HI
   1d86   97                GHI 7               ; beta_hi
   1d87   5a                STR 10
   1d88   1a                INC 10
   1d89   87                GLO 7               ; beta_lo
   1d8a   5a                STR 10              ; SCORE = beta
                        
   1d8b   d4 00 54          CALL RESTORE_PLY_STATE
                        
                            ; Load return value from SCORE memory into R9 (after restore)
   1d8e   68 ca 64 46       RLDI 10, SCORE_HI
   1d92   4a                LDA 10              ; SCORE_HI
   1d93   b9                PHI 9
   1d94   0a                LDN 10              ; SCORE_LO
   1d95   a9                PLO 9               ; R9 = beta
                        
   1d96   d5                RETN
                        
   1d97                 NMP_NO_CUTOFF:
                            ; Null move didn't cause cutoff - restore alpha/beta to memory
                            ; R8 = original alpha, R7 = original beta
   1d97   68 ca 64 42       RLDI 10, ALPHA_HI
   1d9b   98                GHI 8
   1d9c   5a                STR 10
   1d9d   1a                INC 10
   1d9e   88                GLO 8
   1d9f   5a                STR 10              ; ALPHA = original alpha
                        
   1da0   68 ca 64 44       RLDI 10, BETA_HI
   1da4   97                GHI 7
   1da5   5a                STR 10
   1da6   1a                INC 10
   1da7   87                GLO 7
   1da8   5a                STR 10              ; BETA = original beta
                            ; Fall through to normal move generation
                        
   1da9                 NMP_SKIP:
                            ; -----------------------------------------------
                            ; REVERSE FUTILITY PRUNING (RFP) - DISABLED
                            ; -----------------------------------------------
                            ; RFP margins (150/300cp) are too aggressive for material+PST eval.
                            ; The coarse eval causes search collapse when any PV child finds
                            ; tactical improvement: beta drops and RFP prunes all siblings.
                            ; R7 beta-reload fix (below) is preserved for future re-enable.
                            ;
                            ; Conditions: depth <= 2, ply > 0, not in check
                        
                            ; Condition 1: depth <= 2?
   1da9   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   1dad   0a                LDN 10              ; D = depth low byte
   1dae   ff 03             SMI 3               ; D = depth - 3
   1db0   c3 1e 31          LBDF RFP_SKIP       ; depth >= 3, skip RFP
                        
                            ; Condition 2: ply > 0? (don't prune at root)
   1db3   68 ca 64 48       RLDI 10, CURRENT_PLY
   1db7   0a                LDN 10              ; D = current ply
   1db8   c2 1e 31          LBZ RFP_SKIP        ; ply == 0, skip
                        
                            ; Condition 3: not in check?
   1dbb   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if in check, 0 if safe
   1dbe   ca 1e 31          LBNZ RFP_SKIP       ; in check, can't prune
                        
                            ; --- All conditions met ---
                            ; Get static eval
   1dc1   d4 0e 92          CALL EVALUATE
                            ; R9 = score from white's perspective
                        
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   1dc4   8c                GLO 12
   1dc5   fa 08             ANI $08
   1dc7   c2 1d d2          LBZ RFP_NO_NEG
   1dca   89                GLO 9               ; low byte
   1dcb   fd 00             SDI 0               ; negate low
   1dcd   a9                PLO 9
   1dce   99                GHI 9               ; high byte
   1dcf   7d 00             SDBI 0              ; negate high with borrow
   1dd1   b9                PHI 9
   1dd2                 RFP_NO_NEG:
                        
                            ; Save eval in SCORE_HI/LO (for return value if we prune)
   1dd2   68 ca 64 46       RLDI 10, SCORE_HI
   1dd6   99                GHI 9
   1dd7   5a                STR 10
   1dd8   1a                INC 10
   1dd9   89                GLO 9
   1dda   5a                STR 10              ; SCORE_HI/LO = eval
                        
                            ; Select margin based on depth
                            ; Load depth again
   1ddb   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   1ddf   0a                LDN 10              ; D = depth (1 or 2)
   1de0   ff 02             SMI 2
   1de2   cb 1d f0          LBNF RFP_DEPTH1     ; depth < 2, so depth == 1
                        
                            ; Depth 2: subtract 300cp margin
   1de5   89                GLO 9
   1de6   ff 2c             SMI RFP_MARGIN_D2_LO
   1de8   a9                PLO 9
   1de9   99                GHI 9
   1dea   7f 01             SMBI RFP_MARGIN_D2_HI
   1dec   b9                PHI 9
   1ded   c0 1d f8          LBR RFP_COMPARE
                        
   1df0                 RFP_DEPTH1:
                            ; Depth 1: subtract 150cp margin
   1df0   89                GLO 9
   1df1   ff 96             SMI RFP_MARGIN_D1_LO
   1df3   a9                PLO 9
   1df4   99                GHI 9
   1df5   7f 00             SMBI RFP_MARGIN_D1_HI
   1df7   b9                PHI 9
                        
   1df8                 RFP_COMPARE:
                            ; R9 = eval - margin
                            ; Compare: (eval - margin) >= beta (R7)?
                            ; Signed 16-bit comparison using same pattern as NMP
                        
                            ; Load beta from memory into R7
                            ; (R7 was clobbered by time tracking code at NEGAMAX entry!)
   1df8   68 ca 64 44       RLDI 10, BETA_HI
   1dfc   4a                LDA 10              ; D = beta_hi
   1dfd   b7                PHI 7
   1dfe   0a                LDN 10              ; D = beta_lo
   1dff   a7                PLO 7               ; R7 = beta
                        
   1e00   68 ca 64 49       RLDI 10, COMPARE_TEMP
   1e04   ea                SEX 10
                        
                            ; Check if signs differ
   1e05   99                GHI 9               ; (eval-margin)_hi
   1e06   5a                STR 10
   1e07   97                GHI 7               ; beta_hi
   1e08   f3                XOR
   1e09   fa 80             ANI $80             ; Check sign bit difference
   1e0b   e2                SEX 2
   1e0c   ca 1e 1f          LBNZ RFP_CHECK_SIGN
                        
                            ; Same sign: (eval-margin) >= beta if no borrow
   1e0f   ea                SEX 10
   1e10   87                GLO 7               ; beta_lo
   1e11   5a                STR 10
   1e12   89                GLO 9               ; (eval-margin)_lo
   1e13   f7                SM                  ; (eval-margin)_lo - beta_lo
   1e14   97                GHI 7               ; beta_hi
   1e15   5a                STR 10
   1e16   99                GHI 9               ; (eval-margin)_hi
   1e17   77                SMB                 ; (eval-margin)_hi - beta_hi - borrow
   1e18   e2                SEX 2
   1e19   cb 1e 31          LBNF RFP_SKIP       ; Borrow = eval-margin < beta, don't prune
   1e1c   c0 1e 25          LBR RFP_PRUNE       ; No borrow = eval-margin >= beta, prune!
                        
   1e1f                 RFP_CHECK_SIGN:
                            ; Different signs: positive >= negative always
   1e1f   99                GHI 9               ; (eval-margin)_hi
   1e20   fa 80             ANI $80
   1e22   ca 1e 31          LBNZ RFP_SKIP       ; eval-margin negative, beta positive: don't prune
                            ; eval-margin positive, beta negative: prune
                            ; Fall through to RFP_PRUNE
                        
   1e25                 RFP_PRUNE:
                            ; Return eval (saved in SCORE_HI/LO)
   1e25   d4 00 54          CALL RESTORE_PLY_STATE
                            ; Reload R9 from SCORE_HI/LO after restore
   1e28   68 ca 64 46       RLDI 10, SCORE_HI
   1e2c   4a                LDA 10
   1e2d   b9                PHI 9
   1e2e   0a                LDN 10
   1e2f   a9                PLO 9               ; R9 = eval score
   1e30   d5                RETN
                        
   1e31                 RFP_SKIP:
                            ; -----------------------------------------------
                            ; Generate moves for current position
                            ; -----------------------------------------------
                            ; Use ply-indexed move list to avoid overwrites during recursion!
                            ; Each ply gets 128 bytes (64 moves): PLY 0 at $6200, PLY 1 at $6280, etc.
                            ; ply × 128 overflows 8 bits for ply >= 2, so use 16-bit math:
                            ;   offset_hi = ply >> 1, offset_lo = (ply & 1) << 7
                        
   1e31   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e35   0a                LDN 10              ; D = current ply (0-4 with d=5)
                        
                            ; Calculate high byte: HIGH(MOVE_LIST) + (ply >> 1)
   1e36   f6                SHR                 ; D = ply >> 1 (0 or 1)
   1e37   fc 78             ADI HIGH(MOVE_LIST) ; D = $78 + (ply >> 1)
   1e39   b9                PHI 9               ; R9.1 = high byte
                        
                            ; Calculate low byte: (ply & 1) << 7 = $00 or $80
   1e3a   0a                LDN 10              ; D = ply (reload)
   1e3b   fa 01             ANI $01             ; D = ply & 1
   1e3d   c2 1e 45          LBZ NEGAMAX_PLY_EVEN
   1e40   f8 80             LDI $80             ; Odd ply: low byte = $80
   1e42   c0 1e 47          LBR NEGAMAX_PLY_DONE
   1e45                 NEGAMAX_PLY_EVEN:
   1e45   f8 00             LDI $00             ; Even ply: low byte = $00
   1e47                 NEGAMAX_PLY_DONE:
   1e47   a9                PLO 9               ; R9 = ply-indexed move list
                        
   1e48   d4 04 d7          CALL GENERATE_MOVES
                            ; Returns: D = move count
                            ; NOTE: R9 now points PAST the end of the move list!
                        
                            ; Save move count to ply-indexed memory (NOT the stack — see LOOP_MOVE_CNT).
                            ; D = count from GENERATE_MOVES; R11 is movegen scratch (dead on return).
   1e4b   ab                PLO 11             ; stash count in R11.0
   1e4c   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e50   0a                LDN 10             ; D = ply
   1e51   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1e53   aa                PLO 10
   1e54   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1e56   ba                PHI 10             ; R10 = &LOOP_MOVE_CNT[ply]
   1e57   8b                GLO 11             ; D = count
   1e58   5a                STR 10             ; LOOP_MOVE_CNT[ply] = count
                        
                            ; Reset R9 to START of ply-indexed move list (128 bytes per ply)
   1e59   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e5d   0a                LDN 10              ; D = current ply
                        
                            ; Calculate high byte: HIGH(MOVE_LIST) + (ply >> 1)
   1e5e   f6                SHR                 ; D = ply >> 1
   1e5f   fc 78             ADI HIGH(MOVE_LIST)
   1e61   b9                PHI 9
                        
                            ; Calculate low byte: (ply & 1) << 7
   1e62   0a                LDN 10              ; D = ply (reload)
   1e63   fa 01             ANI $01
   1e65   c2 1e 6d          LBZ NEGAMAX_RESET_EVEN
   1e68   f8 80             LDI $80
   1e6a   c0 1e 6f          LBR NEGAMAX_RESET_DONE
   1e6d                 NEGAMAX_RESET_EVEN:
   1e6d   f8 00             LDI $00
   1e6f                 NEGAMAX_RESET_DONE:
   1e6f   a9                PLO 9               ; R9 = ply-indexed move list start
                        
                            ; -----------------------------------------------
                            ; Apply killer move ordering (search killers first)
                            ; Apply at plies 0-4: with d=5 search now active, plies 3 and 4 are
                            ; non-leaves with rich subtrees where alpha-beta cutoffs from a
                            ; well-ordered list save exponentially more work. Skip only at ply >= 5
                            ; (where remaining depth is too shallow for ordering to pay off).
                            ; -----------------------------------------------
   1e70   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e74   0a                LDN 10              ; D = current ply
   1e75   ff 05             SMI 5               ; Check if ply >= 5
   1e77   c3 1e 89          LBDF NEGAMAX_SKIP_KILLER  ; Skip if ply >= 5
                        
   1e7a   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e7e   0a                LDN 10              ; D = ply
   1e7f   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1e81   aa                PLO 10
   1e82   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1e84   ba                PHI 10              ; R10 = &LOOP_MOVE_CNT[ply]
   1e85   0a                LDN 10              ; D = move count (read from memory)
   1e86   d4 28 98          CALL ORDER_KILLER_MOVES
                        
   1e89                 NEGAMAX_SKIP_KILLER:
                            ; -----------------------------------------------
                            ; Order captures first (MVV-LVA preparation)
                            ; Apply at plies 0-4 (same rationale as killers above).
                            ; -----------------------------------------------
   1e89   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e8d   0a                LDN 10              ; D = current ply
   1e8e   ff 05             SMI 5               ; Check if ply >= 5
   1e90   c3 1e a2          LBDF NEGAMAX_SKIP_CAPTURE_ORDER  ; Skip if ply >= 5
                        
   1e93   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e97   0a                LDN 10              ; D = ply
   1e98   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1e9a   aa                PLO 10
   1e9b   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1e9d   ba                PHI 10              ; R10 = &LOOP_MOVE_CNT[ply]
   1e9e   0a                LDN 10              ; D = move count (read from memory)
   1e9f   d4 29 63          CALL ORDER_CAPTURES_FIRST
                        
   1ea2                 NEGAMAX_SKIP_CAPTURE_ORDER:
                            ; -----------------------------------------------
                            ; Order TT/PV move first (highest-priority ordering hint)
                            ; At ply >= 1: TT_PROBE has populated TT_MOVE_HI/LO (or left empty zeros).
                            ; At root: ITER_BEST_FROM/TO holds the principal-variation move from the
                            ; prior iterative-deepening iteration. Copy it into TT_MOVE_HI/LO so the
                            ; existing ORDER_TT_MOVE puts it at the front. This PV-move-first
                            ; ordering is essentially free (no extra search; the move is already
                            ; computed) and typically halves node counts at the next depth via
                            ; immediate alpha-beta cutoffs.
                            ; ITER_BEST is initialized to $FF/$FF in SEARCH_POSITION; only valid
                            ; after at least one successful iteration completes.
                            ; -----------------------------------------------
   1ea2   68 ca 64 48       RLDI 10, CURRENT_PLY
   1ea6   0a                LDN 10              ; D = current ply
   1ea7   ca 1e c5          LBNZ NEGAMAX_TT_ORDER_CALL  ; ply >= 1: TT_PROBE has populated TT_MOVE
                        
                            ; Root: copy ITER_BEST into TT_MOVE if valid, else skip ordering pass.
   1eaa   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   1eae   0a                LDN 10
   1eaf   fb ff             XRI $FF
   1eb1   c2 1e c5          LBZ NEGAMAX_SKIP_TT_ORDER   ; first iteration: no PV — skip
                        
   1eb4   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   1eb8   4a                LDA 10                      ; D = ITER_BEST_FROM, R10 -> ITER_BEST_TO
   1eb9   bd                PHI 13
   1eba   0a                LDN 10                      ; D = ITER_BEST_TO
   1ebb   ad                PLO 13
   1ebc   68 ca 64 c0       RLDI 10, TT_MOVE_HI
   1ec0   9d                GHI 13
   1ec1   5a                STR 10                      ; TT_MOVE_HI = ITER_BEST_FROM
   1ec2   1a                INC 10
   1ec3   8d                GLO 13
   1ec4   5a                STR 10                      ; TT_MOVE_LO = ITER_BEST_TO
                        
   1ec5                 NEGAMAX_TT_ORDER_CALL:
                            ; (move-count peek removed: ORDER_TT_MOVE below is disabled, so nothing
                            ;  consumed it. When re-enabled, read LOOP_MOVE_CNT[ply] into D first.)
                            ; --- ORDER_TT_MOVE disabled 2026-05-13 pending 32-bit TT hash widening ---
                            ; The byte-order fix in ORDER_TT_MOVE (commit 8aa04e6) is correct, but
                            ; enabling it surfaced a regression: with TT keyed on only 16 hash bits,
                            ; collisions are frequent (2^16 = 65k positions per slot). A TT_MOVE
                            ; from a colliding position gets promoted to the front of the move list
                            ; for the WRONG position; alpha-beta commits to that move's search line;
                            ; depth-limited search can't refute it. Observed concretely 2026-05-13:
                            ; engine chose Qg4-g7-h8 (queen sac into rook taking + queen recapture)
                            ; with ordering enabled; chose sensible Qg4-c8 with ordering disabled.
                            ; Killer ordering above is safe (not hash-keyed; per-ply table only).
                            ; Re-enable this CALL when TT_HASH is widened to 32 bits.
                            ; CALL ORDER_TT_MOVE
                        
   1ec5                 NEGAMAX_SKIP_TT_ORDER:
                        
                            ; -----------------------------------------------
                            ; Initialize best score to -INFINITY in memory
                            ; -----------------------------------------------
                            ; Using memory avoids register clobbering bugs!
   1ec5   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   1ec9   f8 80             LDI $80
   1ecb   5a                STR 10              ; BEST_SCORE_HI = $80
   1ecc   1a                INC 10
   1ecd   f8 01             LDI $01
   1ecf   5a                STR 10              ; BEST_SCORE_LO = $01 (best = $8001 = -32767, safe to negate)
                        
                            ; -----------------------------------------------
                            ; Initialize node best move to 0/0 (no move yet)
                            ; -----------------------------------------------
   1ed0   68 ca 64 48       RLDI 10, CURRENT_PLY
   1ed4   0a                LDN 10              ; D = ply
   1ed5   fe                SHL                 ; D = ply * 2
   1ed6   aa                PLO 10
   1ed7   f8 67             LDI HIGH(NODE_BEST_MOVE)
   1ed9   ba                PHI 10              ; R10 = &NODE_BEST_MOVE[ply]
   1eda   f8 00             LDI 0
   1edc   5a                STR 10              ; from = 0
   1edd   1a                INC 10
   1ede   5a                STR 10              ; to = 0
                        
                            ; -----------------------------------------------
                            ; Futility Pruning Setup (depth 1 only)
                            ; -----------------------------------------------
                            ; Clear futility flag for THIS ply (per-ply table prevents recursion corruption)
   1edf   68 ca 64 48       RLDI 10, CURRENT_PLY
   1ee3   0a                LDN 10              ; D = ply
   1ee4   fe                SHL
   1ee5   fe                SHL                 ; D = ply * 4
   1ee6   fc 22             ADI LOW(FUTILITY_TABLE)
   1ee8   aa                PLO 10
   1ee9   f8 67             LDI HIGH(FUTILITY_TABLE)
   1eeb   7c 00             ADCI 0
   1eed   ba                PHI 10              ; R10 = &FUTILITY_TABLE[ply*4] (flag byte)
   1eee   f8 00             LDI 0
   1ef0   5a                STR 10              ; flag = 0 (disabled by default)
                        
                            ; Check if depth == 1 (frontier node)
   1ef1   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   1ef5   4d                LDA 13              ; D = depth high byte
   1ef6   ca 1f 4d          LBNZ NEGAMAX_SKIP_FUTILITY  ; depth > 255, skip
   1ef9   0d                LDN 13              ; D = depth low byte
   1efa   fb 01             XRI 1               ; Check if depth == 1
   1efc   ca 1f 4d          LBNZ NEGAMAX_SKIP_FUTILITY  ; Not depth 1, skip
                        
                            ; Don't enable futility at root — must always search all root moves
   1eff   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f03   0a                LDN 10              ; D = current ply
   1f04   c2 1f 4d          LBZ NEGAMAX_SKIP_FUTILITY  ; ply == 0, skip
                        
                            ; Check guard: don't enable futility if side is in check
                            ; (escape moves must not be pruned — mirrors RFP guard at line 563)
   1f07   d4 01 8e          CALL IS_IN_CHECK    ; R12 = our color; D = 1 if in check
   1f0a   ca 1f 4d          LBNZ NEGAMAX_SKIP_FUTILITY  ; in check, skip futility
                        
                            ; Depth == 1: Cache static eval for futility pruning (per-ply table)
   1f0d   d4 0e 92          CALL EVALUATE       ; Returns score in R9 (white perspective)
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   1f10   8c                GLO 12
   1f11   fa 08             ANI $08
   1f13   c2 1f 1e          LBZ FUTILITY_NO_NEG
   1f16   89                GLO 9               ; low byte
   1f17   fd 00             SDI 0               ; negate low
   1f19   a9                PLO 9
   1f1a   99                GHI 9               ; high byte
   1f1b   7d 00             SDBI 0              ; negate high with borrow
   1f1d   b9                PHI 9
   1f1e                 FUTILITY_NO_NEG:
                            ; Store flag + eval in FUTILITY_TABLE[ply*4]: [flag][eval_hi][eval_lo]
   1f1e   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f22   0a                LDN 10              ; D = ply
   1f23   fe                SHL
   1f24   fe                SHL                 ; D = ply * 4
   1f25   fc 22             ADI LOW(FUTILITY_TABLE)
   1f27   aa                PLO 10
   1f28   f8 67             LDI HIGH(FUTILITY_TABLE)
   1f2a   7c 00             ADCI 0
   1f2c   ba                PHI 10              ; R10 = &FUTILITY_TABLE[ply*4]
   1f2d   f8 01             LDI 1               ; DEBUG: flag=1 (futility active, negate LBR'd = unsigned eval like bd6e4b5)
   1f2f   5a                STR 10              ; flag = 1 (futility enabled)
   1f30   1a                INC 10
   1f31   99                GHI 9
   1f32   5a                STR 10              ; eval_hi
   1f33   1a                INC 10
   1f34   89                GLO 9
   1f35   5a                STR 10              ; eval_lo
                        
                            ; FIX: EVALUATE clobbered R9 (move list pointer) with eval score.
                            ; Re-initialize R9 to move list start for this ply.
   1f36   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f3a   0a                LDN 10              ; D = current ply
   1f3b   f6                SHR                 ; D = ply >> 1
   1f3c   fc 78             ADI HIGH(MOVE_LIST)
   1f3e   b9                PHI 9               ; R9.1 = HIGH(MOVE_LIST) + (ply >> 1)
   1f3f   0a                LDN 10              ; D = ply (reload)
   1f40   fa 01             ANI $01
   1f42   c2 1f 4a          LBZ NEGAMAX_FUTILITY_R9_EVEN
   1f45   f8 80             LDI $80
   1f47   c0 1f 4c          LBR NEGAMAX_FUTILITY_R9_DONE
   1f4a                 NEGAMAX_FUTILITY_R9_EVEN:
   1f4a   f8 00             LDI $00
   1f4c                 NEGAMAX_FUTILITY_R9_DONE:
   1f4c   a9                PLO 9               ; R9 = ply-indexed move list start
                        
   1f4d                 NEGAMAX_SKIP_FUTILITY:
                        
                            ; Initialize LMR move counter to 0
   1f4d   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   1f51   f8 00             LDI 0
   1f53   5a                STR 10              ; LMR_MOVE_INDEX = 0
                        
                            ; Check if there are any legal moves
   1f54   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f58   0a                LDN 10              ; D = ply
   1f59   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1f5b   aa                PLO 10
   1f5c   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1f5e   ba                PHI 10              ; R10 = &LOOP_MOVE_CNT[ply]
   1f5f   0a                LDN 10              ; D = move count (read from memory)
   1f60   ca 1f 66          LBNZ NEGAMAX_HAS_MOVES  ; Long branch (may cross page boundary)
                            ; No legal moves - checkmate or stalemate
   1f63   c0 25 0a          LBR NEGAMAX_NO_MOVES
                        
   1f66                 NEGAMAX_HAS_MOVES:
   1f66                 NEGAMAX_MOVE_LOOP:
                            ; -----------------------------------------------
                            ; Loop through all moves
                            ; -----------------------------------------------
                            ; Read move count from ply-indexed memory
   1f66   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f6a   0a                LDN 10             ; D = ply
   1f6b   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1f6d   aa                PLO 10
   1f6e   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1f70   ba                PHI 10             ; R10 = &LOOP_MOVE_CNT[ply]
   1f71   0a                LDN 10             ; D = move count (read from memory)
   1f72   c2 24 c0          LBZ NEGAMAX_RETURN  ; No moves left
                        
                            ; Get next move from list (big-endian: high byte first)
   1f75   49                LDA 9              ; Load high byte of move
   1f76   b8                PHI 8
   1f77   49                LDA 9              ; Load low byte of move
   1f78   a8                PLO 8              ; R8 = current move (16-bit encoded)
                        
                            ; Save R9 (move pointer) to ply-indexed memory (not stack!)
                            ; This avoids stack alignment bugs across the large move loop
   1f79   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f7d   0a                LDN 10              ; D = ply
   1f7e   fe                SHL                 ; D = ply * 2
   1f7f   fc db             ADI LOW(LOOP_MOVE_PTR)
   1f81   aa                PLO 10
   1f82   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   1f84   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   1f85   99                GHI 9
   1f86   5a                STR 10              ; Save R9.hi
   1f87   1a                INC 10
   1f88   89                GLO 9
   1f89   5a                STR 10              ; Save R9.lo
                        
                            ; Decode move: R8 → R13 (from/to)
   1f8a   d4 03 c7          CALL DECODE_MOVE_16BIT
                            ; R13.1 = from square, R13.0 = to square
                        
                            ; Store to MOVE_FROM/MOVE_TO for MAKE_MOVE
   1f8d   68 ca 64 02       RLDI 10, MOVE_FROM
   1f91   9d                GHI 13              ; from
   1f92   5a                STR 10
   1f93   1a                INC 10
   1f94   8d                GLO 13              ; to
   1f95   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Set LMR_IS_CAPTURE flag based on target square
                            ; -----------------------------------------------
                            ; R13.0 still has 'to' square from DECODE_MOVE_16BIT
   1f96   f8 60             LDI HIGH(BOARD)
   1f98   ba                PHI 10
   1f99   8d                GLO 13              ; D = to square
   1f9a   aa                PLO 10              ; R10 = BOARD + to_square
   1f9b   0a                LDN 10              ; D = piece at target (0 if empty)
   1f9c   a7                PLO 7               ; Save piece in R7.0 (temp)
   1f9d   68 ca 64 a5       RLDI 10, LMR_IS_CAPTURE
   1fa1   87                GLO 7               ; Restore piece
   1fa2   c2 1f aa          LBZ LMR_NOT_CAPTURE
   1fa5   f8 01             LDI 1               ; Non-empty = capture
   1fa7   c0 1f ac          LBR LMR_CAPTURE_DONE
   1faa                 LMR_NOT_CAPTURE:
   1faa   f8 00             LDI 0               ; Empty = not capture
   1fac                 LMR_CAPTURE_DONE:
   1fac   5a                STR 10              ; Store flag
                        
                            ; -----------------------------------------------
                            ; Castling Legality (moved from movegen for performance)
                            ; Only runs when the search actually tries a castling move,
                            ; not at every node during move generation.
                            ; -----------------------------------------------
   1fad   68 ca 64 05       RLDI 10, DECODED_FLAGS
   1fb1   0a                LDN 10
   1fb2   fb 01             XRI MOVE_CASTLE         ; Zero if castling
   1fb4   ca 1f e6          LBNZ NM_NOT_CASTLE
                        
                            ; Castling — check king not in check (can't castle out of check)
   1fb7   68 ca 64 02       RLDI 10, MOVE_FROM
   1fbb   0a                LDN 10                  ; D = from (king square)
   1fbc   ab                PLO 11                  ; R11.0 = king square
   1fbd   d4 01 a4          CALL IS_SQUARE_ATTACKED ; D = 1 if in check
   1fc0   ca 1f d3          LBNZ NM_CASTLE_ILLEGAL
                        
                            ; Check transit square not attacked (can't castle through check)
                            ; Transit = (from + to) / 2
   1fc3   68 ca 64 02       RLDI 10, MOVE_FROM
   1fc7   4a                LDA 10                  ; D = from, R10 -> MOVE_TO
   1fc8   52                STR 2                   ; M[R2] = from
   1fc9   0a                LDN 10                  ; D = to
   1fca   f4                ADD                     ; D = from + to
   1fcb   f6                SHR                     ; D = transit square
   1fcc   ab                PLO 11                  ; R11.0 = transit
   1fcd   d4 01 a4          CALL IS_SQUARE_ATTACKED
   1fd0   c2 1f e6          LBZ NM_NOT_CASTLE       ; Transit safe, proceed
                        
   1fd3                 NM_CASTLE_ILLEGAL:
                            ; Restore R9 from ply-indexed memory
   1fd3   68 ca 64 48       RLDI 10, CURRENT_PLY
   1fd7   0a                LDN 10
   1fd8   fe                SHL
   1fd9   fc db             ADI LOW(LOOP_MOVE_PTR)
   1fdb   aa                PLO 10
   1fdc   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   1fde   ba                PHI 10
   1fdf   4a                LDA 10
   1fe0   b9                PHI 9
   1fe1   0a                LDN 10
   1fe2   a9                PLO 9
   1fe3   c0 24 90          LBR NEGAMAX_NEXT_MOVE
                        
   1fe6                 NM_NOT_CASTLE:
                        
                            ; -----------------------------------------------
                            ; Futility Pruning Check (per-ply, depth 1 quiet moves)
                            ; -----------------------------------------------
                        
                            ; Check: is futility pruning enabled for this ply? (per-ply table)
   1fe6   68 ca 64 48       RLDI 10, CURRENT_PLY
   1fea   0a                LDN 10              ; D = ply
   1feb   fe                SHL
   1fec   fe                SHL                 ; D = ply * 4
   1fed   fc 22             ADI LOW(FUTILITY_TABLE)
   1fef   aa                PLO 10
   1ff0   f8 67             LDI HIGH(FUTILITY_TABLE)
   1ff2   7c 00             ADCI 0
   1ff4   ba                PHI 10              ; R10 = &FUTILITY_TABLE[ply*4]
   1ff5   4a                LDA 10              ; D = flag, R10 → eval_hi
   1ff6   c2 20 3f          LBZ NEGAMAX_NOT_FUTILE  ; Flag=0, skip futility
                            ; Pre-load static eval while R10 is positioned
   1ff9   4a                LDA 10              ; D = eval_hi, R10 → eval_lo
   1ffa   bb                PHI 11
   1ffb   0a                LDN 10              ; D = eval_lo
   1ffc   ab                PLO 11              ; R11 = static eval (from per-ply table)
                        
                            ; Check if move is a capture (target square non-empty)
   1ffd   68 ca 64 03       RLDI 10, MOVE_TO
   2001   0a                LDN 10              ; D = to square
   2002   aa                PLO 10              ; R10.0 = to square
   2003   f8 60             LDI HIGH(BOARD)
   2005   ba                PHI 10              ; R10 = BOARD + to_square
   2006   0a                LDN 10              ; D = piece at target
   2007   ca 20 3f          LBNZ NEGAMAX_NOT_FUTILE  ; Non-empty = capture, don't prune
                        
                            ; Check if move is a promotion (never prune — changes material)
   200a   68 ca 64 05       RLDI 10, DECODED_FLAGS
   200e   0a                LDN 10              ; D = move flags
   200f   fb 03             XRI MOVE_PROMOTION  ; Zero if promotion
   2011   c2 20 3f          LBZ NEGAMAX_NOT_FUTILE  ; Promotion, don't prune
                        
                            ; Add FUTILITY_MARGIN (150 = $0096)
   2014   8b                GLO 11
   2015   fc 96             ADI FUTILITY_MARGIN_D1_LO  ; Add low byte
   2017   ab                PLO 11
   2018   9b                GHI 11
   2019   7c 00             ADCI FUTILITY_MARGIN_D1_HI ; Add high byte with carry
   201b   bb                PHI 11              ; R11 = static_eval + margin
                        
                            ; Safety: don't prune if no move has been searched yet (BEST_SCORE
                            ; is still sentinel $8001). Otherwise all quiet moves get pruned,
                            ; BEST_SCORE stays at sentinel, and the engine detects false checkmate.
   201c   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   2020   0a                LDN 10              ; D = BEST_SCORE_HI
   2021   fb 80             XRI $80             ; Zero if still sentinel high byte
   2023   c2 20 3f          LBZ NEGAMAX_NOT_FUTILE  ; Sentinel → must search this move
                        
                            ; Futility: prune if static_eval + margin < 0 (losing by more than margin)
   2026   9b                GHI 11              ; (eval+margin) high byte
   2027   fa 80             ANI $80             ; Check sign bit
   2029   c2 20 3f          LBZ NEGAMAX_NOT_FUTILE  ; Sign bit clear = positive, don't prune
                        
                            ; Futile! Skip this move
                            ; Restore R9 from ply-indexed memory
   202c   68 ca 64 48       RLDI 10, CURRENT_PLY
   2030   0a                LDN 10              ; D = ply
   2031   fe                SHL                 ; D = ply * 2
   2032   fc db             ADI LOW(LOOP_MOVE_PTR)
   2034   aa                PLO 10
   2035   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   2037   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   2038   4a                LDA 10
   2039   b9                PHI 9               ; R9.hi
   203a   0a                LDN 10
   203b   a9                PLO 9               ; R9 = move list pointer restored
                        
                            ; Jump to decrement move count and continue loop
   203c   c0 24 90          LBR NEGAMAX_NEXT_MOVE
                        
   203f                 NEGAMAX_NOT_FUTILE:
                        
                            ; -----------------------------------------------
                            ; Late Move Pruning (LMP) — at low depth, after first N quiet moves
                            ; have been searched, skip remaining quiet moves entirely. Empirical
                            ; literature: 20-40% node reduction at low depths with low risk.
                            ; Conditions (all must hold to prune):
                            ;   1. CURRENT_PLY > 0      — never prune at root (highest cost of error)
                            ;   2. NODE_IN_CHECK == 0   — never prune when we're in check (legal
                            ;                             escape moves can be late in ordering, and
                            ;                             pruning them = false mate detection)
                            ;   3. SEARCH_DEPTH <= 2    — only at low depths (small subtrees)
                            ;   4. LMR_MOVE_INDEX >= 8  — first 8 moves search normally
                            ;   5. LMR_IS_CAPTURE == 0  — never prune captures
                            ;   6. DECODED_FLAGS != MOVE_PROMOTION
                            ; The in-check guard (cond 2) was added 2026-05-05 after the move-21
                            ; replay surfaced a false +32766 mate at d=1/2/3: opponent in check
                            ; from our Qh5+, with many illegal pseudo-legal moves filling indices
                            ; 0-7, leaving the legal escapes (Ng6, gxh6) at index 9+ where LMP
                            ; pruned them, causing NEGAMAX_NO_MOVES to fire and report mate.
                            ; -----------------------------------------------
                        
                            ; Cond 1: ply > 0?
   203f   68 ca 64 48       RLDI 10, CURRENT_PLY
   2043   0a                LDN 10
   2044   c2 20 7c          LBZ NEGAMAX_LMP_DONE        ; root: never prune
                        
                            ; Cond 2: not in check at this node?
   2047   fc 42             ADI LOW(NODE_IN_CHECK)
   2049   aa                PLO 10
   204a   f8 67             LDI HIGH(NODE_IN_CHECK)
   204c   7c 00             ADCI 0
   204e   ba                PHI 10                      ; R10 = NODE_IN_CHECK + ply
   204f   0a                LDN 10                      ; D = node-in-check flag
   2050   ca 20 7c          LBNZ NEGAMAX_LMP_DONE       ; in check: skip LMP (legal escapes may be late)
                        
                            ; Cond 3: depth <= 2?
   2053   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   2057   0a                LDN 10
   2058   ff 03             SMI 3
   205a   c3 20 7c          LBDF NEGAMAX_LMP_DONE       ; depth >= 3: skip LMP
                        
                            ; Cond 4: index >= 8?
   205d   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   2061   0a                LDN 10
   2062   ff 08             SMI 8
   2064   cb 20 7c          LBNF NEGAMAX_LMP_DONE       ; index < 8: search normally
                        
                            ; Cond 5: not a capture?
   2067   68 ca 64 a5       RLDI 10, LMR_IS_CAPTURE
   206b   0a                LDN 10
   206c   ca 20 7c          LBNZ NEGAMAX_LMP_DONE       ; capture: search normally
                        
                            ; Cond 6: not a promotion?
   206f   68 ca 64 05       RLDI 10, DECODED_FLAGS
   2073   0a                LDN 10
   2074   fb 03             XRI MOVE_PROMOTION
   2076   c2 20 7c          LBZ NEGAMAX_LMP_DONE        ; promotion: search normally
                        
                            ; All conditions met — skip this move (LMP prune)
   2079   c0 24 90          LBR NEGAMAX_NEXT_MOVE
                        
   207c                 NEGAMAX_LMP_DONE:
                        
                            ; Set UNDO_PROMOTION based on move flags
                            ; Must be done before MAKE_MOVE so promotions work correctly
   207c   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   2080   68 cd 64 05       RLDI 13, DECODED_FLAGS
   2084   0d                LDN 13              ; D = flags
   2085   fb 03             XRI MOVE_PROMOTION  ; == $03?
   2087   ca 20 8f          LBNZ NM_NOT_PROMO
   208a   f8 05             LDI QUEEN_TYPE      ; Promote to queen ($05)
   208c   c0 20 91          LBR NM_SET_PROMO
   208f                 NM_NOT_PROMO:
   208f   f8 00             LDI 0               ; Not a promotion
   2091                 NM_SET_PROMO:
   2091   5a                STR 10              ; UNDO_PROMOTION = QUEEN_TYPE or 0
                        
                            ; Make the move on the board
   2092   d4 09 b4          CALL MAKE_MOVE
                        
                            ; -----------------------------------------------
                            ; LEGALITY CHECK: Does this move leave our king in check?
                            ; MAKE_MOVE does NOT toggle R12 - only SIDE in memory.
                            ; R12 still contains our color (the side that just moved).
                            ; -----------------------------------------------
   2095   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if our king is in check (illegal move), 0 if safe
                        
                            ; If in check, this move is illegal - unmake and skip
   2098   c2 20 b1          LBZ NEGAMAX_MOVE_LEGAL  ; D=0 means not in check, move is legal
                        
                            ; ILLEGAL MOVE: Our king is in check after this move
   209b   d4 0c 20          CALL UNMAKE_MOVE
                        
                            ; R12 stays as our color (UNMAKE_MOVE doesn't toggle R12)
                        
                            ; Restore R9 from ply-indexed memory and skip to next move
   209e   68 ca 64 48       RLDI 10, CURRENT_PLY
   20a2   0a                LDN 10              ; D = ply
   20a3   fe                SHL                 ; D = ply * 2
   20a4   fc db             ADI LOW(LOOP_MOVE_PTR)
   20a6   aa                PLO 10
   20a7   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   20a9   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   20aa   4a                LDA 10
   20ab   b9                PHI 9               ; R9.hi
   20ac   0a                LDN 10
   20ad   a9                PLO 9               ; R9 = move list pointer restored
                        
   20ae   c0 24 90          LBR NEGAMAX_NEXT_MOVE   ; Skip this illegal move
                        
   20b1                 NEGAMAX_MOVE_LEGAL:
                            ; --- Check extension: does this move give check? ---
   20b1   8c                GLO 12
   20b2   fb 08             XRI 8
   20b4   ac                PLO 12              ; R12 = opponent's color
   20b5   d4 01 8e          CALL IS_IN_CHECK    ; Check opponent's king
                            ; D = 1 if giving check (RLDI does NOT clobber D)
   20b8   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   20bc   5a                STR 10              ; Save result (0 or 1)
   20bd   8c                GLO 12
   20be   fb 08             XRI 8
   20c0   ac                PLO 12              ; R12 = our color restored
                        
                            ; -----------------------------------------------
                            ; LMR Check: Should we reduce this move's search?
                            ; -----------------------------------------------
                            ; Clear LMR_REDUCED flag first
   20c1   68 ca 64 a4       RLDI 10, LMR_REDUCED
   20c5   f8 00             LDI 0
   20c7   5a                STR 10              ; LMR_REDUCED = 0 (default)
                        
                            ; Condition 1: LMR_MOVE_INDEX >= 4?
   20c8   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   20cc   0a                LDN 10              ; D = moves searched so far
   20cd   ff 04             SMI 4               ; D = index - 4
   20cf   cb 20 f5          LBNF LMR_SKIP       ; < 4, skip LMR
                        
                            ; Condition 2: SEARCH_DEPTH >= 3?
   20d2   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   20d6   0a                LDN 10              ; D = depth low byte
   20d7   ff 03             SMI 3               ; D = depth - 3
   20d9   cb 20 f5          LBNF LMR_SKIP       ; < 3, skip LMR
                        
                            ; Condition 3: Not a capture?
   20dc   68 ca 64 a5       RLDI 10, LMR_IS_CAPTURE
   20e0   0a                LDN 10              ; D = capture flag
   20e1   ca 20 f5          LBNZ LMR_SKIP       ; Is capture, skip LMR
                        
                            ; Condition 4: Not a promotion? (promotions change material, never reduce)
   20e4   68 ca 64 05       RLDI 10, DECODED_FLAGS
   20e8   0a                LDN 10              ; D = move flags
   20e9   fb 03             XRI MOVE_PROMOTION  ; Zero if promotion
   20eb   c2 20 f5          LBZ LMR_SKIP        ; Promotion, skip LMR
                        
                            ; All conditions met - set LMR_REDUCED = 1
   20ee   68 ca 64 a4       RLDI 10, LMR_REDUCED
   20f2   f8 01             LDI 1
   20f4   5a                STR 10              ; LMR_REDUCED = 1
                        
   20f5                 LMR_SKIP:
                        
                            ; -----------------------------------------------
                            ; Save depth to stack and decrement for recursive call
                            ; (PUSH ORDER: R9/R8, depth, alpha/beta, UNDO_* - pop in reverse!)
                            ; -----------------------------------------------
                            ; First, save current depth to stack for later restore
   20f5   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   20f9   4d                LDA 13              ; D = depth high
   20fa   73                STXD
   20fb   0d                LDN 13              ; D = depth low
   20fc   73                STXD                ; Stack now has: ... [depth_hi] [depth_lo]
                        
                            ; Now decrement depth in memory
   20fd   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   2101   0d                LDN 13              ; D = depth low
   2102   ff 01             SMI 1
   2104   5d                STR 13              ; Store decremented low byte
   2105   2d                DEC 13              ; Point to high byte
   2106   0d                LDN 13              ; D = depth high
   2107   7f 00             SMBI 0              ; Subtract borrow
   2109   5d                STR 13              ; Store decremented high byte
                        
                            ; -----------------------------------------------
                            ; LMR: Extra depth decrement if flag is set
                            ; -----------------------------------------------
   210a   68 ca 64 a4       RLDI 10, LMR_REDUCED
   210e   0a                LDN 10              ; D = LMR_REDUCED flag
   210f   c2 21 1f          LBZ LMR_NO_EXTRA_DEC ; Not reduced, skip extra decrement
                        
                            ; LMR applies - decrement depth by 1 MORE (depth now = original - 2)
   2112   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   2116   0d                LDN 13              ; D = depth low
   2117   ff 01             SMI 1
   2119   5d                STR 13              ; depth_lo--
   211a   2d                DEC 13              ; Point to high byte
   211b   0d                LDN 13              ; D = depth high
   211c   7f 00             SMBI 0              ; Subtract borrow
   211e   5d                STR 13              ; depth_hi-- (with borrow)
                        
   211f                 LMR_NO_EXTRA_DEC:
                            ; -----------------------------------------------
                            ; Check extension: if move gives check AND depth is
                            ; at the horizon (depth <= 0 after decrement), undo
                            ; the decrement so checking move stays in main search
                            ; where checkmate can be detected (QS can't detect it)
                            ; -----------------------------------------------
   211f   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   2123   0a                LDN 10              ; D = check flag
   2124   c2 21 40          LBZ CE_DONE         ; Not giving check, skip
                        
                            ; Ply guard: don't extend if ply >= 4 (child would be ply 5).
                            ; With MAX_PLY=8 and MOVE_LIST sized for 5 plies + QS scratch beyond,
                            ; ply 4 extending to 5 stays within bounds.
   2127   68 ca 64 48       RLDI 10, CURRENT_PLY
   212b   0a                LDN 10              ; D = current ply
   212c   ff 04             SMI 4
   212e   c3 21 40          LBDF CE_DONE        ; ply >= 4, skip extension
                        
                            ; Only extend at horizon: depth <= 0 after decrement
   2131   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   2135   4d                LDA 13              ; D = depth_hi
   2136   ca 21 40          LBNZ CE_DONE        ; depth_hi != 0, not at horizon
   2139   0d                LDN 13              ; D = depth_lo
   213a   ca 21 40          LBNZ CE_DONE        ; depth_lo != 0, not at horizon
                        
                            ; Depth is 0 — about to drop to QS. Undo decrement (+1)
   213d   f8 01             LDI 1
   213f   5d                STR 13              ; depth_lo = 1
                            ; depth_hi stays 0 (already confirmed)
                        
   2140                 CE_DONE:
                            ; -----------------------------------------------
                            ; Negate and swap alpha/beta (memory-based - R6 is SCRT linkage!)
                            ; -----------------------------------------------
                            ; For negamax: score = -negamax(depth-1, -beta, -alpha, -color)
                        
                            ; Save current alpha and beta from memory to stack
                            ; Load alpha from memory (big-endian: HI at lower address)
   2140   68 cd 64 42       RLDI 13, ALPHA_HI
   2144   4d                LDA 13              ; D = alpha_hi
   2145   73                STXD
   2146   0d                LDN 13              ; D = alpha_lo
   2147   73                STXD
                            ; Load beta from memory (big-endian: HI at lower address)
   2148   68 cd 64 44       RLDI 13, BETA_HI
   214c   4d                LDA 13              ; D = beta_hi
   214d   73                STXD
   214e   0d                LDN 13              ; D = beta_lo
   214f   73                STXD
                            ; Stack now has: [beta_lo][beta_hi][alpha_lo][alpha_hi][depth]...
                        
                            ; -----------------------------------------------
                            ; Save UNDO_* to stack (7 bytes) for recursive safety
                            ; Child calls will overwrite UNDO_*, so we must save it
                            ; Push LAST so it gets popped FIRST (LIFO order!)
                            ; -----------------------------------------------
   2150   68 ca 64 08       RLDI 10, UNDO_CAPTURED
   2154   4a                LDA 10              ; UNDO_CAPTURED
   2155   73                STXD
   2156   4a                LDA 10              ; UNDO_FROM
   2157   73                STXD
   2158   4a                LDA 10              ; UNDO_TO
   2159   73                STXD
   215a   4a                LDA 10              ; UNDO_CASTLING
   215b   73                STXD
   215c   4a                LDA 10              ; UNDO_EP
   215d   73                STXD
   215e   0a                LDN 10              ; UNDO_HALFMOVE
   215f   73                STXD
                            ; UNDO_PROMOTION is at $6404 (not contiguous)
   2160   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   2164   0a                LDN 10              ; UNDO_PROMOTION
   2165   73                STXD
                            ; UNDO_CAP_SQ is at $64FF (not contiguous)
   2166   68 ca 64 ff       RLDI 10, UNDO_CAP_SQ
   216a   0a                LDN 10              ; UNDO_CAP_SQ
   216b   73                STXD
                        
                            ; -----------------------------------------------
                            ; Save BEST_SCORE to stack (2 bytes) for recursive safety
                            ; Child calls will reinitialize BEST_SCORE to -infinity!
                            ; -----------------------------------------------
   216c   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   2170   4a                LDA 10              ; BEST_SCORE_HI
   2171   73                STXD
   2172   0a                LDN 10              ; BEST_SCORE_LO
   2173   73                STXD
                            ; Stack now has: [BEST_SCORE][UNDO_CAP_SQ][UNDO_*][beta][alpha][depth][R9]...
                        
                            ; Negate beta from memory → R7 = -beta (new alpha)
                            ; Read low byte first for borrow propagation, then high byte
   2174   68 cd 64 45       RLDI 13, BETA_LO
   2178   0d                LDN 13              ; low byte (BETA_LO at higher address)
   2179   fd 00             SDI 0               ; negate low
   217b   a7                PLO 7
   217c   2d                DEC 13              ; → BETA_HI (lower address)
   217d   0d                LDN 13              ; high byte
   217e   7d 00             SDBI 0              ; negate high with borrow
   2180   b7                PHI 7               ; R7 = -beta
                        
                            ; Negate alpha from memory → R8 = -alpha (new beta)
   2181   68 cd 64 43       RLDI 13, ALPHA_LO
   2185   0d                LDN 13              ; low byte (ALPHA_LO at higher address)
   2186   fd 00             SDI 0               ; negate low
   2188   a8                PLO 8
   2189   2d                DEC 13              ; → ALPHA_HI (lower address)
   218a   0d                LDN 13              ; high byte
   218b   7d 00             SDBI 0              ; negate high with borrow
   218d   b8                PHI 8               ; R8 = -alpha
                        
                            ; Now swap: new_alpha = -beta (in R7), new_beta = -alpha (in R8)
                            ; Store to memory (big-endian: high byte at lower address)
   218e   68 cd 64 42       RLDI 13, ALPHA_HI
   2192   97                GHI 7
   2193   5d                STR 13              ; ALPHA_HI = -beta high
   2194   1d                INC 13
   2195   87                GLO 7
   2196   5d                STR 13              ; ALPHA_LO = -beta low
                        
   2197   68 cd 64 44       RLDI 13, BETA_HI
   219b   98                GHI 8
   219c   5d                STR 13              ; BETA_HI = -alpha high
   219d   1d                INC 13
   219e   88                GLO 8
   219f   5d                STR 13              ; BETA_LO = -alpha low
                        
                            ; Toggle color (C): 0=white, 8=black (matches COLOR_MASK)
   21a0   8c                GLO 12
   21a1   fb 08             XRI $08             ; Toggle between 0 and 8
   21a3   ac                PLO 12
                        
                            ; Increment ply counter before recursion
   21a4   68 ca 64 48       RLDI 10, CURRENT_PLY
   21a8   0a                LDN 10
   21a9   fc 01             ADI 1
   21ab   5a                STR 10              ; CURRENT_PLY++
                        
                            ; -----------------------------------------------
                            ; Push LMR state to stack (overwritten by recursive call)
                            ; -----------------------------------------------
                            ; Push LMR_MOVE_INDEX first (popped last)
   21ac   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   21b0   0a                LDN 10              ; D = LMR_MOVE_INDEX
   21b1   73                STXD                ; Push to stack
                            ; Push LMR_REDUCED second (popped first)
   21b2   68 ca 64 a4       RLDI 10, LMR_REDUCED
   21b6   0a                LDN 10              ; D = LMR_REDUCED flag
   21b7   73                STXD                ; Push to stack
                        
                            ; -----------------------------------------------
                            ; Recursive call to NEGAMAX
                            ; -----------------------------------------------
   21b8   d4 1b 35          CALL NEGAMAX
                            ; Returns score in R9 (R6 is SCRT linkage - off limits!)
                        
                            ; -----------------------------------------------
                            ; Pop LMR state (reverse order)
                            ; -----------------------------------------------
                            ; Pop LMR_REDUCED and save to LMR_OUTER
   21bb   60                IRX
   21bc   f0                LDX                 ; D = saved LMR_REDUCED (R2 stays at this slot)
   21bd   a7                PLO 7               ; Save in R7.0 (temp)
   21be   68 ca 64 a6       RLDI 10, LMR_OUTER
   21c2   87                GLO 7               ; Restore LMR_REDUCED value
   21c3   5a                STR 10              ; LMR_OUTER = saved LMR_REDUCED
                            ; Pop LMR_MOVE_INDEX and restore to memory
   21c4   60                IRX
   21c5   f0                LDX                 ; D = saved LMR_MOVE_INDEX
   21c6   a7                PLO 7               ; Temp in R7.0
   21c7   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   21cb   87                GLO 7
   21cc   5a                STR 10              ; LMR_MOVE_INDEX restored
                        
                            ; Decrement ply counter after recursion
   21cd   68 ca 64 48       RLDI 10, CURRENT_PLY
   21d1   0a                LDN 10
   21d2   ff 01             SMI 1
   21d4   5a                STR 10              ; CURRENT_PLY--
                        
                            ; Negate R9 (score = -score)
   21d5   89                GLO 9               ; low byte
   21d6   fd 00             SDI 0               ; negate low
   21d8   a9                PLO 9
   21d9   99                GHI 9               ; high byte
   21da   7d 00             SDBI 0              ; negate high with borrow
   21dc   b9                PHI 9
                        
                            ; Save negated score to SCORE_HI/LO (R9 clobbered by stack pops)
   21dd   68 ca 64 46       RLDI 10, SCORE_HI
   21e1   99                GHI 9               ; high byte → SCORE_HI (lower address)
   21e2   5a                STR 10
   21e3   1a                INC 10
   21e4   89                GLO 9               ; low byte → SCORE_LO (higher address)
   21e5   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; LMR Re-search Check: Did reduced search beat alpha?
                            ; -----------------------------------------------
                            ; Read LMR_OUTER from memory (LMR_REDUCED was cleared by recursive call)
   21e6   68 ca 64 a6       RLDI 10, LMR_OUTER
   21ea   0a                LDN 10              ; D = LMR_OUTER flag
   21eb   c2 22 bb          LBZ LMR_NO_RESEARCH ; Not reduced, skip re-search check
                        
                            ; Peek alpha from stack (alpha_hi at R2+14, alpha_lo at R2+13)
   21ee   82                GLO 2
   21ef   fc 0e             ADI 14              ; Calculate offset to alpha_hi
   21f1   aa                PLO 10
   21f2   92                GHI 2
   21f3   7c 00             ADCI 0
   21f5   ba                PHI 10              ; R10 = address of alpha_hi on stack
   21f6   0a                LDN 10              ; D = alpha_hi
   21f7   b7                PHI 7               ; R7.1 = alpha_hi
   21f8   2a                DEC 10              ; Point to alpha_lo (R2+11)
   21f9   0a                LDN 10              ; D = alpha_lo
   21fa   a7                PLO 7               ; R7 = parent's alpha (big-endian)
                        
                            ; Load score from SCORE_HI/LO
   21fb   68 ca 64 46       RLDI 10, SCORE_HI
   21ff   4a                LDA 10              ; D = score_hi
   2200   bd                PHI 13
   2201   0a                LDN 10              ; D = score_lo
   2202   ad                PLO 13              ; R13 = score
                        
                            ; Signed comparison: score (R13) > alpha (R7)?
                            ; Use COMPARE_TEMP for scratch
   2203   68 ca 64 49       RLDI 10, COMPARE_TEMP
   2207   ea                SEX 10              ; X = R10 for comparisons
                        
                            ; Check if signs differ
   2208   9d                GHI 13              ; score_hi
   2209   5a                STR 10
   220a   97                GHI 7               ; alpha_hi
   220b   f3                XOR
   220c   fa 80             ANI $80             ; Check sign bits differ
   220e   e2                SEX 2               ; Restore X = R2
   220f   ca 22 2a          LBNZ LMR_RESEARCH_DIFF_SIGN
                        
                            ; Same sign: score > alpha if score - alpha > 0 (positive, no borrow)
   2212   ea                SEX 10
   2213   87                GLO 7               ; alpha_lo
   2214   5a                STR 10
   2215   8d                GLO 13              ; score_lo
   2216   f7                SM                  ; D = score_lo - alpha_lo
   2217   b8                PHI 8               ; Save low result in R8.1
   2218   97                GHI 7               ; alpha_hi
   2219   5a                STR 10
   221a   9d                GHI 13              ; score_hi
   221b   77                SMB                 ; D = score_hi - alpha_hi - borrow
   221c   e2                SEX 2               ; Restore X = R2
   221d   cb 22 bb          LBNF LMR_NO_RESEARCH ; Borrow = score <= alpha, no re-search
   2220   ca 22 30          LBNZ LMR_DO_RESEARCH ; High bytes differ and positive
   2223   98                GHI 8               ; Check saved low result
   2224   c2 22 bb          LBZ LMR_NO_RESEARCH  ; Equal (both zero), no re-search
   2227   c0 22 30          LBR LMR_DO_RESEARCH
                        
   222a                 LMR_RESEARCH_DIFF_SIGN:
                            ; Different signs: positive > negative
   222a   9d                GHI 13              ; score_hi
   222b   fa 80             ANI $80
   222d   ca 22 bb          LBNZ LMR_NO_RESEARCH ; score negative, alpha positive: score < alpha
                        
   2230                 LMR_DO_RESEARCH:
                            ; Re-search needed! Score beat alpha on reduced search.
                        
                            ; Clear LMR_REDUCED so we don't re-search again
   2230   68 ca 64 a4       RLDI 10, LMR_REDUCED
   2234   f8 00             LDI 0
   2236   5a                STR 10
                        
                            ; Increment SEARCH_DEPTH by 1 (undo the extra LMR reduction)
                            ; Current depth = original - 2, we want original - 1
   2237   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   223b   0d                LDN 13              ; D = depth_lo
   223c   fc 01             ADI 1
   223e   5d                STR 13              ; depth_lo++
   223f   2d                DEC 13              ; Point to high byte
   2240   0d                LDN 13              ; D = depth_hi
   2241   7c 00             ADCI 0              ; Add carry
   2243   5d                STR 13              ; depth_hi++ (with carry)
                        
                            ; Re-setup alpha/beta for child (same swap as original)
                            ; Peek parent's beta from stack (beta_hi at R2+12, beta_lo at R2+11)
   2244   82                GLO 2
   2245   fc 0c             ADI 12
   2247   aa                PLO 10
   2248   92                GHI 2
   2249   7c 00             ADCI 0
   224b   ba                PHI 10              ; R10 = address of beta_hi on stack
   224c   0a                LDN 10              ; D = beta_hi
   224d   b8                PHI 8
   224e   2a                DEC 10              ; Point to beta_lo
   224f   0a                LDN 10              ; D = beta_lo
   2250   a8                PLO 8               ; R8 = parent's beta
                        
                            ; Negate R8 (beta) → R7 = -beta (new alpha)
   2251   88                GLO 8               ; low byte
   2252   fd 00             SDI 0               ; negate low
   2254   a7                PLO 7
   2255   98                GHI 8               ; high byte
   2256   7d 00             SDBI 0              ; negate high with borrow
   2258   b7                PHI 7               ; R7 = -beta
                        
                            ; Peek parent's alpha again (R2+14, R2+13)
   2259   82                GLO 2
   225a   fc 0e             ADI 14
   225c   aa                PLO 10
   225d   92                GHI 2
   225e   7c 00             ADCI 0
   2260   ba                PHI 10
   2261   0a                LDN 10              ; D = alpha_hi
   2262   b8                PHI 8
   2263   2a                DEC 10
   2264   0a                LDN 10              ; D = alpha_lo
   2265   a8                PLO 8               ; R8 = parent's alpha
                        
                            ; Negate R8 (alpha) in place → R8 = -alpha (new beta)
   2266   88                GLO 8               ; low byte
   2267   fd 00             SDI 0               ; negate low
   2269   a8                PLO 8
   226a   98                GHI 8               ; high byte
   226b   7d 00             SDBI 0              ; negate high with borrow
   226d   b8                PHI 8               ; R8 = -alpha
                        
                            ; Store new alpha/beta to memory
   226e   68 ca 64 42       RLDI 10, ALPHA_HI
   2272   97                GHI 7               ; new_alpha_hi
   2273   5a                STR 10
   2274   1a                INC 10
   2275   87                GLO 7               ; new_alpha_lo
   2276   5a                STR 10              ; ALPHA = -beta
                        
   2277   68 ca 64 44       RLDI 10, BETA_HI
   227b   98                GHI 8               ; new_beta_hi
   227c   5a                STR 10
   227d   1a                INC 10
   227e   88                GLO 8               ; new_beta_lo
   227f   5a                STR 10              ; BETA = -alpha
                        
                            ; ----------------------------------------------------------------
                            ; LMR-RESEARCH FIX 2026-05-06: refresh CHECK_EXT_FLAG before re-search.
                            ; The first reduced-depth call's child overwrote CHECK_EXT_FLAG with
                            ; whatever its last move-loop iteration left (typically 0 for non-checking
                            ; quiet moves). Re-search child's snapshot would read this stale value,
                            ; breaking the LMP in-check guard at line ~1238 even though our move IS
                            ; a check.  R12 is currently BLACK (child's color = opponent of parent
                            ; at root), so direct IS_IN_CHECK checks the opponent's king — exactly
                            ; what we want for "did parent's move give check".
                            ; ----------------------------------------------------------------
   2280   d4 01 8e          CALL IS_IN_CHECK
   2283   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   2287   5a                STR 10              ; CHECK_EXT_FLAG = fresh "in check?" result
                        
                            ; --- BUGFIX (carried from 09ccdcf, origin 2e3333a 2026-01-27): preserve
                            ; LMR_MOVE_INDEX across the re-search. The first (reduced) CALL NEGAMAX
                            ; saves/restores it; this full-depth re-search call did NOT, so the child
                            ; reset+incremented it and never restored this node's value -> corrupts
                            ; LMP/LMR state and, via the LMR_REDUCED-gated SEARCH_DEPTH decrement, can
                            ; underflow depth -> near-infinite child search = the freeze-class hang.
                            ; Latent in 7b3a53d (bug predates it). Push before / restore after.
