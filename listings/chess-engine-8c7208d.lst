   0803                 GEN_SLIDE_E:
   0803   9b                GHI 11
   0804   a7                PLO 7
   0805                 GEN_SLIDE_E_LOOP:
   0805   87                GLO 7
   0806   fc 01             ADI $01
   0808   a7                PLO 7
   0809   fa 88             ANI $88
   080b   ca 08 29          LBNZ GEN_SLIDE_E_RET
   080e   87                GLO 7
   080f   ab                PLO 11
   0810   d4 03 65          CALL CHECK_TARGET_SQUARE
   0813   ab                PLO 11              ; Save result to R11.0
   0814   c2 08 29          LBZ GEN_SLIDE_E_RET
   0817   9b                GHI 11
   0818   bd                PHI 13
   0819   87                GLO 7
   081a   ad                PLO 13
   081b   f8 00             LDI MOVE_NORMAL
   081d   d4 03 e9          CALL ADD_MOVE_ENCODED
   0820   8b                GLO 11              ; Get result from R11.0
   0821   fb 02             XRI 2
   0823   c2 08 29          LBZ GEN_SLIDE_E_RET
   0826   c0 08 05          LBR GEN_SLIDE_E_LOOP
   0829                 GEN_SLIDE_E_RET:
   0829   d5                RETN
                        
                        ; --- GEN_SLIDE_SE: Southeast (+$F1 = -$0F) ---
   082a                 GEN_SLIDE_SE:
   082a   9b                GHI 11
   082b   a7                PLO 7
   082c                 GEN_SLIDE_SE_LOOP:
   082c   87                GLO 7
   082d   fc f1             ADI $F1
   082f   a7                PLO 7
   0830   fa 88             ANI $88
   0832   ca 08 50          LBNZ GEN_SLIDE_SE_RET
   0835   87                GLO 7
   0836   ab                PLO 11
   0837   d4 03 65          CALL CHECK_TARGET_SQUARE
   083a   ab                PLO 11              ; Save result to R11.0
   083b   c2 08 50          LBZ GEN_SLIDE_SE_RET
   083e   9b                GHI 11
   083f   bd                PHI 13
   0840   87                GLO 7
   0841   ad                PLO 13
   0842   f8 00             LDI MOVE_NORMAL
   0844   d4 03 e9          CALL ADD_MOVE_ENCODED
   0847   8b                GLO 11              ; Get result from R11.0
   0848   fb 02             XRI 2
   084a   c2 08 50          LBZ GEN_SLIDE_SE_RET
   084d   c0 08 2c          LBR GEN_SLIDE_SE_LOOP
   0850                 GEN_SLIDE_SE_RET:
