   0bb8   68 ca 64 0a       RLDI 10, UNDO_TO
   0bbc   0a                LDN 10              ; D = to_square
   0bbd   fc 00             ADI LOW(BOARD)
   0bbf   aa                PLO 10
   0bc0   f8 60             LDI HIGH(BOARD)
   0bc2   7c 00             ADCI 0
   0bc4   ba                PHI 10              ; R10 = &BOARD[to_square]
   0bc5   0a                LDN 10              ; D = moving piece
   0bc6   a8                PLO 8               ; R8.0 = moving piece
                        
   0bc7                 MM_HASH_GOT_PIECE:
                            ; Get from square
   0bc7   68 ca 64 09       RLDI 10, UNDO_FROM
   0bcb   0a                LDN 10              ; D = from_square
   0bcc   b8                PHI 8               ; R8.1 = from_square
   0bcd   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
                            ; --- Step 2: XOR out [captured, captured_square] ---
                            ; For normal captures: captured_square = to
