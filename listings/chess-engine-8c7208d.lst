   0c3e   09                LDN 9               ; D = cap_sq
   0c3f   52                STR 2
   0c40   68 c9 64 0a       RLDI 9, UNDO_TO
   0c44   09                LDN 9               ; D = to
   0c45   f3                XOR
   0c46   c2 0c 55          LBZ UM_CAP_DONE     ; cap_sq == to -> nothing more to do
                        
                            ; EP case: clear BOARD[to]
   0c49   68 c9 64 0a       RLDI 9, UNDO_TO
   0c4d   09                LDN 9
   0c4e   a8                PLO 8
   0c4f   f8 60             LDI HIGH(BOARD)
   0c51   b8                PHI 8
   0c52   f8 00             LDI EMPTY
   0c54   58                STR 8               ; BOARD[to] = EMPTY
                        
   0c55                 UM_CAP_DONE:
                        
                            ; =========================================
                            ; PAWN PROMOTION UNDO
                            ; =========================================
                            ; If UNDO_PROMOTION != 0, restore pawn instead of promoted piece
                            ; R10.0 = piece from BOARD[to] (promoted piece if promotion)
                            ; Guard: if piece is EMPTY, skip promotion undo (prevents phantom pawn
                            ; from corrupted UNDO_PROMOTION)
