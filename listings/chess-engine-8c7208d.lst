   0b3a   fb 01             XRI PAWN_TYPE
   0b3c   ca 0b 74          LBNZ MM_EP_CLEAR    ; Not a pawn -> clear EP
                        
                            ; Pawn moved. Check rank difference = $20 (double push)
   0b3f   68 c9 64 09       RLDI 9, UNDO_FROM
   0b43   09                LDN 9               ; D = from
   0b44   fa 70             ANI $70             ; from rank
   0b46   ad                PLO 13              ; R13.0 = from rank
   0b47   68 c9 64 0a       RLDI 9, UNDO_TO
   0b4b   09                LDN 9               ; D = to
   0b4c   fa 70             ANI $70             ; to rank
   0b4e   52                STR 2
   0b4f   8d                GLO 13              ; D = from rank
   0b50   f7                SM                  ; D = from_rank - to_rank
                        
