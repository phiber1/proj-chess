   0b79   ca 0b 8b          LBNZ MM_RESET_HALFMOVE
                        
                            ; Check if pawn moved (piece type == PAWN_TYPE)
   0b7c   8a                GLO 10              ; Get moving piece
   0b7d   fa 07             ANI PIECE_MASK      ; Get piece type
   0b7f   fb 01             XRI PAWN_TYPE       ; Is it a pawn?
   0b81   c2 0b 8b          LBZ MM_RESET_HALFMOVE
                        
