   0c61   8a                GLO 10              ; D = promoted piece
   0c62   fa 08             ANI COLOR_MASK      ; Get color (0=white, 8=black)
   0c64   f9 01             ORI PAWN_TYPE       ; D = pawn of same color
   0c66   aa                PLO 10              ; R10.0 = pawn (overwrites promoted piece)
                        
   0c67                 UM_NOT_PROMOTION:
                            ; Put moving piece back at from square
   0c67   68 c9 64 09       RLDI 9, UNDO_FROM
   0c6b   09                LDN 9               ; D = from square
   0c6c   a8                PLO 8
   0c6d   f8 60             LDI HIGH(BOARD)
   0c6f   b8                PHI 8               ; R8 = &BOARD[from]
   0c70   8a                GLO 10              ; D = moving piece (pawn if promotion)
   0c71   58                STR 8               ; Put back at from square
                        
                            ; =========================================
                            ; KING POSITION RESTORE
                            ; =========================================
                            ; If moving piece is a king, restore GAME_STATE king position to from square
                            ; R10.0 = moving piece
   0c72   8a                GLO 10              ; Get moving piece
   0c73   fa 07             ANI PIECE_MASK      ; Get piece type (0-6)
   0c75   fb 06             XRI KING_TYPE       ; Is it a king?
   0c77   ca 0d 0d          LBNZ UM_NOT_KING    ; Not a king, skip
                        
                            ; It's a king - restore king position in GAME_STATE
                            ; Check color of king (R10.0 has full piece)
   0c7a   8a                GLO 10
   0c7b   fa 08             ANI COLOR_MASK      ; Get color (0=white, 8=black)
   0c7d   ca 0c 87          LBNZ UM_BLACK_KING
                        
   0c80                 UM_WHITE_KING:
                            ; Update STATE_W_KING_SQ with UNDO_FROM
   0c80   68 c9 60 86       RLDI 9, GAME_STATE + STATE_W_KING_SQ
   0c84   c0 0c 8b          LBR UM_STORE_KING
                        
   0c87                 UM_BLACK_KING:
                            ; Update STATE_B_KING_SQ with UNDO_FROM
   0c87   68 c9 60 87       RLDI 9, GAME_STATE + STATE_B_KING_SQ
                        
   0c8b                 UM_STORE_KING:
                            ; Get UNDO_FROM and store as restored king square
   0c8b   68 c8 64 09       RLDI 8, UNDO_FROM
   0c8f   08                LDN 8               ; D = from square
   0c90   59                STR 9               ; Restore king position
                        
                            ; =========================================
                            ; CASTLING ROOK UNDO
                            ; =========================================
                            ; Detect: to - from = $02 (kingside) or $FE (queenside)
   0c91   68 c9 64 49       RLDI 9, COMPARE_TEMP
   0c95   68 c8 64 09       RLDI 8, UNDO_FROM
   0c99   08                LDN 8               ; D = from square
   0c9a   e9                SEX 9
   0c9b   59                STR 9               ; M(COMPARE_TEMP) = from
   0c9c   68 c8 64 0a       RLDI 8, UNDO_TO
   0ca0   08                LDN 8               ; D = to square
   0ca1   f7                SM                   ; D = to - from
   0ca2   e2                SEX 2
                        
   0ca3   fb 02             XRI $02
   0ca5   c2 0c b0          LBZ UM_CASTLE_KS     ; Kingside
   0ca8   fb fc             XRI $FC
   0caa   c2 0c e0          LBZ UM_CASTLE_QS     ; Queenside
   0cad   c0 0d 0d          LBR UM_NOT_KING      ; Normal king move
                        
   0cb0                 UM_CASTLE_KS:
                            ; Kingside undo: rook from to-1 (f-file) back to to+1 (h-file)
   0cb0   68 c9 64 0a       RLDI 9, UNDO_TO
   0cb4   09                LDN 9               ; D = to square
                        
                            ; Read rook from BOARD[to-1]
   0cb5   ff 01             SMI 1                ; D = to - 1
   0cb7   a8                PLO 8
   0cb8   f8 60             LDI HIGH(BOARD)
   0cba   b8                PHI 8               ; R8 = &BOARD[to-1]
   0cbb   08                LDN 8               ; D = rook piece
   0cbc   bd                PHI 13              ; R13.1 = rook piece (temp)
   0cbd   f8 00             LDI EMPTY
   0cbf   58                STR 8               ; Clear f1/f8
                        
                            ; Place rook back at BOARD[to+1]
   0cc0   09                LDN 9               ; D = to square
   0cc1   fc 01             ADI 1                ; D = to + 1
   0cc3   a8                PLO 8
   0cc4   f8 60             LDI HIGH(BOARD)
   0cc6   b8                PHI 8               ; R8 = &BOARD[to+1]
   0cc7   9d                GHI 13              ; D = rook piece
   0cc8   58                STR 8               ; Restore rook to h1/h8
                        
                            ; Hash: XOR [rook, to-1] (same pairs as make - XOR cancels)
   0cc9   9d                GHI 13              ; D = rook piece
   0cca   a8                PLO 8               ; R8.0 = rook piece
   0ccb   09                LDN 9               ; D = to square
   0ccc   ff 01             SMI 1                ; D = to - 1
   0cce   b8                PHI 8               ; R8.1 = f1/f8
   0ccf   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
                            ; Hash: XOR [rook, to+1] (R8.0 preserved)
   0cd2   68 c9 64 0a       RLDI 9, UNDO_TO
   0cd6   09                LDN 9               ; D = to square
   0cd7   fc 01             ADI 1                ; D = to + 1
   0cd9   b8                PHI 8               ; R8.1 = h1/h8
   0cda   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
   0cdd   c0 0d 0d          LBR UM_NOT_KING
                        
   0ce0                 UM_CASTLE_QS:
                            ; Queenside undo: rook from to+1 (d-file) back to to-2 (a-file)
   0ce0   68 c9 64 0a       RLDI 9, UNDO_TO
   0ce4   09                LDN 9               ; D = to square
                        
                            ; Read rook from BOARD[to+1]
   0ce5   fc 01             ADI 1                ; D = to + 1
   0ce7   a8                PLO 8
   0ce8   f8 60             LDI HIGH(BOARD)
   0cea   b8                PHI 8               ; R8 = &BOARD[to+1]
   0ceb   08                LDN 8               ; D = rook piece
   0cec   bd                PHI 13              ; R13.1 = rook piece (temp)
   0ced   f8 00             LDI EMPTY
   0cef   58                STR 8               ; Clear d1/d8
                        
                            ; Place rook back at BOARD[to-2]
   0cf0   09                LDN 9               ; D = to square
   0cf1   ff 02             SMI 2                ; D = to - 2
   0cf3   a8                PLO 8
   0cf4   f8 60             LDI HIGH(BOARD)
   0cf6   b8                PHI 8               ; R8 = &BOARD[to-2]
   0cf7   9d                GHI 13              ; D = rook piece
   0cf8   58                STR 8               ; Restore rook to a1/a8
                        
                            ; Hash: XOR [rook, to+1]
   0cf9   9d                GHI 13              ; D = rook piece
   0cfa   a8                PLO 8               ; R8.0 = rook piece
   0cfb   09                LDN 9               ; D = to square
   0cfc   fc 01             ADI 1                ; D = to + 1
   0cfe   b8                PHI 8               ; R8.1 = d1/d8
   0cff   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
                            ; Hash: XOR [rook, to-2] (R8.0 preserved)
   0d02   68 c9 64 0a       RLDI 9, UNDO_TO
   0d06   09                LDN 9               ; D = to square
   0d07   ff 02             SMI 2                ; D = to - 2
   0d09   b8                PHI 8               ; R8.1 = a1/a8
   0d0a   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
   0d0d                 UM_NOT_KING:
                            ; Restore castling rights to GAME_STATE + STATE_CASTLING
   0d0d   68 c9 64 0b       RLDI 9, UNDO_CASTLING
   0d11   09                LDN 9
   0d12   ba                PHI 10              ; Save in R10.1
                        
   0d13   68 c8 60 81       RLDI 8, GAME_STATE + STATE_CASTLING
   0d17   9a                GHI 10
   0d18   58                STR 8
                        
                            ; Restore en passant square to GAME_STATE + STATE_EP_SQUARE
   0d19   68 c9 64 0c       RLDI 9, UNDO_EP
   0d1d   09                LDN 9
   0d1e   18                INC 8               ; Point to EP_SQUARE ($6082)
   0d1f   58                STR 8
                        
                            ; Restore halfmove clock to GAME_STATE + STATE_HALFMOVE
   0d20   68 c9 64 0d       RLDI 9, UNDO_HALFMOVE
   0d24   09                LDN 9
   0d25   18                INC 8               ; Point to HALFMOVE ($6083)
   0d26   58                STR 8
                        
                            ; Toggle side to move back
   0d27   68 c8 60 80       RLDI 8, SIDE
   0d2b   08                LDN 8
   0d2c   fb 08             XRI BLACK           ; Toggle between 0 and 8
   0d2e   58                STR 8
                        
                            ; =========================================
                            ; HASH UPDATE: XOR piece-square changes (reverse of MAKE_MOVE)
                            ; =========================================
                            ; HASH_XOR_PIECE_SQ: R8.0 = piece, R8.1 = square
                            ; Clobbers: R7, R9, R10, R13. Preserves: R8
                            ; Board is now restored: piece at UNDO_FROM, captured at UNDO_TO
                            ;
                            ; For promotion: need to XOR out [promoted_piece, to], not [pawn, to]
                        
                            ; --- Step 1: XOR out [piece that WAS at to], to ---
                            ; Check if this was a promotion
   0d2f   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   0d33   0a                LDN 10              ; D = promotion type (0 if none)
   0d34   c2 0d 54          LBZ UM_HASH_NOT_PROMO
                        
                            ; Promotion: XOR out [promoted_piece, to]
                            ; Get color from BOARD[from] (the pawn), combine with promotion type
   0d37   68 ca 64 09       RLDI 10, UNDO_FROM
   0d3b   0a                LDN 10              ; D = from_square
   0d3c   fc 00             ADI LOW(BOARD)
   0d3e   aa                PLO 10
   0d3f   f8 60             LDI HIGH(BOARD)
   0d41   7c 00             ADCI 0
   0d43   ba                PHI 10              ; R10 = &BOARD[from_square]
   0d44   0a                LDN 10              ; D = pawn
   0d45   fa 08             ANI COLOR_MASK      ; Get color
   0d47   a8                PLO 8               ; R8.0 = color (temp)
   0d48   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   0d4c   0a                LDN 10              ; D = promotion piece type
   0d4d   52                STR 2               ; Save on stack
   0d4e   88                GLO 8               ; D = color
   0d4f   f4                ADD                 ; D = color + promotion_type = promoted piece
   0d50   a8                PLO 8               ; R8.0 = promoted piece
   0d51   c0 0d 63          LBR UM_HASH_GOT_PIECE
                        
   0d54                 UM_HASH_NOT_PROMO:
                            ; Normal move: XOR out [moving piece, to]
                            ; Moving piece is now at BOARD[UNDO_FROM]
   0d54   68 ca 64 09       RLDI 10, UNDO_FROM
   0d58   0a                LDN 10              ; D = from_square
   0d59   fc 00             ADI LOW(BOARD)
   0d5b   aa                PLO 10
   0d5c   f8 60             LDI HIGH(BOARD)
   0d5e   7c 00             ADCI 0
   0d60   ba                PHI 10              ; R10 = &BOARD[from_square]
   0d61   0a                LDN 10              ; D = moving piece
   0d62   a8                PLO 8               ; R8.0 = moving piece
                        
   0d63                 UM_HASH_GOT_PIECE:
                            ; Get to square
   0d63   68 ca 64 0a       RLDI 10, UNDO_TO
   0d67   0a                LDN 10              ; D = to_square
   0d68   b8                PHI 8               ; R8.1 = to_square
   0d69   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
                            ; --- Step 2: XOR in [captured, captured_square] ---
                            ; For normal captures: captured_square = to
                            ; For EP captures: captured_square = (from_rank | to_file)
   0d6c   68 ca 64 08       RLDI 10, UNDO_CAPTURED
   0d70   0a                LDN 10              ; D = captured piece
   0d71   a8                PLO 8               ; R8.0 = captured piece
   0d72   68 ca 64 ff       RLDI 10, UNDO_CAP_SQ
   0d76   0a                LDN 10              ; D = capture square
   0d77   b8                PHI 8               ; R8.1 = capture square
   0d78   d4 57 bf          CALL HASH_XOR_PIECE_SQ  ; skips if captured == EMPTY
                        
                            ; --- Step 3: XOR in [moving piece, from] ---
                            ; Moving piece is at BOARD[UNDO_FROM]
   0d7b   68 ca 64 09       RLDI 10, UNDO_FROM
   0d7f   0a                LDN 10              ; D = from_square
   0d80   b8                PHI 8               ; R8.1 = from_square
                            ; Compute BOARD[from_square]
   0d81   fc 00             ADI LOW(BOARD)
   0d83   aa                PLO 10
   0d84   f8 60             LDI HIGH(BOARD)
   0d86   7c 00             ADCI 0
   0d88   ba                PHI 10              ; R10 = &BOARD[from_square]
   0d89   0a                LDN 10              ; D = moving piece
   0d8a   a8                PLO 8               ; R8.0 = moving piece
   0d8b   d4 57 bf          CALL HASH_XOR_PIECE_SQ
                        
                            ; --- Step 4: XOR side ---
   0d8e   d4 58 22          CALL HASH_XOR_SIDE
                        
   0d91   d5                SEP 5
                        
                        ; ==============================================================================
                        ; NULL_MAKE_MOVE - Make a null move (pass - just toggle side)
                        ; ==============================================================================
                        ; Used by null move pruning. No actual piece moves.
                        ; Input: None
                        ; Output: Side toggled, hash updated, EP cleared
                        ; Saves: EP square to NULL_SAVED_EP for unmake
                        ; ==============================================================================
   0d92                 NULL_MAKE_MOVE:
                            ; Save EP square to NULL_SAVED_EP
   0d92   68 ca 60 82       RLDI 10, GAME_STATE + STATE_EP_SQUARE
   0d96   0a                LDN 10              ; D = current EP square
   0d97   a7                PLO 7               ; Save in R7.0
   0d98   68 ca 64 a8       RLDI 10, NULL_SAVED_EP
   0d9c   87                GLO 7
   0d9d   5a                STR 10              ; NULL_SAVED_EP = old EP
                        
                            ; Clear EP square (no EP after null move)
   0d9e   68 ca 60 82       RLDI 10, GAME_STATE + STATE_EP_SQUARE
   0da2   f8 ff             LDI $FF             ; Invalid EP
   0da4   5a                STR 10
                        
                            ; Toggle side to move
   0da5   68 ca 60 80       RLDI 10, GAME_STATE + STATE_SIDE_TO_MOVE
   0da9   0a                LDN 10
   0daa   fb 08             XRI $08             ; Toggle 0 <-> 8
   0dac   5a                STR 10
                        
                            ; Update hash for side change
   0dad   d4 58 22          CALL HASH_XOR_SIDE
                        
   0db0   d5                RETN
                        
                        ; ==============================================================================
                        ; NULL_UNMAKE_MOVE - Undo a null move
                        ; ==============================================================================
                        ; Restores state from before null move
                        ; Input: None
                        ; Output: Side toggled back, hash restored, EP restored
                        ; ==============================================================================
   0db1                 NULL_UNMAKE_MOVE:
                            ; Toggle side back
   0db1   68 ca 60 80       RLDI 10, GAME_STATE + STATE_SIDE_TO_MOVE
   0db5   0a                LDN 10
   0db6   fb 08             XRI $08             ; Toggle 8 <-> 0
   0db8   5a                STR 10
                        
                            ; Restore EP square from NULL_SAVED_EP
   0db9   68 ca 64 a8       RLDI 10, NULL_SAVED_EP
   0dbd   0a                LDN 10              ; D = saved EP
   0dbe   a7                PLO 7               ; Save in R7.0
   0dbf   68 ca 60 82       RLDI 10, GAME_STATE + STATE_EP_SQUARE
   0dc3   87                GLO 7
   0dc4   5a                STR 10              ; Restore EP
                        
                            ; Update hash for side change (XOR again = restore)
   0dc5   d4 58 22          CALL HASH_XOR_SIDE
                        
   0dc8   d5                RETN
                        
                        ; ==============================================================================
                        ; END OF MAKE/UNMAKE MODULE
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Position Evaluation
                        ; ==============================================================================
                        ; Evaluate board position and return score
                        ; Positive score favors white, negative favors black
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; Piece Values (in centipawns)
                        ; ------------------------------------------------------------------------------
   0064                 PAWN_VALUE      EQU 100
   0140                 KNIGHT_VALUE    EQU 320
   014a                 BISHOP_VALUE    EQU 330
   01f4                 ROOK_VALUE      EQU 500
   0384                 QUEEN_VALUE     EQU 900
   4e20                 KING_VALUE      EQU 20000   ; Effectively infinite (not used in material count)
                        
                        ; Check bonus: credit the attacker when side-to-move is in check.
                        ; Applied at EVAL exit — rewards moves that deliver check, encourages
                        ; attacking play (especially with queen) in endgame mate-chasing.
   0028                 CHECK_BONUS     EQU 40
                        
                        ; Queen-king proximity bonus (Chebyshev distance lookup).
                        ; Indexed by distance 0-7. Distance 0 unreachable (queen can't be on king's
                        ; square). Encourages queen to attack enemy king in endgame, addressing the
                        ; "queen sits idle" pattern that emerged after the queen-cap removed
                        ; multi-promotion incentive.
   0dc9                 QUEEN_PROX_BONUS:
   0dc9   00                DB 0    ; distance 0 (not reachable)
   0dca   3c                DB 60   ; distance 1 (adjacent — strongest attack)
   0dcb   32                DB 50   ; distance 2
   0dcc   28                DB 40   ; distance 3
   0dcd   1e                DB 30   ; distance 4
   0dce   14                DB 20   ; distance 5
   0dcf   0a                DB 10   ; distance 6
   0dd0   00                DB 0    ; distance 7 (far — no bonus)
                        
                        ; King-safety tables (2026-06-11). SHIELD_PEN indexed by shield_missing (0-3);
                        ; STORM_PEN indexed by (3 - chebyshev_dist) so dist1->idx2, dist2->idx1. Penalties
                        ; are positive magnitudes; max SHIELD(100)+STORM(150)=250 fits one byte.
   0dd1                 SHIELD_PEN:
   0dd1   00 19 3c 64       DB 0, 25, 60, 100       ; missing 0,1,2,3 shield pawns
   0dd5                 STORM_PEN:
   0dd5   00 50 96          DB 0, 80, 150           ; idx 0 (dist3, unused), 1 (dist2), 2 (dist1)
                        ; (DEFENSE_CREDIT table removed 2026-07-13 — see KING_SAFETY note.)
                        ; Racing-passer bonus (2026-06-13): EXTRA value for an advanced white passer with a
                        ; clear front, ramping toward queen value so white pushes it (the d5 search can't
                        ; see the promotion). Indexed by rank-5/6/7. 16-bit (big-endian DW) — > one byte.
   0dd8                 RUNNER_BONUS:
   0dd8   00 96 01 5e       DW 150, 350, 600       ; rank 5, rank 6, rank 7
   0ddc   02 58         
                        
                        ; Piece value table (indexed by piece type 0-6)
   0dde                 PIECE_VALUES:
   0dde   00 00             DW 0            ; Empty (type 0)
   0de0   00 64             DW 100          ; Pawn (type 1)
   0de2   01 40             DW 320          ; Knight (type 2)
   0de4   01 4a             DW 330          ; Bishop (type 3)
   0de6   01 f4             DW 500          ; Rook (type 4)
   0de8   03 84             DW 900          ; Queen (type 5)
   0dea   00 00             DW 0            ; King (type 6) - don't count in material
                        
                        ; ------------------------------------------------------------------------------
                        ; EVALUATE - Main evaluation function
                        ; ------------------------------------------------------------------------------
                        ; Input:  A = board pointer (BOARD)
                        ; Output: R9 = evaluation score (16-bit signed)
                        ;         Positive = white advantage
                        ;         Negative = black advantage
                        ; NOTE:   Returns in R9, NOT R6! R6 is SCRT linkage register - off limits!
                        ; Uses:   All registers except R6
                        ;
                        ; Components (in order of implementation):
                        ;   1. Material count (DONE)
                        ;   2. Piece-square tables (TODO)
                        ;   3. Pawn structure (TODO)
                        ;   4. King safety (TODO)
                        ;   5. Mobility (TODO)
                        ; ------------------------------------------------------------------------------
                        
                        ; ------------------------------------------------------------------------------
                        ; CHECK_INSUFFICIENT_MATERIAL - Detect the canonical dead-draw material configs
                        ; ------------------------------------------------------------------------------
                        ; Returns D = 1 if the position is one of:
                        ;   K vs K, K+N vs K, K+B vs K, K+B vs K+B (bishops on same square colour)
                        ; else D = 0.  These are the four cases where neither side can force mate
                        ; (item C — added 2026-05-18).  Returning 0 from EVALUATE for these stops the
                        ; engine meandering in drawn endgames until the 50-move rule.
                        ;
                        ; Scans BOARD once, early-aborting to "not draw" the moment a pawn, rook, or
                        ; queen is seen, or when the minor count exceeds 2.  In any position with
                        ; pawns/rooks/queens (every opening/middlegame) the very first occupied square
                        ; aborts the scan, so cost is ~1 iteration in normal play; only true bare-king
                        ; endgames pay the full 128-square walk.
                        ;
                        ; Provably safe for non-drawn positions: the short-circuit only fires when
                        ; material is EXACTLY one of the four configs above. Any pawn/rook/queen or a
                        ; 3rd minor falls through untouched — cannot alter winning/losing eval.
                        ;
                        ; Uses: R7 (sq index), R8 (piece + type/sqcolor scratch), R10 (board ptr),
                        ;       R11 (.0=minor total, .1=white bishop count),
                        ;       R13 (.0=black bishop count, .1=bishop sq-colour bits)
                        ; Does NOT touch R6 (SCRT) or R9 (caller score, not yet set at call site).
                        ; ------------------------------------------------------------------------------
   0dec                 CHECK_INSUFFICIENT_MATERIAL:
   0dec   f8 00             LDI 0
   0dee   ab                PLO 11              ; R11.0 = minor total (bishops + knights)
   0def   bb                PHI 11              ; R11.1 = white bishop count
   0df0   ad                PLO 13              ; R13.0 = black bishop count
   0df1   bd                PHI 13              ; R13.1 = bishop sq-colour bits (b0=W, b1=B)
                        
   0df2   f8 00             LDI 0
   0df4   a7                PLO 7               ; R7.0 = square index 0
                        
   0df5                 CIM_LOOP:
   0df5   87                GLO 7
   0df6   fa 88             ANI $88
   0df8   ca 0e 60          LBNZ CIM_NEXT       ; off-board 0x88 square, skip
                        
                            ; R10 = BOARD + sq
   0dfb   87                GLO 7
   0dfc   fc 00             ADI LOW(BOARD)
   0dfe   aa                PLO 10
   0dff   f8 60             LDI HIGH(BOARD)
   0e01   7c 00             ADCI 0
   0e03   ba                PHI 10
   0e04   0a                LDN 10              ; D = piece
   0e05   c2 0e 60          LBZ CIM_NEXT        ; empty square
                        
   0e08   a8                PLO 8               ; R8.0 = full piece byte (kept all loop)
   0e09   fa 07             ANI PIECE_MASK      ; D = piece type 1-6
   0e0b   b8                PHI 8               ; R8.1 = piece type
                        
   0e0c   fb 06             XRI KING_TYPE       ; king? (always present, never counted)
   0e0e   c2 0e 60          LBZ CIM_NEXT
                        
   0e11   98                GHI 8               ; type
   0e12   fb 01             XRI PAWN_TYPE
   0e14   c2 0e 8f          LBZ CIM_NOT_DRAW    ; any pawn → not insufficient
   0e17   98                GHI 8
   0e18   fb 04             XRI ROOK_TYPE
   0e1a   c2 0e 8f          LBZ CIM_NOT_DRAW    ; any rook → not insufficient
   0e1d   98                GHI 8
   0e1e   fb 05             XRI QUEEN_TYPE
   0e20   c2 0e 8f          LBZ CIM_NOT_DRAW    ; any queen → not insufficient
                        
                            ; piece is a minor (knight=2 or bishop=3)
   0e23   8b                GLO 11
   0e24   fc 01             ADI 1
   0e26   ab                PLO 11              ; minor total++
   0e27   ff 03             SMI 3
   0e29   c3 0e 8f          LBDF CIM_NOT_DRAW   ; >=3 minors → not one of the four cases
                        
   0e2c   98                GHI 8               ; type
   0e2d   fb 03             XRI BISHOP_TYPE
   0e2f   ca 0e 60          LBNZ CIM_NEXT       ; knight — counted in total, nothing more
                        
                            ; --- bishop: compute its square colour = ((sq>>4)+(sq&7)) & 1 ---
   0e32   87                GLO 7
   0e33   fa 07             ANI $07             ; file
   0e35   52                STR 2               ; M(R2) = file
   0e36   87                GLO 7
   0e37   f6                SHR
   0e38   f6                SHR
   0e39   f6                SHR
   0e3a   f6                SHR                 ; D = sq>>4 = rank (valid sq → high nibble 0-7)
   0e3b   f4                ADD                 ; D = rank + file
   0e3c   fa 01             ANI $01             ; D = square colour 0/1
   0e3e   b8                PHI 8               ; R8.1 = square colour
                        
   0e3f   88                GLO 8               ; full piece byte
   0e40   fa 08             ANI COLOR_MASK      ; 0 = white bishop, 8 = black bishop
   0e42   ca 0e 54          LBNZ CIM_BLACK_B
                        
                            ; white bishop
   0e45   9b                GHI 11
   0e46   fc 01             ADI 1
   0e48   bb                PHI 11              ; white bishop count++
   0e49   98                GHI 8               ; square colour
   0e4a   c2 0e 60          LBZ CIM_NEXT        ; colour 0 → leave bit0 clear
   0e4d   9d                GHI 13
   0e4e   f9 01             ORI $01
   0e50   bd                PHI 13              ; bit0 = white bishop on colour-1 square
   0e51   c0 0e 60          LBR CIM_NEXT
                        
   0e54                 CIM_BLACK_B:
   0e54   8d                GLO 13
   0e55   fc 01             ADI 1
   0e57   ad                PLO 13              ; black bishop count++
   0e58   98                GHI 8               ; square colour
   0e59   c2 0e 60          LBZ CIM_NEXT
   0e5c   9d                GHI 13
   0e5d   f9 02             ORI $02
   0e5f   bd                PHI 13              ; bit1 = black bishop on colour-1 square
                        
   0e60                 CIM_NEXT:
   0e60   87                GLO 7
   0e61   fc 01             ADI 1
   0e63   a7                PLO 7
   0e64   fb 80             XRI $80             ; scanned squares 0..127?
   0e66   ca 0d f5          LBNZ CIM_LOOP
                        
                            ; --- decision ---
   0e69   8b                GLO 11              ; minor total
   0e6a   c2 0e 8c          LBZ CIM_DRAW        ; 0 minors → K vs K
   0e6d   ff 01             SMI 1
   0e6f   c2 0e 8c          LBZ CIM_DRAW        ; 1 minor  → K+N vs K or K+B vs K (either side)
                        
                            ; minor total == 2 (>=3 already rejected mid-scan).
                            ; Draw only if exactly one bishop per side AND same square colour.
   0e72   9b                GHI 11              ; white bishop count
   0e73   ff 01             SMI 1
   0e75   ca 0e 8f          LBNZ CIM_NOT_DRAW   ; != 1
   0e78   8d                GLO 13              ; black bishop count
   0e79   ff 01             SMI 1
   0e7b   ca 0e 8f          LBNZ CIM_NOT_DRAW   ; != 1
   0e7e   9d                GHI 13
   0e7f   fa 03             ANI $03             ; b0=white sqcolour, b1=black sqcolour
   0e81   c2 0e 8c          LBZ CIM_DRAW        ; 00 → both colour-0 → same → draw
   0e84   fb 03             XRI $03
   0e86   c2 0e 8c          LBZ CIM_DRAW        ; 11 → both colour-1 → same → draw
   0e89   c0 0e 8f          LBR CIM_NOT_DRAW    ; 01/10 → opposite colours (not in item-C list)
                        
   0e8c                 CIM_DRAW:
   0e8c   f8 01             LDI 1
   0e8e   d5                RETN
                        
   0e8f                 CIM_NOT_DRAW:
   0e8f   f8 00             LDI 0
   0e91   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
   0e92                 EVALUATE:
                            ; Ensure X=2 for all stack/memory operations
   0e92   e2                SEX 2
                        
   0e93   68 ca 64 1d       RLDI 10, TRACE_WHERE
   0e97   f8 e1             LDI $E1
   0e99   5a                STR 10              ; tracer: in EVALUATE
                        
                            ; Insufficient-material dead-draw short-circuit (item C, 2026-05-18).
                            ; Safe by construction: only fires for K-K / K+N-K / K+B-K / K+B-K+B
                            ; same-colour; any other material falls through to the full eval.
   0e9a   d4 0d ec          CALL CHECK_INSUFFICIENT_MATERIAL
   0e9d   c2 0e a5          LBZ EVAL_NOT_DEAD_DRAW
   0ea0   f8 00             LDI 0
   0ea2   b9                PHI 9
   0ea3   a9                PLO 9              ; R9 = 0 (draw)
   0ea4   d5                RETN
   0ea5                 EVAL_NOT_DEAD_DRAW:
                        
                            ; Initialize score to 0
                            ; NOTE: Use R9 for score, NOT R6! R6 is SCRT linkage register!
   0ea5   f8 00             LDI 0
   0ea7   b9                PHI 9
   0ea8   a9                PLO 9              ; R9 = 0 (score accumulator)
                        
                            ; Scan board and count material
   0ea9   68 ca 60 00       RLDI 10, BOARD
                        
                            ; Initialize square counter in memory (avoid R14!)
   0ead   68 cd 64 1d       RLDI 13, EVAL_SQ_INDEX
   0eb1   f8 00             LDI 0
   0eb3   5d                STR 13              ; EVAL_SQ_INDEX = 0
                        
                            ; Initialize piece counter in memory (D is still 0)
   0eb4   68 cb 64 ec       RLDI 11, EG_PIECE_COUNT
   0eb8   5b                STR 11              ; EG_PIECE_COUNT = 0
                        
                            ; Initialize advanced pawn counters (D is still 0)
   0eb9   68 cb 64 fd       RLDI 11, ADV_PAWN_W
   0ebd   5b                STR 11              ; ADV_PAWN_W = 0
   0ebe   1b                INC 11
   0ebf   5b                STR 11              ; ADV_PAWN_B = 0
                        
                            ; Initialize pawn file counts: 16 bytes at $6710-$671F (D is still 0)
   0ec0   68 cb 67 10       RLDI 11, W_PAWN_FILE_CT
   0ec4   f8 10             LDI 16              ; 16 bytes to clear
   0ec6   a8                PLO 8               ; R8.0 = loop counter
   0ec7                 EVAL_CLR_PAWN_CT:
   0ec7   f8 00             LDI 0
   0ec9   5b                STR 11
   0eca   1b                INC 11
   0ecb   28                DEC 8
   0ecc   88                GLO 8
   0ecd   ca 0e c7          LBNZ EVAL_CLR_PAWN_CT
                        
                            ; Initialize bishop counts + rook file trackers + queen counts
   0ed0   f8 00             LDI 0
   0ed2   68 cb 64 af       RLDI 11, EVAL_W_BISHOPS
   0ed6   5b                STR 11              ; EVAL_W_BISHOPS = 0
   0ed7   1b                INC 11
   0ed8   5b                STR 11              ; EVAL_B_BISHOPS = 0
   0ed9   68 cb 64 b5       RLDI 11, W_QUEEN_CNT
   0edd   5b                STR 11              ; W_QUEEN_CNT = 0
   0ede   1b                INC 11
   0edf   5b                STR 11              ; B_QUEEN_CNT = 0
   0ee0   1b                INC 11
   0ee1   5b                STR 11              ; PIECE_BALANCE = 0 ($64B7, signed W-B non-pawn count; D still 0)
                            ; Rook files = $FF (no rook); queen squares also default to $FF (no queen)
   0ee2   f8 ff             LDI $FF
   0ee4   68 cb 64 b1       RLDI 11, EVAL_W_ROOK_F1
   0ee8   5b                STR 11              ; EVAL_W_ROOK_F1 = $FF
   0ee9   1b                INC 11
   0eea   5b                STR 11              ; EVAL_W_ROOK_F2 = $FF
   0eeb   1b                INC 11
   0eec   5b                STR 11              ; EVAL_B_ROOK_F1 = $FF
   0eed   1b                INC 11
   0eee   5b                STR 11              ; EVAL_B_ROOK_F2 = $FF
   0eef   68 cb 67 20       RLDI 11, W_QUEEN_SQ
   0ef3   5b                STR 11              ; W_QUEEN_SQ = $FF
   0ef4   1b                INC 11
   0ef5   5b                STR 11              ; B_QUEEN_SQ = $FF
                        
   0ef6                 EVAL_SCAN:
                            ; Check if square is valid (R13 points to EVAL_SQ_INDEX)
   0ef6   0d                LDN 13
   0ef7   fa 88             ANI $88
   0ef9   ca 10 77          LBNZ EVAL_NEXT_SQUARE
                        
                            ; Load piece at square
   0efc   0a                LDN 10
   0efd   c2 10 77          LBZ EVAL_NEXT_SQUARE ; Empty square
                        
                            ; Get piece type and color
                            ; NOTE: R13 must stay pointing to EVAL_SQ_INDEX - use R8 for piece temp!
   0f00   a8                PLO 8               ; R8.0 = piece (temp storage)
                        
                            ; Check color
   0f01   fa 08             ANI COLOR_MASK
   0f03   af                PLO 15              ; F.0 = color (0=white, 8=black)
                        
                            ; Get piece type
   0f04   88                GLO 8               ; Get piece back from R8.0
   0f05   fa 07             ANI PIECE_MASK
   0f07   a8                PLO 8               ; R8.0 = piece type (1-6)
                        
                            ; Skip king (type 6)
   0f08   fb 06             XRI 6
   0f0a   c2 10 77          LBZ EVAL_NEXT_SQUARE
                        
                            ; Count non-king piece (memory variable — R12 is side-to-move, off limits)
   0f0d   68 cb 64 ec       RLDI 11, EG_PIECE_COUNT
   0f11   0b                LDN 11
   0f12   fc 01             ADI 1
   0f14   5b                STR 11
                        
                            ; Accumulate SIGNED non-pawn piece balance (W-B) for the white RUNNER_BONUS gate
                            ; (2026-06-30). type in R8.0 (1-5; king already skipped), color in R15. White N/B/R/Q
                            ; -> +1, black -> -1. R11/D clobbered (both reloaded below).
   0f15   88                GLO 8
   0f16   ff 02             SMI 2               ; type - 2  (DF=0 if type < 2, i.e. pawn)
   0f18   cb 0f 2e          LBNF EVAL_PB_DONE   ; pawn -> not a piece, skip
   0f1b   68 cb 64 b7       RLDI 11, PIECE_BALANCE
   0f1f   8f                GLO 15              ; color (0=white, 8=black)
   0f20   ca 0f 2a          LBNZ EVAL_PB_BLACK  ; black -> decrement
   0f23   0b                LDN 11              ; white: balance + 1
   0f24   fc 01             ADI 1
   0f26   5b                STR 11
   0f27   c0 0f 2e          LBR EVAL_PB_DONE
   0f2a                 EVAL_PB_BLACK:
   0f2a   0b                LDN 11              ; black: balance - 1
   0f2b   ff 01             SMI 1
   0f2d   5b                STR 11
   0f2e                 EVAL_PB_DONE:
                        
                            ; Check if pawn for advanced pawn bonus (graduated)
   0f2e   88                GLO 8               ; piece type (1-5)
   0f2f   fb 01             XRI 1
   0f31   ca 0f ab          LBNZ EVAL_NOT_ADV_PAWN  ; not a pawn (+3 instr for non-pawns)
                            ; Pawn — extract rank from 0x88 square
   0f34   0d                LDN 13              ; D = 0x88 square (from EVAL_SQ_INDEX)
   0f35   fa 70             ANI $70             ; D = rank << 4 ($00-$70)
   0f37   52                STR 2               ; save rank<<4 on stack
   0f38   8f                GLO 15              ; D = color (0=white, 8=black)
   0f39   ca 0f 75          LBNZ EVAL_BP_ADV
                            ; === White pawn: rank 7=$60 (+150), rank 6=$50 (+100), rank 5=$40 (+50), rank 4=$30 (+25) ===
   0f3c   02                LDN 2
   0f3d   fb 60             XRI $60
   0f3f   c2 0f 5e          LBZ EVAL_WP_R7
   0f42   02                LDN 2
   0f43   fb 50             XRI $50
   0f45   c2 0f 63          LBZ EVAL_WP_R6
   0f48   02                LDN 2
   0f49   fb 40             XRI $40
   0f4b   c2 0f 59          LBZ EVAL_WP_R5
   0f4e   02                LDN 2
   0f4f   fb 30             XRI $30
   0f51   ca 0f ab          LBNZ EVAL_NOT_ADV_PAWN
   0f54   f8 19             LDI 25              ; rank 4
   0f56   c0 0f 65          LBR EVAL_WP_ADD
   0f59                 EVAL_WP_R5:
   0f59   f8 32             LDI 50              ; rank 5
   0f5b   c0 0f 65          LBR EVAL_WP_ADD
   0f5e                 EVAL_WP_R7:
   0f5e   f8 96             LDI 150             ; rank 7
   0f60   c0 0f 65          LBR EVAL_WP_ADD
   0f63                 EVAL_WP_R6:
   0f63   f8 64             LDI 100             ; rank 6
   0f65                 EVAL_WP_ADD:
   0f65   52                STR 2
   0f66   68 cb 64 fd       RLDI 11, ADV_PAWN_W
   0f6a   0b                LDN 11
   0f6b   f4                ADD
   0f6c   cb 0f 71          LBNF EVAL_WP_NOSAT  ; DF=0: no carry, no overflow
   0f6f   f8 ff             LDI 255             ; Overflow: saturate at 255
   0f71                 EVAL_WP_NOSAT:
   0f71   5b                STR 11              ; ADV_PAWN_W = min(sum, 255)
   0f72   c0 0f ab          LBR EVAL_NOT_ADV_PAWN
   0f75                 EVAL_BP_ADV:
                            ; === Black pawn: rank 2=$10 (+150), rank 3=$20 (+100), rank 4=$30 (+50), rank 5=$40 (+25) ===
   0f75   02                LDN 2
   0f76   fb 10             XRI $10
   0f78   c2 0f 97          LBZ EVAL_BP_R2
   0f7b   02                LDN 2
   0f7c   fb 20             XRI $20
   0f7e   c2 0f 9c          LBZ EVAL_BP_R3
   0f81   02                LDN 2
   0f82   fb 30             XRI $30
   0f84   c2 0f 92          LBZ EVAL_BP_R4
   0f87   02                LDN 2
   0f88   fb 40             XRI $40
   0f8a   ca 0f ab          LBNZ EVAL_NOT_ADV_PAWN
   0f8d   f8 19             LDI 25              ; rank 5
   0f8f   c0 0f 9e          LBR EVAL_BP_ADD
   0f92                 EVAL_BP_R4:
   0f92   f8 32             LDI 50              ; rank 4
   0f94   c0 0f 9e          LBR EVAL_BP_ADD
   0f97                 EVAL_BP_R2:
   0f97   f8 96             LDI 150             ; rank 2
   0f99   c0 0f 9e          LBR EVAL_BP_ADD
   0f9c                 EVAL_BP_R3:
   0f9c   f8 64             LDI 100             ; rank 3
   0f9e                 EVAL_BP_ADD:
   0f9e   52                STR 2
   0f9f   68 cb 64 fe       RLDI 11, ADV_PAWN_B
   0fa3   0b                LDN 11
   0fa4   f4                ADD
   0fa5   cb 0f aa          LBNF EVAL_BP_NOSAT  ; DF=0: no carry, no overflow
   0fa8   f8 ff             LDI 255             ; Overflow: saturate at 255
   0faa                 EVAL_BP_NOSAT:
   0faa   5b                STR 11              ; ADV_PAWN_B = min(sum, 255)
   0fab                 EVAL_NOT_ADV_PAWN:
                        
                            ; ==================================================================
                            ; Track pawn files, bishop count, rook files for structure eval
                            ; R8.0 = piece type (1-6), R15.0 = color, R13 -> EVAL_SQ_INDEX
                            ; ==================================================================
                        
                            ; --- PAWN: increment per-file count ---
   0fab   88                GLO 8               ; piece type
   0fac   fb 01             XRI 1               ; pawn?
   0fae   ca 0f d6          LBNZ EVAL_NOT_PAWN_TRACK
   0fb1   0d                LDN 13              ; D = 0x88 square
   0fb2   fa 07             ANI $07             ; D = file (0-7)
   0fb4   52                STR 2               ; save file on stack
   0fb5   8f                GLO 15              ; color
   0fb6   ca 0f c9          LBNZ EVAL_BP_COUNT
                            ; White pawn: W_PAWN_FILE_CT[file]++
   0fb9   02                LDN 2               ; D = file
   0fba   fc 10             ADI LOW(W_PAWN_FILE_CT)
   0fbc   ab                PLO 11
   0fbd   f8 67             LDI HIGH(W_PAWN_FILE_CT)
   0fbf   7c 00             ADCI 0
   0fc1   bb                PHI 11              ; R11 = &W_PAWN_FILE_CT[file]
   0fc2   0b                LDN 11
   0fc3   fc 01             ADI 1
   0fc5   5b                STR 11
   0fc6   c0 0f d6          LBR EVAL_NOT_PAWN_TRACK
   0fc9                 EVAL_BP_COUNT:
                            ; Black pawn: B_PAWN_FILE_CT[file]++
   0fc9   02                LDN 2               ; D = file
   0fca   fc 18             ADI LOW(B_PAWN_FILE_CT)
   0fcc   ab                PLO 11
   0fcd   f8 67             LDI HIGH(B_PAWN_FILE_CT)
   0fcf   7c 00             ADCI 0
   0fd1   bb                PHI 11              ; R11 = &B_PAWN_FILE_CT[file]
   0fd2   0b                LDN 11
   0fd3   fc 01             ADI 1
   0fd5   5b                STR 11
   0fd6                 EVAL_NOT_PAWN_TRACK:
                        
                            ; --- BISHOP: count per color ---
   0fd6   88                GLO 8               ; piece type
   0fd7   fb 03             XRI 3               ; bishop?
   0fd9   ca 0f f3          LBNZ EVAL_NOT_BISHOP_TRACK
   0fdc   8f                GLO 15              ; color
   0fdd   ca 0f eb          LBNZ EVAL_BB_TRACK
   0fe0   68 cb 64 af       RLDI 11, EVAL_W_BISHOPS
   0fe4   0b                LDN 11
   0fe5   fc 01             ADI 1
   0fe7   5b                STR 11
   0fe8   c0 0f f3          LBR EVAL_NOT_BISHOP_TRACK
   0feb                 EVAL_BB_TRACK:
   0feb   68 cb 64 b0       RLDI 11, EVAL_B_BISHOPS
   0fef   0b                LDN 11
   0ff0   fc 01             ADI 1
   0ff2   5b                STR 11
   0ff3                 EVAL_NOT_BISHOP_TRACK:
                        
                            ; --- ROOK: save file number (up to 2 per side) ---
   0ff3   88                GLO 8               ; piece type
   0ff4   fb 04             XRI 4               ; rook?
   0ff6   ca 10 2e          LBNZ EVAL_NOT_ROOK_TRACK
   0ff9   0d                LDN 13              ; 0x88 square
   0ffa   fa 07             ANI $07             ; D = file (0-7)
   0ffc   b8                PHI 8               ; save file in R8.1
   0ffd   8f                GLO 15              ; color
   0ffe   ca 10 19          LBNZ EVAL_BROOK_TRACK
                            ; White rook: store in F1 or F2
   1001   68 cb 64 b1       RLDI 11, EVAL_W_ROOK_F1
   1005   0b                LDN 11
   1006   fb ff             XRI $FF             ; is F1 empty?
   1008   ca 10 10          LBNZ EVAL_WR_F2
   100b   98                GHI 8               ; D = file
   100c   5b                STR 11              ; F1 = file
   100d   c0 10 2e          LBR EVAL_NOT_ROOK_TRACK
   1010                 EVAL_WR_F2:
   1010   68 cb 64 b2       RLDI 11, EVAL_W_ROOK_F2
   1014   98                GHI 8
   1015   5b                STR 11              ; F2 = file
   1016   c0 10 2e          LBR EVAL_NOT_ROOK_TRACK
   1019                 EVAL_BROOK_TRACK:
                            ; Black rook: store in F1 or F2
   1019   68 cb 64 b3       RLDI 11, EVAL_B_ROOK_F1
   101d   0b                LDN 11
   101e   fb ff             XRI $FF
   1020   ca 10 28          LBNZ EVAL_BR_F2
   1023   98                GHI 8
   1024   5b                STR 11
   1025   c0 10 2e          LBR EVAL_NOT_ROOK_TRACK
   1028                 EVAL_BR_F2:
   1028   68 cb 64 b4       RLDI 11, EVAL_B_ROOK_F2
   102c   98                GHI 8
   102d   5b                STR 11
   102e                 EVAL_NOT_ROOK_TRACK:
                        
                            ; --- QUEEN: count + remember square (for redundant-queen cap and proximity bonus) ---
   102e   88                GLO 8               ; piece type
   102f   fb 05             XRI 5               ; queen?
   1031   ca 10 57          LBNZ EVAL_NOT_QUEEN_TRACK
   1034   8f                GLO 15              ; color
   1035   ca 10 49          LBNZ EVAL_BQ_TRACK
                            ; White queen
   1038   68 cb 64 b5       RLDI 11, W_QUEEN_CNT
   103c   0b                LDN 11
   103d   fc 01             ADI 1
   103f   5b                STR 11
   1040   0d                LDN 13              ; current 0x88 square from EVAL_SQ_INDEX
   1041   68 cb 67 20       RLDI 11, W_QUEEN_SQ
   1045   5b                STR 11
   1046   c0 10 57          LBR EVAL_NOT_QUEEN_TRACK
   1049                 EVAL_BQ_TRACK:
                            ; Black queen
   1049   68 cb 64 b6       RLDI 11, B_QUEEN_CNT
   104d   0b                LDN 11
   104e   fc 01             ADI 1
   1050   5b                STR 11
   1051   0d                LDN 13              ; current 0x88 square from EVAL_SQ_INDEX
   1052   68 cb 67 21       RLDI 11, B_QUEEN_SQ
   1056   5b                STR 11
   1057                 EVAL_NOT_QUEEN_TRACK:
                        
                            ; Get piece value from table
                            ; R8.0 = piece type (1-6), need to look up in PIECE_VALUES table
   1057   88                GLO 8               ; Piece type from R8.0
   1058   fe                SHL                 ; Multiply by 2 (16-bit table entries)
   1059   52                STR 2               ; Save offset to stack
   105a   f8 de             LDI LOW(PIECE_VALUES)
   105c   f4                ADD                 ; D = LOW(PIECE_VALUES) + offset
   105d   ab                PLO 11              ; R11.0 = low byte of address
   105e   f8 0d             LDI HIGH(PIECE_VALUES)
   1060   7c 00             ADCI 0              ; Add carry if low byte overflowed
   1062   bb                PHI 11              ; R11 = PIECE_VALUES + (type * 2)
                        
                            ; Load 16-bit value
   1063   4b                LDA 11
   1064   b7                PHI 7              ; 7.1 = value high
   1065   0b                LDN 11
   1066   a7                PLO 7              ; 7.0 = value low
                                                ; 7 = piece value
                        
                            ; Add or subtract based on color
   1067   8f                GLO 15              ; Color
   1068   32 6d             BZ EVAL_ADD_WHITE
                        
   106a                 EVAL_ADD_BLACK:
                            ; Black piece - subtract from score (negate 7)
   106a   d4 00 0f          CALL NEG16_R7
                            ; Fall through to add
                        
   106d                 EVAL_ADD_WHITE:
                            ; White piece or negated black - add to score
                            ; R9 = R9 + R7 (using R9 for score, not R6 which is SCRT linkage!)
   106d   89                GLO 9
   106e   52                STR 2
   106f   87                GLO 7
   1070   f4                ADD
   1071   a9                PLO 9
   1072   99                GHI 9
   1073   52                STR 2
   1074   97                GHI 7
   1075   74                ADC
   1076   b9                PHI 9
                            ; 6 updated with new score
                        
   1077                 EVAL_NEXT_SQUARE:
   1077   1a                INC 10              ; Next square
                            ; Increment square counter in memory (R13 still points to EVAL_SQ_INDEX)
   1078   0d                LDN 13
   1079   fc 01             ADI 1
   107b   5d                STR 13
   107c   ff 80             SMI 128
   107e   cb 0e f6          LBNF EVAL_SCAN      ; Continue if < 128 (DF=0 means borrow, i.e., D was < 128)
                        
   1081                 EVAL_DONE:
                            ; R9 contains material score
                        
                            ; ==================================================================
                            ; Redundant-queen cap (RETUNED 2026-07-15): extra queens beyond the
                            ; first score 500 cp, not 0. The 0-cap (anti-3-queen-shuffle) was
                            ; side-symmetric and DELETED the OPPONENT's 2nd queen from the ledger:
                            ; move 47 vs b1=Q read Rxc2 as "+500, opponent gains nothing" and the
                            ; engine walked into a Q-vs-2Q mate reading +773. At 500/extra the
                            ; anti-shuffle intent survives (2nd queen << 900, promotion never
                            ; outbids mating) but an enemy 2nd queen stays a live threat.
                            ; Implementation: subtract (W_QUEEN_CNT - 1) * 400 from white side,
                            ; add (B_QUEEN_CNT - 1) * 400 for black side (900 - 400 = 500 net).
                            ; ==================================================================
                        
                            ; --- White side ---
   1081   68 c8 64 b5       RLDI 8, W_QUEEN_CNT
   1085   08                LDN 8
   1086   c2 10 a3          LBZ QC_W_DONE       ; 0 queens: nothing to cap
   1089   ff 01             SMI 1
   108b   c2 10 a3          LBZ QC_W_DONE       ; 1 queen: no extras
                        
   108e   a7                PLO 7               ; R7.0 = number of extras (>= 1)
   108f   f8 00             LDI 0
   1091   b7                PHI 7               ; clean R7.1 for predictable DEC
                        
   1092                 QC_W_LOOP:
   1092   f8 90             LDI $90             ; low byte of 400 ($0190)
   1094   52                STR 2
   1095   89                GLO 9
   1096   f7                SM
   1097   a9                PLO 9
   1098   f8 01             LDI $01             ; high byte of 400
   109a   52                STR 2
   109b   99                GHI 9
   109c   77                SMB
   109d   b9                PHI 9
   109e   27                DEC 7
   109f   87                GLO 7
   10a0   ca 10 92          LBNZ QC_W_LOOP
   10a3                 QC_W_DONE:
                        
                            ; --- Black side (extras flip sign: ADD 900 each) ---
   10a3   68 c8 64 b6       RLDI 8, B_QUEEN_CNT
   10a7   08                LDN 8
   10a8   c2 10 c5          LBZ QC_B_DONE
   10ab   ff 01             SMI 1
   10ad   c2 10 c5          LBZ QC_B_DONE
                        
   10b0   a7                PLO 7
   10b1   f8 00             LDI 0
   10b3   b7                PHI 7
                        
   10b4                 QC_B_LOOP:
   10b4   f8 90             LDI $90             ; low byte of 400
   10b6   52                STR 2
   10b7   89                GLO 9
   10b8   f4                ADD
   10b9   a9                PLO 9
   10ba   f8 01             LDI $01             ; high byte of 400
   10bc   52                STR 2
   10bd   99                GHI 9
   10be   74                ADC
   10bf   b9                PHI 9
   10c0   27                DEC 7
   10c1   87                GLO 7
   10c2   ca 10 b4          LBNZ QC_B_LOOP
   10c5                 QC_B_DONE:
                        
                            ; ==================================================================
                            ; Queen-king proximity bonus
                            ; For each side that has a queen, bonus = lookup[chebyshev_distance]
                            ; from queen to enemy king. Encourages attacking play in endgame
                            ; (paired with queen-cap which removed the redundant-promotion bias).
                            ; ==================================================================
                        
                            ; --- White queen → black king proximity ---
   10c5   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   10c9   08                LDN 8
   10ca   fb ff             XRI $FF
   10cc   c2 11 20          LBZ QP_W_DONE       ; W_QUEEN_SQ == $FF (no queen), skip
                        
                            ; D was XOR'd; reload queen square
   10cf   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   10d3   08                LDN 8
   10d4   b7                PHI 7               ; R7.1 = W queen 0x88 square
                        
   10d5   68 c8 60 87       RLDI 8, GAME_STATE + STATE_B_KING_SQ
   10d9   08                LDN 8
   10da   b8                PHI 8               ; R8.1 = B king 0x88 square (use R8.1 to free R8.0)
                        
                            ; |q_rank - k_rank|
   10db   97                GHI 7
   10dc   fa 70             ANI $70
   10de   f6                SHR
   10df   f6                SHR
   10e0   f6                SHR
   10e1   f6                SHR                 ; D = q_rank
   10e2   ad                PLO 13              ; R13.0 = q_rank
   10e3   98                GHI 8
   10e4   fa 70             ANI $70
   10e6   f6                SHR
   10e7   f6                SHR
   10e8   f6                SHR
   10e9   f6                SHR                 ; D = k_rank
   10ea   52                STR 2
   10eb   8d                GLO 13
   10ec   f5                SD                  ; D = k_rank - q_rank
   10ed   c3 10 f2          LBDF QP_W_RANK_OK
   10f0   fd 00             SDI 0               ; negate to get magnitude
   10f2                 QP_W_RANK_OK:
   10f2   bd                PHI 13              ; R13.1 = |rank diff|
                        
                            ; |q_file - k_file|
   10f3   97                GHI 7
   10f4   fa 07             ANI $07             ; D = q_file
   10f6   ad                PLO 13              ; R13.0 = q_file
   10f7   98                GHI 8
   10f8   fa 07             ANI $07             ; D = k_file
   10fa   52                STR 2
   10fb   8d                GLO 13
   10fc   f5                SD                  ; D = k_file - q_file
   10fd   c3 11 02          LBDF QP_W_FILE_OK
   1100   fd 00             SDI 0
   1102                 QP_W_FILE_OK:
   1102   ad                PLO 13              ; R13.0 = |file diff|
                        
                            ; max(R13.1, R13.0)
   1103   9d                GHI 13
   1104   52                STR 2
   1105   8d                GLO 13
   1106   f5                SD                  ; D = R13.1 - R13.0 (rank - file)
   1107   c3 11 0e          LBDF QP_W_USE_RANK
   110a   8d                GLO 13              ; file > rank → max = file
   110b   c0 11 0f          LBR QP_W_HAVE_DIST
   110e                 QP_W_USE_RANK:
   110e   9d                GHI 13              ; rank >= file → max = rank
   110f                 QP_W_HAVE_DIST:
                            ; D = chebyshev distance (1-7 typically, 0 impossible)
   110f   fc c9             ADI LOW(QUEEN_PROX_BONUS)
   1111   ab                PLO 11
   1112   f8 00             LDI 0
   1114   7c 0d             ADCI HIGH(QUEEN_PROX_BONUS)
   1116   bb                PHI 11
   1117   0b                LDN 11              ; D = bonus
   1118   52                STR 2
   1119   89                GLO 9
   111a   f4                ADD
   111b   a9                PLO 9
   111c   99                GHI 9
   111d   7c 00             ADCI 0
   111f   b9                PHI 9
   1120                 QP_W_DONE:
                        
                            ; --- Black queen → white king proximity (subtract bonus from R9) ---
   1120   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   1124   08                LDN 8
   1125   fb ff             XRI $FF
   1127   c2 11 7b          LBZ QP_B_DONE
                        
   112a   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   112e   08                LDN 8
   112f   b7                PHI 7
                        
   1130   68 c8 60 86       RLDI 8, GAME_STATE + STATE_W_KING_SQ
   1134   08                LDN 8
   1135   b8                PHI 8
                        
                            ; |q_rank - k_rank|
   1136   97                GHI 7
   1137   fa 70             ANI $70
   1139   f6                SHR
   113a   f6                SHR
   113b   f6                SHR
   113c   f6                SHR
   113d   ad                PLO 13
   113e   98                GHI 8
   113f   fa 70             ANI $70
   1141   f6                SHR
   1142   f6                SHR
   1143   f6                SHR
   1144   f6                SHR
   1145   52                STR 2
   1146   8d                GLO 13
   1147   f5                SD
   1148   c3 11 4d          LBDF QP_B_RANK_OK
   114b   fd 00             SDI 0
   114d                 QP_B_RANK_OK:
   114d   bd                PHI 13
                        
                            ; |q_file - k_file|
   114e   97                GHI 7
   114f   fa 07             ANI $07
   1151   ad                PLO 13
   1152   98                GHI 8
   1153   fa 07             ANI $07
   1155   52                STR 2
   1156   8d                GLO 13
   1157   f5                SD
   1158   c3 11 5d          LBDF QP_B_FILE_OK
   115b   fd 00             SDI 0
   115d                 QP_B_FILE_OK:
   115d   ad                PLO 13
                        
                            ; max
   115e   9d                GHI 13
   115f   52                STR 2
   1160   8d                GLO 13
   1161   f5                SD
   1162   c3 11 69          LBDF QP_B_USE_RANK
   1165   8d                GLO 13
   1166   c0 11 6a          LBR QP_B_HAVE_DIST
   1169                 QP_B_USE_RANK:
   1169   9d                GHI 13
   116a                 QP_B_HAVE_DIST:
   116a   fc c9             ADI LOW(QUEEN_PROX_BONUS)
   116c   ab                PLO 11
   116d   f8 00             LDI 0
   116f   7c 0d             ADCI HIGH(QUEEN_PROX_BONUS)
   1171   bb                PHI 11
   1172   0b                LDN 11              ; D = bonus
   1173   52                STR 2
   1174   89                GLO 9
   1175   f7                SM                  ; subtract bonus from white-relative score
   1176   a9                PLO 9
   1177   99                GHI 9
   1178   7f 00             SMBI 0
   117a   b9                PHI 9
   117b                 QP_B_DONE:
                        
                            ; ==================================================================
                            ; King safety (2026-06-11): pawn-shield + enemy-queen "storm".
                            ; The base had NO king safety (only the +20 castling-RIGHTS bonus), which
                            ; let ELPH get mated while up a queen (queen on a6, king g1 stripped bare).
                            ; KING_SAFETY(R7.0=king sq, R7.1=enemy queen sq, R8.0=friendly pawn code,
                            ; R8.1=shield "ahead" offset) -> D = penalty (0-250). Shield-aware: a fully
                            ; shielded king scores 0 (queen near a fortress is fine); penalty grows with
                            ; missing shield pawns and an enemy queen within Chebyshev 2. Always-on
                            ; (naturally ~0 in endgames: no enemy queen / king active).
                            ; ==================================================================
   117b   68 c8 60 86       RLDI 8, GAME_STATE + STATE_W_KING_SQ
   117f   08                LDN 8
   1180   a7                PLO 7               ; R7.0 = white king sq
   1181   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   1185   08                LDN 8
   1186   b7                PHI 7               ; R7.1 = enemy (black) queen sq ($FF if none)
   1187   f8 01             LDI W_PAWN
   1189   a8                PLO 8               ; R8.0 = friendly pawn code ($01)
   118a   f8 10             LDI $10
   118c   b8                PHI 8               ; R8.1 = ahead offset (white: +1 rank)
   118d   d4 17 83          CALL KING_SAFETY
   1190   52                STR 2
   1191   89                GLO 9
   1192   f7                SM                  ; R9 -= white king danger
   1193   a9                PLO 9
   1194   99                GHI 9
   1195   7f 00             SMBI 0
   1197   b9                PHI 9
                        
   1198   68 c8 60 87       RLDI 8, GAME_STATE + STATE_B_KING_SQ
   119c   08                LDN 8
   119d   a7                PLO 7               ; R7.0 = black king sq
   119e   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   11a2   08                LDN 8
   11a3   b7                PHI 7               ; R7.1 = enemy (white) queen sq
   11a4   f8 09             LDI B_PAWN
   11a6   a8                PLO 8               ; R8.0 = friendly pawn code ($09)
   11a7   f8 f0             LDI $F0
   11a9   b8                PHI 8               ; R8.1 = ahead offset (black: -1 rank)
   11aa   d4 17 83          CALL KING_SAFETY
   11ad   52                STR 2
   11ae   89                GLO 9
   11af   f4                ADD                 ; R9 += black king danger
   11b0   a9                PLO 9
   11b1   99                GHI 9
   11b2   7c 00             ADCI 0
   11b4   b9                PHI 9
                        
                            ; --- O-O-O discomfort (ported 2026-07-13, task #53): queenside king
                            ; posture vs a developed enemy queen (files a-d). Returns D = signed net
                            ; (-50/0/+50); sign-extend and add to R9. Routine in the $7B00 page.
                            ; Master IS exposed: losses 2+3 (7/2, 7/3) were master-line storm mates.
   11b5   d4 7b 00          CALL OOO_DISCOMFORT
   11b8   52                STR 2               ; M(2) = signed adjustment
   11b9   fa 80             ANI $80
   11bb   c2 11 c3          LBZ OOO_SEXT_POS
   11be   f8 ff             LDI $FF
   11c0   c0 11 c5          LBR OOO_SEXT_GO
   11c3                 OOO_SEXT_POS:
   11c3   f8 00             LDI $00
   11c5                 OOO_SEXT_GO:
   11c5   b8                PHI 8               ; R8.1 = sign-extension byte
   11c6   89                GLO 9
   11c7   f4                ADD                 ; R9.lo += adjustment (M(2))
   11c8   a9                PLO 9
   11c9   98                GHI 8
   11ca   52                STR 2
   11cb   99                GHI 9
   11cc   74                ADC                 ; R9.hi += sign byte + carry
   11cd   b9                PHI 9
                        
                            ; Add piece-square table bonuses
   11ce   d4 19 f4          CALL EVAL_PST
                        
                            ; ==================================================================
                            ; Castling Rights Bonus
                            ; +20cp per side that still has castling rights remaining
                            ; Incentivizes preserving the option to castle
                            ; ==================================================================
   11d1   68 cb 60 81       RLDI 11, GAME_STATE + STATE_CASTLING
   11d5   0b                LDN 11              ; D = castling rights byte
   11d6   52                STR 2               ; save for reuse
   11d7   fa 03             ANI $03             ; white bits (WK|WQ)
   11d9   c2 11 e4          LBZ EVAL_NO_W_CASTLE
   11dc   89                GLO 9
   11dd   fc 14             ADI 20
   11df   a9                PLO 9
   11e0   99                GHI 9
   11e1   7c 00             ADCI 0
   11e3   b9                PHI 9               ; R9 += 20 (white has castling rights)
   11e4                 EVAL_NO_W_CASTLE:
   11e4   02                LDN 2               ; reload castling byte
   11e5   fa 0c             ANI $0C             ; black bits (BK|BQ)
   11e7   c2 11 f2          LBZ EVAL_NO_B_CASTLE
   11ea   89                GLO 9
   11eb   ff 14             SMI 20
   11ed   a9                PLO 9
   11ee   99                GHI 9
   11ef   7f 00             SMBI 0
   11f1   b9                PHI 9               ; R9 -= 20 (black has castling rights)
   11f2                 EVAL_NO_B_CASTLE:
                        
                            ; ==================================================================
                            ; Queen mobility (2026-06-17, always-on): low magnitude (mobility x2 = ~2cp/
                            ; square) to break ties toward an active queen without overriding material or
                            ; distorting trades. Tunable: SHL=x2 (start), SHL SHL=x4. Watch in matches for
                            ; premature queen sorties (the one real risk). See QUEEN_MOBILITY.
                            ; ==================================================================
   11f2   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   11f6   08                LDN 8
   11f7   a7                PLO 7                   ; R7.0 = white queen sq
   11f8   fb ff             XRI $FF
   11fa   c2 12 09          LBZ QMOB_BLACK          ; no white queen, skip
   11fd   d4 18 29          CALL QUEEN_MOBILITY     ; D = mobility (0..27)
   1200   fe                SHL                     ; x2 (low magnitude)
   1201   52                STR 2
   1202   89                GLO 9
   1203   f4                ADD
   1204   a9                PLO 9
   1205   99                GHI 9
   1206   7c 00             ADCI 0
   1208   b9                PHI 9                   ; R9 += white queen mobility x2
   1209                 QMOB_BLACK:
   1209   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   120d   08                LDN 8
   120e   a7                PLO 7                   ; R7.0 = black queen sq
   120f   fb ff             XRI $FF
   1211   c2 12 20          LBZ QMOB_DONE           ; no black queen, skip
   1214   d4 18 29          CALL QUEEN_MOBILITY
   1217   fe                SHL                     ; x2
   1218   52                STR 2
   1219   89                GLO 9
   121a   f7                SM                      ; D = R9.0 - mobility x2
   121b   a9                PLO 9
   121c   99                GHI 9
   121d   7f 00             SMBI 0
   121f   b9                PHI 9                   ; R9 -= black queen mobility x2
   1220                 QMOB_DONE:
                        
                            ; ==================================================================
                            ; Doubled Pawn Penalty: -15cp per extra pawn on same file
                            ; Iterate 8 files; if count >= 2, penalty += (count - 1) * 15
                            ; ==================================================================
                        
                            ; --- White doubled pawns ---
   1220   68 cb 67 10       RLDI 11, W_PAWN_FILE_CT     ; $6710
   1224   f8 08             LDI 8
   1226   ad                PLO 13                      ; R13.0 = file counter (temp, will restore later)
   1227   f8 00             LDI 0
   1229   b7                PHI 7                       ; R7.1 = white doubled penalty accumulator
   122a                 EVAL_WDP_LOOP:
   122a   4b                LDA 11                      ; D = pawn count for this file, R11++
   122b   ff 02             SMI 2                       ; D = count - 2 (DF=1 if count >= 2)
   122d   cb 12 3e          LBNF EVAL_WDP_NEXT          ; count < 2, no doubled
                            ; count >= 2: penalty = (count - 1) * 15
                            ; D = count - 2, so D + 1 = count - 1
   1230   fc 01             ADI 1                       ; D = count - 1
                            ; Multiply by 15: x*16 - x = (x<<4) - x
                            ; But with 8-bit arithmetic, max extra pawns = 7, 7*15 = 105 fits in byte
   1232   a7                PLO 7                       ; save (count-1) in R7.0
   1233   fe                SHL
   1234   fe                SHL
   1235   fe                SHL
   1236   fe                SHL                         ; D = (count-1) * 16
   1237   52                STR 2                       ; M(R2) = (count-1) * 16
   1238   87                GLO 7                       ; D = (count-1)
   1239   f5                SD                          ; D = M(R2) - D = (count-1)*16 - (count-1) = (count-1)*15
   123a   52                STR 2                       ; save penalty on stack
   123b   97                GHI 7                       ; accumulated penalty
   123c   f4                ADD                         ; D = accumulated + this file's penalty
   123d   b7                PHI 7                       ; update accumulator
   123e                 EVAL_WDP_NEXT:
   123e   2d                DEC 13
   123f   8d                GLO 13
   1240   ca 12 2a          LBNZ EVAL_WDP_LOOP
                            ; R7.1 = total white doubled penalty (always positive)
                            ; Subtract from score (penalty for white)
   1243   97                GHI 7
   1244   c2 12 4f          LBZ EVAL_WDP_DONE           ; skip if 0
   1247   52                STR 2
   1248   89                GLO 9
   1249   f7                SM                          ; R9.0 - penalty
   124a   a9                PLO 9
   124b   99                GHI 9
   124c   7f 00             SMBI 0
   124e   b9                PHI 9                       ; R9 -= white doubled penalty
   124f                 EVAL_WDP_DONE:
                        
                            ; --- Black doubled pawns ---
   124f   68 cb 67 18       RLDI 11, B_PAWN_FILE_CT     ; $6718
   1253   f8 08             LDI 8
   1255   ad                PLO 13
   1256   f8 00             LDI 0
   1258   b7                PHI 7
   1259                 EVAL_BDP_LOOP:
   1259   4b                LDA 11
   125a   ff 02             SMI 2
   125c   cb 12 6d          LBNF EVAL_BDP_NEXT
   125f   fc 01             ADI 1                       ; D = count - 1
   1261   a7                PLO 7
   1262   fe                SHL
   1263   fe                SHL
   1264   fe                SHL
   1265   fe                SHL                         ; (count-1) * 16
   1266   52                STR 2
   1267   87                GLO 7
   1268   f5                SD                          ; (count-1) * 15
   1269   52                STR 2
   126a   97                GHI 7
   126b   f4                ADD
   126c   b7                PHI 7
   126d                 EVAL_BDP_NEXT:
   126d   2d                DEC 13
   126e   8d                GLO 13
   126f   ca 12 59          LBNZ EVAL_BDP_LOOP
                            ; Add black penalty to score (good for white)
   1272   97                GHI 7
   1273   c2 12 7e          LBZ EVAL_BDP_DONE
   1276   52                STR 2
   1277   89                GLO 9
   1278   f4                ADD
   1279   a9                PLO 9
   127a   99                GHI 9
   127b   7c 00             ADCI 0
   127d   b9                PHI 9                       ; R9 += black doubled penalty
   127e                 EVAL_BDP_DONE:
                        
                            ; ==================================================================
