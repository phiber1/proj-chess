   0aa8   c2 0a b3          LBZ MM_CASTLE_KS     ; to - from = 2: kingside
   0aab   fb fc             XRI $FC              ; XOR chain: checks if original was $FE
   0aad   c2 0a e3          LBZ MM_CASTLE_QS     ; to - from = $FE: queenside
   0ab0   c0 0b 21          LBR MM_NOT_KING      ; Normal king move
                        
   0ab3                 MM_CASTLE_KS:
                            ; Kingside: rook from to+1 (h-file) to to-1 (f-file)
   0ab3   68 c9 64 0a       RLDI 9, UNDO_TO
   0ab7   09                LDN 9               ; D = to square
                        
