   22ae   1a                INC 10
   22af   88                GLO 8               ; new_beta_lo
   22b0   5a                STR 10              ; BETA = -alpha
                        
                            ; ----------------------------------------------------------------
                            ; LMR-RESEARCH FIX 2026-05-06: refresh CHECK_EXT_FLAG before re-search.
                            ; The first reduced-depth call's child overwrote CHECK_EXT_FLAG with
                            ; whatever its last move-loop iteration left (typically 0 for non-checking
                            ; quiet moves). Re-search child's snapshot would read this stale value,
                            ; breaking the LMP in-check guard at line ~1238 even though our move IS
                            ; a check.  R12 is currently BLACK (child's color = opponent of parent
                            ; at root), so direct IS_IN_CHECK checks the opponent's king — exactly
                            ; what we want for "did parent's move give check".
                            ; ----------------------------------------------------------------
   22b1   d4 01 8e          CALL IS_IN_CHECK
   22b4   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   22b8   5a                STR 10              ; CHECK_EXT_FLAG = fresh "in check?" result
                        
                            ; --- BUGFIX (carried from 09ccdcf, origin 2e3333a 2026-01-27): preserve
                            ; LMR_MOVE_INDEX across the re-search. The first (reduced) CALL NEGAMAX
                            ; saves/restores it; this full-depth re-search call did NOT, so the child
                            ; reset+incremented it and never restored this node's value -> corrupts
                            ; LMP/LMR state and, via the LMR_REDUCED-gated SEARCH_DEPTH decrement, can
                            ; underflow depth -> near-infinite child search = the freeze-class hang.
                            ; Latent in 7b3a53d (bug predates it). Push before / restore after.
   22b9   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   22bd   0a                LDN 10
   22be   73                STXD                ; push LMR_MOVE_INDEX
                        
                            ; Increment ply for recursive call
   22bf   68 ca 64 48       RLDI 10, CURRENT_PLY
   22c3   0a                LDN 10
   22c4   fc 01             ADI 1
   22c6   5a                STR 10              ; CURRENT_PLY++
                        
                            ; Call NEGAMAX again (full depth this time)
   22c7   d4 1b 58          CALL NEGAMAX
                        
                            ; DIAG stamp (2026-07-17 hang hunt): back from LMR re-search child.
   22ca   68 ca 64 1d       RLDI 10, TRACE_WHERE
   22ce   f8 a7             LDI $A7
   22d0   5a                STR 10              ; tracer: post-LMR-re-search (R10 reloaded below)
                        
                            ; Restore LMR_MOVE_INDEX (the re-searched child clobbered it)
   22d1   60                IRX
   22d2   f0                LDX                 ; D = saved LMR_MOVE_INDEX
   22d3   a7                PLO 7               ; temp (R7.0 dead here — R9 holds the score)
   22d4   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   22d8   87                GLO 7
   22d9   5a                STR 10              ; LMR_MOVE_INDEX restored to this node's value
                        
                            ; Decrement ply
   22da   68 ca 64 48       RLDI 10, CURRENT_PLY
   22de   0a                LDN 10
   22df   ff 01             SMI 1
   22e1   5a                STR 10              ; CURRENT_PLY--
                        
                            ; Negate R9 (score = -score)
   22e2   89                GLO 9               ; low byte
   22e3   fd 00             SDI 0               ; negate low
   22e5   a9                PLO 9
   22e6   99                GHI 9               ; high byte
   22e7   7d 00             SDBI 0              ; negate high with borrow
   22e9   b9                PHI 9
                        
                            ; Save to SCORE_HI/LO
   22ea   68 ca 64 46       RLDI 10, SCORE_HI
   22ee   99                GHI 9               ; high byte → SCORE_HI (lower address)
   22ef   5a                STR 10
   22f0   1a                INC 10
   22f1   89                GLO 9               ; low byte → SCORE_LO (higher address)
   22f2   5a                STR 10
                        
   22f3                 LMR_NO_RESEARCH:
                        
                            ; -----------------------------------------------
                            ; Restore BEST_SCORE from stack FIRST (it was pushed last - LIFO!)
                            ; This was corrupted by child's NEGAMAX initialization!
                            ; -----------------------------------------------
   22f3   68 ca 64 0f       RLDI 10, BEST_SCORE_LO
   22f7   60                IRX
   22f8   72                LDXA                ; BEST_SCORE_LO
   22f9   5a                STR 10
   22fa   2a                DEC 10
   22fb   f0                LDX                 ; BEST_SCORE_HI (R2 stays at this slot)
   22fc   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Restore UNDO_* from stack (7 bytes) before UNMAKE_MOVE
                            ; -----------------------------------------------
                            ; UNDO_CAP_SQ first (it was pushed last - LIFO)
   22fd   68 ca 64 ff       RLDI 10, UNDO_CAP_SQ
   2301   60                IRX
   2302   f0                LDX                 ; UNDO_CAP_SQ
   2303   5a                STR 10
                            ; UNDO_PROMOTION next
   2304   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   2308   60                IRX
   2309   f0                LDX                 ; UNDO_PROMOTION
   230a   5a                STR 10
                            ; Now restore the contiguous block ($6408-$640D)
   230b   68 ca 64 0d       RLDI 10, UNDO_HALFMOVE
   230f   60                IRX
   2310   72                LDXA                ; UNDO_HALFMOVE
   2311   5a                STR 10
   2312   2a                DEC 10
   2313   72                LDXA                ; UNDO_EP
   2314   5a                STR 10
   2315   2a                DEC 10
   2316   72                LDXA                ; UNDO_CASTLING
   2317   5a                STR 10
   2318   2a                DEC 10
   2319   72                LDXA                ; UNDO_TO
   231a   5a                STR 10
   231b   2a                DEC 10
   231c   72                LDXA                ; UNDO_FROM
   231d   5a                STR 10
   231e   2a                DEC 10
   231f   f0                LDX                 ; UNDO_CAPTURED (last, no inc)
   2320   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Unmake the move
                            ; -----------------------------------------------
   2321   d4 0c 2e          CALL UNMAKE_MOVE
                            ; Board restored to previous state
                        
                            ; -----------------------------------------------
                            ; Restore context (memory-based alpha/beta - R6 is SCRT linkage!)
                            ; -----------------------------------------------
                            ; Stack order (low to high): beta_lo, beta_hi, alpha_lo, alpha_hi, depth_lo, depth_hi, R9
                        
                            ; Pop beta from stack to BETA memory (big-endian)
   2324   60                IRX                 ; Point to beta_lo
   2325   72                LDXA                ; D = beta_lo
   2326   a7                PLO 7               ; R7.0 = beta_lo
   2327   72                LDXA                ; D = beta_hi
   2328   b7                PHI 7               ; R7.1 = beta_hi, R7 = beta
   2329   68 cd 64 44       RLDI 13, BETA_HI
   232d   97                GHI 7
   232e   5d                STR 13              ; BETA_HI (high byte at lower addr)
   232f   1d                INC 13
   2330   87                GLO 7
   2331   5d                STR 13              ; BETA_LO (low byte at higher addr)
                        
                            ; Pop alpha from stack to ALPHA memory (NO extra IRX - R2 already at alpha_lo)
   2332   72                LDXA                ; D = alpha_lo
   2333   a7                PLO 7               ; R7.0 = alpha_lo
   2334   72                LDXA                ; D = alpha_hi
   2335   b7                PHI 7               ; R7.1 = alpha_hi, R7 = alpha
   2336   68 cd 64 42       RLDI 13, ALPHA_HI
   233a   97                GHI 7
   233b   5d                STR 13              ; ALPHA_HI (high byte at lower addr)
   233c   1d                INC 13
   233d   87                GLO 7
   233e   5d                STR 13              ; ALPHA_LO (low byte at higher addr)
                        
                            ; Pop depth from stack to SEARCH_DEPTH memory
                            ; Stack has: depth_lo, depth_hi (depth_lo at lower addr)
                            ; R9 no longer on stack; move count no longer on stack (LOOP_MOVE_CNT) —
                            ; depth_hi is now the TOP byte of this iteration's search-context frame.
   233f   72                LDXA                ; D = depth_lo, R2 advances to depth_hi
   2340   a7                PLO 7               ; Temp
   2341   f0                LDX                 ; D = depth_hi, R2 stays AT depth_hi (frame top)
   2342   b7                PHI 7               ; R7 = depth (temp: hi.lo)
   2343   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   2347   97                GHI 7
   2348   5d                STR 13              ; SEARCH_DEPTH high
   2349   1d                INC 13
   234a   87                GLO 7
   234b   5d                STR 13              ; SEARCH_DEPTH+1 low
                        
                            ; Toggle color back to parent's color (0/8)
   234c   8c                GLO 12
   234d   fb 08             XRI $08
   234f   ac                PLO 12              ; C = color restored
                        
                            ; Restore R9 (move list pointer) from ply-indexed memory
   2350   68 ca 64 48       RLDI 10, CURRENT_PLY
   2354   0a                LDN 10              ; D = ply
   2355   fe                SHL                 ; D = ply * 2
   2356   fc db             ADI LOW(LOOP_MOVE_PTR)
   2358   aa                PLO 10
   2359   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   235b   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   235c   4a                LDA 10
   235d   b9                PHI 9               ; R9.hi
   235e   0a                LDN 10
   235f   a9                PLO 9               ; R9 = move list pointer restored
                        
                            ; Load score from SCORE memory into R13 (R9 is move list pointer!)
                            ; Big-endian: high byte at lower address (SCORE_HI)
   2360   68 ca 64 46       RLDI 10, SCORE_HI
   2364   4a                LDA 10              ; SCORE_HI -> high byte
   2365   bd                PHI 13
   2366   0a                LDN 10              ; SCORE_LO -> low byte
   2367   ad                PLO 13              ; R13 = negated score from memory
                        
                            ; -----------------------------------------------
                            ; Beta Cutoff Check: if (score >= beta) return beta
                            ; -----------------------------------------------
                            ; Compare score (R13) with beta (from BETA memory)
                            ; Score is already saved to SCORE_HI/LO, can reload if needed
                        
                            ; Load beta from memory into R7 (use R10 as pointer, preserve R13=score)
                            ; Big-endian: high byte at lower address (BETA_HI)
   2368   68 ca 64 44       RLDI 10, BETA_HI
   236c   4a                LDA 10              ; D = beta_hi
   236d   b7                PHI 7
   236e   0a                LDN 10              ; D = beta_lo
   236f   a7                PLO 7               ; R7 = beta (loaded from memory)
                        
                            ; SIGNED comparison: score (R13) vs beta (R7)
                            ; Use COMPARE_TEMP for scratch (NEVER use STR 2 for scratch!)
   2370   68 ca 64 49       RLDI 10, COMPARE_TEMP
   2374   ea                SEX 10              ; X = R10 for comparisons
                        
                            ; First check if signs differ
   2375   9d                GHI 13              ; score high byte
   2376   5a                STR 10
   2377   97                GHI 7               ; beta high byte
   2378   f3                XOR                 ; XOR high bytes
   2379   fa 80             ANI $80             ; Check if sign bits differ
   237b   e2                SEX 2               ; X = R2 (restore for branches)
   237c   ca 23 91          LBNZ NEGAMAX_BETA_DIFF_SIGN
                        
                            ; Same sign - use subtraction result
                            ; Compute score - beta: SM does D - M(X), SD does M(X) - D
   237f   ea                SEX 10
   2380   87                GLO 7
   2381   5a                STR 10              ; M(R10) = beta_lo
   2382   8d                GLO 13              ; D = score_lo
   2383   f7                SM                  ; D = D - M(X) = score_lo - beta_lo
   2384   97                GHI 7
   2385   5a                STR 10              ; M(R10) = beta_hi
   2386   9d                GHI 13              ; D = score_hi
   2387   77                SMB                 ; D = D - M(X) - borrow = score_hi - beta_hi - borrow
   2388   e2                SEX 2               ; X = R2 (restore)
                        
                            ; Check sign bit (negative means score < beta, no cutoff)
   2389   fa 80             ANI $80
   238b   ca 24 06          LBNZ NEGAMAX_NO_BETA_CUTOFF  ; score < beta, no cutoff
                            ; Fall through to cutoff (score >= beta)
   238e   c0 23 97          LBR NEGAMAX_DO_BETA_CUTOFF
                        
   2391                 NEGAMAX_BETA_DIFF_SIGN:
                            ; Different signs - positive number is greater
   2391   9d                GHI 13              ; score high byte
   2392   fa 80             ANI $80
   2394   ca 24 06          LBNZ NEGAMAX_NO_BETA_CUTOFF  ; Score negative, beta positive: score < beta, NO cutoff
                            ; Score positive, beta negative: score > beta, CUTOFF (fall through)
                        
   2397                 NEGAMAX_DO_BETA_CUTOFF:
                            ; Beta cutoff! Return beta (already in R7)
                            ; Store beta to BEST_SCORE memory for return
                        
                            ; Store beta (R7) to BEST_SCORE memory
   2397   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   239b   97                GHI 7               ; Beta high byte
   239c   5a                STR 10
   239d   1a                INC 10
   239e   87                GLO 7               ; Beta low byte
   239f   5a                STR 10
                        
                            ; Save cutoff move to NODE_BEST_MOVE (all plies)
   23a0   68 ca 64 48       RLDI 10, CURRENT_PLY
   23a4   0a                LDN 10              ; D = ply
   23a5   fe                SHL                 ; D = ply * 2
   23a6   aa                PLO 10
   23a7   f8 67             LDI HIGH(NODE_BEST_MOVE)
   23a9   ba                PHI 10              ; R10 = &NODE_BEST_MOVE[ply]
   23aa   68 c7 64 09       RLDI 7, UNDO_FROM
