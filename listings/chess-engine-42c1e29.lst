   141c   fe                SHL
   141d   fe                SHL
   141e   fe                SHL                 ; D = rank * 8
   141f   73                STXD                ; push rank*8
   1420   8d                GLO 13
   1421   fa 07             ANI $07             ; D = file
   1423   60                IRX
