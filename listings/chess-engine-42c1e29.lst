   0b9c   68 c9 64 09       RLDI 9, UNDO_FROM
   0ba0   49                LDA 9               ; D = from square, R9 advances to UNDO_TO
   0ba1   d4 0c 06          CALL MM_ROOK_HOME_CHECK
   0ba4   09                LDN 9               ; D = to square (R9 already at UNDO_TO)
   0ba5   d4 0c 06          CALL MM_ROOK_HOME_CHECK
                        
   0ba8                 MM_ROOK_DONE:
                        
   0ba8                 MM_DONE:
                            ; =========================================
                            ; HASH UPDATE: XOR piece-square changes
                            ; =========================================
                            ; HASH_XOR_PIECE_SQ: R8.0 = piece, R8.1 = square
                            ; Clobbers: R7, R9, R10, R13. Preserves: R8
                            ; After each call, reload from memory (safe, no register deps)
                            ;
                            ; For promotion: BOARD[to] has promoted piece, but we need to
                            ; XOR out [pawn, from]. Check UNDO_PROMOTION to get original piece.
                        
                            ; --- Step 1: XOR out [moving piece, from] ---
                            ; Check if this was a promotion
   0ba8   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   0bac   0a                LDN 10              ; D = promotion type (0 if none)
   0bad   c2 0b c6          LBZ MM_HASH_NOT_PROMO
                        
                            ; Promotion: original piece was a pawn. Get color from BOARD[to].
   0bb0   68 ca 64 0a       RLDI 10, UNDO_TO
   0bb4   0a                LDN 10              ; D = to_square
   0bb5   fc 00             ADI LOW(BOARD)
   0bb7   aa                PLO 10
   0bb8   f8 60             LDI HIGH(BOARD)
   0bba   7c 00             ADCI 0
   0bbc   ba                PHI 10              ; R10 = &BOARD[to_square]
   0bbd   0a                LDN 10              ; D = promoted piece
   0bbe   fa 08             ANI COLOR_MASK      ; Get color (0=white, 8=black)
   0bc0   f9 01             ORI PAWN_TYPE       ; D = pawn of same color
   0bc2   a8                PLO 8               ; R8.0 = pawn
   0bc3   c0 0b d5          LBR MM_HASH_GOT_PIECE
                        
