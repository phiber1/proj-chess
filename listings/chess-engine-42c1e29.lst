   247d   a8                PLO 8               ; R8 = alpha
                        
                            ; Signed compare: score (R13) > alpha (R8)?
   247e   68 ca 64 49       RLDI 10, COMPARE_TEMP
   2482   ea                SEX 10
                        
                            ; Check if signs differ
   2483   9d                GHI 13              ; score_hi
   2484   5a                STR 10
   2485   98                GHI 8               ; alpha_hi
   2486   f3                XOR
   2487   fa 80             ANI $80
   2489   e2                SEX 2
   248a   ca 24 ab          LBNZ NEGAMAX_ALPHA_DIFF_SIGN
                        
                            ; Same sign: score > alpha if (score - alpha) > 0
   248d   ea                SEX 10
   248e   98                GHI 8               ; alpha_hi
   248f   5a                STR 10
   2490   9d                GHI 13              ; score_hi
   2491   f5                SD                  ; D = score_hi - alpha_hi
   2492   e2                SEX 2
   2493   ca 24 a5          LBNZ NEGAMAX_ALPHA_HI_DIFF
                            ; High bytes equal, compare low
   2496   ea                SEX 10
   2497   88                GLO 8               ; alpha_lo
   2498   5a                STR 10
   2499   8d                GLO 13              ; score_lo
   249a   f5                SD                  ; D = score_lo - alpha_lo
   249b   e2                SEX 2
   249c   c2 24 c8          LBZ NEGAMAX_NEXT_MOVE           ; Equal, don't update
   249f   cb 24 b1          LBNF NEGAMAX_ALPHA_DO_UPDATE    ; DF=0: score > alpha
   24a2   c0 24 c8          LBR NEGAMAX_NEXT_MOVE           ; DF=1: score < alpha
                        
   24a5                 NEGAMAX_ALPHA_HI_DIFF:
   24a5   cb 24 b1          LBNF NEGAMAX_ALPHA_DO_UPDATE    ; DF=0: score > alpha
   24a8   c0 24 c8          LBR NEGAMAX_NEXT_MOVE           ; DF=1: score < alpha
                        
   24ab                 NEGAMAX_ALPHA_DIFF_SIGN:
                            ; Different signs: positive > negative
   24ab   9d                GHI 13              ; score_hi
   24ac   fa 80             ANI $80
   24ae   ca 24 c8          LBNZ NEGAMAX_NEXT_MOVE          ; Score negative, alpha positive - skip
                            ; Score positive, alpha negative - update (fall through)
                        
   24b1                 NEGAMAX_ALPHA_DO_UPDATE:
                            ; alpha = score
   24b1   68 ca 64 42       RLDI 10, ALPHA_HI
   24b5   9d                GHI 13
   24b6   5a                STR 10
   24b7   1a                INC 10
   24b8   8d                GLO 13
   24b9   5a                STR 10              ; ALPHA = score
                        
                            ; -- TT node flag: EXACT (PV node) --
   24ba   68 ca 64 48       RLDI 10, CURRENT_PLY
   24be   0a                LDN 10
   24bf   fc d2             ADI LOW(NODE_TT_FLAGS)
   24c1   aa                PLO 10
   24c2   f8 64             LDI HIGH(NODE_TT_FLAGS)
   24c4   ba                PHI 10
   24c5   f8 01             LDI TT_FLAG_EXACT
   24c7   5a                STR 10
                        
   24c8                 NEGAMAX_NEXT_MOVE:
                            ; -----------------------------------------------
                            ; Increment LMR move counter (move was processed)
                            ; -----------------------------------------------
   24c8   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   24cc   0a                LDN 10
   24cd   fc 01             ADI 1
   24cf   5a                STR 10              ; LMR_MOVE_INDEX++
                        
                            ; -----------------------------------------------
                            ; Decrement move counter and continue loop
                            ; -----------------------------------------------
   24d0   68 ca 64 48       RLDI 10, CURRENT_PLY
   24d4   0a                LDN 10             ; D = ply
   24d5   fc ef             ADI LOW(LOOP_MOVE_CNT)
   24d7   aa                PLO 10
   24d8   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   24da   ba                PHI 10             ; R10 = &LOOP_MOVE_CNT[ply]
   24db   0a                LDN 10             ; D = move count
   24dc   ff 01             SMI 1              ; Decrement
   24de   5a                STR 10             ; LOOP_MOVE_CNT[ply]-- (D still holds new value)
   24df   c2 24 e5          LBZ NEGAMAX_LOOP_DONE ; If count == 0, exit loop (long branch)
   24e2   c0 1f 90          LBR NEGAMAX_MOVE_LOOP
                        
   24e5                 NEGAMAX_LOOP_DONE:
                            ; Count (now in LOOP_MOVE_CNT[ply], not the stack) reached 0.
                            ; R2 was never perturbed by count management — no stack re-sync needed.
                        
                            ; Check if any legal move updated BEST_SCORE.
                            ; If BEST_SCORE is still $8001 (initial sentinel), no legal move
                            ; was found - all pseudo-legal moves left king in check.
                            ; This is checkmate or stalemate; handle via NEGAMAX_NO_MOVES.
                            ; (R2 is at the function-entry position; count is in LOOP_MOVE_CNT, not stack)
   24e5   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   24e9   4a                LDA 10              ; D = BEST_SCORE_HI
   24ea   fb 80             XRI $80
   24ec   ca 24 f8          LBNZ NEGAMAX_RETURN ; BEST_SCORE_HI != $80 → a legal move was scored
   24ef   0a                LDN 10              ; D = BEST_SCORE_LO
   24f0   fb 01             XRI $01
   24f2   ca 24 f8          LBNZ NEGAMAX_RETURN ; BEST_SCORE_LO != $01 → a legal move was scored
                        
                            ; BEST_SCORE == $8001: no legal move improved the sentinel.
                            ; All pseudo-legal moves were illegal → checkmate or stalemate.
   24f5   c0 25 49          LBR NEGAMAX_NO_MOVES
                        
   24f8                 NEGAMAX_RETURN:
                            ; -----------------------------------------------
                            ; Return best score (from BEST_SCORE memory) via R9
                            ; -----------------------------------------------
                            ; Move count now lives in LOOP_MOVE_CNT[ply], never on the stack, so R2
                            ; is already at the function-entry position here — no count byte to pop.
                            ; (Was: IRX to skip a stack-resident move count. See LOOP_MOVE_CNT.)
                        
                            ; Copy BEST_SCORE to SCORE memory BEFORE restore (RESTORE clobbers R9!)
                            ; Best score is in BEST_SCORE_HI/LO, copy to SCORE_HI/LO for return
   24f8   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   24fc   4a                LDA 10              ; BEST_SCORE_HI
   24fd   b8                PHI 8               ; Temp in R8.1
   24fe   0a                LDN 10              ; BEST_SCORE_LO
   24ff   a8                PLO 8               ; Temp in R8.0
                        
   2500   68 ca 64 46       RLDI 10, SCORE_HI
   2504   98                GHI 8               ; Best score high byte
   2505   5a                STR 10
   2506   1a                INC 10
   2507   88                GLO 8               ; Best score low byte
   2508   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Store result in Transposition Table
                            ; -----------------------------------------------
                            ; Hash is updated incrementally in MAKE/UNMAKE_MOVE,
                            ; so TT works correctly at all nodes.
                        
                            ; TT_STORE expects: D = depth, R8.0 = flag, SCORE_HI/LO and BEST_MOVE set
                            ; -- Load TT node flag for current ply --
   2509   68 ca 64 48       RLDI 10, CURRENT_PLY
   250d   0a                LDN 10
   250e   fc d2             ADI LOW(NODE_TT_FLAGS)
   2510   aa                PLO 10
   2511   f8 64             LDI HIGH(NODE_TT_FLAGS)
   2513   ba                PHI 10
   2514   0a                LDN 10              ; D = flag
   2515   a8                PLO 8               ; R8.0 = flag
   2516   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   251a   0a                LDN 10              ; D = depth (low byte = actual depth)
   251b   d4 57 a5          CALL TT_STORE
                        
                            ; Restore caller's context (clobbers R7, R8, R9, R11, R12)
   251e   d4 00 54          CALL RESTORE_PLY_STATE
                        
                            ; Load return value back into R9 AFTER restore
                            ; Big-endian: load high byte from lower address first
   2521   68 ca 64 46       RLDI 10, SCORE_HI
   2525   4a                LDA 10              ; SCORE_HI -> high byte
   2526   b9                PHI 9
   2527   0a                LDN 10              ; SCORE_LO -> low byte
   2528   a9                PLO 9
                        
   2529   d5                RETN
                        
   252a                 NEGAMAX_LEAF:
                            ; -----------------------------------------------
                            ; Leaf node - do quiescence search
                            ; -----------------------------------------------
   252a   d4 25 98          CALL QUIESCENCE_SEARCH
                            ; Returns score in R9 (already from side-to-move's perspective)
                        
                            ; DIAG stamp (2026-07-17 hang hunt): leaf bookkeeping after QSEARCH.
   252d   68 ca 64 1d       RLDI 10, TRACE_WHERE
   2531   f8 a6             LDI $A6
   2533   5a                STR 10              ; tracer: back from QSEARCH (R10 reloaded below)
                        
                            ; Save return value to SCORE memory BEFORE restore (RESTORE clobbers R9!)
                            ; Big-endian: store high byte at lower address (SCORE_HI), low at SCORE_LO
   2534   68 ca 64 46       RLDI 10, SCORE_HI
   2538   99                GHI 9               ; Score high byte first
   2539   5a                STR 10
   253a   1a                INC 10
   253b   89                GLO 9               ; Score low byte second
   253c   5a                STR 10
                        
                            ; Restore caller's context (clobbers R7, R8, R9, R11, R12)
   253d   d4 00 54          CALL RESTORE_PLY_STATE
                        
                            ; Load return value back into R9 AFTER restore
                            ; Big-endian: load high byte from lower address first
   2540   68 ca 64 46       RLDI 10, SCORE_HI
   2544   4a                LDA 10              ; SCORE_HI -> high byte
   2545   b9                PHI 9
   2546   0a                LDN 10              ; SCORE_LO -> low byte
   2547   a9                PLO 9
                        
   2548   d5                RETN
                        
   2549                 NEGAMAX_NO_MOVES:
                            ; -----------------------------------------------
                            ; No legal moves - checkmate or stalemate
                            ; -----------------------------------------------
                            ; Check if in check
   2549   d4 01 8e          CALL IS_IN_CHECK
                            ; Returns: D = 1 if in check, 0 if not
                        
   254c   c2 25 7e          LBZ NEGAMAX_STALEMATE   ; Long branch - may cross page
                        
                            ; Checkmate - return mate-score adjusted by ply so shorter mates score higher.
                            ; Formula: score = -MATE_VAL + ply  (standard negamax mate convention)
                            ; The mated side's score is "less negative" the farther from root we are,
                            ; so after the negation chain back to root, the side delivering the mate
                            ; sees a HIGHER score for SHORTER mate sequences (mate-in-1 > mate-in-2 > ...).
                            ;
                            ; FIXED 2026-04-27: previously used SEARCH_DEPTH+1 (depth_remaining), which
                            ; INVERTED the preference — engine consistently picked longer mates over
                            ; shorter ones at d>=3. Manifested visibly only after 2271af2 enabled real
                            ; promotions (positions with multiple forced-mate sequences became reachable).
                            ;
                            ; NOTE: Use $8001 (-32767) not $8000 (-32768) to avoid overflow when negating!
                            ; -(-32768) = -32768 due to two's complement overflow, breaking score propagation!
   254f   f8 80             LDI $80
   2551   b9                PHI 9
   2552   f8 01             LDI $01
   2554   a9                PLO 9              ; R9 = -32767 (R6 is SCRT linkage - off limits!)
                        
                            ; Add ply (distance from root) so shorter mates score higher
   2555   68 cd 64 48       RLDI 13, CURRENT_PLY
   2559   0d                LDN 13              ; D = current ply (0 at root, increases with depth)
                            ; Use COMPARE_TEMP for ADD scratch (NEVER use STR 2!)
   255a   68 ca 64 49       RLDI 10, COMPARE_TEMP
   255e   ea                SEX 10
   255f   5a                STR 10
   2560   89                GLO 9
   2561   f4                ADD
   2562   e2                SEX 2
   2563   a9                PLO 9
                            ; High byte stays same (adding small depth won't overflow)
                        
                            ; Store checkmate score to BEST_SCORE memory for return
   2564   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   2568   99                GHI 9               ; Score high byte
   2569   5a                STR 10
   256a   1a                INC 10
   256b   89                GLO 9               ; Score low byte
   256c   5a                STR 10
                        
                            ; -- TT node flag: EXACT (checkmate) --
   256d   68 ca 64 48       RLDI 10, CURRENT_PLY
   2571   0a                LDN 10
   2572   fc d2             ADI LOW(NODE_TT_FLAGS)
   2574   aa                PLO 10
   2575   f8 64             LDI HIGH(NODE_TT_FLAGS)
   2577   ba                PHI 10
   2578   f8 01             LDI TT_FLAG_EXACT
   257a   5a                STR 10
                        
   257b   c0 24 f8          LBR NEGAMAX_RETURN
                        
   257e                 NEGAMAX_STALEMATE:
                            ; Stalemate - return 0 (draw)
                            ; Store 0 to BEST_SCORE memory for return
   257e   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   2582   f8 00             LDI 0
   2584   5a                STR 10              ; BEST_SCORE_HI = 0
   2585   1a                INC 10
   2586   5a                STR 10              ; BEST_SCORE_LO = 0
                        
                            ; -- TT node flag: EXACT (stalemate) --
   2587   68 ca 64 48       RLDI 10, CURRENT_PLY
   258b   0a                LDN 10
   258c   fc d2             ADI LOW(NODE_TT_FLAGS)
   258e   aa                PLO 10
   258f   f8 64             LDI HIGH(NODE_TT_FLAGS)
   2591   ba                PHI 10
   2592   f8 01             LDI TT_FLAG_EXACT
   2594   5a                STR 10
                        
   2595   c0 24 f8          LBR NEGAMAX_RETURN
                        
                        ; ==============================================================================
                        ; QUIESCENCE_SEARCH - Search captures at leaf nodes
                        ; ==============================================================================
                        ; Avoids horizon effect by extending search for captures
                        ; Input:  C = color (0 for white, 8 for black - matches COLOR_MASK)
                        ;         A = board pointer
                        ; Output: R9 = best score (from side-to-move's perspective)
                        ; NOTE:   R6 is SCRT linkage register - off limits for application data!
                        ; ==============================================================================
   2598                 QUIESCENCE_SEARCH:
                            ; Ensure X=2 for stack operations
   2598   e2                SEX 2
                        
   2599   68 ca 64 1d       RLDI 10, TRACE_WHERE
   259d   f8 c1             LDI $C1
   259f   5a                STR 10              ; tracer: in QSEARCH
                        
                            ; Stack overflow detection (see NEGAMAX comment).
   25a0   d4 00 87          CALL CHECK_STACK_OVERFLOW
                        
                            ; Stand-pat: evaluate current position
   25a3   d4 0e a7          CALL EVALUATE
                            ; Returns score in R9 (from white's perspective)
                        
                            ; DIAG stamp (2026-07-17 hang hunt): QS stand-pat/capture-gen window.
   25a6   68 ca 64 1d       RLDI 10, TRACE_WHERE
   25aa   f8 c2             LDI $C2
   25ac   5a                STR 10              ; tracer: QS post-eval (R10 reloaded below)
                        
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   25ad   8c                GLO 12
   25ae   fa 08             ANI $08
   25b0   c2 25 bb          LBZ QS_SAVE_STANDPAT
   25b3   89                GLO 9               ; low byte
   25b4   fd 00             SDI 0               ; negate low
   25b6   a9                PLO 9
   25b7   99                GHI 9               ; high byte
   25b8   7d 00             SDBI 0              ; negate high with borrow
   25ba   b9                PHI 9
                        
   25bb                 QS_SAVE_STANDPAT:
                            ; Save stand-pat score to QS_BEST_HI/LO
   25bb   68 ca 64 18       RLDI 10, QS_BEST_HI
   25bf   99                GHI 9               ; high byte → QS_BEST_HI (lower address)
   25c0   5a                STR 10
   25c1   1a                INC 10
   25c2   89                GLO 9               ; low byte → QS_BEST_LO (higher address)
   25c3   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Stand-pat beta cutoff: if stand-pat >= beta, return
                            ; (Position is already good enough, no need to search captures)
                            ; -----------------------------------------------
                            ; Load beta from memory (big-endian: HI at lower address)
   25c4   68 ca 64 44       RLDI 10, BETA_HI
   25c8   4a                LDA 10              ; beta high
   25c9   b7                PHI 7
   25ca   0a                LDN 10              ; beta low
   25cb   a7                PLO 7               ; R7 = beta
                        
                            ; Compare: stand-pat (R9) >= beta (R7)?
                            ; Signed comparison using COMPARE_TEMP
   25cc   68 ca 64 49       RLDI 10, COMPARE_TEMP
   25d0   ea                SEX 10
   25d1   99                GHI 9               ; stand-pat high
   25d2   5a                STR 10
   25d3   97                GHI 7               ; beta high
   25d4   f3                XOR
   25d5   fa 80             ANI $80             ; Check if different signs
   25d7   e2                SEX 2
   25d8   ca 25 eb          LBNZ QS_BETA_DIFF_SIGN
                        
                            ; Same sign - compare magnitudes
                            ; stand-pat >= beta means stand-pat - beta >= 0, i.e., no borrow
   25db   ea                SEX 10
   25dc   87                GLO 7               ; beta low
   25dd   5a                STR 10
   25de   89                GLO 9               ; stand-pat low
   25df   f7                SM                  ; D = stand-pat_lo - beta_lo
   25e0   97                GHI 7               ; beta high
   25e1   5a                STR 10
   25e2   99                GHI 9               ; stand-pat high
   25e3   77                SMB                 ; D = stand-pat_hi - beta_hi - borrow
   25e4   e2                SEX 2
   25e5   c3 28 46          LBDF QS_RETURN      ; No borrow = stand-pat >= beta, cutoff!
   25e8   c0 25 f1          LBR QS_NO_BETA_CUTOFF
                        
   25eb                 QS_BETA_DIFF_SIGN:
                            ; Different signs: positive >= negative always
                            ; stand-pat positive (bit 7 = 0) means stand-pat >= beta
   25eb   99                GHI 9
   25ec   fa 80             ANI $80
   25ee   c2 28 46          LBZ QS_RETURN       ; stand-pat positive, beta negative -> cutoff
                        
   25f1                 QS_NO_BETA_CUTOFF:
                            ; -----------------------------------------------
                            ; Alpha update: if stand-pat > alpha, alpha = stand-pat
                            ; (Tightens window, makes beta cutoffs more likely)
                            ; -----------------------------------------------
                            ; Load alpha (R9 still has stand-pat)
   25f1   68 ca 64 42       RLDI 10, ALPHA_HI
   25f5   4a                LDA 10              ; alpha high
   25f6   b7                PHI 7
   25f7   0a                LDN 10              ; alpha low
   25f8   a7                PLO 7               ; R7 = alpha
                        
                            ; Compare: stand-pat (R9) > alpha (R7)?
   25f9   68 ca 64 49       RLDI 10, COMPARE_TEMP
   25fd   ea                SEX 10
   25fe   99                GHI 9
   25ff   5a                STR 10
   2600   97                GHI 7
   2601   f3                XOR
   2602   fa 80             ANI $80
   2604   e2                SEX 2
   2605   ca 26 20          LBNZ QS_ALPHA_DIFF_SIGN
                        
                            ; Same sign - R9 > R7 means R9 - R7 > 0 (positive, no borrow, not zero)
   2608   ea                SEX 10
   2609   87                GLO 7
   260a   5a                STR 10
   260b   89                GLO 9
   260c   f7                SM                  ; D = stand-pat_lo - alpha_lo
   260d   b8                PHI 8               ; Save low result
   260e   97                GHI 7
   260f   5a                STR 10
   2610   99                GHI 9
   2611   77                SMB                 ; D = stand-pat_hi - alpha_hi - borrow
   2612   e2                SEX 2
   2613   cb 26 2f          LBNF QS_NO_ALPHA_UPDATE  ; Borrow = stand-pat <= alpha
   2616   ca 26 26          LBNZ QS_UPDATE_ALPHA     ; High diff non-zero and positive
   2619   98                GHI 8                    ; Check low diff
   261a   c2 26 2f          LBZ QS_NO_ALPHA_UPDATE   ; Both zero = equal, don't update
   261d   c0 26 26          LBR QS_UPDATE_ALPHA
                        
   2620                 QS_ALPHA_DIFF_SIGN:
                            ; Different signs: positive > negative
   2620   99                GHI 9
   2621   fa 80             ANI $80
   2623   ca 26 2f          LBNZ QS_NO_ALPHA_UPDATE  ; stand-pat negative, alpha positive
                            ; stand-pat positive, alpha negative -> update
                        
   2626                 QS_UPDATE_ALPHA:
                            ; alpha = stand-pat
   2626   68 ca 64 42       RLDI 10, ALPHA_HI
   262a   99                GHI 9
   262b   5a                STR 10
   262c   1a                INC 10
   262d   89                GLO 9
   262e   5a                STR 10
                        
   262f                 QS_NO_ALPHA_UPDATE:
                            ; -----------------------------------------------
                            ; Delta pruning: if stand-pat + QUEEN_VALUE < alpha, return alpha
                            ; (Even capturing a queen can't raise alpha - futile to search)
                            ; -----------------------------------------------
                            ; Load alpha from memory (big-endian: HI at lower address)
   262f   68 ca 64 42       RLDI 10, ALPHA_HI
   2633   4a                LDA 10              ; alpha high
   2634   b7                PHI 7
   2635   0a                LDN 10              ; alpha low
   2636   a7                PLO 7               ; R7 = alpha
                        
                            ; Calculate stand-pat + QUEEN_VALUE (900 = $0384)
                            ; R9 = stand-pat, add 900
   2637   89                GLO 9
   2638   fc 84             ADI LOW(900)        ; Add low byte of 900 ($84)
   263a   a8                PLO 8
   263b   99                GHI 9
   263c   7c 03             ADCI HIGH(900)      ; Add high byte of 900 ($03) + carry
   263e   b8                PHI 8               ; R8 = stand-pat + 900
                        
                            ; Compare: (stand-pat + 900) < alpha?
                            ; If R8 < R7, then delta prune
   263f   68 ca 64 49       RLDI 10, COMPARE_TEMP
   2643   ea                SEX 10
   2644   98                GHI 8               ; (stand-pat + 900) high
   2645   5a                STR 10
   2646   97                GHI 7               ; alpha high
   2647   f3                XOR
   2648   fa 80             ANI $80             ; Check if different signs
   264a   e2                SEX 2
   264b   ca 26 5e          LBNZ QS_DELTA_DIFF_SIGN
                        
                            ; Same sign - compare: R8 < R7 means R8 - R7 has borrow
   264e   ea                SEX 10
   264f   87                GLO 7               ; alpha low
   2650   5a                STR 10
   2651   88                GLO 8               ; (stand-pat + 900) low
   2652   f7                SM                  ; D = (sp+900)_lo - alpha_lo
   2653   97                GHI 7               ; alpha high
   2654   5a                STR 10
   2655   98                GHI 8               ; (stand-pat + 900) high
   2656   77                SMB                 ; D = (sp+900)_hi - alpha_hi - borrow
   2657   e2                SEX 2
   2658   cb 26 64          LBNF QS_DELTA_PRUNE ; Borrow = (stand-pat + 900) < alpha, prune!
   265b   c0 26 69          LBR QS_NO_DELTA_PRUNE
                        
   265e                 QS_DELTA_DIFF_SIGN:
                            ; Different signs: negative < positive always
                            ; (stand-pat + 900) negative means it's < alpha (if alpha positive)
   265e   98                GHI 8
   265f   fa 80             ANI $80
   2661   c2 26 69          LBZ QS_NO_DELTA_PRUNE ; (stand-pat + 900) positive -> no prune
                        
   2664                 QS_DELTA_PRUNE:
                            ; Return alpha (in R7) - we're too far behind
   2664   97                GHI 7
   2665   b9                PHI 9
   2666   87                GLO 7
   2667   a9                PLO 9               ; R9 = alpha
   2668   d5                RETN
                        
   2669                 QS_NO_DELTA_PRUNE:
                            ; Generate all moves (use QS_MOVE_LIST to avoid clobbering parent's move list!)
   2669   68 c9 67 80       RLDI 9, QS_MOVE_LIST
   266d   d4 04 d7          CALL GENERATE_MOVES
                            ; D = move count
                        
                            ; Save move count to temp (must clear R15.1 to avoid DEC underflow!)
   2670   af                PLO 15              ; R15.0 = move count (temp)
   2671   f8 00             LDI 0
   2673   bf                PHI 15              ; R15.1 = 0 (prevents underflow when DEC 15)
                        
                            ; Save move list start pointer (big-endian: high byte first)
   2674   68 ca 64 1a       RLDI 10, QS_MOVE_PTR_HI
   2678   f8 67             LDI HIGH(QS_MOVE_LIST)
   267a   5a                STR 10
   267b   1a                INC 10
   267c   f8 80             LDI LOW(QS_MOVE_LIST)
   267e   5a                STR 10
                        
                            ; Initialize capture limit counter
   267f   f8 08             LDI 8                   ; QS_CAPTURE_LIMIT = 8 captures max
   2681   bb                PHI 11                  ; R11.1 = captures remaining
                        
   2682                 QS_LOOP:
   2682   3f 86             BN4  BRK_QS_LOOP      ; /EF4 break trap (DEBUG)
   2684   79                MARK
   2685   d1                SEP  1
   2686                 BRK_QS_LOOP:
                            ; Check if any moves left
   2686   8f                GLO 15
   2687   c2 28 46          LBZ QS_RETURN
                        
                            ; Load move list pointer (big-endian: high byte first)
   268a   68 ca 64 1a       RLDI 10, QS_MOVE_PTR_HI
   268e   4a                LDA 10              ; High byte
   268f   b9                PHI 9
   2690   0a                LDN 10              ; Low byte
   2691   a9                PLO 9               ; R9 = move pointer
                        
                            ; Load encoded move (big-endian: high byte first)
   2692   49                LDA 9
   2693   b8                PHI 8
   2694   49                LDA 9
   2695   a8                PLO 8               ; R8 = encoded move
                        
                            ; Save updated pointer (big-endian: high byte first)
   2696   68 ca 64 1a       RLDI 10, QS_MOVE_PTR_HI
   269a   99                GHI 9
   269b   5a                STR 10
   269c   1a                INC 10
   269d   89                GLO 9
   269e   5a                STR 10
                        
                            ; Decrement move count
   269f   2f                DEC 15
                        
                            ; Decode move to get from/to squares
   26a0   d4 03 c7          CALL DECODE_MOVE_16BIT
                            ; R13.1 = from, R13.0 = to (R14.0 = flags - but we don't use it)
                        
                            ; Check if this is a capture: target square must have enemy piece
   26a3   f8 60             LDI HIGH(BOARD)
   26a5   ba                PHI 10
   26a6   8d                GLO 13              ; to square
   26a7   aa                PLO 10
   26a8   0a                LDN 10              ; piece at target
   26a9   c2 26 82          LBZ QS_LOOP         ; Empty = not a capture, skip
                        
                            ; Has piece - check if enemy color
   26ac   fa 08             ANI COLOR_MASK      ; D = target piece color (0 or 8)
                            ; Use COMPARE_TEMP for XOR scratch (NEVER use STR 2!)
   26ae   68 ca 64 49       RLDI 10, COMPARE_TEMP
   26b2   ea                SEX 10
   26b3   5a                STR 10              ; Store target color to COMPARE_TEMP
   26b4   8c                GLO 12              ; D = our color (0 or 8, per COLOR_MASK)
   26b5   fa 08             ANI COLOR_MASK      ; D = our color masked (0 or 8)
   26b7   f3                XOR                 ; D = our_color XOR target_color
   26b8   e2                SEX 2
   26b9   c2 26 82          LBZ QS_LOOP         ; Same color (result 0) = own piece, skip
                        
                            ; -------------------------------------------------
                            ; Per-capture delta pruning:
                            ; If stand_pat + victim_value < alpha, skip capture
                            ; (Even capturing this piece won't raise score above alpha)
                            ; -------------------------------------------------
                            ; Reload victim piece and extract type
   26bc   f8 60             LDI HIGH(BOARD)
   26be   ba                PHI 10
   26bf   8d                GLO 13              ; to square (preserved in R13.0)
   26c0   aa                PLO 10
   26c1   0a                LDN 10              ; piece at target
   26c2   fa 07             ANI $07             ; D = piece type (1-6)
                        
                            ; Look up value: PIECE_VALUES + type*2
   26c4   fe                SHL                 ; D = type * 2
   26c5   fc f3             ADI LOW(PIECE_VALUES)
   26c7   aa                PLO 10
   26c8   f8 0d             LDI HIGH(PIECE_VALUES)
   26ca   7c 00             ADCI 0
   26cc   ba                PHI 10              ; R10 = &PIECE_VALUES[type]
                        
   26cd   4a                LDA 10              ; victim value high
   26ce   b8                PHI 8
   26cf   0a                LDN 10              ; victim value low
   26d0   a8                PLO 8               ; R8 = victim_value
                        
                            ; Load stand_pat from QS_BEST
   26d1   68 ca 64 18       RLDI 10, QS_BEST_HI
   26d5   4a                LDA 10
   26d6   b7                PHI 7
   26d7   0a                LDN 10
   26d8   a7                PLO 7               ; R7 = stand_pat
                        
                            ; R7 = stand_pat + victim_value
   26d9   88                GLO 8
   26da   52                STR 2               ; Use stack top as temp
   26db   87                GLO 7
   26dc   f4                ADD
   26dd   a7                PLO 7
   26de   98                GHI 8
   26df   52                STR 2
   26e0   97                GHI 7
   26e1   74                ADC
   26e2   b7                PHI 7               ; R7 = stand_pat + victim_value
                        
                            ; Load alpha
   26e3   68 ca 64 42       RLDI 10, ALPHA_HI
   26e7   4a                LDA 10
   26e8   b8                PHI 8
   26e9   0a                LDN 10
   26ea   a8                PLO 8               ; R8 = alpha
                        
                            ; Compare: (stand_pat + victim) < alpha?
                            ; If R7 < R8, skip this capture
   26eb   68 ca 64 49       RLDI 10, COMPARE_TEMP
   26ef   ea                SEX 10
   26f0   97                GHI 7               ; (stand_pat + victim) high
   26f1   5a                STR 10
   26f2   98                GHI 8               ; alpha high
   26f3   f3                XOR
   26f4   fa 80             ANI $80             ; Check if different signs
   26f6   e2                SEX 2
   26f7   ca 27 0a          LBNZ QS_DELTA_DIFF_SIGN2
                        
                            ; Same sign: R7 < R8 means R7 - R8 has borrow
   26fa   ea                SEX 10
   26fb   88                GLO 8               ; alpha low
   26fc   5a                STR 10
   26fd   87                GLO 7               ; (stand_pat + victim) low
   26fe   f7                SM                  ; D = (sp+v)_lo - alpha_lo
   26ff   98                GHI 8               ; alpha high
   2700   5a                STR 10
   2701   97                GHI 7               ; (stand_pat + victim) high
   2702   77                SMB                 ; D = (sp+v)_hi - alpha_hi - borrow
   2703   e2                SEX 2
   2704   cb 26 82          LBNF QS_LOOP        ; Borrow = (stand_pat + victim) < alpha, skip!
   2707   c0 27 10          LBR QS_DELTA_NO_PRUNE
                        
   270a                 QS_DELTA_DIFF_SIGN2:
                            ; Different signs: negative < positive always
                            ; (stand_pat + victim) negative means it's < alpha (if alpha positive)
   270a   97                GHI 7
   270b   fa 80             ANI $80
   270d   ca 26 82          LBNZ QS_LOOP        ; (stand_pat + victim) negative -> skip capture
                        
   2710                 QS_DELTA_NO_PRUNE:
                            ; -------------------------------------------------
                            ; End per-capture delta pruning
                            ; -------------------------------------------------
                        
                            ; It's a capture! Process it.
                            ; Save move count to stack (BOTH bytes! IS_IN_CHECK clobbers R15.1)
   2710   9f                GHI 15
   2711   73                STXD
   2712   8f                GLO 15
   2713   73                STXD
                        
                            ; ===============================================================
                            ; QSEARCH defender-check pre-filter (added 2026-05-07)
                            ; ===============================================================
                            ; QSEARCH lacks recursion: each capture is evaluated as if its
                            ; recapture won't happen. This causes phantom material wins when
                            ; we capture a defended piece with a more valuable attacker.
                            ;
                            ; Filter: if captor_value > victim_value AND target is defended
                            ; by enemy, skip this capture entirely. Single-level defender
                            ; check; doesn't see exchange chains, but catches the dominant
                            ; bug class (e.g., Bxg6 when h7-pawn defends).
                            ;
                            ; Empirical motivation (2026-05-07): post-Kxf7 d=1 returned +220cp
                            ; bestmove d3g6 (Bxg6) despite h7 pawn obviously recapturing —
                            ; QSEARCH saw bishop "win" but not the recapture.
                            ; ===============================================================
                        
                            ; Load victim_value from board[to_square]
   2714   f8 60             LDI HIGH(BOARD)
   2716   ba                PHI 10
   2717   8d                GLO 13                          ; to square
   2718   aa                PLO 10
   2719   0a                LDN 10
   271a   fa 07             ANI $07                         ; victim piece type 1-6
   271c   fe                SHL                             ; * 2 for 16-bit table
   271d   fc f3             ADI LOW(PIECE_VALUES)
   271f   aa                PLO 10
   2720   f8 0d             LDI HIGH(PIECE_VALUES)
   2722   7c 00             ADCI 0
   2724   ba                PHI 10
   2725   4a                LDA 10                          ; victim_value hi
   2726   b8                PHI 8
   2727   0a                LDN 10                          ; victim_value lo
   2728   a8                PLO 8                           ; R8 = victim_value
                        
                            ; Load captor_value from board[from_square]
   2729   f8 60             LDI HIGH(BOARD)
   272b   ba                PHI 10
   272c   9d                GHI 13                          ; from square
   272d   aa                PLO 10
   272e   0a                LDN 10
   272f   fa 07             ANI $07                         ; captor piece type 1-6
   2731   fe                SHL
   2732   fc f3             ADI LOW(PIECE_VALUES)
   2734   aa                PLO 10
   2735   f8 0d             LDI HIGH(PIECE_VALUES)
   2737   7c 00             ADCI 0
   2739   ba                PHI 10
   273a   4a                LDA 10                          ; captor_value hi
   273b   b7                PHI 7
   273c   0a                LDN 10                          ; captor_value lo
   273d   a7                PLO 7                           ; R7 = captor_value
                        
                            ; Compare: victim - captor (16-bit signed). DF=1 if victim >= captor.
   273e   87                GLO 7
   273f   52                STR 2                           ; M(R2) = captor_lo
   2740   88                GLO 8
   2741   f7                SM                              ; D = victim_lo - captor_lo
   2742   97                GHI 7
   2743   52                STR 2                           ; M(R2) = captor_hi
   2744   98                GHI 8
   2745   77                SMB                             ; D = victim_hi - captor_hi - borrow
   2746   c3 27 61          LBDF QS_DEF_OK                  ; victim >= captor: no filter
                        
                            ; Captor > victim. Check if target square is defended by enemy.
                            ; Save R11.1 (capture limit) and R13 (from/to) — IS_SQUARE_ATTACKED
                            ; restores R11.0 and R12.0 but clobbers everything else including
                            ; R13 and R15.0.
   2749   9b                GHI 11
   274a   73                STXD                            ; push capture limit
   274b   9d                GHI 13
   274c   73                STXD                            ; push from
   274d   8d                GLO 13
   274e   73                STXD                            ; push to
                        
                            ; Set R11.0 = target square, R12.0 already = our color
   274f   8d                GLO 13
   2750   ab                PLO 11
   2751   d4 01 a4          CALL IS_SQUARE_ATTACKED
   2754   a7                PLO 7                           ; R7.0 = result (0=safe, 1=attacked)
   2755   e2                SEX 2                           ; Defensive: ensure X=2 for following pop
                        
                            ; Restore saved state
   2756   60                IRX
   2757   72                LDXA                            ; pop to → R13.0
   2758   ad                PLO 13
   2759   72                LDXA                            ; pop from → R13.1
   275a   bd                PHI 13
   275b   f0                LDX                             ; pop capture limit → R11.1
   275c   bb                PHI 11
                        
   275d   87                GLO 7
   275e   ca 27 94          LBNZ QS_DEF_SKIP                ; defended: filter fires, skip capture
                        
   2761                 QS_DEF_OK:
                            ; ===============================================================
                            ; End QSEARCH defender-check pre-filter
                            ; ===============================================================
                        
                            ; Store from/to for MAKE_MOVE
   2761   68 ca 64 02       RLDI 10, MOVE_FROM
   2765   9d                GHI 13              ; from
   2766   5a                STR 10
   2767   1a                INC 10
   2768   8d                GLO 13              ; to
   2769   5a                STR 10
                        
                            ; Set UNDO_PROMOTION based on move flags (capture-promotions)
   276a   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   276e   68 cd 64 05       RLDI 13, DECODED_FLAGS
   2772   0d                LDN 13              ; D = flags
   2773   fb 03             XRI MOVE_PROMOTION  ; == $03?
   2775   ca 27 7d          LBNZ QS_NOT_PROMO
   2778   f8 05             LDI QUEEN_TYPE      ; Promote to queen ($05)
   277a   c0 27 7f          LBR QS_SET_PROMO
   277d                 QS_NOT_PROMO:
   277d   f8 00             LDI 0               ; Not a promotion
   277f                 QS_SET_PROMO:
   277f   5a                STR 10              ; UNDO_PROMOTION = QUEEN_TYPE or 0
                        
                            ; Make move
   2780   d4 09 bb          CALL MAKE_MOVE
                        
                            ; -----------------------------------------------
                            ; LEGALITY CHECK: Does this capture leave our king in check?
                            ; MAKE_MOVE does NOT toggle R12 - only SIDE in memory.
                            ; R12 still contains our color (the side that just moved).
                            ; -----------------------------------------------
   2783   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if our king is in check (illegal), 0 if safe
                        
   2786   c2 27 9c          LBZ QS_CAPTURE_LEGAL  ; D=0 means not in check, capture is legal
                        
                            ; ILLEGAL CAPTURE: Unmake and skip to next capture
   2789   d4 0c 2e          CALL UNMAKE_MOVE
                        
                            ; R12 stays as our color (UNMAKE_MOVE doesn't toggle R12)
                        
                            ; Restore move count from stack and continue loop (both bytes)
   278c   60                IRX
   278d   72                LDXA
   278e   af                PLO 15              ; R15.0 = move count low
   278f   f0                LDX
   2790   bf                PHI 15              ; R15.1 = move count high (0)
   2791   c0 26 82          LBR QS_LOOP         ; Skip this illegal capture, try next
                        
   2794                 QS_DEF_SKIP:
                            ; Defender-check filter fired: skip capture WITHOUT make/unmake.
                            ; Pop R15 (saved before our filter ran) and continue.
   2794   60                IRX
   2795   72                LDXA
   2796   af                PLO 15              ; R15.0 = move count low
   2797   f0                LDX
   2798   bf                PHI 15              ; R15.1 = move count high (0)
   2799   c0 26 82          LBR QS_LOOP
                        
   279c                 QS_CAPTURE_LEGAL:
                            ; Check capture limit - decrement and bail if exhausted
   279c   9b                GHI 11                  ; D = captures remaining
   279d   c2 28 3e          LBZ QS_CAPTURE_LIMIT_HIT ; Already at 0, don't process more
   27a0   ff 01             SMI 1
   27a2   bb                PHI 11                  ; R11.1 = captures remaining - 1
                        
                            ; Evaluate position after capture
   27a3   d4 0e a7          CALL EVALUATE
                            ; Score in R9 (from white's perspective)
                        
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   27a6   8c                GLO 12
   27a7   fa 08             ANI $08
   27a9   c2 27 b4          LBZ QS_NO_NEG
   27ac   89                GLO 9               ; low byte
   27ad   fd 00             SDI 0               ; negate low
   27af   a9                PLO 9
   27b0   99                GHI 9               ; high byte
   27b1   7d 00             SDBI 0              ; negate high with borrow
   27b3   b9                PHI 9
   27b4                 QS_NO_NEG:
                            ; Save score (R9) before UNMAKE_MOVE clobbers it
   27b4   99                GHI 9
   27b5   73                STXD
   27b6   89                GLO 9
   27b7   73                STXD
                        
                            ; Unmake move
   27b8   d4 0c 2e          CALL UNMAKE_MOVE
                        
                            ; Restore score (R9)
   27bb   60                IRX
   27bc   72                LDXA
   27bd   a9                PLO 9
   27be   f0                LDX
   27bf   b9                PHI 9
                        
                            ; Restore move count (both bytes)
   27c0   60                IRX
   27c1   72                LDXA
   27c2   af                PLO 15              ; R15.0 = move count low
   27c3   f0                LDX
   27c4   bf                PHI 15              ; R15.1 = move count high (0)
                        
                            ; Compare: if score (R9) > best (QS_BEST), update best
                            ; Load QS_BEST into R7 for comparison (big-endian: HI first)
   27c5   68 ca 64 18       RLDI 10, QS_BEST_HI
   27c9   4a                LDA 10              ; High byte
   27ca   b7                PHI 7
   27cb   0a                LDN 10              ; Low byte
   27cc   a7                PLO 7               ; R7 = QS_BEST
                        
                            ; Signed comparison: R9 > R7?
                            ; Use COMPARE_TEMP for scratch (NEVER use STR 2!)
   27cd   68 ca 64 49       RLDI 10, COMPARE_TEMP
   27d1   ea                SEX 10
   27d2   99                GHI 9
   27d3   5a                STR 10
   27d4   97                GHI 7
   27d5   f3                XOR
   27d6   fa 80             ANI $80
   27d8   e2                SEX 2
   27d9   ca 27 fa          LBNZ QS_DIFF_SIGN
                        
                            ; Same sign - compare normally
   27dc   ea                SEX 10
   27dd   97                GHI 7
   27de   5a                STR 10
   27df   99                GHI 9
   27e0   f5                SD
   27e1   e2                SEX 2
   27e2   ca 27 f4          LBNZ QS_HI_DIFF
                            ; High bytes equal, compare low
   27e5   ea                SEX 10
   27e6   87                GLO 7
   27e7   5a                STR 10
   27e8   89                GLO 9
   27e9   f5                SD
   27ea   e2                SEX 2
   27eb   c2 26 82          LBZ QS_LOOP         ; Equal, don't update
   27ee   cb 28 00          LBNF QS_UPDATE      ; Score > best
   27f1   c0 26 82          LBR QS_LOOP         ; Score < best
                        
   27f4                 QS_HI_DIFF:
   27f4   cb 28 00          LBNF QS_UPDATE      ; Score > best
   27f7   c0 26 82          LBR QS_LOOP         ; Score < best
                        
   27fa                 QS_DIFF_SIGN:
                            ; Different signs - positive is greater
   27fa   99                GHI 9
   27fb   fa 80             ANI $80
   27fd   ca 26 82          LBNZ QS_LOOP        ; Score negative, best positive - don't update
                            ; Score positive, best negative - update
                        
   2800                 QS_UPDATE:
                            ; Update best = score (big-endian: HI first)
   2800   68 ca 64 18       RLDI 10, QS_BEST_HI
   2804   99                GHI 9               ; High byte first
   2805   5a                STR 10
   2806   1a                INC 10
   2807   89                GLO 9               ; Low byte second
   2808   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Beta cutoff check: if best >= beta, return beta
                            ; -----------------------------------------------
                            ; Load beta (big-endian: HI first)
   2809   68 ca 64 44       RLDI 10, BETA_HI
   280d   4a                LDA 10              ; beta high
   280e   b7                PHI 7
   280f   0a                LDN 10              ; beta low
   2810   a7                PLO 7               ; R7 = beta
                        
                            ; Compare: best (R9) >= beta (R7)?
   2811   68 ca 64 49       RLDI 10, COMPARE_TEMP
   2815   ea                SEX 10
   2816   99                GHI 9               ; best high
   2817   5a                STR 10
   2818   97                GHI 7               ; beta high
   2819   f3                XOR
   281a   fa 80             ANI $80
   281c   e2                SEX 2
   281d   ca 28 30          LBNZ QS_BETA_CUT_DIFF
                        
                            ; Same sign: best >= beta means best - beta >= 0 (no borrow)
   2820   ea                SEX 10
   2821   87                GLO 7               ; beta low
   2822   5a                STR 10
   2823   89                GLO 9               ; best low
   2824   f7                SM
   2825   97                GHI 7               ; beta high
   2826   5a                STR 10
   2827   99                GHI 9               ; best high
   2828   77                SMB
   2829   e2                SEX 2
   282a   c3 28 39          LBDF QS_BETA_CUTOFF ; No borrow = best >= beta, cutoff!
   282d   c0 26 82          LBR QS_LOOP
                        
   2830                 QS_BETA_CUT_DIFF:
                            ; Different signs: positive >= negative
   2830   99                GHI 9               ; best high
   2831   fa 80             ANI $80
   2833   c2 28 39          LBZ QS_BETA_CUTOFF  ; best positive, beta negative -> cutoff
   2836   c0 26 82          LBR QS_LOOP
                        
   2839                 QS_BETA_CUTOFF:
                            ; Return beta (fail-high)
   2839   97                GHI 7
   283a   b9                PHI 9
   283b   87                GLO 7
   283c   a9                PLO 9               ; R9 = beta
   283d   d5                RETN
                        
   283e                 QS_CAPTURE_LIMIT_HIT:
                            ; Hit capture limit - unmake the move and return best so far
   283e   d4 0c 2e          CALL UNMAKE_MOVE
                            ; Restore move count from stack (was pushed at capture processing start)
   2841   60                IRX
   2842   72                LDXA
   2843   af                PLO 15              ; R15.0 = move count low
   2844   f0                LDX
   2845   bf                PHI 15              ; R15.1 = move count high (0)
                            ; Fall through to QS_RETURN
                        
   2846                 QS_RETURN:
                            ; Return best score in R9 (big-endian: HI first)
   2846   68 ca 64 18       RLDI 10, QS_BEST_HI
   284a   4a                LDA 10              ; High byte
   284b   b9                PHI 9
   284c   0a                LDN 10              ; Low byte
   284d   a9                PLO 9
   284e   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; Helper Functions - STUBS REMOVED (functions now in other modules)
                        ; ------------------------------------------------------------------------------
                        ; GENERATE_MOVES - implemented in movegen.asm
                        ; MAKE_MOVE - implemented in makemove.asm
                        ; UNMAKE_MOVE - implemented in makemove.asm
                        ; EVALUATE - implemented in evaluate.asm
                        ; IS_IN_CHECK - implemented in check.asm
                        
                        ; Only these helper functions remain here:
                        
                        ; ------------------------------------------------------------------------------
                        ; STORE_KILLER_MOVE - Store killer move for move ordering
                        ; ------------------------------------------------------------------------------
                        ; Input:  R11 = move that caused beta cutoff
                        ;         CURRENT_PLY = current ply (in memory)
                        ; Output: Killer move stored in table
                        ; Uses:   R10, R13, D
                        ; ------------------------------------------------------------------------------
   284f                 STORE_KILLER_MOVE:
                            ; Calculate killer table offset from CURRENT_PLY
                            ; (Use ply, not depth, so killers work across different search depths)
   284f   68 cd 64 48       RLDI 13, CURRENT_PLY
   2853   0d                LDN 13              ; D = current ply
   2854   fa 0f             ANI $0F             ; Limit to 16 plies
   2856   fe                SHL
   2857   fe                SHL                 ; × 4 (2 moves × 2 bytes each)
   2858   ad                PLO 13
                        
                            ; Point to killer table (offset in R13.0 is 0-60, won't overflow with ADI)
   2859   f8 64             LDI HIGH(KILLER_MOVES)
   285b   ba                PHI 10
   285c   8d                GLO 13              ; Get offset (0, 4, 8, ... 60)
   285d   fc 20             ADI LOW(KILLER_MOVES)  ; Add base address low byte
   285f   aa                PLO 10              ; R10 = KILLER_MOVES + offset
                        
                            ; Shift killers: killer2 = killer1
   2860   4a                LDA 10              ; Load killer1 low
   2861   ad                PLO 13
   2862   4a                LDA 10              ; Load killer1 high
   2863   bd                PHI 13              ; D = old killer1
                        
                            ; Store old killer1 as new killer2
   2864   8d                GLO 13
   2865   5a                STR 10
   2866   1a                INC 10
   2867   9d                GHI 13
   2868   5a                STR 10
                        
                            ; Reset pointer to killer1 position (R10 is at killer2_high, need killer1_low)
   2869   2a                DEC 10              ; killer2_low
   286a   2a                DEC 10              ; killer1_high
   286b   2a                DEC 10              ; killer1_low
                        
                            ; Store new killer1 (R11 = move that caused cutoff)
   286c   8b                GLO 11
   286d   5a                STR 10
   286e   1a                INC 10
   286f   9b                GHI 11
   2870   5a                STR 10
                        
   2871   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ORDER_TT_MOVE - Promote TT best move to front of move list
                        ; ------------------------------------------------------------------------------
                        ; Input:  R9 = start of move list
                        ;         D = move count
                        ; Output: Move list reordered with TT move at front (if found)
                        ; Uses:   R7, R8, R10, R11, R13
                        ; Note:   TT_MOVE_HI/LO must be populated by TT_PROBE before calling
                        ; ------------------------------------------------------------------------------
   2872                 ORDER_TT_MOVE:
   2872   a7                PLO 7               ; R7.0 = move count
   2873   c2 28 dd          LBZ OTM_DONE        ; No moves, return
                        
                            ; Load TT move (raw from/to squares)
   2876   68 ca 64 c0       RLDI 10, TT_MOVE_HI
   287a   4a                LDA 10              ; D = from
   287b   bd                PHI 13              ; R13.1 = from
   287c   0a                LDN 10              ; D = to
   287d   ad                PLO 13              ; R13.0 = to
                        
                            ; Check validity: both zero = no TT move
   287e   9d                GHI 13
   287f   ca 28 86          LBNZ OTM_VALID
   2882   8d                GLO 13
   2883   c2 28 dd          LBZ OTM_DONE
   2886                 OTM_VALID:
                        
                            ; Save move count (ENCODE clobbers R7)
   2886   87                GLO 7
   2887   73                STXD
                        
                            ; Set flags = 0 for encoding
   2888   68 ca 64 06       RLDI 10, MOVE_FLAGS_TEMP
   288c   f8 00             LDI 0
   288e   5a                STR 10
                        
                            ; Encode TT move to 16-bit format
   288f   d4 03 8d          CALL ENCODE_MOVE_16BIT
                            ; R8 = encoded TT move (flags=0 in top 2 bits)
                        
                            ; Save to R11 for comparison
   2892   98                GHI 8
   2893   bb                PHI 11
   2894   88                GLO 8
   2895   ab                PLO 11              ; R11 = encoded TT move
                        
                            ; Restore move count
   2896   60                IRX
   2897   f0                LDX                 ; D = move count
   2898   b7                PHI 7               ; R7.1 = loop counter
                        
                            ; Set up scan pointer
   2899   99                GHI 9
   289a   b8                PHI 8
   289b   89                GLO 9
   289c   a8                PLO 8               ; R8 = list start
                        
   289d                 OTM_SCAN:
   289d   97                GHI 7
   289e   c2 28 dd          LBZ OTM_DONE        ; Scanned all, no match
                        
                            ; MOVE_LIST entries are stored HIGH byte first (ADD_MOVE_ENCODED
                            ; movegen-helpers.asm:221). Fixed 2026-05-13 — old code mistakenly
                            ; called LDA 8's read "low byte". Compare HIGH (mask flag bits 6-7)
                            ; first, then LOW.
   28a1   48                LDA 8               ; list move HIGH byte; R8 advances
   28a2   fa 3f             ANI $3F             ; mask off flag bits 6-7
   28a4   52                STR 2
   28a5   9b                GHI 11              ; TT encoded HIGH byte (flags=0)
   28a6   f3                XOR
   28a7   ca 28 b1          LBNZ OTM_NEXT       ; HIGH bytes differ
                        
                            ; HIGH match — compare LOW byte (no mask)
   28aa   08                LDN 8               ; list move LOW byte; R8 stays
   28ab   52                STR 2
   28ac   8b                GLO 11              ; TT encoded LOW byte
   28ad   f3                XOR
   28ae   c2 28 b9          LBZ OTM_FOUND       ; Match!
                        
   28b1                 OTM_NEXT:
   28b1   18                INC 8               ; skip past LOW byte to next entry
   28b2   97                GHI 7
   28b3   ff 01             SMI 1
   28b5   b7                PHI 7
   28b6   c0 28 9d          LBR OTM_SCAN
                        
   28b9                 OTM_FOUND:
                            ; Match at R8-1 (LDA advanced). Swap with front (R9).
   28b9   28                DEC 8               ; R8 → matched move low byte
                        
                            ; Skip if already at front
   28ba   98                GHI 8
   28bb   52                STR 2
   28bc   99                GHI 9
   28bd   f3                XOR
   28be   ca 28 c8          LBNZ OTM_SWAP
   28c1   88                GLO 8
   28c2   52                STR 2
   28c3   89                GLO 9
   28c4   f3                XOR
   28c5   c2 28 dd          LBZ OTM_DONE        ; Already first
                        
   28c8                 OTM_SWAP:
                            ; Save front (R9) to stack
   28c8   49                LDA 9               ; front low, R9++
   28c9   73                STXD
   28ca   09                LDN 9               ; front high
   28cb   73                STXD
                        
                            ; Copy matched (R8) to front
   28cc   29                DEC 9               ; R9 back to front low
   28cd   48                LDA 8               ; src low, R8++
   28ce   59                STR 9
   28cf   19                INC 9
   28d0   08                LDN 8               ; src high
   28d1   59                STR 9
   28d2   19                INC 9               ; R9 = front + 2
                        
                            ; Copy saved front to matched position
   28d3   28                DEC 8               ; R8 back to src low
   28d4   60                IRX
   28d5   72                LDXA                ; saved high
   28d6   18                INC 8
   28d7   58                STR 8               ; R8+1 = saved high
   28d8   28                DEC 8
   28d9   f0                LDX                 ; saved low
   28da   58                STR 8               ; R8 = saved low
                        
                            ; Reset R9 to front
   28db   29                DEC 9
   28dc   29                DEC 9
                        
   28dd                 OTM_DONE:
   28dd   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ORDER_KILLER_MOVES - Promote killer moves to front of move list
                        ; ------------------------------------------------------------------------------
                        ; Input:  R9 = start of move list
                        ;         D = move count
                        ;         CURRENT_PLY = current ply (for killer table index)
                        ; Output: Move list reordered with killers at front
                        ; Uses:   R7, R8, R10, R11, R13
                        ; Note:   Call this right after GENERATE_MOVES, before move loop
                        ; ------------------------------------------------------------------------------
   28de                 ORDER_KILLER_MOVES:
                            ; Save move count
   28de   a7                PLO 7               ; R7.0 = move count
   28df   c2 29 a8          LBZ OKM_DONE        ; No moves, nothing to order
                        
                            ; Calculate killer table offset from CURRENT_PLY
   28e2   68 ca 64 48       RLDI 10, CURRENT_PLY
   28e6   0a                LDN 10              ; D = ply
   28e7   fa 0f             ANI $0F             ; Limit to 16 plies
   28e9   fe                SHL
   28ea   fe                SHL                 ; × 4 (2 moves × 2 bytes each)
   28eb   ad                PLO 13              ; R13.0 = offset
                        
                            ; Point to killer table entry
   28ec   f8 64             LDI HIGH(KILLER_MOVES)
   28ee   ba                PHI 10
   28ef   8d                GLO 13
   28f0   fc 20             ADI LOW(KILLER_MOVES)
   28f2   aa                PLO 10              ; R10 = &killer1 for this ply
                        
                            ; Load killer1 (16-bit) into R11
   28f3   4a                LDA 10              ; killer1 low
   28f4   ab                PLO 11
   28f5   4a                LDA 10              ; killer1 high
   28f6   bb                PHI 11              ; R11 = killer1
                        
                            ; Load killer2 (16-bit) into R13
   28f7   4a                LDA 10              ; killer2 low
   28f8   ad                PLO 13
   28f9   0a                LDN 10              ; killer2 high
   28fa   bd                PHI 13              ; R13 = killer2
                        
                            ; Check if killers are zero (uninitialized)
   28fb   8b                GLO 11
   28fc   f1                OR
   28fd   9b                GHI 11
   28fe   c2 29 47          LBZ OKM_TRY_KILLER2 ; killer1 is zero, skip
                        
                            ; === Search for killer1 in move list ===
                            ; R8 = scan pointer, start from R9
   2901   99                GHI 9
   2902   b8                PHI 8
   2903   89                GLO 9
   2904   a8                PLO 8               ; R8 = move list start
                        
   2905   87                GLO 7               ; D = move count
   2906   b7                PHI 7               ; R7.1 = loop counter
                        
   2907                 OKM_SCAN_K1:
   2907   97                GHI 7
   2908   c2 29 47          LBZ OKM_TRY_KILLER2 ; No more moves to scan
                        
                            ; MOVE_LIST entries stored HIGH first (ADD_MOVE_ENCODED:221). Killer is
                            ; stored with flags=0 (see beta-cutoff store at line ~2042). Compare
                            ; HIGH (mask flag bits 6-7 from list entry), then LOW. Fixed 2026-05-13
                            ; — old code had reversed byte order, so the optimization never matched.
   290b   48                LDA 8               ; list move HIGH byte; R8 advances
   290c   fa 3f             ANI $3F             ; mask off flag bits
   290e   52                STR 2
   290f   9b                GHI 11              ; killer1 HIGH (flags=0)
   2910   f3                XOR
   2911   ca 29 1b          LBNZ OKM_K1_NEXT    ; HIGH bytes don't match
                        
   2914   08                LDN 8               ; list move LOW byte; R8 stays
   2915   52                STR 2
   2916   8b                GLO 11              ; killer1 LOW
   2917   f3                XOR
   2918   c2 29 23          LBZ OKM_K1_FOUND    ; Match! Swap to front
                        
   291b                 OKM_K1_NEXT:
   291b   18                INC 8               ; skip past LOW byte to next entry
   291c   97                GHI 7
   291d   ff 01             SMI 1
   291f   b7                PHI 7               ; Decrement counter
   2920   c0 29 07          LBR OKM_SCAN_K1
                        
   2923                 OKM_K1_FOUND:
                            ; Killer1 found at R8-1 (we did LDA). Swap with first move.
   2923   28                DEC 8               ; R8 points to killer1_low in list
                        
                            ; Only swap if not already at front
   2924   98                GHI 8
   2925   52                STR 2
   2926   99                GHI 9
   2927   f3                XOR
   2928   ca 29 32          LBNZ OKM_K1_SWAP
   292b   88                GLO 8
   292c   52                STR 2
   292d   89                GLO 9
   292e   f3                XOR
   292f   c2 29 47          LBZ OKM_TRY_KILLER2 ; Already at front, no swap needed
                        
   2932                 OKM_K1_SWAP:
                            ; Swap 2-byte entry at R8 with entry at R9
                            ; Save move at R9 to stack
   2932   49                LDA 9
   2933   73                STXD
   2934   09                LDN 9
   2935   73                STXD
                        
                            ; Copy killer from R8 to R9 (LDA advanced R9 by 1, undo it)
   2936   29                DEC 9
   2937   48                LDA 8               ; killer low
   2938   59                STR 9
   2939   19                INC 9
   293a   08                LDN 8               ; killer high
   293b   59                STR 9
   293c   19                INC 9               ; R9 back to +2
                        
                            ; Copy saved move from stack to R8
   293d   28                DEC 8               ; Back to low byte position
   293e   60                IRX
   293f   72                LDXA                ; Saved high byte
   2940   18                INC 8
   2941   58                STR 8               ; Store at R8+1
   2942   28                DEC 8
   2943   f0                LDX                 ; Saved low byte
   2944   58                STR 8               ; Store at R8
                        
                            ; Reset R9 to list start
   2945   29                DEC 9
   2946   29                DEC 9
                        
   2947                 OKM_TRY_KILLER2:
                            ; Check if killer2 is zero
   2947   8d                GLO 13
   2948   f1                OR
   2949   9d                GHI 13
   294a   c2 29 a8          LBZ OKM_DONE        ; killer2 is zero, skip
                        
                            ; Check if we have at least 2 moves
   294d   87                GLO 7               ; Original move count
   294e   ff 02             SMI 2
   2950   cb 29 a8          LBNF OKM_DONE       ; Less than 2 moves
                        
                            ; === Search for killer2 in move list (skip first entry) ===
   2953   99                GHI 9
   2954   b8                PHI 8
   2955   89                GLO 9
   2956   fc 02             ADI 2               ; Skip first entry
   2958   a8                PLO 8
   2959   99                GHI 9
   295a   7c 00             ADCI 0
   295c   b8                PHI 8               ; R8 = second entry
                        
   295d   87                GLO 7               ; move count
   295e   ff 01             SMI 1               ; Skip first
   2960   b7                PHI 7               ; R7.1 = counter
                        
   2961                 OKM_SCAN_K2:
   2961   97                GHI 7
   2962   c2 29 a8          LBZ OKM_DONE        ; No more moves
                        
                            ; Byte-order fix (2026-05-13) — HIGH first with mask, then LOW.
   2965   48                LDA 8               ; list move HIGH byte; R8 advances
   2966   fa 3f             ANI $3F             ; mask off flag bits 6-7
   2968   52                STR 2
   2969   9d                GHI 13              ; killer2 HIGH (flags=0)
   296a   f3                XOR
   296b   ca 29 75          LBNZ OKM_K2_NEXT    ; HIGH bytes don't match
                        
   296e   08                LDN 8               ; list move LOW byte; R8 stays
   296f   52                STR 2
   2970   8d                GLO 13              ; killer2 LOW
   2971   f3                XOR
   2972   c2 29 7d          LBZ OKM_K2_FOUND    ; Match!
                        
   2975                 OKM_K2_NEXT:
   2975   18                INC 8               ; skip past LOW byte to next entry
   2976   97                GHI 7
   2977   ff 01             SMI 1
   2979   b7                PHI 7
   297a   c0 29 61          LBR OKM_SCAN_K2
                        
   297d                 OKM_K2_FOUND:
                            ; Killer2 found at R8-1. Swap with second move (R9+2).
   297d   28                DEC 8               ; R8 points to killer2_low
                        
                            ; Calculate second entry position
   297e   99                GHI 9
   297f   ba                PHI 10
   2980   89                GLO 9
   2981   fc 02             ADI 2
   2983   aa                PLO 10
   2984   99                GHI 9
   2985   7c 00             ADCI 0
   2987   ba                PHI 10              ; R10 = second entry
                        
                            ; Only swap if not already there
   2988   98                GHI 8
   2989   52                STR 2
   298a   9a                GHI 10
   298b   f3                XOR
   298c   ca 29 96          LBNZ OKM_K2_SWAP
   298f   88                GLO 8
   2990   52                STR 2
   2991   8a                GLO 10
   2992   f3                XOR
   2993   c2 29 a8          LBZ OKM_DONE        ; Already in position
                        
   2996                 OKM_K2_SWAP:
                            ; Swap 2-byte entry at R8 with entry at R10
   2996   4a                LDA 10              ; second entry low
   2997   73                STXD
   2998   0a                LDN 10              ; second entry high
   2999   73                STXD
                        
                            ; Copy killer to second position
   299a   2a                DEC 10
   299b   48                LDA 8               ; killer low
   299c   5a                STR 10
   299d   1a                INC 10
   299e   08                LDN 8               ; killer high
   299f   5a                STR 10
                        
                            ; Copy saved to R8
   29a0   28                DEC 8
   29a1   60                IRX
   29a2   72                LDXA                ; high byte
   29a3   18                INC 8
   29a4   58                STR 8
   29a5   28                DEC 8
   29a6   f0                LDX                 ; low byte
   29a7   58                STR 8
                        
   29a8                 OKM_DONE:
   29a8   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ORDER_CAPTURES_FIRST - Move captures to front of move list, sorted by
                        ;                        victim piece-type value (queen first, pawn last).
                        ; ------------------------------------------------------------------------------
                        ; Input:  R9 = start of move list
                        ;         D = move count
                        ; Output: Move list reordered with captures at front, victim-value descending
                        ;         (Q-takes, R-takes, B-takes, N-takes, P-takes, then non-captures).
                        ; Uses:   R7, R8, R10, R11, R13
                        ; Note:   Call after GENERATE_MOVES, before move loop. Implements simplified
                        ;         victim-only sort (no attacker analysis): 5 passes filtering by
                        ;         piece-type value 5..1. Front pointer R8 persists across passes.
                        ; ------------------------------------------------------------------------------
   29a9                 ORDER_CAPTURES_FIRST:
                            ; Save move count
   29a9   a7                PLO 7               ; R7.0 = move count
   29aa   c2 2a 20          LBZ OCF_DONE        ; No moves
                        
                            ; R8 = front pointer (where to put next capture; persists across passes)
   29ad   99                GHI 9
   29ae   b8                PHI 8
   29af   89                GLO 9
   29b0   a8                PLO 8               ; R8 = front = list start
                        
                            ; Initialize filter: start with QUEEN piece type (5), decrement each pass
   29b1   68 cd 64 49       RLDI 13, COMPARE_TEMP
   29b5   f8 05             LDI 5
   29b7   5d                STR 13              ; M(COMPARE_TEMP) = filter type
                        
   29b8                 OCF_PASS_LOOP:
                            ; R10 = scan pointer (re-init each pass)
   29b8   99                GHI 9
   29b9   ba                PHI 10
   29ba   89                GLO 9
   29bb   aa                PLO 10              ; R10 = scan = list start
                        
                            ; R7.1 = remaining count to scan (re-init each pass)
   29bc   87                GLO 7
   29bd   b7                PHI 7
                        
   29be                 OCF_SCAN_LOOP:
   29be   97                GHI 7
   29bf   c2 2a 15          LBZ OCF_PASS_DONE   ; No more moves to scan in this pass
                        
                            ; Decode move at R10 to get target square
                            ; Move format: [flags:2][to:7][from:7]
                            ; Move list is big-endian: high byte first, low byte second
   29c2   4a                LDA 10              ; High byte (first in big-endian)
   29c3   bb                PHI 11              ; R11.1 = high byte
   29c4   0a                LDN 10              ; Low byte (second in big-endian)
   29c5   ab                PLO 11              ; R11.0 = low byte
                        
                            ; Extract 'to' square: (high & $3F) << 1 | (low >> 7)
   29c6   9b                GHI 11              ; D = high byte (LDN left D with low byte)
   29c7   fa 3f             ANI $3F
   29c9   fe                SHL
   29ca   ad                PLO 13              ; R13.0 = to bits 1-6
   29cb   8b                GLO 11              ; Low byte
   29cc   fa 80             ANI $80             ; Bit 7
   29ce   c2 29 d5          LBZ OCF_TO_BIT0_CLR
   29d1   8d                GLO 13
   29d2   f9 01             ORI $01
   29d4   ad                PLO 13
   29d5                 OCF_TO_BIT0_CLR:
                            ; R13.0 = to square, R11 = encoded move
                        
                            ; Check if target square has a piece (any piece = potential capture)
                            ; Calculate BOARD + to_square
                            ; BOARD is at $6000, so high byte is $60, low byte is to_square
   29d5   f8 60             LDI HIGH(BOARD)
   29d7   bd                PHI 13
                            ; R13 now = $60xx where xx = to_square (already in R13.0)
                        
                            ; Load piece at target square
   29d8   0d                LDN 13              ; D = piece at target
   29d9   2a                DEC 10              ; Reset R10 to low byte position
                        
                            ; If piece is 0 (empty), not a capture
   29da   c2 2a 0c          LBZ OCF_NEXT_MOVE   ; Empty square, skip
                        
                            ; Check victim type against current pass filter.
                            ; D still holds piece byte; mask off color to get type (1-6).
   29dd   fa 07             ANI PIECE_MASK      ; D = victim type (1-5; king=6 can't actually be captured)
   29df   52                STR 2               ; M(R2) = victim type (temp)
   29e0   68 cd 64 49       RLDI 13, COMPARE_TEMP
   29e4   0d                LDN 13              ; D = current pass filter type
   29e5   f3                XOR                 ; D = filter ^ victim (0 if match, since SEX 2 set globally)
   29e6   ca 2a 0c          LBNZ OCF_NEXT_MOVE  ; victim type doesn't match this pass — skip
                        
                            ; Match: capture with current filter type. Fall through to swap.
                        
   29e9                 OCF_IS_CAPTURE:
                            ; Move is a capture - swap to front if not already there
                            ; R10 points to current move, R8 points to front
   29e9   9a                GHI 10
   29ea   52                STR 2
   29eb   98                GHI 8
   29ec   f3                XOR
   29ed   ca 29 f7          LBNZ OCF_DO_SWAP
   29f0   8a                GLO 10
   29f1   52                STR 2
   29f2   88                GLO 8
   29f3   f3                XOR
   29f4   c2 2a 0a          LBZ OCF_ADVANCE_FRONT  ; Already at front
                        
   29f7                 OCF_DO_SWAP:
                            ; Swap 2-byte entries at R8 and R10
                            ; Save R8 entry to stack
   29f7   48                LDA 8
   29f8   73                STXD
   29f9   08                LDN 8
   29fa   73                STXD
   29fb   28                DEC 8               ; Reset R8
                        
                            ; Copy R10 to R8
   29fc   4a                LDA 10
   29fd   58                STR 8
   29fe   18                INC 8
   29ff   0a                LDN 10
   2a00   58                STR 8
   2a01   28                DEC 8
   2a02   2a                DEC 10              ; Reset both
                        
                            ; Copy stack to R10
   2a03   60                IRX
   2a04   72                LDXA                ; High byte
   2a05   1a                INC 10
   2a06   5a                STR 10
   2a07   2a                DEC 10
   2a08   f0                LDX                 ; Low byte
   2a09   5a                STR 10
                        
   2a0a                 OCF_ADVANCE_FRONT:
                            ; Advance front pointer
   2a0a   18                INC 8
   2a0b   18                INC 8
                        
   2a0c                 OCF_NEXT_MOVE:
                            ; Advance scan pointer
   2a0c   1a                INC 10
   2a0d   1a                INC 10
                            ; Decrement counter
   2a0e   97                GHI 7
   2a0f   ff 01             SMI 1
   2a11   b7                PHI 7
   2a12   c0 29 be          LBR OCF_SCAN_LOOP
                        
   2a15                 OCF_PASS_DONE:
                            ; Decrement filter type for next pass; loop until filter reaches 0.
   2a15   68 cd 64 49       RLDI 13, COMPARE_TEMP
   2a19   0d                LDN 13
   2a1a   ff 01             SMI 1
   2a1c   5d                STR 13              ; filter--
   2a1d   ca 29 b8          LBNZ OCF_PASS_LOOP  ; continue if filter > 0
                        
   2a20                 OCF_DONE:
   2a20   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; INC_NODE_COUNT - Increment 32-bit node counter (FULL VERSION)
                        ; ------------------------------------------------------------------------------
                        ; Input:  None
                        ; Output: NODES_SEARCHED incremented
                        ; Uses:   A, D
                        ; ------------------------------------------------------------------------------
   2a21                 INC_NODE_COUNT:
   2a21   68 ca 64 12       RLDI 10, NODES_SEARCHED
                        
                            ; Increment byte 0 (LSB)
   2a25   0a                LDN 10
   2a26   fc 01             ADI 1
   2a28   5a                STR 10
   2a29   ca 2a 41          LBNZ INC_NODE_DONE   ; No carry
                        
                            ; Carry to byte 1
   2a2c   1a                INC 10
   2a2d   0a                LDN 10
   2a2e   7c 00             ADCI 0
   2a30   5a                STR 10
   2a31   ca 2a 41          LBNZ INC_NODE_DONE
                        
                            ; Carry to byte 2
   2a34   1a                INC 10
   2a35   0a                LDN 10
   2a36   7c 00             ADCI 0
   2a38   5a                STR 10
   2a39   ca 2a 41          LBNZ INC_NODE_DONE
                        
                            ; Carry to byte 3 (MSB)
   2a3c   1a                INC 10
   2a3d   0a                LDN 10
   2a3e   7c 00             ADCI 0
   2a40   5a                STR 10
                        
   2a41                 INC_NODE_DONE:
   2a41   d5                RETN
                        
                        ; ==============================================================================
                        ; SEARCH_POSITION - Iterative Deepening Entry Point
                        ; ==============================================================================
                        ; Input:  SEARCH_DEPTH = target depth (stored in memory by UCI handler)
                        ; Output: R9 = best score (R6 is SCRT linkage - off limits!)
                        ;         BEST_MOVE = best move found
                        ; Searches depth 1, 2, ..., TARGET_DEPTH. If depth N exceeds node budget,
                        ; aborts and returns depth N-1's bestmove.
                        ; ==============================================================================
   2a42                 SEARCH_POSITION:
   2a42   e2                SEX 2
                        
                            ; --- Save TARGET_DEPTH from SEARCH_DEPTH (set by UCI handler) ---
   2a43   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   2a47   0a                LDN 10                      ; D = target depth (low byte)
   2a48   73                STXD                        ; Save depth on stack (LDI clobbers D!)
   2a49   68 ca 64 c6       RLDI 10, TARGET_DEPTH
   2a4d   60                IRX
   2a4e   f0                LDX                         ; D = target depth (restored from stack)
   2a4f   5a                STR 10                      ; TARGET_DEPTH = original depth
                        
                            ; --- Clear SEARCH_ABORTED flag ---
   2a50   68 ca 64 c4       RLDI 10, SEARCH_ABORTED
   2a54   f8 00             LDI 0
   2a56   5a                STR 10
                        
                            ; --- Clear ITER_BEST (no bestmove yet) ---
   2a57   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   2a5b   f8 ff             LDI $FF
   2a5d   5a                STR 10
   2a5e   1a                INC 10
   2a5f   5a                STR 10                      ; ITER_BEST_TO = $FF
                        
                            ; --- Set starting depth = 1 ---
   2a60   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2a64   f8 01             LDI 1
   2a66   5a                STR 10
                        
                            ; --- Initialize RTC elapsed timer ---
                            ; Read current seconds from DS12887 RTC (binary mode)
                            ; Protocol: OUT port 2 = register select, INP port 3 = read data
   2a67   f8 80             LDI $80                     ; $80 = seconds register
   2a69   52                STR 2                       ; Store at M(R2) for OUT
   2a6a   62                OUT 2                       ; Send to port 2 (selects seconds), R2++
   2a6b   22                DEC 2                       ; Restore stack pointer
   2a6c   6b                INP 3                       ; D = seconds (binary 0-59), also M(R2)
   2a6d   73                STXD                        ; Save seconds on stack (LDI clobbers D!)
   2a6e   68 ca 64 ca       RLDI 10, SEARCH_PREV_SECS
   2a72   60                IRX
   2a73   f0                LDX                         ; D = seconds (restored)
   2a74   5a                STR 10                      ; SEARCH_PREV_SECS = current seconds
                        
                            ; Clear elapsed counter
   2a75   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2a79   f8 00             LDI 0
   2a7b   5a                STR 10                      ; SEARCH_ELAPSED = 0
                        
                            ; --- Canary check (ported 2026-07-13): CANARY_ZONE $64F7-$64FC must be all
                            ; zero (no code owns it; the 7/3 v3-build crash dump found stray writes
                            ; there). Sticky-OR into CANARY_HIT once per search — a nonzero CANARY_HIT
                            ; in any post-crash dump = the stray writer struck this game.
   2a7c   68 ca 64 f7       RLDI 10, CANARY_ZONE
   2a80   f8 00             LDI 0
   2a82   52                STR 2                       ; M(2) = accumulator = 0
   2a83   f8 06             LDI 6
   2a85   ab                PLO 11                      ; R11.0 = byte counter (R11 reloaded below)
   2a86                 SP_CANARY_LP:
   2a86   4a                LDA 10
   2a87   f1                OR                          ; D = zone byte | acc
   2a88   52                STR 2                       ; acc back to M(2)
   2a89   2b                DEC 11
   2a8a   8b                GLO 11
   2a8b   ca 2a 86          LBNZ SP_CANARY_LP
   2a8e   68 ca 64 1e       RLDI 10, CANARY_HIT
   2a92   0a                LDN 10
   2a93   f1                OR                          ; D = CANARY_HIT | acc
   2a94   5a                STR 10                      ; sticky
                        
                            ; --- Clear node counter (once for entire search) ---
   2a95   68 cb 64 12       RLDI 11, NODES_SEARCHED
   2a99   f8 00             LDI 0
   2a9b   5b                STR 11
   2a9c   1b                INC 11
   2a9d   5b                STR 11
   2a9e   1b                INC 11
   2a9f   5b                STR 11
   2aa0   1b                INC 11
   2aa1   5b                STR 11
                        
                            ; --- Zobrist hash: use the incremental hash from UCI parsing ---
                            ; Do NOT call HASH_INIT here! HASH_INIT includes castling/EP Zobrist
                            ; keys, but MAKE_MOVE doesn't XOR castling/EP changes. This creates a
                            ; mismatch between search hashes (from-scratch) and HASH_HIST entries
                            ; (incremental), which breaks repetition detection completely.
                            ; The hash left by UCI parsing is already correct and consistent.
                        
                        ; ======================================================================
                        ; ITERATIVE DEEPENING LOOP
                        ; ======================================================================
   2aa2                 ITER_LOOP:
                            ; --- Set SEARCH_DEPTH = CURRENT_MAX_DEPTH for this iteration ---
   2aa2   68 ca 64 16       RLDI 10, SEARCH_DEPTH
   2aa6   f8 00             LDI 0
   2aa8   5a                STR 10                      ; SEARCH_DEPTH high = 0
   2aa9   1a                INC 10
                            ; Load CURRENT_MAX_DEPTH
   2aaa   68 cd 64 c5       RLDI 13, CURRENT_MAX_DEPTH
   2aae   0d                LDN 13                      ; D = current depth
   2aaf   5a                STR 10                      ; SEARCH_DEPTH low = current depth
                        
                            ; --- Reset SEARCH_ABORTED for this iteration ---
   2ab0   68 ca 64 c4       RLDI 10, SEARCH_ABORTED
   2ab4   f8 00             LDI 0
   2ab6   5a                STR 10
                        
                            ; --- Capture iteration start time for iteration-time gate ---
   2ab7   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2abb   0a                LDN 10
   2abc   68 ca 64 ed       RLDI 10, ITER_START_ELAPSED
   2ac0   5a                STR 10
                        
                            ; --- Standard search init ---
                            ; Alpha = -32767
   2ac1   68 ca 64 42       RLDI 10, ALPHA_HI
   2ac5   f8 80             LDI $80
   2ac7   5a                STR 10                      ; ALPHA_HI = $80
   2ac8   1a                INC 10
   2ac9   f8 01             LDI $01
   2acb   5a                STR 10                      ; ALPHA_LO = $01
                        
                            ; Beta = +32767
   2acc   68 ca 64 44       RLDI 10, BETA_HI
   2ad0   f8 7f             LDI $7F
   2ad2   5a                STR 10                      ; BETA_HI = $7F
   2ad3   1a                INC 10
   2ad4   f8 ff             LDI $FF
   2ad6   5a                STR 10                      ; BETA_LO = $FF
                        
                            ; CURRENT_PLY = 0
   2ad7   68 ca 64 48       RLDI 10, CURRENT_PLY
   2adb   f8 00             LDI 0
   2add   5a                STR 10
                        
                            ; NULL_MOVE_OK = 1
   2ade   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   2ae2   f8 01             LDI 1
   2ae4   5a                STR 10
                        
                            ; Get side to move
   2ae5   d4 01 3e          CALL GET_SIDE_TO_MOVE
   2ae8   ac                PLO 12                      ; C.0 = color
                        
                            ; Board pointer
   2ae9   68 ca 60 00       RLDI 10, BOARD
                        
                            ; Clear best move for this iteration
   2aed   68 cb 64 10       RLDI 11, BEST_MOVE
   2af1   f8 ff             LDI $FF
   2af3   5b                STR 11
   2af4   1b                INC 11
   2af5   5b                STR 11
                        
                            ; --- Run search for this depth ---
   2af6   d4 1b 58          CALL NEGAMAX
                        
                            ; --- Check if search was aborted ---
   2af9   68 ca 64 c4       RLDI 10, SEARCH_ABORTED
   2afd   0a                LDN 10
   2afe   ca 2b 73          LBNZ ITER_ABORTED           ; Aborted: use previous depth's bestmove
                        
                            ; --- Depth completed: save bestmove ---
                            ; Set up BOTH pointers first, then copy (LDI clobbers D!)
   2b01   68 ca 64 10       RLDI 10, BEST_MOVE
   2b05   68 cb 64 c2       RLDI 11, ITER_BEST_FROM
                            ; Now copy: R10→BEST_MOVE, R11→ITER_BEST
   2b09   4a                LDA 10                      ; D = from square
   2b0a   5b                STR 11                      ; ITER_BEST_FROM = from
   2b0b   1b                INC 11
   2b0c   0a                LDN 10                      ; D = to square (BEST_MOVE+1)
   2b0d   5b                STR 11                      ; ITER_BEST_TO = to
                        
                            ; --- Save score from this depth ---
   2b0e   68 ca 64 c8       RLDI 10, ITER_SCORE_HI
   2b12   99                GHI 9
   2b13   5a                STR 10                      ; ITER_SCORE_HI = R9.hi
   2b14   1a                INC 10
   2b15   89                GLO 9
   2b16   5a                STR 10                      ; ITER_SCORE_LO = R9.lo
                        
                            ; --- Send UCI "info" for this depth ---
   2b17   d4 2b 81          CALL SEND_UCI_INFO
                        
                            ; Stack-overflow handling moved to CHECK_STACK_OVERFLOW (2026-05-16):
                            ; it now traps via MARK/SEP 1 immediately on detection, so this
                            ; IDS-boundary report path is unreachable. STACK_OVERFLOW_FLAG remains
                            ; written by the guard for post-trap memory dump inspection.
   2b1a                 ITER_NO_SOVF:
                        
                            ; --- Iterative deepening termination decision ---
                            ; UCI semantics: TARGET_DEPTH is treated as a CAP (max depth we may reach),
                            ; not a fixed target. The engine self-decides whether to attempt the next
                            ; deeper iteration based on iteration-time prediction and a hard safety cap.
                            ;
                            ; Termination rules (stop if any are true; else continue to current+1):
                            ;   1. current >= TARGET_DEPTH   — respect UCI cap
                            ;   2. current >= 5              — hard safety cap (MOVE_LIST sized for 5 plies)
                            ;   3. current >= 3 AND predicted_next > remaining_budget — iter-time gate
                            ;
                            ; Iter-time gate (rule 3, replaces 60s/90s cumulative thresholds 2026-05-06):
                            ;   predicted_next = 3 * last_iter_seconds  (BF=3, conservative)
                            ;   remaining      = 180 - SEARCH_ELAPSED
                            ;   stop if predicted_next >= remaining
                            ; Rationale: closed positions branch ~3x at d>=4 (vs ~1.8x in open). Old
                            ; cumulative gate let d=5 start with insufficient budget in Hippo-class
                            ; positions, wasting 80-110s/move on incomplete d=5 (lost match 2026-05-06
                            ; move 5-9, all d=4 timeouts). Iteration-time gate uses the actual measured
                            ; iteration time so it adapts to position. RTC is 1s resolution; gate only
                            ; applies at d>=3 where iteration times are reliably multi-second.
                        
                            ; Rule 1: current >= TARGET_DEPTH?
   2b1a   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2b1e   0a                LDN 10
   2b1f   52                STR 2                       ; M(R2) = current
   2b20   68 ca 64 c6       RLDI 10, TARGET_DEPTH
   2b24   0a                LDN 10                      ; D = target
   2b25   f7                SM                          ; D = target - current; DF=1 if target >= current
   2b26   cb 2b 80          LBNF ITER_DONE              ; target < current — defensive (shouldn't happen)
   2b29   c2 2b 80          LBZ ITER_DONE               ; target == current — UCI cap reached
                        
                            ; Rule 2: current >= 5?
   2b2c   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2b30   0a                LDN 10
   2b31   ff 05             SMI 5
   2b33   c3 2b 80          LBDF ITER_DONE              ; current >= 5 — hard safety cap
                        
                            ; Rule 3: iteration-time gate. Apply only at depth >= 3.
   2b36   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2b3a   0a                LDN 10
   2b3b   ff 03             SMI 3
   2b3d   cb 2b 68          LBNF ITER_INCREMENT         ; current < 3 — always continue (RTC granularity)
                        
                            ; last_iter_seconds = SEARCH_ELAPSED - ITER_START_ELAPSED
   2b40   68 ca 64 ed       RLDI 10, ITER_START_ELAPSED
   2b44   0a                LDN 10
   2b45   52                STR 2                       ; M(R2) = iter_start
   2b46   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2b4a   0a                LDN 10                      ; D = elapsed
   2b4b   f7                SM                          ; D = elapsed - iter_start = last_iter
   2b4c   ad                PLO 13                      ; R13.0 = last_iter
                        
                            ; Fast path: last_iter > 60 → 3*last_iter overflows AND exceeds remaining
   2b4d   ff 3d             SMI 61
   2b4f   c3 2b 80          LBDF ITER_DONE              ; last_iter >= 61 — stop
                        
                            ; predicted = 3 * last_iter (no overflow: last_iter <= 60, so 3x <= 180)
   2b52   8d                GLO 13                      ; D = last_iter
   2b53   fe                SHL                         ; D = 2 * last_iter
   2b54   52                STR 2                       ; M(R2) = 2 * last_iter
   2b55   8d                GLO 13                      ; D = last_iter
   2b56   f4                ADD                         ; D = 3 * last_iter
   2b57   ad                PLO 13                      ; R13.0 = predicted
                        
                            ; remaining = 180 - SEARCH_ELAPSED
   2b58   68 ca 64 cb       RLDI 10, SEARCH_ELAPSED
   2b5c   0a                LDN 10
   2b5d   fd b4             SDI 180                     ; D = 180 - elapsed
   2b5f   cb 2b 80          LBNF ITER_DONE              ; elapsed > 180 (defensive; budget abort handles too)
                        
                            ; if predicted >= remaining: stop, else continue
   2b62   52                STR 2                       ; M(R2) = remaining
   2b63   8d                GLO 13                      ; D = predicted
   2b64   f7                SM                          ; D = predicted - remaining
   2b65   c3 2b 80          LBDF ITER_DONE              ; predicted >= remaining — stop
                        
   2b68                 ITER_INCREMENT:
                            ; --- Increment depth and loop ---
   2b68   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2b6c   0a                LDN 10
   2b6d   fc 01             ADI 1
   2b6f   5a                STR 10                      ; CURRENT_MAX_DEPTH++
   2b70   c0 2a a2          LBR ITER_LOOP
                        
   2b73                 ITER_ABORTED:
                            ; Search at this depth was aborted — fall back to ITER_BEST
                            ; Set up BOTH pointers first, then copy (LDI clobbers D!)
   2b73   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   2b77   68 cb 64 10       RLDI 11, BEST_MOVE
                            ; Now copy: R10→ITER_BEST, R11→BEST_MOVE
   2b7b   4a                LDA 10                      ; D = ITER_BEST_FROM
   2b7c   5b                STR 11                      ; BEST_MOVE[0] = from
   2b7d   1b                INC 11
   2b7e   0a                LDN 10                      ; D = ITER_BEST_TO
   2b7f   5b                STR 11                      ; BEST_MOVE[1] = to
                        
   2b80                 ITER_DONE:
   2b80   d5                RETN
                        
                        ; ==============================================================================
                        ; SEND_UCI_INFO - Send "info depth N score cp S nodes NNNNN" after each iteration
                        ; ==============================================================================
                        ; Sends: "info depth N score cp S nodes NNNNN\r\n"
                        ;   N = CURRENT_MAX_DEPTH (ASCII digit)
                        ;   S = ITER_SCORE as signed decimal (centipawns)
                        ;   NNNNN = NODES_SEARCHED as decimal via F_UINTOUT (lower 16 bits)
                        ; ==============================================================================
   2b81                 SEND_UCI_INFO:
                            ; Send "info depth "
   2b81   68 cf 2c af       RLDI 15, STR_INFO_DEPTH
   2b85   d4                SEP 4
   2b86   ff 09             DW F_MSG
                        
                            ; Send depth digit (1-9)
   2b88   68 ca 64 c5       RLDI 10, CURRENT_MAX_DEPTH
   2b8c   0a                LDN 10                      ; D = depth (1-9)
   2b8d   fc 30             ADI '0'                     ; Convert to ASCII
   2b8f   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
                            ; Send " score cp "
   2b92   68 cf 2c bb       RLDI 15, STR_SCORE_CP
   2b96   d4                SEP 4
   2b97   ff 09             DW F_MSG
                        
                            ; Load score into R13 (big-endian: HI at $64C8, LO at $64C9)
   2b99   68 ca 64 c8       RLDI 10, ITER_SCORE_HI
   2b9d   4a                LDA 10                      ; D = score high byte, R10 -> LO
   2b9e   bd                PHI 13
   2b9f   0a                LDN 10                      ; D = score low byte
   2ba0   ad                PLO 13                      ; R13 = signed 16-bit score
                        
                            ; Check if negative
   2ba1   9d                GHI 13
   2ba2   fa 80             ANI $80
   2ba4   c2 2b b4          LBZ SUCI_POSITIVE
                        
                            ; Negative: print '-' and negate R13 to get absolute value
   2ba7   f8 2d             LDI '-'
   2ba9   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2bac   8d                GLO 13                      ; low byte
   2bad   fd 00             SDI 0                       ; negate low
   2baf   ad                PLO 13
   2bb0   9d                GHI 13                      ; high byte
   2bb1   7d 00             SDBI 0                      ; negate high with borrow
   2bb3   bd                PHI 13
                        
   2bb4                 SUCI_POSITIVE:
                            ; Convert R13 (now unsigned magnitude) to ASCII decimal
   2bb4   68 cf 64 cc       RLDI 15, UINT_BUFFER
   2bb8   d4                SEP 4
   2bb9   ff 60             DW F_UINTOUT
                        
                            ; Null-terminate (R15 points past last digit)
   2bbb   f8 00             LDI 0
   2bbd   5f                STR 15
                        
                            ; Print the score string
   2bbe   68 cf 64 cc       RLDI 15, UINT_BUFFER
   2bc2   d4                SEP 4
   2bc3   ff 09             DW F_MSG
                        
                            ; Send " nodes "
   2bc5   68 cf 2c c6       RLDI 15, STR_NODES
   2bc9   d4                SEP 4
   2bca   ff 09             DW F_MSG
                        
                            ; Load NODES_SEARCHED (16-bit) into R13: high byte first, then low
   2bcc   68 ca 64 13       RLDI 10, NODES_SEARCHED + 1
   2bd0   0a                LDN 10                      ; D = high byte of node count
   2bd1   bd                PHI 13                      ; R13.1 = high byte
   2bd2   68 ca 64 12       RLDI 10, NODES_SEARCHED
   2bd6   0a                LDN 10                      ; D = low byte of node count
   2bd7   ad                PLO 13                      ; R13.0 = low byte
                        
                            ; Point R15 at ASCII scratch buffer
   2bd8   68 cf 64 cc       RLDI 15, UINT_BUFFER
                        
                            ; Convert R13 to ASCII decimal at R15
   2bdc   d4                SEP 4
   2bdd   ff 60             DW F_UINTOUT
                        
                            ; Null-terminate (R15 points past last digit)
   2bdf   f8 00             LDI 0
   2be1   5f                STR 15
                        
                            ; Print the decimal string
   2be2   68 cf 64 cc       RLDI 15, UINT_BUFFER
   2be6   d4                SEP 4
   2be7   ff 09             DW F_MSG
                        
                            ; Send CR+LF
   2be9   f8 0d             LDI 13
   2beb   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2bee   f8 0a             LDI 10
   2bf0   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   2bf3   d5                RETN
                        
                        ; ==============================================================================
                        ; End of Negamax Core
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - UCI Protocol Implementation
                        ; ==============================================================================
                        ; Universal Chess Interface for communication with GUI
                        ; Implements minimal UCI subset for playability
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI Command Buffer - defined in board.asm
                        ; ------------------------------------------------------------------------------
                        ; UCI_BUFFER ($7000, 2048 bytes) and UCI_STATE ($64B8) defined in board.asm
   07ff                 UCI_BUFFER_LEN  EQU 2047    ; Max chars (16-bit counter, 2048-byte buffer)
   0001                 UCI_READY       EQU 1       ; Ready state
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI String Constants
                        ; ------------------------------------------------------------------------------
                        ; These would be defined as byte arrays in actual implementation
                        
   2bf4   75 63 69 00   STR_UCI         DB "uci", 0
   2bf8   69 73 72 65   STR_ISREADY     DB "isready", 0
   2bfc   61 64 79 00   
   2c00   70 6f 73 69   STR_POSITION    DB "position", 0
   2c04   74 69 6f 6e   
   2c08   00            
   2c09   67 6f 00      STR_GO          DB "go", 0
   2c0c   71 75 69 74   STR_QUIT        DB "quit", 0
   2c10   00            
   2c11   75 63 69 6e   STR_UCINEWGAME  DB "ucinewgame", 0
   2c15   65 77 67 61   
   2c19   6d 65 00      
   2c1c   73 74 6f 70   STR_STOP        DB "stop", 0
   2c20   00            
                        
                        ; Response strings (CR+LF for terminal display)
   2c21   69 64 20 6e   STR_ID_NAME     DB "id name RCA-Chess-1806", 13, 10, 0
   2c25   61 6d 65 20   
   2c29   52 43 41 2d   
   2c2d   43 68 65 73   
   2c31   73 2d 31 38   
   2c35   30 36 0d 0a   
   2c39   00            
   2c3a   69 64 20 61   STR_ID_AUTHOR   DB "id author Mark Abene & Claude Code", 13, 10, 0
   2c3e   75 74 68 6f   
   2c42   72 20 4d 61   
   2c46   72 6b 20 41   
   2c4a   62 65 6e 65   
   2c4e   20 26 20 43   
   2c52   6c 61 75 64   
   2c56   65 20 43 6f   
   2c5a   64 65 0d 0a   
   2c5e   00            
   2c5f   6f 70 74 69   STR_OPTION_DEPTH DB "option name Depth type spin default 4 min 1 max 6", 13, 10, 0
   2c63   6f 6e 20 6e   
   2c67   61 6d 65 20   
   2c6b   44 65 70 74   
   2c6f   68 20 74 79   
   2c73   70 65 20 73   
   2c77   70 69 6e 20   
   2c7b   64 65 66 61   
   2c7f   75 6c 74 20   
   2c83   34 20 6d 69   
   2c87   6e 20 31 20   
   2c8b   6d 61 78 20   
   2c8f   36 0d 0a 00   
   2c93   75 63 69 6f   STR_UCIOK       DB "uciok", 13, 10, 0
   2c97   6b 0d 0a 00   
   2c9b   72 65 61 64   STR_READYOK     DB "readyok", 13, 10, 0
   2c9f   79 6f 6b 0d   
   2ca3   0a 00         
   2ca5   62 65 73 74   STR_BESTMOVE    DB "bestmove ", 0
   2ca9   6d 6f 76 65   
   2cad   20 00         
   2caf   69 6e 66 6f   STR_INFO_DEPTH  DB "info depth ", 0
   2cb3   20 64 65 70   
   2cb7   74 68 20 00   
   2cbb   20 73 63 6f   STR_SCORE_CP    DB " score cp ", 0
   2cbf   72 65 20 63   
   2cc3   70 20 00      
   2cc6   20 6e 6f 64   STR_NODES       DB " nodes ", 0
   2cca   65 73 20 00   
                        ; STR_INFO_SOVF removed 2026-05-16 — CHECK_STACK_OVERFLOW now hard-traps
                        ; via MARK/SEP 1 instead of emitting an info string via a corrupted stack.
   2cce   69 6e 66 6f   STR_INFO_RMV    DB "info string ROOT_MOVE_INVALID_SUBSTITUTED", 13, 10, 0
   2cd2   20 73 74 72   
   2cd6   69 6e 67 20   
   2cda   52 4f 4f 54   
   2cde   5f 4d 4f 56   
   2ce2   45 5f 49 4e   
   2ce6   56 41 4c 49   
   2cea   44 5f 53 55   
   2cee   42 53 54 49   
   2cf2   54 55 54 45   
   2cf6   44 0d 0a 00   
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_INIT - Initialize UCI interface
                        ; ------------------------------------------------------------------------------
   2cfa                 UCI_INIT:
                            ; Set up serial I/O (if needed)
                            ; TODO: Hardware-specific initialization
                        
                            ; Set initial state
   2cfa   f8 01             LDI UCI_READY
   2cfc   ad                PLO 13
                        
   2cfd   68 ca 64 b8       RLDI 10, UCI_STATE
                        
   2d01   8d                GLO 13
   2d02   5a                STR 10
                        
   2d03   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_READ_LINE - Read a line of input
                        ; ------------------------------------------------------------------------------
                        ; Input:  None
                        ; Output: Line in UCI_BUFFER, null-terminated
                        ;         D = length
                        ; Uses:   A, D
                        ;
                        ; Reads characters until newline or max length
                        ; ------------------------------------------------------------------------------
   2d04                 UCI_READ_LINE:
   2d04   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d08   f8 00             LDI 0
   2d0a   bd                PHI 13              ; R13.1 = count high byte = 0
   2d0b   ad                PLO 13              ; R13.0 = count low byte = 0
                        
   2d0c                 UCI_READ_LOOP:
                            ; Read character from serial input
   2d0c   d4 00 07          CALL SERIAL_READ_CHAR
                            ; Returns character in D
                        
                            ; Check for carriage return (CR = 13)
   2d0f   ff 0d             SMI 13
   2d11   c2 2d 2c          LBZ UCI_READ_DONE
                        
                            ; Check for newline (LF = 10) - restore D first
   2d14   fc 0d             ADI 13              ; Restore: (D-13)+13 = D
   2d16   ff 0a             SMI 10              ; Check for LF
   2d18   c2 2d 2c          LBZ UCI_READ_DONE
   2d1b   fc 0a             ADI 10              ; Restore D
                        
                            ; Store character
   2d1d   5a                STR 10
   2d1e   1a                INC 10
                        
                            ; Increment 16-bit count
   2d1f   1d                INC 13
                        
                            ; Check buffer limit (16-bit: UCI_BUFFER_LEN = 2047 = $07FF)
   2d20   8d                GLO 13
   2d21   fb ff             XRI LOW(UCI_BUFFER_LEN)
   2d23   ca 2d 0c          LBNZ UCI_READ_LOOP
   2d26   9d                GHI 13
   2d27   fb 07             XRI HIGH(UCI_BUFFER_LEN)
   2d29   ca 2d 0c          LBNZ UCI_READ_LOOP
                            ; Count == UCI_BUFFER_LEN, buffer full
                        
                        
                        
   2d2c                 UCI_READ_DONE:
                            ; Null-terminate string
   2d2c   f8 00             LDI 0
   2d2e   5a                STR 10
                        
                            ; Echo CR+LF
   2d2f   f8 0d             LDI 13
   2d31   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2d34   f8 0a             LDI 10
   2d36   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
                            ; Return length
   2d39   8d                GLO 13
   2d3a   d5                RETN
                        
                        ; NOTE: UCI_WRITE_STRING removed - use F_MSG with R15 directly
                        ; The old UCI_WRITE_STRING used R10, which clobbered the negamax loop counter!
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_PROCESS_COMMAND - Process UCI command from buffer
                        ; ------------------------------------------------------------------------------
                        ; Input:  Command in UCI_BUFFER
                        ; Output: Appropriate action taken
                        ; ------------------------------------------------------------------------------
   2d3b                 UCI_PROCESS_COMMAND:
                            ; Compare command with known commands
                        
                            ; Check "uci"
   2d3b   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d3f   68 cb 2b f4       RLDI 11, STR_UCI
                        
   2d43   d4 30 57          CALL STRCMP
   2d46   c2 2d 9e          LBZ UCI_CMD_UCI
                        
                            ; Check "isready"
   2d49   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d4d   68 cb 2b f8       RLDI 11, STR_ISREADY
                        
   2d51   d4 30 57          CALL STRCMP
   2d54   c2 2d bb          LBZ UCI_CMD_ISREADY
                        
                            ; Check "position"
   2d57   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d5b   68 cb 2c 00       RLDI 11, STR_POSITION
                        
   2d5f   d4 30 6d          CALL STRNCMP        ; Compare first 8 chars
   2d62   c2 2d c3          LBZ UCI_CMD_POSITION
                        
                            ; Check "go"
   2d65   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d69   68 cb 2c 09       RLDI 11, STR_GO
                        
   2d6d   d4 30 6d          CALL STRNCMP
   2d70   c2 2e f2          LBZ UCI_CMD_GO
                        
                            ; Check "quit"
   2d73   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d77   68 cb 2c 0c       RLDI 11, STR_QUIT
                        
   2d7b   d4 30 57          CALL STRCMP
   2d7e   c2 2f da          LBZ UCI_CMD_QUIT
                        
                            ; Check "ucinewgame"
   2d81   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d85   68 cb 2c 11       RLDI 11, STR_UCINEWGAME
                        
   2d89   d4 30 57          CALL STRCMP
   2d8c   c2 2f dd          LBZ UCI_CMD_UCINEWGAME
                        
                            ; Check "stop"
   2d8f   68 ca 70 00       RLDI 10, UCI_BUFFER
                        
   2d93   68 cb 2c 1c       RLDI 11, STR_STOP
                        
   2d97   d4 30 57          CALL STRCMP
   2d9a   c2 30 08          LBZ UCI_CMD_STOP
                        
                            ; Unknown command - ignore
   2d9d   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI Command Handlers
                        ; ------------------------------------------------------------------------------
                        
   2d9e                 UCI_CMD_UCI:
                            ; Send identification
   2d9e   68 cf 2c 21       RLDI 15, STR_ID_NAME
   2da2   d4                SEP 4
   2da3   ff 09             DW F_MSG
                        
   2da5   68 cf 2c 3a       RLDI 15, STR_ID_AUTHOR
   2da9   d4                SEP 4
   2daa   ff 09             DW F_MSG
                        
                            ; Send options
   2dac   68 cf 2c 5f       RLDI 15, STR_OPTION_DEPTH
   2db0   d4                SEP 4
   2db1   ff 09             DW F_MSG
                        
                            ; Send uciok
   2db3   68 cf 2c 93       RLDI 15, STR_UCIOK
   2db7   d4                SEP 4
   2db8   ff 09             DW F_MSG
                        
   2dba   d5                RETN
                        
   2dbb                 UCI_CMD_ISREADY:
                            ; Send readyok
   2dbb   68 cf 2c 9b       RLDI 15, STR_READYOK
   2dbf   d4                SEP 4
   2dc0   ff 09             DW F_MSG
                        
   2dc2   d5                RETN
                        
   2dc3                 UCI_CMD_POSITION:
                            ; Parse position command
                            ; Format: "position startpos" or "position startpos moves e2e4 ..."
                        
                            ; Check if "startpos"
   2dc3   68 ca 70 09       RLDI 10, UCI_BUFFER + 9
                        
                            ; Check for "startpos"
   2dc7   0a                LDN 10
   2dc8   fb 73             XRI 's'
   2dca   ca 2e cc          LBNZ UCI_POS_DONE   ; Not startpos (FEN not supported yet)
                        
                            ; Initialize to starting position
   2dcd   d4 00 a6          CALL INIT_BOARD
   2dd0   d4 01 76          CALL INIT_MOVE_HISTORY
                        
                            ; --- Compute and store starting position hash for repetition detection ---
   2dd3   d4 55 e0          CALL HASH_INIT          ; Compute hash for starting position
   2dd6   68 ca 65 00       RLDI 10, HASH_HIST      ; R10 → first hash history entry
   2dda   68 cd 64 b9       RLDI 13, HASH_HI
   2dde   4d                LDA 13                  ; D = HASH_HI, R13 → HASH_LO
   2ddf   5a                STR 10
   2de0   1a                INC 10
   2de1   0d                LDN 13                  ; D = HASH_LO
   2de2   5a                STR 10
   2de3   68 ca 64 eb       RLDI 10, HASH_HIST_COUNT
   2de7   f8 01             LDI 1
   2de9   5a                STR 10                  ; count = 1 (starting position stored)
                        
                            ; Skip past "startpos" (8 chars) to check for " moves"
                            ; Buffer now at "startpos..." - need to find " moves "
   2dea   68 ca 70 11       RLDI 10, UCI_BUFFER + 17
                        
                            ; Check if there's more (should be space or null)
   2dee   0a                LDN 10
   2def   c2 2e cc          LBZ UCI_POS_DONE    ; End of string, no moves
   2df2   fb 20             XRI ' '
   2df4   ca 2e cc          LBNZ UCI_POS_DONE   ; Not a space, unexpected
                        
                            ; Skip the space
   2df7   1a                INC 10
                        
                            ; Check for "moves" (5 chars)
   2df8   0a                LDN 10
   2df9   fb 6d             XRI 'm'
   2dfb   ca 2e cc          LBNZ UCI_POS_DONE
   2dfe   1a                INC 10
   2dff   0a                LDN 10
   2e00   fb 6f             XRI 'o'
   2e02   ca 2e cc          LBNZ UCI_POS_DONE
   2e05   1a                INC 10
   2e06   0a                LDN 10
   2e07   fb 76             XRI 'v'
   2e09   ca 2e cc          LBNZ UCI_POS_DONE
   2e0c   1a                INC 10
   2e0d   0a                LDN 10
   2e0e   fb 65             XRI 'e'
   2e10   ca 2e cc          LBNZ UCI_POS_DONE
   2e13   1a                INC 10
   2e14   0a                LDN 10
   2e15   fb 73             XRI 's'
   2e17   ca 2e cc          LBNZ UCI_POS_DONE
   2e1a   1a                INC 10              ; R10 now past "moves"
                        
                            ; Now parse move list: " e2e4 e7e5 ..."
   2e1b                 UCI_POS_MOVE_LOOP:
                            ; Skip spaces
   2e1b   0a                LDN 10
   2e1c   c2 2e cc          LBZ UCI_POS_DONE    ; End of string
   2e1f   fb 20             XRI ' '
   2e21   ca 2e 28          LBNZ UCI_POS_PARSE_MOVE  ; Not a space, should be move
   2e24   1a                INC 10
   2e25   c0 2e 1b          LBR UCI_POS_MOVE_LOOP
                        
   2e28                 UCI_POS_PARSE_MOVE:
                            ; R10 points to start of move (e.g., "e2e4")
                            ; Parse from square (2 chars)
   2e28   d4 2e cd          CALL ALGEBRAIC_TO_SQUARE
   2e2b   fb ff             XRI $FF
   2e2d   c2 2e cc          LBZ UCI_POS_DONE    ; Invalid square, abort
                        
                            ; Save from square
   2e30   fb ff             XRI $FF             ; Restore value (XRI is self-inverse)
   2e32   b7                PHI 7               ; R7.1 = from square
                        
                            ; Parse to square (2 chars)
   2e33   d4 2e cd          CALL ALGEBRAIC_TO_SQUARE
   2e36   fb ff             XRI $FF
   2e38   c2 2e cc          LBZ UCI_POS_DONE    ; Invalid square, abort
   2e3b   fb ff             XRI $FF             ; Restore value
                        
                            ; Store from and to in MOVE_FROM/MOVE_TO
   2e3d   a7                PLO 7               ; R7.0 = to square
                        
   2e3e   68 c8 64 02       RLDI 8, MOVE_FROM
   2e42   97                GHI 7
   2e43   58                STR 8               ; MOVE_FROM = from
   2e44   18                INC 8
   2e45   87                GLO 7
   2e46   58                STR 8               ; MOVE_TO = to
                        
                            ; ---- Check for promotion suffix (5th char: q/r/b/n) ----
                            ; Clear UNDO_PROMOTION first (default: no promotion)
   2e47   68 c8 64 04       RLDI 8, UNDO_PROMOTION
   2e4b   f8 00             LDI 0
   2e4d   58                STR 8               ; UNDO_PROMOTION = 0
                        
                            ; Check next char for promotion piece
   2e4e   0a                LDN 10              ; Peek next char
   2e4f   fb 71             XRI 'q'
   2e51   c2 2e 66          LBZ UCI_PROMO_QUEEN
   2e54   fb 03             XRI $03             ; 'q'^'r' = $71^$72 = $03
   2e56   c2 2e 6b          LBZ UCI_PROMO_ROOK
   2e59   fb 10             XRI $10             ; 'r'^'b' = $72^$62 = $10
   2e5b   c2 2e 70          LBZ UCI_PROMO_BISHOP
   2e5e   fb 0c             XRI $0C             ; 'b'^'n' = $62^$6E = $0C
   2e60   c2 2e 75          LBZ UCI_PROMO_KNIGHT
   2e63   c0 2e 79          LBR UCI_PROMO_DONE  ; Not a promotion char, don't advance
                        
   2e66                 UCI_PROMO_QUEEN:
   2e66   f8 05             LDI QUEEN_TYPE      ; $05
   2e68   c0 2e 77          LBR UCI_PROMO_STORE
   2e6b                 UCI_PROMO_ROOK:
   2e6b   f8 04             LDI ROOK_TYPE       ; $04
   2e6d   c0 2e 77          LBR UCI_PROMO_STORE
   2e70                 UCI_PROMO_BISHOP:
   2e70   f8 03             LDI BISHOP_TYPE     ; $03
   2e72   c0 2e 77          LBR UCI_PROMO_STORE
   2e75                 UCI_PROMO_KNIGHT:
   2e75   f8 02             LDI KNIGHT_TYPE     ; $02
                        
   2e77                 UCI_PROMO_STORE:
   2e77   58                STR 8               ; UNDO_PROMOTION = piece type
   2e78   1a                INC 10              ; Advance past promotion char
                        
   2e79                 UCI_PROMO_DONE:
                        
                            ; ---- Record move in MOVE_HIST for opening book ----
                            ; Skip recording past book depth (prevents 8-bit GAME_PLY overflow)
   2e79   68 c8 64 4d       RLDI 8, GAME_PLY
   2e7d   08                LDN 8               ; D = GAME_PLY
   2e7e   ff 0f             SMI BOOK_PLY_LIMIT  ; past book depth?
   2e80   c3 2e 9e          LBDF UCI_HIST_DONE  ; skip recording + increment
                            ; Calculate offset: GAME_PLY * 2
   2e83   08                LDN 8               ; reload GAME_PLY (SMI clobbered D)
   2e84   fe                SHL                 ; D = GAME_PLY * 2
   2e85   a9                PLO 9               ; R9.0 = offset
                        
                            ; R9 = MOVE_HIST + offset
   2e86   f8 60             LDI HIGH(MOVE_HIST)
   2e88   b9                PHI 9
   2e89   f8 90             LDI LOW(MOVE_HIST)
   2e8b   e2                SEX 2
   2e8c   52                STR 2
   2e8d   89                GLO 9               ; D = offset
   2e8e   f4                ADD                 ; D = LOW(MOVE_HIST) + offset
   2e8f   a9                PLO 9
   2e90   f8 60             LDI HIGH(MOVE_HIST)
   2e92   7c 00             ADCI 0              ; Add carry to high byte
   2e94   b9                PHI 9
                        
                            ; Store from square
   2e95   97                GHI 7               ; from square
   2e96   59                STR 9
   2e97   19                INC 9
                            ; Store to square
   2e98   87                GLO 7               ; to square
   2e99   59                STR 9
                        
                            ; Increment GAME_PLY
   2e9a   08                LDN 8               ; R8 still points to GAME_PLY
   2e9b   fc 01             ADI 1
   2e9d   58                STR 8
   2e9e                 UCI_HIST_DONE:
                            ; ---- End of MOVE_HIST recording ----
                        
                            ; Apply the move (save R10 - MAKE_MOVE clobbers it!)
   2e9e   9a                GHI 10
   2e9f   73                STXD
   2ea0   8a                GLO 10
   2ea1   73                STXD
   2ea2   d4 09 bb          CALL MAKE_MOVE
   2ea5   60                IRX
   2ea6   72                LDXA
   2ea7   aa                PLO 10
   2ea8   f0                LDX
   2ea9   ba                PHI 10
                        
                            ; ---- Record hash for repetition detection ----
   2eaa   68 cd 64 eb       RLDI 13, HASH_HIST_COUNT
   2eae   0d                LDN 13              ; D = count
   2eaf   fb ff             XRI 255             ; Zero if count == 255 (table full)
   2eb1   c2 2e 1b          LBZ UCI_POS_MOVE_LOOP   ; Full, skip recording
   2eb4   0d                LDN 13              ; D = count (reload)
   2eb5   fe                SHL                 ; D = (count*2) & $FF, DF = carry for counts >= 128
   2eb6   a8                PLO 8               ; R8.0 = offset low byte
   2eb7   f8 65             LDI HIGH(HASH_HIST) ; DF preserved (LDI doesn't affect DF)
   2eb9   7c 00             ADCI 0              ; D = HIGH(HASH_HIST) + carry from SHL
   2ebb   b8                PHI 8               ; R8 = &HASH_HIST[count] (correct for all counts)
   2ebc   68 c9 64 b9       RLDI 9, HASH_HI
   2ec0   49                LDA 9               ; D = HASH_HI
   2ec1   58                STR 8
   2ec2   18                INC 8
   2ec3   09                LDN 9               ; D = HASH_LO
   2ec4   58                STR 8
   2ec5   0d                LDN 13              ; count (R13 still at HASH_HIST_COUNT)
   2ec6   fc 01             ADI 1
   2ec8   5d                STR 13              ; count++
   2ec9   c0 2e 1b          LBR UCI_POS_MOVE_LOOP
                        
   2ecc                 UCI_POS_DONE:
   2ecc   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; ALGEBRAIC_TO_SQUARE - Convert algebraic notation to 0x88 square
                        ; ------------------------------------------------------------------------------
                        ; Input:  R10 = pointer to 2-char string (e.g., "e2"), advanced by 2
                        ; Output: D = 0x88 square index, or $FF if invalid
                        ; Uses:   R7.0 for file temp
                        ; ------------------------------------------------------------------------------
   2ecd                 ALGEBRAIC_TO_SQUARE:
                            ; Get file character (a-h)
   2ecd   4a                LDA 10              ; Load file char, advance R10
   2ece   ff 61             SMI 'a'             ; Convert to 0-7
   2ed0   cb 2e ee          LBNF ATS_INVALID    ; If DF=0 (borrow), char < 'a', invalid
   2ed3   a7                PLO 7               ; Save potential file in R7.0
   2ed4   ff 08             SMI 8               ; Check if >= 8
   2ed6   c3 2e ee          LBDF ATS_INVALID    ; If >= 8, invalid
                        
                            ; Get rank character (1-8)
   2ed9   4a                LDA 10              ; Load rank char, advance R10
   2eda   ff 31             SMI '1'             ; Convert to 0-7
   2edc   cb 2e ee          LBNF ATS_INVALID    ; If DF=0 (borrow), char < '1', invalid
   2edf   ff 08             SMI 8               ; Check if >= 8
   2ee1   c3 2e ee          LBDF ATS_INVALID    ; If >= 8, invalid
   2ee4   fc 08             ADI 8               ; Restore 0-7 value
                        
                            ; Calculate 0x88 square = rank * 16 + file
                            ; rank is in D (0-7), file in R7.0
   2ee6   fe                SHL                 ; D = rank * 2
   2ee7   fe                SHL                 ; D = rank * 4
   2ee8   fe                SHL                 ; D = rank * 8
   2ee9   fe                SHL                 ; D = rank * 16
   2eea   52                STR 2               ; Save rank*16 on stack
   2eeb   87                GLO 7               ; Get file (0-7)
   2eec   f4                ADD                 ; D = rank*16 + file
   2eed   d5                RETN
                        
   2eee                 ATS_INVALID:
   2eee   1a                INC 10              ; Skip second char even on error (keep R10 consistent)
   2eef   f8 ff             LDI $FF
   2ef1   d5                RETN
                        
   2ef2                 UCI_CMD_GO:
                            ; Parse go command
                            ; Format: "go depth 6" or "go infinite", etc.
                            ; Default to depth 1, parse "depth N" if present
                            ; Store in memory (R5 is SRET in BIOS mode!)
                        
                            ; Default depth = 1
   2ef2   f8 01             LDI 1
   2ef4   a7                PLO 7               ; R7.0 = depth (default 1)
                        
                            ; Check for "depth " after "go "
                            ; Buffer: "go depth 3" or "go" or "go infinite"
   2ef5   68 ca 70 03       RLDI 10, UCI_BUFFER + 3
                        
                            ; Check if we have "depth"
   2ef9   0a                LDN 10
   2efa   fb 64             XRI 'd'
   2efc   ca 2f 34          LBNZ UCI_GO_SET_DEPTH   ; Not "depth", use default
   2eff   1a                INC 10
   2f00   0a                LDN 10
   2f01   fb 65             XRI 'e'
   2f03   ca 2f 34          LBNZ UCI_GO_SET_DEPTH
   2f06   1a                INC 10
   2f07   0a                LDN 10
   2f08   fb 70             XRI 'p'
   2f0a   ca 2f 34          LBNZ UCI_GO_SET_DEPTH
   2f0d   1a                INC 10
   2f0e   0a                LDN 10
   2f0f   fb 74             XRI 't'
   2f11   ca 2f 34          LBNZ UCI_GO_SET_DEPTH
   2f14   1a                INC 10
   2f15   0a                LDN 10
   2f16   fb 68             XRI 'h'
   2f18   ca 2f 34          LBNZ UCI_GO_SET_DEPTH
   2f1b   1a                INC 10
   2f1c   0a                LDN 10
   2f1d   fb 20             XRI ' '
   2f1f   ca 2f 34          LBNZ UCI_GO_SET_DEPTH
   2f22   1a                INC 10              ; R10 now at the number
                        
                            ; Parse the depth number (1-9, single digit only)
                            ; Depths > 9 would take impractically long on the 1802 anyway
   2f23   0a                LDN 10
   2f24   ff 30             SMI '0'             ; Convert ASCII to value
   2f26   cb 2f 34          LBNF UCI_GO_SET_DEPTH ; Invalid (< '0'), use default
   2f29   ff 0a             SMI 10              ; Check if >= 10
   2f2b   c3 2f 34          LBDF UCI_GO_SET_DEPTH ; >= 10, use default
   2f2e   fc 0a             ADI 10              ; Restore 0-9 value
   2f30   c2 2f 34          LBZ UCI_GO_SET_DEPTH ; Depth 0 invalid, use default
   2f33   a7                PLO 7               ; R7.0 = parsed depth (1-9)
                        
   2f34                 UCI_GO_SET_DEPTH:
                            ; Set SEARCH_DEPTH from R7.0
   2f34   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   2f38   f8 00             LDI 0
   2f3a   5d                STR 13              ; SEARCH_DEPTH high = 0
   2f3b   1d                INC 13
   2f3c   87                GLO 7
   2f3d   5d                STR 13              ; SEARCH_DEPTH low = depth
                        
                            ; ---- Check opening book first ----
   2f3e   d4 30 90          CALL BOOK_LOOKUP
   2f41   c2 2f 54          LBZ UCI_GO_SEARCH   ; D=0: no book hit, do normal search
                        
                            ; Book hit! Copy BOOK_MOVE to BEST_MOVE
   2f44   68 c8 64 4e       RLDI 8, BOOK_MOVE_FROM
   2f48   68 c9 64 10       RLDI 9, BEST_MOVE
                        
                            ; Store book move in BEST_MOVE (from in high, to in low)
   2f4c   48                LDA 8               ; BOOK_MOVE_FROM
   2f4d   59                STR 9               ; BEST_MOVE high = from
   2f4e   19                INC 9
   2f4f   08                LDN 8               ; BOOK_MOVE_TO
   2f50   59                STR 9               ; BEST_MOVE low = to
   2f51   c0 2f 5e          LBR UCI_GO_SEND_MOVE
                        
   2f54                 UCI_GO_SEARCH:
                            ; Clear stale promotion flag before search
                            ; (opponent's promotion move leaves UNDO_PROMOTION set, which would
                            ; corrupt every MAKE_MOVE during search)
   2f54   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   2f58   f8 00             LDI 0
   2f5a   5a                STR 10              ; UNDO_PROMOTION = 0
                        
                            ; Run search
   2f5b   d4 2a 42          CALL SEARCH_POSITION
                        
   2f5e                 UCI_GO_SEND_MOVE:
                            ; Best move now at BEST_MOVE.
                            ;
                            ; --- Root-move validation (added 2026-05-12) ---
                            ; Defense against MOVE_LIST corruption causing illegal-move output.
                            ; Regenerate moves from current board; verify BEST_MOVE appears in
                            ; the regenerated list. If not, emit info string + substitute first
                            ; legal move. Catches the symptom of any state corruption affecting
                            ; root MOVE_LIST regardless of underlying cause.
                        
                            ; Encode BEST_MOVE for byte-by-byte comparison (mirrors ORDER_TT_MOVE)
   2f5e   68 ca 64 10       RLDI 10, BEST_MOVE
   2f62   4a                LDA 10
   2f63   bd                PHI 13                      ; R13.1 = BEST_MOVE from (0x88)
   2f64   0a                LDN 10
   2f65   ad                PLO 13                      ; R13.0 = BEST_MOVE to (0x88)
                        
   2f66   68 ca 64 06       RLDI 10, MOVE_FLAGS_TEMP
   2f6a   f8 00             LDI 0
   2f6c   5a                STR 10                      ; flags=0 for the comparison encoding
                        
   2f6d   d4 03 8d          CALL ENCODE_MOVE_16BIT
                            ; R8 = encoded BEST_MOVE (flags=0)
                        
                            ; Save encoded BEST_MOVE on stack across GENERATE_MOVES
                            ; (GENERATE_MOVES clobbers R11 — uses R11.1 as current-from-square)
   2f70   98                GHI 8
   2f71   73                STXD
   2f72   88                GLO 8
   2f73   73                STXD
                        
                            ; Regenerate legal moves into MOVE_LIST
   2f74   68 c9 78 00       RLDI 9, MOVE_LIST
   2f78   d4 04 d7          CALL GENERATE_MOVES
                            ; D = move count
                        
   2f7b   a7                PLO 7                       ; R7.0 = move count
   2f7c   b7                PHI 7                       ; R7.1 = loop counter (D unchanged by PLO)
                        
                            ; Restore encoded BEST_MOVE to R11
   2f7d   60                IRX
   2f7e   72                LDXA
   2f7f   ab                PLO 11                      ; R11.0 = LOW
   2f80   f0                LDX
   2f81   bb                PHI 11                      ; R11.1 = HIGH
                        
   2f82   97                GHI 7                       ; check count
   2f83   c2 2f c5          LBZ RMV_DONE                ; 0 moves (mate/stalemate) — leave as-is
                        
   2f86   68 c8 78 00       RLDI 8, MOVE_LIST           ; R8 = scan pointer
                        
   2f8a                 RMV_SCAN_LOOP:
   2f8a   97                GHI 7
   2f8b   c2 2f a6          LBZ RMV_NOT_FOUND
                        
                            ; MOVE_LIST stores HIGH byte first (per ADD_MOVE_ENCODED line 221):
                            ; entry layout in memory is [HIGH][LOW] for each 2-byte move.
                            ; Compare HIGH byte (with flag bits 6-7 masked off)
   2f8e   48                LDA 8                       ; list move HIGH byte; R8++
   2f8f   fa 3f             ANI $3F                     ; mask off flag bits
   2f91   52                STR 2
   2f92   9b                GHI 11                      ; encoded BEST_MOVE HIGH byte (flags=0)
   2f93   f3                XOR
   2f94   ca 2f 9e          LBNZ RMV_NEXT
                        
                            ; HIGH bytes match — compare LOW byte (no masking needed)
   2f97   08                LDN 8                       ; list move LOW byte; R8 stays
   2f98   52                STR 2
   2f99   8b                GLO 11                      ; encoded BEST_MOVE LOW byte
   2f9a   f3                XOR
   2f9b   c2 2f c5          LBZ RMV_DONE                ; Match — BEST_MOVE is legal, emit normally
                        
   2f9e                 RMV_NEXT:
   2f9e   18                INC 8                       ; skip past LOW byte to next entry
   2f9f   97                GHI 7
   2fa0   ff 01             SMI 1
   2fa2   b7                PHI 7
   2fa3   c0 2f 8a          LBR RMV_SCAN_LOOP
                        
   2fa6                 RMV_NOT_FOUND:
                            ; BEST_MOVE not in regenerated legal list — corruption symptom.
   2fa6   68 cf 2c ce       RLDI 15, STR_INFO_RMV
   2faa   d4                SEP 4
   2fab   ff 09             DW F_MSG
                        
                            ; Substitute first legal move from regenerated list
                            ; (memory order is [HIGH][LOW]; DECODE_MOVE_16BIT wants R8.0=LOW, R8.1=HIGH)
   2fad   68 c8 78 00       RLDI 8, MOVE_LIST
   2fb1   48                LDA 8                       ; HIGH byte from memory
   2fb2   bb                PHI 11                      ; R11.1 = HIGH
   2fb3   08                LDN 8                       ; LOW byte from memory
   2fb4   ab                PLO 11                      ; R11.0 = LOW
                        
                            ; Now build R8 = [HIGH in .1, LOW in .0] for DECODE
   2fb5   9b                GHI 11
   2fb6   b8                PHI 8
   2fb7   8b                GLO 11
   2fb8   a8                PLO 8
   2fb9   d4 03 c7          CALL DECODE_MOVE_16BIT
                            ; R13.1 = from, R13.0 = to
                        
                            ; Write back to BEST_MOVE
   2fbc   68 ca 64 10       RLDI 10, BEST_MOVE
   2fc0   9d                GHI 13
   2fc1   5a                STR 10
   2fc2   1a                INC 10
   2fc3   8d                GLO 13
   2fc4   5a                STR 10
                        
   2fc5                 RMV_DONE:
                            ; Send best move (validated or substituted)
   2fc5   68 cf 2c a5       RLDI 15, STR_BESTMOVE
   2fc9   d4                SEP 4
   2fca   ff 09             DW F_MSG
                        
                            ; Convert best move to algebraic and send
                            ; TODO: Load best move and convert
   2fcc   d4 30 09          CALL UCI_SEND_BEST_MOVE
                        
                            ; Send CR+LF
   2fcf   f8 0d             LDI 13
   2fd1   d4 00 0b          CALL SERIAL_WRITE_CHAR
   2fd4   f8 0a             LDI 10
   2fd6   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   2fd9   d5                RETN
                        
   2fda                 UCI_CMD_QUIT:
                            ; Return to monitor at $8000
   2fda   c0 80 03          LBR $8003
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_CMD_UCINEWGAME - Prepare for a new game
                        ; ------------------------------------------------------------------------------
                        ; Clears transposition table and resets game state
                        ; ------------------------------------------------------------------------------
   2fdd                 UCI_CMD_UCINEWGAME:
                            ; Clear workspace RAM to prevent stale variable bugs
   2fdd   d4 5e c9          CALL WORKSPACE_CLEAR
                        
                            ; Clear transposition table
   2fe0   d4 56 ef          CALL TT_CLEAR
                        
                            ; Reset game ply counter
   2fe3   68 ca 64 4d       RLDI 10, GAME_PLY
   2fe7   f8 00             LDI 0
   2fe9   5a                STR 10
                        
                            ; Clear move history
   2fea   d4 01 76          CALL INIT_MOVE_HISTORY
                        
                            ; Initialize board to starting position
   2fed   d4 00 a6          CALL INIT_BOARD
                        
                            ; Compute and store starting-position Zobrist hash + first HASH_HIST entry.
                            ; UCI_CMD_POSITION normally does this when parsing "position startpos",
                            ; but the first such command after ucinewgame is frequently dropped at
                            ; the start of every match since 2026-04-30 ("PARTIAL_ECHO 'sition
                            ; startpos'"). The bridge sends ucinewgame and position back-to-back,
                            ; and BIOS serial RX drops the first 1-2 bytes during the long
                            ; WORKSPACE_CLEAR/TT_CLEAR processing window. Without hash init here,
                            ; the first search runs with hash=0 and pollutes TT with mis-keyed
                            ; entries that persist for the entire match.
   2ff0   d4 55 e0          CALL HASH_INIT
   2ff3   68 ca 65 00       RLDI 10, HASH_HIST
   2ff7   68 cd 64 b9       RLDI 13, HASH_HI
   2ffb   4d                LDA 13                  ; D = HASH_HI, R13 → HASH_LO
   2ffc   5a                STR 10
   2ffd   1a                INC 10
   2ffe   0d                LDN 13                  ; D = HASH_LO
   2fff   5a                STR 10
   3000   68 ca 64 eb       RLDI 10, HASH_HIST_COUNT
   3004   f8 01             LDI 1
   3006   5a                STR 10                  ; HASH_HIST_COUNT = 1 (startpos stored)
                        
   3007   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_CMD_STOP - Stop calculating (no-op for now)
                        ; ------------------------------------------------------------------------------
                        ; On a single-threaded system we cannot interrupt search.
                        ; GUI should wait for bestmove response.
                        ; This is here for protocol compatibility.
                        ; ------------------------------------------------------------------------------
   3008                 UCI_CMD_STOP:
                            ; No-op - search completes naturally
                            ; GUI will receive bestmove when search finishes
   3008   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; UCI_SEND_BEST_MOVE - Send best move in algebraic notation
                        ; ------------------------------------------------------------------------------
   3009                 UCI_SEND_BEST_MOVE:
                            ; BEST_MOVE contains raw from/to squares (not encoded)
                            ; BEST_MOVE[0] = from square (0x88), BEST_MOVE[1] = to square (0x88)
   3009   68 ca 64 10       RLDI 10, BEST_MOVE
                        
   300d   4a                LDA 10              ; from square (raw 0x88)
   300e   bd                PHI 13              ; R13.1 = from
   300f   0a                LDN 10              ; to square (raw 0x88)
   3010   ad                PLO 13              ; R13.0 = to
                        
                            ; Convert to algebraic notation (e.g., "e2e4")
                            ; From square
   3011   9d                GHI 13              ; From square
   3012   d4 30 44          CALL SQUARE_TO_ALGEBRAIC
                            ; Sends two characters (file, rank)
                        
                            ; To square
   3015   8d                GLO 13              ; To square
   3016   d4 30 44          CALL SQUARE_TO_ALGEBRAIC
                        
                            ; Check if this is a promotion move (pawn reaching last rank)
                            ; Load piece at from square
   3019   f8 60             LDI HIGH(BOARD)
   301b   ba                PHI 10
   301c   9d                GHI 13              ; from square
   301d   aa                PLO 10
   301e   f8 00             LDI LOW(BOARD)
   3020   52                STR 2
   3021   8a                GLO 10
   3022   f4                ADD
   3023   aa                PLO 10
   3024   9a                GHI 10
   3025   7c 00             ADCI 0
   3027   ba                PHI 10              ; R10 = &BOARD[from]
   3028   0a                LDN 10              ; D = piece at from
   3029   fa 07             ANI PIECE_MASK      ; Get piece type
   302b   fb 01             XRI PAWN_TYPE       ; Is it a pawn?
   302d   ca 30 43          LBNZ UCI_BM_NO_PROMO
                        
                            ; It's a pawn - check if to square is on last rank
   3030   8d                GLO 13              ; to square
   3031   fa 70             ANI $70             ; Isolate rank
   3033   c2 30 3e          LBZ UCI_BM_IS_PROMO ; Rank 0 = promotion for black
   3036   fb 70             XRI $70
   3038   c2 30 3e          LBZ UCI_BM_IS_PROMO ; Rank 7 = promotion for white
   303b   c0 30 43          LBR UCI_BM_NO_PROMO
                        
   303e                 UCI_BM_IS_PROMO:
                            ; Append 'q' for queen promotion
   303e   f8 71             LDI 'q'
   3040   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   3043                 UCI_BM_NO_PROMO:
   3043   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; SQUARE_TO_ALGEBRAIC - Convert 0x88 square to algebraic notation
                        ; ------------------------------------------------------------------------------
                        ; Input:  D = square (0x88 format)
                        ; Output: Two characters sent (file letter, rank number)
                        ; ------------------------------------------------------------------------------
   3044                 SQUARE_TO_ALGEBRAIC:
   3044   a7                PLO 7               ; Save square in R7.0 (R13 used by caller!)
                        
                            ; Get file (0-7 → 'a'-'h')
   3045   fa 07             ANI $07             ; File bits
   3047   fc 61             ADI 'a'             ; Convert to ASCII
   3049   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
                            ; Get rank (0-7 → '1'-'8')
   304c   87                GLO 7               ; Get square from R7.0
   304d   f6                SHR
   304e   f6                SHR
   304f   f6                SHR
   3050   f6                SHR                 ; Rank bits
   3051   fc 31             ADI '1'             ; Convert to ASCII
   3053   d4 00 0b          CALL SERIAL_WRITE_CHAR
                        
   3056   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; String Comparison Functions
                        ; ------------------------------------------------------------------------------
                        
                        ; STRCMP - Compare two null-terminated strings
                        ; Input:  A = string 1, B = string 2
                        ; Output: D = 0 if equal, non-zero if different
   3057                 STRCMP:
   3057   0a                LDN 10              ; D = char from string 1
   3058   52                STR 2               ; Save to stack
   3059   0b                LDN 11              ; D = char from string 2
   305a   f3                XOR                 ; D = char1 XOR char2 (0 if equal)
   305b   ca 30 6a          LBNZ STRCMP_DIFF     ; If XOR != 0, characters differ
                        
                            ; Characters are equal, check if end of both strings
   305e   0a                LDN 10
   305f   c2 30 67          LBZ STRCMP_EQUAL     ; If null terminator, both ended - equal
                        
                            ; Continue comparing
   3062   1a                INC 10
   3063   1b                INC 11
   3064   c0 30 57          LBR STRCMP
                        
   3067                 STRCMP_EQUAL:
   3067   f8 00             LDI 0
   3069   d5                RETN
                        
   306a                 STRCMP_DIFF:
   306a   f8 01             LDI 1
   306c   d5                RETN
                        
                        ; STRNCMP - Compare until space or null in string 1
                        ; Input:  R10 = string 1 (command buffer), R11 = string 2 (command name)
                        ; Output: D = 0 if equal, non-zero if different
   306d                 STRNCMP:
                            ; Check if string 1 hit space (end of command word)
   306d   0a                LDN 10
   306e   fb 20             XRI ' '
   3070   c2 30 83          LBZ STRNCMP_CHECK_END
                        
                            ; Check if string 1 hit null
   3073   0a                LDN 10
   3074   c2 30 83          LBZ STRNCMP_CHECK_END
                        
                            ; Compare characters
   3077   0a                LDN 10              ; D = char from string 1
   3078   52                STR 2               ; Save to stack
   3079   0b                LDN 11              ; D = char from string 2
   307a   f3                XOR                 ; D = char1 XOR char2 (0 if equal)
   307b   ca 30 8d          LBNZ STRNCMP_DIFF   ; If different, not equal
                        
   307e   1a                INC 10
   307f   1b                INC 11
   3080   c0 30 6d          LBR STRNCMP
                        
   3083                 STRNCMP_CHECK_END:
                            ; String 1 ended (space or null) - check if string 2 also ended
   3083   0b                LDN 11
   3084   c2 30 8a          LBZ STRNCMP_EQUAL   ; String 2 is null - match!
   3087   c0 30 8d          LBR STRNCMP_DIFF    ; String 2 has more chars - no match
                        
   308a                 STRNCMP_EQUAL:
   308a   f8 00             LDI 0
   308c   d5                RETN
                        
   308d                 STRNCMP_DIFF:
   308d   f8 01             LDI 1
   308f   d5                RETN
                        
                        ; ==============================================================================
                        ; End of UCI Implementation
                        ; ==============================================================================
                        ; NOTE: SERIAL_READ_CHAR and SERIAL_WRITE_CHAR are provided by serial-io-9600.asm
                        ; ==============================================================================
                        ; ==============================================================================
                        ; Opening Book Lookup - Check if current position is in opening book
                        ; ==============================================================================
                        ;
                        ; Book format (from opening-book.asm):
                        ;   Each entry: [ply] [move1_from] [move1_to] ... [response_from] [response_to]
                        ;   Terminated with $FF
                        ;   Entries sorted by ply
                        ;
                        ; Uses: GAME_PLY - number of moves played since start
                        ;       MOVE_HIST - array of (from, to) pairs for game moves
                        ;       BOOK_MOVE_FROM/TO - output for book response
                        ;
                        ; ==============================================================================
                        
                        ; ==============================================================================
                        ; BOOK_LOOKUP - Search opening book for current position
                        ; ==============================================================================
                        ; Input:  GAME_PLY = number of moves played
                        ;         MOVE_HIST = game move history (2 bytes per move)
                        ; Output: D = 1 if book hit, 0 if no match
                        ;         BOOK_MOVE_FROM/TO = response move (if hit)
                        ; Uses:   R7, R8, R9, R10
                        ; ==============================================================================
   3090                 BOOK_LOOKUP:
                            ; R8 = pointer to current book entry
   3090   68 c8 30 fe       RLDI 8, OPENING_BOOK
                        
                            ; Load GAME_PLY into R7.1 for quick comparison
   3094   68 ca 64 4d       RLDI 10, GAME_PLY
   3098   0a                LDN 10
   3099   b7                PHI 7               ; R7.1 = GAME_PLY
                        
   309a                 BL_ENTRY_LOOP:
                            ; Read entry ply byte
   309a   08                LDN 8               ; D = entry ply
   309b   fb ff             XRI $FF             ; Check for end marker
   309d   c2 30 fb          LBZ BL_NO_MATCH     ; End of book, no match
                        
                            ; Restore ply value
   30a0   fb ff             XRI $FF
   30a2   a7                PLO 7               ; R7.0 = entry_ply
                        
                            ; Check if entry_ply > GAME_PLY (early exit - book sorted by ply)
   30a3   97                GHI 7               ; D = GAME_PLY
   30a4   52                STR 2               ; Store on stack
   30a5   87                GLO 7               ; D = entry_ply
   30a6   f5                SD                  ; D = GAME_PLY - entry_ply
   30a7   cb 30 fb          LBNF BL_NO_MATCH    ; If borrow (entry_ply > GAME_PLY), no match possible
                        
                            ; Check if entry_ply == GAME_PLY
   30aa   c2 30 bc          LBZ BL_CHECK_MOVES  ; If equal, check the moves
                        
                            ; entry_ply < GAME_PLY, skip to next entry
                            ; Entry length = 1 + entry_ply*2 + 2 = 3 + entry_ply*2
   30ad   87                GLO 7               ; D = entry_ply
   30ae   fe                SHL                 ; D = entry_ply * 2
   30af   fc 03             ADI 3               ; D = 3 + entry_ply * 2
   30b1   52                STR 2               ; Save skip amount
   30b2   88                GLO 8
   30b3   f4                ADD
   30b4   a8                PLO 8
   30b5   98                GHI 8
   30b6   7c 00             ADCI 0
   30b8   b8                PHI 8
   30b9   c0 30 9a          LBR BL_ENTRY_LOOP
                        
   30bc                 BL_CHECK_MOVES:
                            ; entry_ply == GAME_PLY, compare all moves
                            ; R8 points to ply byte, moves start at R8+1
                            ; R9 = pointer to MOVE_HIST
   30bc   68 c9 60 90       RLDI 9, MOVE_HIST
                        
                            ; R10.0 = move counter (number of move pairs to compare)
   30c0   87                GLO 7               ; entry_ply = number of moves to compare
   30c1   aa                PLO 10
                        
                            ; Move past ply byte
   30c2   18                INC 8
                        
                            ; If ply == 0, no moves to compare - direct match!
   30c3   8a                GLO 10
   30c4   c2 30 de          LBZ BL_MATCH_FOUND
                        
   30c7                 BL_COMPARE_LOOP:
                            ; Compare from square
   30c7   08                LDN 8               ; Book from
   30c8   52                STR 2
   30c9   09                LDN 9               ; History from
   30ca   f3                XOR                 ; Compare
   30cb   ca 30 ec          LBNZ BL_SKIP_ENTRY  ; Mismatch
                        
                            ; Compare to square
   30ce   18                INC 8
   30cf   19                INC 9
   30d0   08                LDN 8               ; Book to
   30d1   52                STR 2
   30d2   09                LDN 9               ; History to
   30d3   f3                XOR                 ; Compare
   30d4   ca 30 ea          LBNZ BL_SKIP_TO     ; TO mismatch - different skip path
                        
                            ; Move to next pair
   30d7   18                INC 8
   30d8   19                INC 9
   30d9   2a                DEC 10
   30da   8a                GLO 10
   30db   ca 30 c7          LBNZ BL_COMPARE_LOOP
                        
   30de                 BL_MATCH_FOUND:
                            ; All moves matched! R8 now points to response
                            ; Store response in BOOK_MOVE_FROM/TO
   30de   68 c9 64 4e       RLDI 9, BOOK_MOVE_FROM
                        
   30e2   48                LDA 8               ; Response from
   30e3   59                STR 9
   30e4   19                INC 9
   30e5   08                LDN 8               ; Response to
   30e6   59                STR 9
                        
                            ; Return success
   30e7   f8 01             LDI 1
   30e9   d5                RETN
                        
   30ea                 BL_SKIP_TO:
                            ; TO byte mismatch: R8 points to TO byte (already past FROM via INC 8)
                            ; Advance past TO and count this pair as consumed, then fall through
   30ea   18                INC 8               ; Past TO byte -> R8 at start of next pair
   30eb   2a                DEC 10              ; This pair consumed
                            ; Fall through to BL_SKIP_ENTRY
                        
   30ec                 BL_SKIP_ENTRY:
                            ; FROM byte mismatch: R8 points to FROM byte of mismatched pair
                            ; R10.0 = remaining move pairs to skip (not yet compared)
                            ; Skip: remaining_moves*2 + 2 (response bytes)
   30ec   8a                GLO 10              ; Remaining moves
   30ed   fe                SHL                 ; * 2
   30ee   fc 02             ADI 2               ; + response
   30f0   52                STR 2
   30f1   88                GLO 8
   30f2   f4                ADD
   30f3   a8                PLO 8
   30f4   98                GHI 8
   30f5   7c 00             ADCI 0
   30f7   b8                PHI 8
                        
                            ; Reset book pointer past ply (we compared some moves already)
   30f8   c0 30 9a          LBR BL_ENTRY_LOOP
                        
   30fb                 BL_NO_MATCH:
                            ; No book match found
   30fb   f8 00             LDI 0
   30fd   d5                RETN
                        
                        ; ==============================================================================
                        ; End of Opening Book Lookup
                        ; ==============================================================================
                        ; ==============================================================================
                        ; Combined Opening Book Data - Merged from multiple PGN sources
                        ; Total entries: 504, Total size: 9385 bytes
                        ; Duplicates removed: 6
                        ; Sources:
                        ;   giuoco-piano: 97 entries
                        ;   sicilian-rossolimo: 91 entries
                        ;   french-advance: 46 entries
                        ;   caro-kann-advance: 81 entries
                        ;   qgd-exchange: 62 entries
                        ;   alekhine-modern: 30 entries
                        ;   scandinavian: 31 entries
                        ;   pirc-austrian: 23 entries
                        ;   opponent-prep (manual, 2026-04-21): 10 entries targeting Stockfish Skill 2 sidelines
                        ;   krejcik-sacrifice (2026-04-22): 5 entries for 1.e4 Nf6 2.e5 Ne4 3.d3 Nxf2!? line
                        ;   krejcik-retreat (2026-04-22): 3 entries for 1.e4 Nf6 2.e5 Ne4 3.d3 Nc5 line
                        ;   opponent-prep (2026-04-27): 5 entries continuing existing 2026-04-21 lines past the engine's first searched move
                        ; ==============================================================================
                        
