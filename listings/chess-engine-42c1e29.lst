   2283   fd 00             SDI 0               ; negate low
   2285   a7                PLO 7
   2286   98                GHI 8               ; high byte
   2287   7d 00             SDBI 0              ; negate high with borrow
   2289   b7                PHI 7               ; R7 = -beta
                        
