   0c3b   f8 60             LDI HIGH(BOARD)
   0c3d   b8                PHI 8               ; R8 = &BOARD[to]
   0c3e   08                LDN 8               ; D = piece at to square
   0c3f   aa                PLO 10              ; Save in R10.0
                        
