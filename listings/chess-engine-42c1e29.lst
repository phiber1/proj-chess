   1172   ad                PLO 13
                        
                            ; max
   1173   9d                GHI 13
   1174   52                STR 2
   1175   8d                GLO 13
   1176   f5                SD
   1177   c3 11 7e          LBDF QP_B_USE_RANK
   117a   8d                GLO 13
   117b   c0 11 7f          LBR QP_B_HAVE_DIST
   117e                 QP_B_USE_RANK:
   117e   9d                GHI 13
   117f                 QP_B_HAVE_DIST:
   117f   fc de             ADI LOW(QUEEN_PROX_BONUS)
   1181   ab                PLO 11
   1182   f8 00             LDI 0
   1184   7c 0d             ADCI HIGH(QUEEN_PROX_BONUS)
   1186   bb                PHI 11
   1187   0b                LDN 11              ; D = bonus
   1188   52                STR 2
   1189   89                GLO 9
   118a   f7                SM                  ; subtract bonus from white-relative score
   118b   a9                PLO 9
   118c   99                GHI 9
   118d   7f 00             SMBI 0
   118f   b9                PHI 9
   1190                 QP_B_DONE:
                        
                            ; ==================================================================
                            ; King safety (2026-06-11): pawn-shield + enemy-queen "storm".
                            ; The base had NO king safety (only the +20 castling-RIGHTS bonus), which
                            ; let ELPH get mated while up a queen (queen on a6, king g1 stripped bare).
                            ; KING_SAFETY(R7.0=king sq, R7.1=enemy queen sq, R8.0=friendly pawn code,
                            ; R8.1=shield "ahead" offset) -> D = penalty (0-250). Shield-aware: a fully
                            ; shielded king scores 0 (queen near a fortress is fine); penalty grows with
                            ; missing shield pawns and an enemy queen within Chebyshev 2. Always-on
                            ; (naturally ~0 in endgames: no enemy queen / king active).
                            ; ==================================================================
   1190   68 c8 60 86       RLDI 8, GAME_STATE + STATE_W_KING_SQ
   1194   08                LDN 8
   1195   a7                PLO 7               ; R7.0 = white king sq
   1196   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   119a   08                LDN 8
   119b   b7                PHI 7               ; R7.1 = enemy (black) queen sq ($FF if none)
   119c   f8 01             LDI W_PAWN
   119e   a8                PLO 8               ; R8.0 = friendly pawn code ($01)
   119f   f8 10             LDI $10
   11a1   b8                PHI 8               ; R8.1 = ahead offset (white: +1 rank)
   11a2   d4 17 a6          CALL KING_SAFETY
   11a5   52                STR 2
   11a6   89                GLO 9
   11a7   f7                SM                  ; R9 -= white king danger
   11a8   a9                PLO 9
   11a9   99                GHI 9
   11aa   7f 00             SMBI 0
   11ac   b9                PHI 9
                        
   11ad   68 c8 60 87       RLDI 8, GAME_STATE + STATE_B_KING_SQ
   11b1   08                LDN 8
   11b2   a7                PLO 7               ; R7.0 = black king sq
   11b3   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   11b7   08                LDN 8
   11b8   b7                PHI 7               ; R7.1 = enemy (white) queen sq
   11b9   f8 09             LDI B_PAWN
   11bb   a8                PLO 8               ; R8.0 = friendly pawn code ($09)
   11bc   f8 f0             LDI $F0
   11be   b8                PHI 8               ; R8.1 = ahead offset (black: -1 rank)
   11bf   d4 17 a6          CALL KING_SAFETY
   11c2   52                STR 2
   11c3   89                GLO 9
   11c4   f4                ADD                 ; R9 += black king danger
   11c5   a9                PLO 9
   11c6   99                GHI 9
   11c7   7c 00             ADCI 0
   11c9   b9                PHI 9
                        
                            ; --- O-O-O discomfort (ported 2026-07-13, task #53): queenside king
                            ; posture vs a developed enemy queen (files a-d). Returns D = signed net
                            ; (-50/0/+50); sign-extend and add to R9. Routine in the $7B00 page.
                            ; Master IS exposed: losses 2+3 (7/2, 7/3) were master-line storm mates.
   11ca   d4 7b 00          CALL OOO_DISCOMFORT
   11cd   52                STR 2               ; M(2) = signed adjustment
   11ce   fa 80             ANI $80
   11d0   c2 11 d8          LBZ OOO_SEXT_POS
   11d3   f8 ff             LDI $FF
   11d5   c0 11 da          LBR OOO_SEXT_GO
   11d8                 OOO_SEXT_POS:
   11d8   f8 00             LDI $00
   11da                 OOO_SEXT_GO:
   11da   b8                PHI 8               ; R8.1 = sign-extension byte
   11db   89                GLO 9
   11dc   f4                ADD                 ; R9.lo += adjustment (M(2))
   11dd   a9                PLO 9
   11de   98                GHI 8
   11df   52                STR 2
   11e0   99                GHI 9
   11e1   74                ADC                 ; R9.hi += sign byte + carry
   11e2   b9                PHI 9
                        
                            ; Add piece-square table bonuses
   11e3   d4 1a 17          CALL EVAL_PST
                        
                            ; ==================================================================
                            ; Castling Rights Bonus
                            ; +20cp per side that still has castling rights remaining
                            ; Incentivizes preserving the option to castle
                            ; ==================================================================
   11e6   68 cb 60 81       RLDI 11, GAME_STATE + STATE_CASTLING
   11ea   0b                LDN 11              ; D = castling rights byte
   11eb   52                STR 2               ; save for reuse
   11ec   fa 03             ANI $03             ; white bits (WK|WQ)
   11ee   c2 11 f9          LBZ EVAL_NO_W_CASTLE
   11f1   89                GLO 9
   11f2   fc 14             ADI 20
   11f4   a9                PLO 9
   11f5   99                GHI 9
   11f6   7c 00             ADCI 0
   11f8   b9                PHI 9               ; R9 += 20 (white has castling rights)
   11f9                 EVAL_NO_W_CASTLE:
   11f9   02                LDN 2               ; reload castling byte
   11fa   fa 0c             ANI $0C             ; black bits (BK|BQ)
   11fc   c2 12 07          LBZ EVAL_NO_B_CASTLE
   11ff   89                GLO 9
   1200   ff 14             SMI 20
   1202   a9                PLO 9
   1203   99                GHI 9
   1204   7f 00             SMBI 0
   1206   b9                PHI 9               ; R9 -= 20 (black has castling rights)
   1207                 EVAL_NO_B_CASTLE:
                        
                            ; ==================================================================
                            ; Queen mobility (2026-06-17, always-on): low magnitude (mobility x2 = ~2cp/
                            ; square) to break ties toward an active queen without overriding material or
                            ; distorting trades. Tunable: SHL=x2 (start), SHL SHL=x4. Watch in matches for
                            ; premature queen sorties (the one real risk). See QUEEN_MOBILITY.
                            ; ==================================================================
   1207   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   120b   08                LDN 8
   120c   a7                PLO 7                   ; R7.0 = white queen sq
   120d   fb ff             XRI $FF
   120f   c2 12 1e          LBZ QMOB_BLACK          ; no white queen, skip
   1212   d4 18 4c          CALL QUEEN_MOBILITY     ; D = mobility (0..27)
   1215   fe                SHL                     ; x2 (low magnitude)
   1216   52                STR 2
   1217   89                GLO 9
   1218   f4                ADD
   1219   a9                PLO 9
   121a   99                GHI 9
   121b   7c 00             ADCI 0
   121d   b9                PHI 9                   ; R9 += white queen mobility x2
   121e                 QMOB_BLACK:
   121e   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   1222   08                LDN 8
   1223   a7                PLO 7                   ; R7.0 = black queen sq
   1224   fb ff             XRI $FF
   1226   c2 12 35          LBZ QMOB_DONE           ; no black queen, skip
   1229   d4 18 4c          CALL QUEEN_MOBILITY
   122c   fe                SHL                     ; x2
   122d   52                STR 2
   122e   89                GLO 9
   122f   f7                SM                      ; D = R9.0 - mobility x2
   1230   a9                PLO 9
   1231   99                GHI 9
   1232   7f 00             SMBI 0
   1234   b9                PHI 9                   ; R9 -= black queen mobility x2
   1235                 QMOB_DONE:
                        
                            ; DIAG stamp (2026-07-17 hang hunt): eval tail after mobility
                            ; (doubled pawns / rook files / passed pawns / endgame gate).
   1235   68 cb 64 1d       RLDI 11, TRACE_WHERE
   1239   f8 e5             LDI $E5
   123b   5b                STR 11              ; tracer: eval tail (R11 reloaded below)
                        
                            ; ==================================================================
                            ; Doubled Pawn Penalty: -15cp per extra pawn on same file
                            ; Iterate 8 files; if count >= 2, penalty += (count - 1) * 15
                            ; ==================================================================
                        
                            ; --- White doubled pawns ---
   123c   68 cb 67 10       RLDI 11, W_PAWN_FILE_CT     ; $6710
   1240   f8 08             LDI 8
   1242   ad                PLO 13                      ; R13.0 = file counter (temp, will restore later)
   1243   f8 00             LDI 0
   1245   b7                PHI 7                       ; R7.1 = white doubled penalty accumulator
   1246                 EVAL_WDP_LOOP:
   1246   4b                LDA 11                      ; D = pawn count for this file, R11++
   1247   ff 02             SMI 2                       ; D = count - 2 (DF=1 if count >= 2)
   1249   cb 12 5a          LBNF EVAL_WDP_NEXT          ; count < 2, no doubled
                            ; count >= 2: penalty = (count - 1) * 15
                            ; D = count - 2, so D + 1 = count - 1
   124c   fc 01             ADI 1                       ; D = count - 1
                            ; Multiply by 15: x*16 - x = (x<<4) - x
                            ; But with 8-bit arithmetic, max extra pawns = 7, 7*15 = 105 fits in byte
   124e   a7                PLO 7                       ; save (count-1) in R7.0
   124f   fe                SHL
   1250   fe                SHL
   1251   fe                SHL
   1252   fe                SHL                         ; D = (count-1) * 16
   1253   52                STR 2                       ; M(R2) = (count-1) * 16
   1254   87                GLO 7                       ; D = (count-1)
   1255   f5                SD                          ; D = M(R2) - D = (count-1)*16 - (count-1) = (count-1)*15
   1256   52                STR 2                       ; save penalty on stack
   1257   97                GHI 7                       ; accumulated penalty
   1258   f4                ADD                         ; D = accumulated + this file's penalty
   1259   b7                PHI 7                       ; update accumulator
   125a                 EVAL_WDP_NEXT:
   125a   2d                DEC 13
   125b   8d                GLO 13
   125c   ca 12 46          LBNZ EVAL_WDP_LOOP
                            ; R7.1 = total white doubled penalty (always positive)
                            ; Subtract from score (penalty for white)
   125f   97                GHI 7
   1260   c2 12 6b          LBZ EVAL_WDP_DONE           ; skip if 0
   1263   52                STR 2
   1264   89                GLO 9
   1265   f7                SM                          ; R9.0 - penalty
   1266   a9                PLO 9
   1267   99                GHI 9
   1268   7f 00             SMBI 0
   126a   b9                PHI 9                       ; R9 -= white doubled penalty
   126b                 EVAL_WDP_DONE:
                        
                            ; --- Black doubled pawns ---
   126b   68 cb 67 18       RLDI 11, B_PAWN_FILE_CT     ; $6718
   126f   f8 08             LDI 8
   1271   ad                PLO 13
   1272   f8 00             LDI 0
   1274   b7                PHI 7
   1275                 EVAL_BDP_LOOP:
   1275   4b                LDA 11
   1276   ff 02             SMI 2
   1278   cb 12 89          LBNF EVAL_BDP_NEXT
   127b   fc 01             ADI 1                       ; D = count - 1
   127d   a7                PLO 7
   127e   fe                SHL
   127f   fe                SHL
   1280   fe                SHL
   1281   fe                SHL                         ; (count-1) * 16
   1282   52                STR 2
   1283   87                GLO 7
   1284   f5                SD                          ; (count-1) * 15
   1285   52                STR 2
   1286   97                GHI 7
   1287   f4                ADD
   1288   b7                PHI 7
   1289                 EVAL_BDP_NEXT:
   1289   2d                DEC 13
   128a   8d                GLO 13
   128b   ca 12 75          LBNZ EVAL_BDP_LOOP
                            ; Add black penalty to score (good for white)
   128e   97                GHI 7
   128f   c2 12 9a          LBZ EVAL_BDP_DONE
   1292   52                STR 2
   1293   89                GLO 9
   1294   f4                ADD
   1295   a9                PLO 9
   1296   99                GHI 9
   1297   7c 00             ADCI 0
   1299   b9                PHI 9                       ; R9 += black doubled penalty
   129a                 EVAL_BDP_DONE:
                        
