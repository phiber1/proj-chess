   222c   68 ca 64 46       RLDI 10, SCORE_HI
   2230   4a                LDA 10              ; D = score_hi
   2231   bd                PHI 13
   2232   0a                LDN 10              ; D = score_lo
   2233   ad                PLO 13              ; R13 = score
                        
                            ; Signed comparison: score (R13) > alpha (R7)?
                            ; Use COMPARE_TEMP for scratch
   2234   68 ca 64 49       RLDI 10, COMPARE_TEMP
   2238   ea                SEX 10              ; X = R10 for comparisons
                        
                            ; Check if signs differ
   2239   9d                GHI 13              ; score_hi
   223a   5a                STR 10
   223b   97                GHI 7               ; alpha_hi
   223c   f3                XOR
   223d   fa 80             ANI $80             ; Check sign bits differ
   223f   e2                SEX 2               ; Restore X = R2
   2240   ca 22 5b          LBNZ LMR_RESEARCH_DIFF_SIGN
                        
