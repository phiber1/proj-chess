   1163   97                GHI 7
   1164   fa 07             ANI $07
   1166   ad                PLO 13
   1167   98                GHI 8
   1168   fa 07             ANI $07
   116a   52                STR 2
   116b   8d                GLO 13
   116c   f5                SD
   116d   c3 11 72          LBDF QP_B_FILE_OK
   1170   fd 00             SDI 0
