                            ; ==================================================================
                            ; Advanced Pawn Bonus (endgame only)
                            ; Graduated: +50/+100/+150 cp based on distance from promotion (saturated at 255)
                            ; ==================================================================
                        
                            ; White advanced pawn bonus (accumulated)
                            ; Asymmetric scaling: 1/4 in conversion phase only (we have queen,
                            ; opp doesn't). Preserves full pawn aggression in opening (both have
                            ; queens) and post-queen-exchange middlegame (neither has queen).
   144d   68 cb 64 fd       RLDI 11, ADV_PAWN_W
   1451   0b                LDN 11              ; D = accumulated white bonus (0-255)
   1452   c2 14 71          LBZ EG_NO_W_ADV     ; none, skip
   1455   52                STR 2               ; save bonus on stack
   1456   68 cb 64 b5       RLDI 11, W_QUEEN_CNT
   145a   0b                LDN 11
   145b   c2 14 6a          LBZ EG_W_ADV_GO     ; we don't have queen — full bonus, push toward promotion
   145e   68 cb 64 b6       RLDI 11, B_QUEEN_CNT
   1462   0b                LDN 11
   1463   ca 14 6a          LBNZ EG_W_ADV_GO    ; opp has queen too — full bonus, normal play
   1466   02                LDN 2               ; conversion phase: scale to 1/4
   1467   f6                SHR
   1468   f6                SHR
   1469   52                STR 2
   146a                 EG_W_ADV_GO:
