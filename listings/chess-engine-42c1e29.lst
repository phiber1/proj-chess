   0c53   09                LDN 9               ; D = cap_sq
   0c54   52                STR 2
   0c55   68 c9 64 0a       RLDI 9, UNDO_TO
   0c59   09                LDN 9               ; D = to
   0c5a   f3                XOR
   0c5b   c2 0c 6a          LBZ UM_CAP_DONE     ; cap_sq == to -> nothing more to do
                        
                            ; EP case: clear BOARD[to]
   0c5e   68 c9 64 0a       RLDI 9, UNDO_TO
   0c62   09                LDN 9
   0c63   a8                PLO 8
   0c64   f8 60             LDI HIGH(BOARD)
   0c66   b8                PHI 8
   0c67   f8 00             LDI EMPTY
   0c69   58                STR 8               ; BOARD[to] = EMPTY
                        
   0c6a                 UM_CAP_DONE:
                        
                            ; =========================================
                            ; PAWN PROMOTION UNDO
                            ; =========================================
                            ; If UNDO_PROMOTION != 0, restore pawn instead of promoted piece
                            ; R10.0 = piece from BOARD[to] (promoted piece if promotion)
                            ; Guard: if piece is EMPTY, skip promotion undo (prevents phantom pawn
                            ; from corrupted UNDO_PROMOTION)
   0c6a   8a                GLO 10              ; D = piece from BOARD[to]
   0c6b   c2 0c 7c          LBZ UM_NOT_PROMOTION ; EMPTY piece = nothing to un-promote
   0c6e   68 c9 64 04       RLDI 9, UNDO_PROMOTION
   0c72   09                LDN 9               ; D = promotion type (0 if none)
   0c73   c2 0c 7c          LBZ UM_NOT_PROMOTION
                        
                            ; Promotion: restore pawn (get color from R10.0, the promoted piece)
   0c76   8a                GLO 10              ; D = promoted piece
   0c77   fa 08             ANI COLOR_MASK      ; Get color (0=white, 8=black)
   0c79   f9 01             ORI PAWN_TYPE       ; D = pawn of same color
   0c7b   aa                PLO 10              ; R10.0 = pawn (overwrites promoted piece)
                        
   0c7c                 UM_NOT_PROMOTION:
                            ; Put moving piece back at from square
   0c7c   68 c9 64 09       RLDI 9, UNDO_FROM
   0c80   09                LDN 9               ; D = from square
   0c81   a8                PLO 8
   0c82   f8 60             LDI HIGH(BOARD)
   0c84   b8                PHI 8               ; R8 = &BOARD[from]
   0c85   8a                GLO 10              ; D = moving piece (pawn if promotion)
   0c86   58                STR 8               ; Put back at from square
                        
                            ; =========================================
                            ; KING POSITION RESTORE
                            ; =========================================
                            ; If moving piece is a king, restore GAME_STATE king position to from square
                            ; R10.0 = moving piece
   0c87   8a                GLO 10              ; Get moving piece
   0c88   fa 07             ANI PIECE_MASK      ; Get piece type (0-6)
   0c8a   fb 06             XRI KING_TYPE       ; Is it a king?
   0c8c   ca 0d 22          LBNZ UM_NOT_KING    ; Not a king, skip
                        
                            ; It's a king - restore king position in GAME_STATE
                            ; Check color of king (R10.0 has full piece)
   0c8f   8a                GLO 10
   0c90   fa 08             ANI COLOR_MASK      ; Get color (0=white, 8=black)
   0c92   ca 0c 9c          LBNZ UM_BLACK_KING
                        
   0c95                 UM_WHITE_KING:
                            ; Update STATE_W_KING_SQ with UNDO_FROM
   0c95   68 c9 60 86       RLDI 9, GAME_STATE + STATE_W_KING_SQ
   0c99   c0 0c a0          LBR UM_STORE_KING
                        
   0c9c                 UM_BLACK_KING:
                            ; Update STATE_B_KING_SQ with UNDO_FROM
   0c9c   68 c9 60 87       RLDI 9, GAME_STATE + STATE_B_KING_SQ
                        
   0ca0                 UM_STORE_KING:
                            ; Get UNDO_FROM and store as restored king square
   0ca0   68 c8 64 09       RLDI 8, UNDO_FROM
   0ca4   08                LDN 8               ; D = from square
   0ca5   59                STR 9               ; Restore king position
                        
                            ; =========================================
                            ; CASTLING ROOK UNDO
                            ; =========================================
                            ; Detect: to - from = $02 (kingside) or $FE (queenside)
   0ca6   68 c9 64 49       RLDI 9, COMPARE_TEMP
   0caa   68 c8 64 09       RLDI 8, UNDO_FROM
   0cae   08                LDN 8               ; D = from square
   0caf   e9                SEX 9
   0cb0   59                STR 9               ; M(COMPARE_TEMP) = from
   0cb1   68 c8 64 0a       RLDI 8, UNDO_TO
   0cb5   08                LDN 8               ; D = to square
   0cb6   f7                SM                   ; D = to - from
   0cb7   e2                SEX 2
                        
   0cb8   fb 02             XRI $02
   0cba   c2 0c c5          LBZ UM_CASTLE_KS     ; Kingside
   0cbd   fb fc             XRI $FC
   0cbf   c2 0c f5          LBZ UM_CASTLE_QS     ; Queenside
   0cc2   c0 0d 22          LBR UM_NOT_KING      ; Normal king move
                        
   0cc5                 UM_CASTLE_KS:
                            ; Kingside undo: rook from to-1 (f-file) back to to+1 (h-file)
   0cc5   68 c9 64 0a       RLDI 9, UNDO_TO
   0cc9   09                LDN 9               ; D = to square
                        
                            ; Read rook from BOARD[to-1]
   0cca   ff 01             SMI 1                ; D = to - 1
   0ccc   a8                PLO 8
   0ccd   f8 60             LDI HIGH(BOARD)
   0ccf   b8                PHI 8               ; R8 = &BOARD[to-1]
   0cd0   08                LDN 8               ; D = rook piece
   0cd1   bd                PHI 13              ; R13.1 = rook piece (temp)
   0cd2   f8 00             LDI EMPTY
   0cd4   58                STR 8               ; Clear f1/f8
                        
                            ; Place rook back at BOARD[to+1]
   0cd5   09                LDN 9               ; D = to square
   0cd6   fc 01             ADI 1                ; D = to + 1
   0cd8   a8                PLO 8
   0cd9   f8 60             LDI HIGH(BOARD)
   0cdb   b8                PHI 8               ; R8 = &BOARD[to+1]
   0cdc   9d                GHI 13              ; D = rook piece
   0cdd   58                STR 8               ; Restore rook to h1/h8
                        
                            ; Hash: XOR [rook, to-1] (same pairs as make - XOR cancels)
   0cde   9d                GHI 13              ; D = rook piece
   0cdf   a8                PLO 8               ; R8.0 = rook piece
   0ce0   09                LDN 9               ; D = to square
   0ce1   ff 01             SMI 1                ; D = to - 1
   0ce3   b8                PHI 8               ; R8.1 = f1/f8
   0ce4   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
                            ; Hash: XOR [rook, to+1] (R8.0 preserved)
   0ce7   68 c9 64 0a       RLDI 9, UNDO_TO
   0ceb   09                LDN 9               ; D = to square
   0cec   fc 01             ADI 1                ; D = to + 1
   0cee   b8                PHI 8               ; R8.1 = h1/h8
   0cef   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
   0cf2   c0 0d 22          LBR UM_NOT_KING
                        
   0cf5                 UM_CASTLE_QS:
                            ; Queenside undo: rook from to+1 (d-file) back to to-2 (a-file)
   0cf5   68 c9 64 0a       RLDI 9, UNDO_TO
   0cf9   09                LDN 9               ; D = to square
                        
                            ; Read rook from BOARD[to+1]
   0cfa   fc 01             ADI 1                ; D = to + 1
   0cfc   a8                PLO 8
   0cfd   f8 60             LDI HIGH(BOARD)
   0cff   b8                PHI 8               ; R8 = &BOARD[to+1]
   0d00   08                LDN 8               ; D = rook piece
   0d01   bd                PHI 13              ; R13.1 = rook piece (temp)
   0d02   f8 00             LDI EMPTY
   0d04   58                STR 8               ; Clear d1/d8
                        
                            ; Place rook back at BOARD[to-2]
   0d05   09                LDN 9               ; D = to square
   0d06   ff 02             SMI 2                ; D = to - 2
   0d08   a8                PLO 8
   0d09   f8 60             LDI HIGH(BOARD)
   0d0b   b8                PHI 8               ; R8 = &BOARD[to-2]
   0d0c   9d                GHI 13              ; D = rook piece
   0d0d   58                STR 8               ; Restore rook to a1/a8
                        
                            ; Hash: XOR [rook, to+1]
   0d0e   9d                GHI 13              ; D = rook piece
   0d0f   a8                PLO 8               ; R8.0 = rook piece
   0d10   09                LDN 9               ; D = to square
   0d11   fc 01             ADI 1                ; D = to + 1
   0d13   b8                PHI 8               ; R8.1 = d1/d8
   0d14   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
                            ; Hash: XOR [rook, to-2] (R8.0 preserved)
   0d17   68 c9 64 0a       RLDI 9, UNDO_TO
   0d1b   09                LDN 9               ; D = to square
   0d1c   ff 02             SMI 2                ; D = to - 2
   0d1e   b8                PHI 8               ; R8.1 = a1/a8
   0d1f   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
   0d22                 UM_NOT_KING:
                            ; Restore castling rights to GAME_STATE + STATE_CASTLING
   0d22   68 c9 64 0b       RLDI 9, UNDO_CASTLING
   0d26   09                LDN 9
   0d27   ba                PHI 10              ; Save in R10.1
                        
   0d28   68 c8 60 81       RLDI 8, GAME_STATE + STATE_CASTLING
   0d2c   9a                GHI 10
   0d2d   58                STR 8
                        
                            ; Restore en passant square to GAME_STATE + STATE_EP_SQUARE
   0d2e   68 c9 64 0c       RLDI 9, UNDO_EP
   0d32   09                LDN 9
   0d33   18                INC 8               ; Point to EP_SQUARE ($6082)
   0d34   58                STR 8
                        
                            ; Restore halfmove clock to GAME_STATE + STATE_HALFMOVE
   0d35   68 c9 64 0d       RLDI 9, UNDO_HALFMOVE
   0d39   09                LDN 9
   0d3a   18                INC 8               ; Point to HALFMOVE ($6083)
   0d3b   58                STR 8
                        
                            ; Toggle side to move back
   0d3c   68 c8 60 80       RLDI 8, SIDE
   0d40   08                LDN 8
   0d41   fb 08             XRI BLACK           ; Toggle between 0 and 8
   0d43   58                STR 8
                        
                            ; =========================================
                            ; HASH UPDATE: XOR piece-square changes (reverse of MAKE_MOVE)
                            ; =========================================
                            ; HASH_XOR_PIECE_SQ: R8.0 = piece, R8.1 = square
                            ; Clobbers: R7, R9, R10, R13. Preserves: R8
                            ; Board is now restored: piece at UNDO_FROM, captured at UNDO_TO
                            ;
                            ; For promotion: need to XOR out [promoted_piece, to], not [pawn, to]
                        
                            ; --- Step 1: XOR out [piece that WAS at to], to ---
                            ; Check if this was a promotion
   0d44   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   0d48   0a                LDN 10              ; D = promotion type (0 if none)
   0d49   c2 0d 69          LBZ UM_HASH_NOT_PROMO
                        
                            ; Promotion: XOR out [promoted_piece, to]
                            ; Get color from BOARD[from] (the pawn), combine with promotion type
   0d4c   68 ca 64 09       RLDI 10, UNDO_FROM
   0d50   0a                LDN 10              ; D = from_square
   0d51   fc 00             ADI LOW(BOARD)
   0d53   aa                PLO 10
   0d54   f8 60             LDI HIGH(BOARD)
   0d56   7c 00             ADCI 0
   0d58   ba                PHI 10              ; R10 = &BOARD[from_square]
   0d59   0a                LDN 10              ; D = pawn
   0d5a   fa 08             ANI COLOR_MASK      ; Get color
   0d5c   a8                PLO 8               ; R8.0 = color (temp)
   0d5d   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   0d61   0a                LDN 10              ; D = promotion piece type
   0d62   52                STR 2               ; Save on stack
   0d63   88                GLO 8               ; D = color
   0d64   f4                ADD                 ; D = color + promotion_type = promoted piece
   0d65   a8                PLO 8               ; R8.0 = promoted piece
   0d66   c0 0d 78          LBR UM_HASH_GOT_PIECE
                        
   0d69                 UM_HASH_NOT_PROMO:
                            ; Normal move: XOR out [moving piece, to]
                            ; Moving piece is now at BOARD[UNDO_FROM]
   0d69   68 ca 64 09       RLDI 10, UNDO_FROM
   0d6d   0a                LDN 10              ; D = from_square
   0d6e   fc 00             ADI LOW(BOARD)
   0d70   aa                PLO 10
   0d71   f8 60             LDI HIGH(BOARD)
   0d73   7c 00             ADCI 0
   0d75   ba                PHI 10              ; R10 = &BOARD[from_square]
   0d76   0a                LDN 10              ; D = moving piece
   0d77   a8                PLO 8               ; R8.0 = moving piece
                        
   0d78                 UM_HASH_GOT_PIECE:
                            ; Get to square
   0d78   68 ca 64 0a       RLDI 10, UNDO_TO
   0d7c   0a                LDN 10              ; D = to_square
   0d7d   b8                PHI 8               ; R8.1 = to_square
   0d7e   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
                            ; --- Step 2: XOR in [captured, captured_square] ---
                            ; For normal captures: captured_square = to
                            ; For EP captures: captured_square = (from_rank | to_file)
   0d81   68 ca 64 08       RLDI 10, UNDO_CAPTURED
   0d85   0a                LDN 10              ; D = captured piece
   0d86   a8                PLO 8               ; R8.0 = captured piece
   0d87   68 ca 64 ff       RLDI 10, UNDO_CAP_SQ
   0d8b   0a                LDN 10              ; D = capture square
   0d8c   b8                PHI 8               ; R8.1 = capture square
   0d8d   d4 58 05          CALL HASH_XOR_PIECE_SQ  ; skips if captured == EMPTY
                        
                            ; --- Step 3: XOR in [moving piece, from] ---
                            ; Moving piece is at BOARD[UNDO_FROM]
   0d90   68 ca 64 09       RLDI 10, UNDO_FROM
   0d94   0a                LDN 10              ; D = from_square
   0d95   b8                PHI 8               ; R8.1 = from_square
                            ; Compute BOARD[from_square]
   0d96   fc 00             ADI LOW(BOARD)
   0d98   aa                PLO 10
   0d99   f8 60             LDI HIGH(BOARD)
   0d9b   7c 00             ADCI 0
   0d9d   ba                PHI 10              ; R10 = &BOARD[from_square]
   0d9e   0a                LDN 10              ; D = moving piece
   0d9f   a8                PLO 8               ; R8.0 = moving piece
   0da0   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
                            ; --- Step 4: XOR side ---
   0da3   d4 58 68          CALL HASH_XOR_SIDE
                        
   0da6   d5                SEP 5
                        
                        ; ==============================================================================
                        ; NULL_MAKE_MOVE - Make a null move (pass - just toggle side)
                        ; ==============================================================================
                        ; Used by null move pruning. No actual piece moves.
                        ; Input: None
                        ; Output: Side toggled, hash updated, EP cleared
                        ; Saves: EP square to NULL_SAVED_EP for unmake
                        ; ==============================================================================
   0da7                 NULL_MAKE_MOVE:
                            ; Save EP square to NULL_SAVED_EP
   0da7   68 ca 60 82       RLDI 10, GAME_STATE + STATE_EP_SQUARE
   0dab   0a                LDN 10              ; D = current EP square
   0dac   a7                PLO 7               ; Save in R7.0
   0dad   68 ca 64 a8       RLDI 10, NULL_SAVED_EP
   0db1   87                GLO 7
   0db2   5a                STR 10              ; NULL_SAVED_EP = old EP
                        
                            ; Clear EP square (no EP after null move)
   0db3   68 ca 60 82       RLDI 10, GAME_STATE + STATE_EP_SQUARE
   0db7   f8 ff             LDI $FF             ; Invalid EP
   0db9   5a                STR 10
                        
                            ; Toggle side to move
   0dba   68 ca 60 80       RLDI 10, GAME_STATE + STATE_SIDE_TO_MOVE
   0dbe   0a                LDN 10
   0dbf   fb 08             XRI $08             ; Toggle 0 <-> 8
   0dc1   5a                STR 10
                        
                            ; Update hash for side change
   0dc2   d4 58 68          CALL HASH_XOR_SIDE
                        
   0dc5   d5                RETN
                        
                        ; ==============================================================================
                        ; NULL_UNMAKE_MOVE - Undo a null move
                        ; ==============================================================================
                        ; Restores state from before null move
                        ; Input: None
                        ; Output: Side toggled back, hash restored, EP restored
                        ; ==============================================================================
   0dc6                 NULL_UNMAKE_MOVE:
                            ; Toggle side back
   0dc6   68 ca 60 80       RLDI 10, GAME_STATE + STATE_SIDE_TO_MOVE
   0dca   0a                LDN 10
   0dcb   fb 08             XRI $08             ; Toggle 8 <-> 0
   0dcd   5a                STR 10
                        
                            ; Restore EP square from NULL_SAVED_EP
   0dce   68 ca 64 a8       RLDI 10, NULL_SAVED_EP
   0dd2   0a                LDN 10              ; D = saved EP
   0dd3   a7                PLO 7               ; Save in R7.0
   0dd4   68 ca 60 82       RLDI 10, GAME_STATE + STATE_EP_SQUARE
   0dd8   87                GLO 7
   0dd9   5a                STR 10              ; Restore EP
                        
                            ; Update hash for side change (XOR again = restore)
   0dda   d4 58 68          CALL HASH_XOR_SIDE
                        
   0ddd   d5                RETN
                        
                        ; ==============================================================================
                        ; END OF MAKE/UNMAKE MODULE
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Position Evaluation
                        ; ==============================================================================
                        ; Evaluate board position and return score
                        ; Positive score favors white, negative favors black
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; Piece Values (in centipawns)
                        ; ------------------------------------------------------------------------------
   0064                 PAWN_VALUE      EQU 100
   0140                 KNIGHT_VALUE    EQU 320
   014a                 BISHOP_VALUE    EQU 330
   01f4                 ROOK_VALUE      EQU 500
   0384                 QUEEN_VALUE     EQU 900
   4e20                 KING_VALUE      EQU 20000   ; Effectively infinite (not used in material count)
                        
                        ; Check bonus: credit the attacker when side-to-move is in check.
                        ; Applied at EVAL exit — rewards moves that deliver check, encourages
                        ; attacking play (especially with queen) in endgame mate-chasing.
   0028                 CHECK_BONUS     EQU 40
                        
                        ; Queen-king proximity bonus (Chebyshev distance lookup).
                        ; Indexed by distance 0-7. Distance 0 unreachable (queen can't be on king's
                        ; square). Encourages queen to attack enemy king in endgame, addressing the
                        ; "queen sits idle" pattern that emerged after the queen-cap removed
                        ; multi-promotion incentive.
   0dde                 QUEEN_PROX_BONUS:
   0dde   00                DB 0    ; distance 0 (not reachable)
   0ddf   3c                DB 60   ; distance 1 (adjacent — strongest attack)
   0de0   32                DB 50   ; distance 2
   0de1   28                DB 40   ; distance 3
   0de2   1e                DB 30   ; distance 4
   0de3   14                DB 20   ; distance 5
   0de4   0a                DB 10   ; distance 6
   0de5   00                DB 0    ; distance 7 (far — no bonus)
                        
                        ; King-safety tables (2026-06-11). SHIELD_PEN indexed by shield_missing (0-3);
                        ; STORM_PEN indexed by (3 - chebyshev_dist) so dist1->idx2, dist2->idx1. Penalties
                        ; are positive magnitudes; max SHIELD(100)+STORM(150)=250 fits one byte.
   0de6                 SHIELD_PEN:
   0de6   00 19 3c 64       DB 0, 25, 60, 100       ; missing 0,1,2,3 shield pawns
   0dea                 STORM_PEN:
   0dea   00 50 96          DB 0, 80, 150           ; idx 0 (dist3, unused), 1 (dist2), 2 (dist1)
                        ; (DEFENSE_CREDIT table removed 2026-07-13 — see KING_SAFETY note.)
                        ; Racing-passer bonus (2026-06-13): EXTRA value for an advanced white passer with a
                        ; clear front, ramping toward queen value so white pushes it (the d5 search can't
                        ; see the promotion). Indexed by rank-5/6/7. 16-bit (big-endian DW) — > one byte.
   0ded                 RUNNER_BONUS:
   0ded   00 96 01 5e       DW 150, 350, 600       ; rank 5, rank 6, rank 7
   0df1   02 58         
                        
                        ; Piece value table (indexed by piece type 0-6)
   0df3                 PIECE_VALUES:
   0df3   00 00             DW 0            ; Empty (type 0)
   0df5   00 64             DW 100          ; Pawn (type 1)
   0df7   01 40             DW 320          ; Knight (type 2)
   0df9   01 4a             DW 330          ; Bishop (type 3)
   0dfb   01 f4             DW 500          ; Rook (type 4)
   0dfd   03 84             DW 900          ; Queen (type 5)
   0dff   00 00             DW 0            ; King (type 6) - don't count in material
                        
                        ; ------------------------------------------------------------------------------
                        ; EVALUATE - Main evaluation function
                        ; ------------------------------------------------------------------------------
                        ; Input:  A = board pointer (BOARD)
                        ; Output: R9 = evaluation score (16-bit signed)
                        ;         Positive = white advantage
                        ;         Negative = black advantage
                        ; NOTE:   Returns in R9, NOT R6! R6 is SCRT linkage register - off limits!
                        ; Uses:   All registers except R6
                        ;
                        ; Components (in order of implementation):
                        ;   1. Material count (DONE)
                        ;   2. Piece-square tables (TODO)
                        ;   3. Pawn structure (TODO)
                        ;   4. King safety (TODO)
                        ;   5. Mobility (TODO)
                        ; ------------------------------------------------------------------------------
                        
                        ; ------------------------------------------------------------------------------
                        ; CHECK_INSUFFICIENT_MATERIAL - Detect the canonical dead-draw material configs
                        ; ------------------------------------------------------------------------------
                        ; Returns D = 1 if the position is one of:
                        ;   K vs K, K+N vs K, K+B vs K, K+B vs K+B (bishops on same square colour)
                        ; else D = 0.  These are the four cases where neither side can force mate
                        ; (item C — added 2026-05-18).  Returning 0 from EVALUATE for these stops the
                        ; engine meandering in drawn endgames until the 50-move rule.
                        ;
                        ; Scans BOARD once, early-aborting to "not draw" the moment a pawn, rook, or
                        ; queen is seen, or when the minor count exceeds 2.  In any position with
                        ; pawns/rooks/queens (every opening/middlegame) the very first occupied square
                        ; aborts the scan, so cost is ~1 iteration in normal play; only true bare-king
                        ; endgames pay the full 128-square walk.
                        ;
                        ; Provably safe for non-drawn positions: the short-circuit only fires when
                        ; material is EXACTLY one of the four configs above. Any pawn/rook/queen or a
                        ; 3rd minor falls through untouched — cannot alter winning/losing eval.
                        ;
                        ; Uses: R7 (sq index), R8 (piece + type/sqcolor scratch), R10 (board ptr),
                        ;       R11 (.0=minor total, .1=white bishop count),
                        ;       R13 (.0=black bishop count, .1=bishop sq-colour bits)
                        ; Does NOT touch R6 (SCRT) or R9 (caller score, not yet set at call site).
                        ; ------------------------------------------------------------------------------
   0e01                 CHECK_INSUFFICIENT_MATERIAL:
   0e01   f8 00             LDI 0
   0e03   ab                PLO 11              ; R11.0 = minor total (bishops + knights)
   0e04   bb                PHI 11              ; R11.1 = white bishop count
   0e05   ad                PLO 13              ; R13.0 = black bishop count
   0e06   bd                PHI 13              ; R13.1 = bishop sq-colour bits (b0=W, b1=B)
                        
   0e07   f8 00             LDI 0
   0e09   a7                PLO 7               ; R7.0 = square index 0
                        
   0e0a                 CIM_LOOP:
   0e0a   87                GLO 7
   0e0b   fa 88             ANI $88
   0e0d   ca 0e 75          LBNZ CIM_NEXT       ; off-board 0x88 square, skip
                        
                            ; R10 = BOARD + sq
   0e10   87                GLO 7
   0e11   fc 00             ADI LOW(BOARD)
   0e13   aa                PLO 10
   0e14   f8 60             LDI HIGH(BOARD)
   0e16   7c 00             ADCI 0
   0e18   ba                PHI 10
   0e19   0a                LDN 10              ; D = piece
   0e1a   c2 0e 75          LBZ CIM_NEXT        ; empty square
                        
   0e1d   a8                PLO 8               ; R8.0 = full piece byte (kept all loop)
   0e1e   fa 07             ANI PIECE_MASK      ; D = piece type 1-6
   0e20   b8                PHI 8               ; R8.1 = piece type
                        
   0e21   fb 06             XRI KING_TYPE       ; king? (always present, never counted)
   0e23   c2 0e 75          LBZ CIM_NEXT
                        
   0e26   98                GHI 8               ; type
   0e27   fb 01             XRI PAWN_TYPE
   0e29   c2 0e a4          LBZ CIM_NOT_DRAW    ; any pawn → not insufficient
   0e2c   98                GHI 8
   0e2d   fb 04             XRI ROOK_TYPE
   0e2f   c2 0e a4          LBZ CIM_NOT_DRAW    ; any rook → not insufficient
   0e32   98                GHI 8
   0e33   fb 05             XRI QUEEN_TYPE
   0e35   c2 0e a4          LBZ CIM_NOT_DRAW    ; any queen → not insufficient
                        
                            ; piece is a minor (knight=2 or bishop=3)
   0e38   8b                GLO 11
   0e39   fc 01             ADI 1
   0e3b   ab                PLO 11              ; minor total++
   0e3c   ff 03             SMI 3
   0e3e   c3 0e a4          LBDF CIM_NOT_DRAW   ; >=3 minors → not one of the four cases
                        
   0e41   98                GHI 8               ; type
   0e42   fb 03             XRI BISHOP_TYPE
   0e44   ca 0e 75          LBNZ CIM_NEXT       ; knight — counted in total, nothing more
                        
                            ; --- bishop: compute its square colour = ((sq>>4)+(sq&7)) & 1 ---
   0e47   87                GLO 7
   0e48   fa 07             ANI $07             ; file
   0e4a   52                STR 2               ; M(R2) = file
   0e4b   87                GLO 7
   0e4c   f6                SHR
   0e4d   f6                SHR
   0e4e   f6                SHR
   0e4f   f6                SHR                 ; D = sq>>4 = rank (valid sq → high nibble 0-7)
   0e50   f4                ADD                 ; D = rank + file
   0e51   fa 01             ANI $01             ; D = square colour 0/1
   0e53   b8                PHI 8               ; R8.1 = square colour
                        
   0e54   88                GLO 8               ; full piece byte
   0e55   fa 08             ANI COLOR_MASK      ; 0 = white bishop, 8 = black bishop
   0e57   ca 0e 69          LBNZ CIM_BLACK_B
                        
                            ; white bishop
   0e5a   9b                GHI 11
   0e5b   fc 01             ADI 1
   0e5d   bb                PHI 11              ; white bishop count++
   0e5e   98                GHI 8               ; square colour
   0e5f   c2 0e 75          LBZ CIM_NEXT        ; colour 0 → leave bit0 clear
   0e62   9d                GHI 13
   0e63   f9 01             ORI $01
   0e65   bd                PHI 13              ; bit0 = white bishop on colour-1 square
   0e66   c0 0e 75          LBR CIM_NEXT
                        
   0e69                 CIM_BLACK_B:
   0e69   8d                GLO 13
   0e6a   fc 01             ADI 1
   0e6c   ad                PLO 13              ; black bishop count++
   0e6d   98                GHI 8               ; square colour
   0e6e   c2 0e 75          LBZ CIM_NEXT
   0e71   9d                GHI 13
   0e72   f9 02             ORI $02
   0e74   bd                PHI 13              ; bit1 = black bishop on colour-1 square
                        
   0e75                 CIM_NEXT:
   0e75   87                GLO 7
   0e76   fc 01             ADI 1
   0e78   a7                PLO 7
   0e79   fb 80             XRI $80             ; scanned squares 0..127?
   0e7b   ca 0e 0a          LBNZ CIM_LOOP
                        
                            ; --- decision ---
   0e7e   8b                GLO 11              ; minor total
   0e7f   c2 0e a1          LBZ CIM_DRAW        ; 0 minors → K vs K
   0e82   ff 01             SMI 1
   0e84   c2 0e a1          LBZ CIM_DRAW        ; 1 minor  → K+N vs K or K+B vs K (either side)
                        
                            ; minor total == 2 (>=3 already rejected mid-scan).
                            ; Draw only if exactly one bishop per side AND same square colour.
   0e87   9b                GHI 11              ; white bishop count
   0e88   ff 01             SMI 1
   0e8a   ca 0e a4          LBNZ CIM_NOT_DRAW   ; != 1
   0e8d   8d                GLO 13              ; black bishop count
   0e8e   ff 01             SMI 1
   0e90   ca 0e a4          LBNZ CIM_NOT_DRAW   ; != 1
   0e93   9d                GHI 13
   0e94   fa 03             ANI $03             ; b0=white sqcolour, b1=black sqcolour
   0e96   c2 0e a1          LBZ CIM_DRAW        ; 00 → both colour-0 → same → draw
   0e99   fb 03             XRI $03
   0e9b   c2 0e a1          LBZ CIM_DRAW        ; 11 → both colour-1 → same → draw
   0e9e   c0 0e a4          LBR CIM_NOT_DRAW    ; 01/10 → opposite colours (not in item-C list)
                        
   0ea1                 CIM_DRAW:
   0ea1   f8 01             LDI 1
   0ea3   d5                RETN
                        
   0ea4                 CIM_NOT_DRAW:
   0ea4   f8 00             LDI 0
   0ea6   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
   0ea7                 EVALUATE:
                            ; Ensure X=2 for all stack/memory operations
   0ea7   e2                SEX 2
                        
   0ea8   68 ca 64 1d       RLDI 10, TRACE_WHERE
   0eac   f8 e1             LDI $E1
   0eae   5a                STR 10              ; tracer: in EVALUATE
                        
                            ; Insufficient-material dead-draw short-circuit (item C, 2026-05-18).
                            ; Safe by construction: only fires for K-K / K+N-K / K+B-K / K+B-K+B
                            ; same-colour; any other material falls through to the full eval.
   0eaf   d4 0e 01          CALL CHECK_INSUFFICIENT_MATERIAL
   0eb2   c2 0e ba          LBZ EVAL_NOT_DEAD_DRAW
   0eb5   f8 00             LDI 0
   0eb7   b9                PHI 9
   0eb8   a9                PLO 9              ; R9 = 0 (draw)
   0eb9   d5                RETN
   0eba                 EVAL_NOT_DEAD_DRAW:
                        
                            ; Initialize score to 0
                            ; NOTE: Use R9 for score, NOT R6! R6 is SCRT linkage register!
   0eba   f8 00             LDI 0
   0ebc   b9                PHI 9
   0ebd   a9                PLO 9              ; R9 = 0 (score accumulator)
                        
                            ; Scan board and count material
   0ebe   68 ca 60 00       RLDI 10, BOARD
                        
                            ; Initialize square counter in memory (avoid R14!)
   0ec2   68 cd 64 1d       RLDI 13, EVAL_SQ_INDEX
   0ec6   f8 00             LDI 0
   0ec8   5d                STR 13              ; EVAL_SQ_INDEX = 0
                        
                            ; Initialize piece counter in memory (D is still 0)
   0ec9   68 cb 64 ec       RLDI 11, EG_PIECE_COUNT
   0ecd   5b                STR 11              ; EG_PIECE_COUNT = 0
                        
                            ; Initialize advanced pawn counters (D is still 0)
   0ece   68 cb 64 fd       RLDI 11, ADV_PAWN_W
   0ed2   5b                STR 11              ; ADV_PAWN_W = 0
   0ed3   1b                INC 11
   0ed4   5b                STR 11              ; ADV_PAWN_B = 0
                        
                            ; Initialize pawn file counts: 16 bytes at $6710-$671F (D is still 0)
   0ed5   68 cb 67 10       RLDI 11, W_PAWN_FILE_CT
   0ed9   f8 10             LDI 16              ; 16 bytes to clear
   0edb   a8                PLO 8               ; R8.0 = loop counter
   0edc                 EVAL_CLR_PAWN_CT:
   0edc   f8 00             LDI 0
   0ede   5b                STR 11
   0edf   1b                INC 11
   0ee0   28                DEC 8
   0ee1   88                GLO 8
   0ee2   ca 0e dc          LBNZ EVAL_CLR_PAWN_CT
                        
                            ; Initialize bishop counts + rook file trackers + queen counts
   0ee5   f8 00             LDI 0
   0ee7   68 cb 64 af       RLDI 11, EVAL_W_BISHOPS
   0eeb   5b                STR 11              ; EVAL_W_BISHOPS = 0
   0eec   1b                INC 11
   0eed   5b                STR 11              ; EVAL_B_BISHOPS = 0
   0eee   68 cb 64 b5       RLDI 11, W_QUEEN_CNT
   0ef2   5b                STR 11              ; W_QUEEN_CNT = 0
   0ef3   1b                INC 11
   0ef4   5b                STR 11              ; B_QUEEN_CNT = 0
   0ef5   1b                INC 11
   0ef6   5b                STR 11              ; PIECE_BALANCE = 0 ($64B7, signed W-B non-pawn count; D still 0)
                            ; Rook files = $FF (no rook); queen squares also default to $FF (no queen)
   0ef7   f8 ff             LDI $FF
   0ef9   68 cb 64 b1       RLDI 11, EVAL_W_ROOK_F1
   0efd   5b                STR 11              ; EVAL_W_ROOK_F1 = $FF
   0efe   1b                INC 11
   0eff   5b                STR 11              ; EVAL_W_ROOK_F2 = $FF
   0f00   1b                INC 11
   0f01   5b                STR 11              ; EVAL_B_ROOK_F1 = $FF
   0f02   1b                INC 11
   0f03   5b                STR 11              ; EVAL_B_ROOK_F2 = $FF
   0f04   68 cb 67 20       RLDI 11, W_QUEEN_SQ
   0f08   5b                STR 11              ; W_QUEEN_SQ = $FF
   0f09   1b                INC 11
   0f0a   5b                STR 11              ; B_QUEEN_SQ = $FF
                        
   0f0b                 EVAL_SCAN:
                            ; Check if square is valid (R13 points to EVAL_SQ_INDEX)
   0f0b   0d                LDN 13
   0f0c   fa 88             ANI $88
   0f0e   ca 10 8c          LBNZ EVAL_NEXT_SQUARE
                        
                            ; Load piece at square
   0f11   0a                LDN 10
   0f12   c2 10 8c          LBZ EVAL_NEXT_SQUARE ; Empty square
                        
                            ; Get piece type and color
                            ; NOTE: R13 must stay pointing to EVAL_SQ_INDEX - use R8 for piece temp!
   0f15   a8                PLO 8               ; R8.0 = piece (temp storage)
                        
                            ; Check color
   0f16   fa 08             ANI COLOR_MASK
   0f18   af                PLO 15              ; F.0 = color (0=white, 8=black)
                        
                            ; Get piece type
   0f19   88                GLO 8               ; Get piece back from R8.0
   0f1a   fa 07             ANI PIECE_MASK
   0f1c   a8                PLO 8               ; R8.0 = piece type (1-6)
                        
                            ; Skip king (type 6)
   0f1d   fb 06             XRI 6
   0f1f   c2 10 8c          LBZ EVAL_NEXT_SQUARE
                        
                            ; Count non-king piece (memory variable — R12 is side-to-move, off limits)
   0f22   68 cb 64 ec       RLDI 11, EG_PIECE_COUNT
   0f26   0b                LDN 11
   0f27   fc 01             ADI 1
   0f29   5b                STR 11
                        
                            ; Accumulate SIGNED non-pawn piece balance (W-B) for the white RUNNER_BONUS gate
                            ; (2026-06-30). type in R8.0 (1-5; king already skipped), color in R15. White N/B/R/Q
                            ; -> +1, black -> -1. R11/D clobbered (both reloaded below).
   0f2a   88                GLO 8
   0f2b   ff 02             SMI 2               ; type - 2  (DF=0 if type < 2, i.e. pawn)
   0f2d   cb 0f 43          LBNF EVAL_PB_DONE   ; pawn -> not a piece, skip
   0f30   68 cb 64 b7       RLDI 11, PIECE_BALANCE
   0f34   8f                GLO 15              ; color (0=white, 8=black)
   0f35   ca 0f 3f          LBNZ EVAL_PB_BLACK  ; black -> decrement
   0f38   0b                LDN 11              ; white: balance + 1
   0f39   fc 01             ADI 1
   0f3b   5b                STR 11
   0f3c   c0 0f 43          LBR EVAL_PB_DONE
   0f3f                 EVAL_PB_BLACK:
   0f3f   0b                LDN 11              ; black: balance - 1
   0f40   ff 01             SMI 1
   0f42   5b                STR 11
   0f43                 EVAL_PB_DONE:
                        
                            ; Check if pawn for advanced pawn bonus (graduated)
   0f43   88                GLO 8               ; piece type (1-5)
   0f44   fb 01             XRI 1
   0f46   ca 0f c0          LBNZ EVAL_NOT_ADV_PAWN  ; not a pawn (+3 instr for non-pawns)
                            ; Pawn — extract rank from 0x88 square
   0f49   0d                LDN 13              ; D = 0x88 square (from EVAL_SQ_INDEX)
   0f4a   fa 70             ANI $70             ; D = rank << 4 ($00-$70)
   0f4c   52                STR 2               ; save rank<<4 on stack
   0f4d   8f                GLO 15              ; D = color (0=white, 8=black)
   0f4e   ca 0f 8a          LBNZ EVAL_BP_ADV
                            ; === White pawn: rank 7=$60 (+150), rank 6=$50 (+100), rank 5=$40 (+50), rank 4=$30 (+25) ===
   0f51   02                LDN 2
   0f52   fb 60             XRI $60
   0f54   c2 0f 73          LBZ EVAL_WP_R7
   0f57   02                LDN 2
   0f58   fb 50             XRI $50
   0f5a   c2 0f 78          LBZ EVAL_WP_R6
   0f5d   02                LDN 2
   0f5e   fb 40             XRI $40
   0f60   c2 0f 6e          LBZ EVAL_WP_R5
   0f63   02                LDN 2
   0f64   fb 30             XRI $30
   0f66   ca 0f c0          LBNZ EVAL_NOT_ADV_PAWN
   0f69   f8 19             LDI 25              ; rank 4
   0f6b   c0 0f 7a          LBR EVAL_WP_ADD
   0f6e                 EVAL_WP_R5:
   0f6e   f8 32             LDI 50              ; rank 5
   0f70   c0 0f 7a          LBR EVAL_WP_ADD
   0f73                 EVAL_WP_R7:
   0f73   f8 96             LDI 150             ; rank 7
   0f75   c0 0f 7a          LBR EVAL_WP_ADD
   0f78                 EVAL_WP_R6:
   0f78   f8 64             LDI 100             ; rank 6
   0f7a                 EVAL_WP_ADD:
   0f7a   52                STR 2
   0f7b   68 cb 64 fd       RLDI 11, ADV_PAWN_W
   0f7f   0b                LDN 11
   0f80   f4                ADD
   0f81   cb 0f 86          LBNF EVAL_WP_NOSAT  ; DF=0: no carry, no overflow
   0f84   f8 ff             LDI 255             ; Overflow: saturate at 255
   0f86                 EVAL_WP_NOSAT:
   0f86   5b                STR 11              ; ADV_PAWN_W = min(sum, 255)
   0f87   c0 0f c0          LBR EVAL_NOT_ADV_PAWN
   0f8a                 EVAL_BP_ADV:
                            ; === Black pawn: rank 2=$10 (+150), rank 3=$20 (+100), rank 4=$30 (+50), rank 5=$40 (+25) ===
   0f8a   02                LDN 2
   0f8b   fb 10             XRI $10
   0f8d   c2 0f ac          LBZ EVAL_BP_R2
   0f90   02                LDN 2
   0f91   fb 20             XRI $20
   0f93   c2 0f b1          LBZ EVAL_BP_R3
   0f96   02                LDN 2
   0f97   fb 30             XRI $30
   0f99   c2 0f a7          LBZ EVAL_BP_R4
   0f9c   02                LDN 2
   0f9d   fb 40             XRI $40
   0f9f   ca 0f c0          LBNZ EVAL_NOT_ADV_PAWN
   0fa2   f8 19             LDI 25              ; rank 5
   0fa4   c0 0f b3          LBR EVAL_BP_ADD
   0fa7                 EVAL_BP_R4:
   0fa7   f8 32             LDI 50              ; rank 4
   0fa9   c0 0f b3          LBR EVAL_BP_ADD
   0fac                 EVAL_BP_R2:
   0fac   f8 96             LDI 150             ; rank 2
   0fae   c0 0f b3          LBR EVAL_BP_ADD
   0fb1                 EVAL_BP_R3:
   0fb1   f8 64             LDI 100             ; rank 3
   0fb3                 EVAL_BP_ADD:
   0fb3   52                STR 2
   0fb4   68 cb 64 fe       RLDI 11, ADV_PAWN_B
   0fb8   0b                LDN 11
   0fb9   f4                ADD
   0fba   cb 0f bf          LBNF EVAL_BP_NOSAT  ; DF=0: no carry, no overflow
   0fbd   f8 ff             LDI 255             ; Overflow: saturate at 255
   0fbf                 EVAL_BP_NOSAT:
   0fbf   5b                STR 11              ; ADV_PAWN_B = min(sum, 255)
   0fc0                 EVAL_NOT_ADV_PAWN:
                        
                            ; ==================================================================
                            ; Track pawn files, bishop count, rook files for structure eval
                            ; R8.0 = piece type (1-6), R15.0 = color, R13 -> EVAL_SQ_INDEX
                            ; ==================================================================
                        
                            ; --- PAWN: increment per-file count ---
   0fc0   88                GLO 8               ; piece type
   0fc1   fb 01             XRI 1               ; pawn?
   0fc3   ca 0f eb          LBNZ EVAL_NOT_PAWN_TRACK
   0fc6   0d                LDN 13              ; D = 0x88 square
   0fc7   fa 07             ANI $07             ; D = file (0-7)
   0fc9   52                STR 2               ; save file on stack
   0fca   8f                GLO 15              ; color
   0fcb   ca 0f de          LBNZ EVAL_BP_COUNT
                            ; White pawn: W_PAWN_FILE_CT[file]++
   0fce   02                LDN 2               ; D = file
   0fcf   fc 10             ADI LOW(W_PAWN_FILE_CT)
   0fd1   ab                PLO 11
   0fd2   f8 67             LDI HIGH(W_PAWN_FILE_CT)
   0fd4   7c 00             ADCI 0
   0fd6   bb                PHI 11              ; R11 = &W_PAWN_FILE_CT[file]
   0fd7   0b                LDN 11
   0fd8   fc 01             ADI 1
   0fda   5b                STR 11
   0fdb   c0 0f eb          LBR EVAL_NOT_PAWN_TRACK
   0fde                 EVAL_BP_COUNT:
                            ; Black pawn: B_PAWN_FILE_CT[file]++
   0fde   02                LDN 2               ; D = file
   0fdf   fc 18             ADI LOW(B_PAWN_FILE_CT)
   0fe1   ab                PLO 11
   0fe2   f8 67             LDI HIGH(B_PAWN_FILE_CT)
   0fe4   7c 00             ADCI 0
   0fe6   bb                PHI 11              ; R11 = &B_PAWN_FILE_CT[file]
   0fe7   0b                LDN 11
   0fe8   fc 01             ADI 1
   0fea   5b                STR 11
   0feb                 EVAL_NOT_PAWN_TRACK:
                        
                            ; --- BISHOP: count per color ---
   0feb   88                GLO 8               ; piece type
   0fec   fb 03             XRI 3               ; bishop?
   0fee   ca 10 08          LBNZ EVAL_NOT_BISHOP_TRACK
   0ff1   8f                GLO 15              ; color
   0ff2   ca 10 00          LBNZ EVAL_BB_TRACK
   0ff5   68 cb 64 af       RLDI 11, EVAL_W_BISHOPS
   0ff9   0b                LDN 11
   0ffa   fc 01             ADI 1
   0ffc   5b                STR 11
   0ffd   c0 10 08          LBR EVAL_NOT_BISHOP_TRACK
   1000                 EVAL_BB_TRACK:
   1000   68 cb 64 b0       RLDI 11, EVAL_B_BISHOPS
   1004   0b                LDN 11
   1005   fc 01             ADI 1
   1007   5b                STR 11
   1008                 EVAL_NOT_BISHOP_TRACK:
                        
                            ; --- ROOK: save file number (up to 2 per side) ---
   1008   88                GLO 8               ; piece type
   1009   fb 04             XRI 4               ; rook?
   100b   ca 10 43          LBNZ EVAL_NOT_ROOK_TRACK
   100e   0d                LDN 13              ; 0x88 square
   100f   fa 07             ANI $07             ; D = file (0-7)
   1011   b8                PHI 8               ; save file in R8.1
   1012   8f                GLO 15              ; color
   1013   ca 10 2e          LBNZ EVAL_BROOK_TRACK
                            ; White rook: store in F1 or F2
   1016   68 cb 64 b1       RLDI 11, EVAL_W_ROOK_F1
   101a   0b                LDN 11
   101b   fb ff             XRI $FF             ; is F1 empty?
   101d   ca 10 25          LBNZ EVAL_WR_F2
   1020   98                GHI 8               ; D = file
   1021   5b                STR 11              ; F1 = file
   1022   c0 10 43          LBR EVAL_NOT_ROOK_TRACK
   1025                 EVAL_WR_F2:
   1025   68 cb 64 b2       RLDI 11, EVAL_W_ROOK_F2
   1029   98                GHI 8
   102a   5b                STR 11              ; F2 = file
   102b   c0 10 43          LBR EVAL_NOT_ROOK_TRACK
   102e                 EVAL_BROOK_TRACK:
                            ; Black rook: store in F1 or F2
   102e   68 cb 64 b3       RLDI 11, EVAL_B_ROOK_F1
   1032   0b                LDN 11
   1033   fb ff             XRI $FF
   1035   ca 10 3d          LBNZ EVAL_BR_F2
   1038   98                GHI 8
   1039   5b                STR 11
   103a   c0 10 43          LBR EVAL_NOT_ROOK_TRACK
   103d                 EVAL_BR_F2:
   103d   68 cb 64 b4       RLDI 11, EVAL_B_ROOK_F2
   1041   98                GHI 8
   1042   5b                STR 11
   1043                 EVAL_NOT_ROOK_TRACK:
                        
                            ; --- QUEEN: count + remember square (for redundant-queen cap and proximity bonus) ---
   1043   88                GLO 8               ; piece type
   1044   fb 05             XRI 5               ; queen?
   1046   ca 10 6c          LBNZ EVAL_NOT_QUEEN_TRACK
   1049   8f                GLO 15              ; color
   104a   ca 10 5e          LBNZ EVAL_BQ_TRACK
                            ; White queen
   104d   68 cb 64 b5       RLDI 11, W_QUEEN_CNT
   1051   0b                LDN 11
   1052   fc 01             ADI 1
   1054   5b                STR 11
   1055   0d                LDN 13              ; current 0x88 square from EVAL_SQ_INDEX
   1056   68 cb 67 20       RLDI 11, W_QUEEN_SQ
   105a   5b                STR 11
   105b   c0 10 6c          LBR EVAL_NOT_QUEEN_TRACK
   105e                 EVAL_BQ_TRACK:
                            ; Black queen
   105e   68 cb 64 b6       RLDI 11, B_QUEEN_CNT
   1062   0b                LDN 11
   1063   fc 01             ADI 1
   1065   5b                STR 11
   1066   0d                LDN 13              ; current 0x88 square from EVAL_SQ_INDEX
   1067   68 cb 67 21       RLDI 11, B_QUEEN_SQ
   106b   5b                STR 11
   106c                 EVAL_NOT_QUEEN_TRACK:
                        
                            ; Get piece value from table
                            ; R8.0 = piece type (1-6), need to look up in PIECE_VALUES table
   106c   88                GLO 8               ; Piece type from R8.0
   106d   fe                SHL                 ; Multiply by 2 (16-bit table entries)
   106e   52                STR 2               ; Save offset to stack
   106f   f8 f3             LDI LOW(PIECE_VALUES)
   1071   f4                ADD                 ; D = LOW(PIECE_VALUES) + offset
   1072   ab                PLO 11              ; R11.0 = low byte of address
   1073   f8 0d             LDI HIGH(PIECE_VALUES)
   1075   7c 00             ADCI 0              ; Add carry if low byte overflowed
   1077   bb                PHI 11              ; R11 = PIECE_VALUES + (type * 2)
                        
                            ; Load 16-bit value
   1078   4b                LDA 11
   1079   b7                PHI 7              ; 7.1 = value high
   107a   0b                LDN 11
   107b   a7                PLO 7              ; 7.0 = value low
                                                ; 7 = piece value
                        
                            ; Add or subtract based on color
   107c   8f                GLO 15              ; Color
   107d   32 82             BZ EVAL_ADD_WHITE
                        
   107f                 EVAL_ADD_BLACK:
                            ; Black piece - subtract from score (negate 7)
   107f   d4 00 0f          CALL NEG16_R7
                            ; Fall through to add
                        
   1082                 EVAL_ADD_WHITE:
                            ; White piece or negated black - add to score
                            ; R9 = R9 + R7 (using R9 for score, not R6 which is SCRT linkage!)
   1082   89                GLO 9
   1083   52                STR 2
   1084   87                GLO 7
   1085   f4                ADD
   1086   a9                PLO 9
   1087   99                GHI 9
   1088   52                STR 2
   1089   97                GHI 7
   108a   74                ADC
   108b   b9                PHI 9
                            ; 6 updated with new score
                        
   108c                 EVAL_NEXT_SQUARE:
   108c   1a                INC 10              ; Next square
                            ; Increment square counter in memory (R13 still points to EVAL_SQ_INDEX)
   108d   0d                LDN 13
   108e   fc 01             ADI 1
   1090   5d                STR 13
   1091   ff 80             SMI 128
   1093   cb 0f 0b          LBNF EVAL_SCAN      ; Continue if < 128 (DF=0 means borrow, i.e., D was < 128)
                        
   1096                 EVAL_DONE:
                            ; R9 contains material score
                        
                            ; ==================================================================
                            ; Redundant-queen cap (RETUNED 2026-07-15): extra queens beyond the
                            ; first score 500 cp, not 0. The 0-cap (anti-3-queen-shuffle) was
                            ; side-symmetric and DELETED the OPPONENT's 2nd queen from the ledger:
                            ; move 47 vs b1=Q read Rxc2 as "+500, opponent gains nothing" and the
                            ; engine walked into a Q-vs-2Q mate reading +773. At 500/extra the
                            ; anti-shuffle intent survives (2nd queen << 900, promotion never
                            ; outbids mating) but an enemy 2nd queen stays a live threat.
                            ; Implementation: subtract (W_QUEEN_CNT - 1) * 400 from white side,
                            ; add (B_QUEEN_CNT - 1) * 400 for black side (900 - 400 = 500 net).
                            ; ==================================================================
                        
                            ; --- White side ---
   1096   68 c8 64 b5       RLDI 8, W_QUEEN_CNT
   109a   08                LDN 8
   109b   c2 10 b8          LBZ QC_W_DONE       ; 0 queens: nothing to cap
   109e   ff 01             SMI 1
   10a0   c2 10 b8          LBZ QC_W_DONE       ; 1 queen: no extras
                        
   10a3   a7                PLO 7               ; R7.0 = number of extras (>= 1)
   10a4   f8 00             LDI 0
   10a6   b7                PHI 7               ; clean R7.1 for predictable DEC
                        
   10a7                 QC_W_LOOP:
   10a7   f8 90             LDI $90             ; low byte of 400 ($0190)
   10a9   52                STR 2
   10aa   89                GLO 9
   10ab   f7                SM
   10ac   a9                PLO 9
   10ad   f8 01             LDI $01             ; high byte of 400
   10af   52                STR 2
   10b0   99                GHI 9
   10b1   77                SMB
   10b2   b9                PHI 9
   10b3   27                DEC 7
   10b4   87                GLO 7
   10b5   ca 10 a7          LBNZ QC_W_LOOP
   10b8                 QC_W_DONE:
                        
                            ; --- Black side (extras flip sign: ADD 900 each) ---
   10b8   68 c8 64 b6       RLDI 8, B_QUEEN_CNT
   10bc   08                LDN 8
   10bd   c2 10 da          LBZ QC_B_DONE
   10c0   ff 01             SMI 1
   10c2   c2 10 da          LBZ QC_B_DONE
                        
   10c5   a7                PLO 7
   10c6   f8 00             LDI 0
   10c8   b7                PHI 7
                        
   10c9                 QC_B_LOOP:
   10c9   f8 90             LDI $90             ; low byte of 400
   10cb   52                STR 2
   10cc   89                GLO 9
   10cd   f4                ADD
   10ce   a9                PLO 9
   10cf   f8 01             LDI $01             ; high byte of 400
   10d1   52                STR 2
   10d2   99                GHI 9
   10d3   74                ADC
   10d4   b9                PHI 9
   10d5   27                DEC 7
   10d6   87                GLO 7
   10d7   ca 10 c9          LBNZ QC_B_LOOP
   10da                 QC_B_DONE:
                        
                            ; ==================================================================
                            ; Queen-king proximity bonus
                            ; For each side that has a queen, bonus = lookup[chebyshev_distance]
                            ; from queen to enemy king. Encourages attacking play in endgame
                            ; (paired with queen-cap which removed the redundant-promotion bias).
                            ; ==================================================================
                        
                            ; --- White queen → black king proximity ---
   10da   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   10de   08                LDN 8
   10df   fb ff             XRI $FF
   10e1   c2 11 35          LBZ QP_W_DONE       ; W_QUEEN_SQ == $FF (no queen), skip
                        
                            ; D was XOR'd; reload queen square
   10e4   68 c8 67 20       RLDI 8, W_QUEEN_SQ
   10e8   08                LDN 8
   10e9   b7                PHI 7               ; R7.1 = W queen 0x88 square
                        
   10ea   68 c8 60 87       RLDI 8, GAME_STATE + STATE_B_KING_SQ
   10ee   08                LDN 8
   10ef   b8                PHI 8               ; R8.1 = B king 0x88 square (use R8.1 to free R8.0)
                        
                            ; |q_rank - k_rank|
   10f0   97                GHI 7
   10f1   fa 70             ANI $70
   10f3   f6                SHR
   10f4   f6                SHR
   10f5   f6                SHR
   10f6   f6                SHR                 ; D = q_rank
   10f7   ad                PLO 13              ; R13.0 = q_rank
   10f8   98                GHI 8
   10f9   fa 70             ANI $70
   10fb   f6                SHR
   10fc   f6                SHR
   10fd   f6                SHR
   10fe   f6                SHR                 ; D = k_rank
   10ff   52                STR 2
   1100   8d                GLO 13
   1101   f5                SD                  ; D = k_rank - q_rank
   1102   c3 11 07          LBDF QP_W_RANK_OK
   1105   fd 00             SDI 0               ; negate to get magnitude
   1107                 QP_W_RANK_OK:
   1107   bd                PHI 13              ; R13.1 = |rank diff|
                        
                            ; |q_file - k_file|
   1108   97                GHI 7
   1109   fa 07             ANI $07             ; D = q_file
   110b   ad                PLO 13              ; R13.0 = q_file
   110c   98                GHI 8
   110d   fa 07             ANI $07             ; D = k_file
   110f   52                STR 2
   1110   8d                GLO 13
   1111   f5                SD                  ; D = k_file - q_file
   1112   c3 11 17          LBDF QP_W_FILE_OK
   1115   fd 00             SDI 0
   1117                 QP_W_FILE_OK:
   1117   ad                PLO 13              ; R13.0 = |file diff|
                        
                            ; max(R13.1, R13.0)
   1118   9d                GHI 13
   1119   52                STR 2
   111a   8d                GLO 13
   111b   f5                SD                  ; D = R13.1 - R13.0 (rank - file)
   111c   c3 11 23          LBDF QP_W_USE_RANK
   111f   8d                GLO 13              ; file > rank → max = file
   1120   c0 11 24          LBR QP_W_HAVE_DIST
   1123                 QP_W_USE_RANK:
   1123   9d                GHI 13              ; rank >= file → max = rank
   1124                 QP_W_HAVE_DIST:
                            ; D = chebyshev distance (1-7 typically, 0 impossible)
   1124   fc de             ADI LOW(QUEEN_PROX_BONUS)
   1126   ab                PLO 11
   1127   f8 00             LDI 0
   1129   7c 0d             ADCI HIGH(QUEEN_PROX_BONUS)
   112b   bb                PHI 11
   112c   0b                LDN 11              ; D = bonus
   112d   52                STR 2
   112e   89                GLO 9
   112f   f4                ADD
   1130   a9                PLO 9
   1131   99                GHI 9
   1132   7c 00             ADCI 0
   1134   b9                PHI 9
   1135                 QP_W_DONE:
                        
                            ; --- Black queen → white king proximity (subtract bonus from R9) ---
   1135   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   1139   08                LDN 8
   113a   fb ff             XRI $FF
   113c   c2 11 90          LBZ QP_B_DONE
                        
   113f   68 c8 67 21       RLDI 8, B_QUEEN_SQ
   1143   08                LDN 8
   1144   b7                PHI 7
                        
   1145   68 c8 60 86       RLDI 8, GAME_STATE + STATE_W_KING_SQ
   1149   08                LDN 8
   114a   b8                PHI 8
                        
                            ; |q_rank - k_rank|
   114b   97                GHI 7
   114c   fa 70             ANI $70
   114e   f6                SHR
   114f   f6                SHR
   1150   f6                SHR
   1151   f6                SHR
   1152   ad                PLO 13
   1153   98                GHI 8
   1154   fa 70             ANI $70
   1156   f6                SHR
   1157   f6                SHR
   1158   f6                SHR
   1159   f6                SHR
   115a   52                STR 2
   115b   8d                GLO 13
   115c   f5                SD
   115d   c3 11 62          LBDF QP_B_RANK_OK
   1160   fd 00             SDI 0
   1162                 QP_B_RANK_OK:
   1162   bd                PHI 13
                        
