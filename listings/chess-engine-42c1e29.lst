   2292   0a                LDN 10              ; D = alpha_hi
   2293   b8                PHI 8
   2294   2a                DEC 10
   2295   0a                LDN 10              ; D = alpha_lo
   2296   a8                PLO 8               ; R8 = parent's alpha
                        
