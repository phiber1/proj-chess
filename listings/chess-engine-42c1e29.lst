   14bb   0a                LDN 10
   14bc   fb ff             XRI $FF
   14be   c2 14 c5          LBZ OG_WQ               ; no white rook in slot 2
   14c1   87                GLO 7
   14c2   ff 01             SMI 1
   14c4   a7                PLO 7
