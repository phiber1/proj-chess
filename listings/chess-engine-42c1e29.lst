   0aab   e9                SEX 9
   0aac   59                STR 9               ; M(COMPARE_TEMP) = from
   0aad   68 c8 64 0a       RLDI 8, UNDO_TO
   0ab1   08                LDN 8               ; D = to square
   0ab2   f7                SM                   ; D = to - from
   0ab3   e2                SEX 2
                        
   0ab4   fb 02             XRI $02
   0ab6   c2 0a c1          LBZ MM_CASTLE_KS     ; to - from = 2: kingside
   0ab9   fb fc             XRI $FC              ; XOR chain: checks if original was $FE
   0abb   c2 0a f1          LBZ MM_CASTLE_QS     ; to - from = $FE: queenside
   0abe   c0 0b 2f          LBR MM_NOT_KING      ; Normal king move
                        
   0ac1                 MM_CASTLE_KS:
                            ; Kingside: rook from to+1 (h-file) to to-1 (f-file)
