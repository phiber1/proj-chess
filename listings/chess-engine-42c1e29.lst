   2244   87                GLO 7               ; alpha_lo
   2245   5a                STR 10
   2246   8d                GLO 13              ; score_lo
   2247   f7                SM                  ; D = score_lo - alpha_lo
   2248   b8                PHI 8               ; Save low result in R8.1
   2249   97                GHI 7               ; alpha_hi
   224a   5a                STR 10
   224b   9d                GHI 13              ; score_hi
   224c   77                SMB                 ; D = score_hi - alpha_hi - borrow
   224d   e2                SEX 2               ; Restore X = R2
   224e   cb 22 f3          LBNF LMR_NO_RESEARCH ; Borrow = score <= alpha, no re-search
   2251   ca 22 61          LBNZ LMR_DO_RESEARCH ; High bytes differ and positive
   2254   98                GHI 8               ; Check saved low result
   2255   c2 22 f3          LBZ LMR_NO_RESEARCH  ; Equal (both zero), no re-search
   2258   c0 22 61          LBR LMR_DO_RESEARCH
                        
   225b                 LMR_RESEARCH_DIFF_SIGN:
                            ; Different signs: positive > negative
   225b   9d                GHI 13              ; score_hi
   225c   fa 80             ANI $80
   225e   ca 22 f3          LBNZ LMR_NO_RESEARCH ; score negative, alpha positive: score < alpha
                        
   2261                 LMR_DO_RESEARCH:
                            ; Re-search needed! Score beat alpha on reduced search.
                        
                            ; Clear LMR_REDUCED so we don't re-search again
   2261   68 ca 64 a4       RLDI 10, LMR_REDUCED
   2265   f8 00             LDI 0
   2267   5a                STR 10
                        
                            ; Increment SEARCH_DEPTH by 1 (undo the extra LMR reduction)
                            ; Current depth = original - 2, we want original - 1
   2268   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   226c   0d                LDN 13              ; D = depth_lo
   226d   fc 01             ADI 1
   226f   5d                STR 13              ; depth_lo++
   2270   2d                DEC 13              ; Point to high byte
   2271   0d                LDN 13              ; D = depth_hi
   2272   7c 00             ADCI 0              ; Add carry
   2274   5d                STR 13              ; depth_hi++ (with carry)
                        
                            ; Re-setup alpha/beta for child (same swap as original)
                            ; Peek parent's beta from stack (beta_hi at R2+12, beta_lo at R2+11)
   2275   82                GLO 2
   2276   fc 0c             ADI 12
   2278   aa                PLO 10
   2279   92                GHI 2
   227a   7c 00             ADCI 0
   227c   ba                PHI 10              ; R10 = address of beta_hi on stack
