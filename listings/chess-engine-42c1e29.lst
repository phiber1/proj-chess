                        ; Total size: 8610 bytes
                        ; ==============================================================================
                        ; TRANSPOSITION TABLE FUNCTIONS
                        ; ==============================================================================
                        ; Provides Zobrist hashing and transposition table lookup/store.
                        ;
                        ; Functions:
                        ;   HASH_INIT   - Compute full hash from current board position
                        ;   TT_CLEAR    - Clear all TT entries
                        ;   TT_PROBE    - Look up position in TT
                        ;   TT_STORE    - Store position result in TT
                        ;
                        ; Hash is updated incrementally by MAKE_MOVE/UNMAKE_MOVE (in makemove.asm)
                        ; ==============================================================================
                        
                        ; ==============================================================================
                        ; HASH_INIT - Compute Zobrist hash from current board position
                        ; ==============================================================================
                        ; Scans the board and XORs all piece-square keys, plus side/castling/EP.
                        ; Result stored in HASH_HI/HASH_LO.
                        ;
                        ; Uses: R7 (hash accumulator), R8 (temp), R9 (square counter), R10 (pointer)
                        ; ==============================================================================
   55e0                 HASH_INIT:
                            ; Initialize hash to zero
   55e0   f8 00             LDI 0
   55e2   b7                PHI 7
   55e3   a7                PLO 7               ; R7 = 0 (hash accumulator)
                        
                            ; Scan all 64 valid squares (0x88 format)
   55e4   f8 00             LDI 0
   55e6   a9                PLO 9               ; R9.0 = square index (0x88 format)
                        
   55e7                 HASH_INIT_LOOP:
                            ; Check if square is valid (not off-board)
   55e7   89                GLO 9
   55e8   fa 88             ANI $88
   55ea   ca 56 4c          LBNZ HASH_INIT_NEXT_SQ  ; Off-board, skip
                        
                            ; Get piece at this square
   55ed   f8 60             LDI HIGH(BOARD)
   55ef   ba                PHI 10
   55f0   89                GLO 9
   55f1   aa                PLO 10              ; R10 = BOARD + square
   55f2   0a                LDN 10              ; D = piece at square
   55f3   c2 56 4c          LBZ HASH_INIT_NEXT_SQ   ; Empty square, skip
                        
                            ; Have a piece - compute Zobrist key offset
                            ; piece_index = (piece & 7) - 1 for white, + 6 for black
                            ; Piece encoding: 1-6 = white P/N/B/R/Q/K, 9-14 = black
   55f6   a8                PLO 8               ; R8.0 = piece
   55f7   fa 07             ANI $07             ; D = piece type (1-6)
   55f9   ff 01             SMI 1               ; D = piece_type - 1 (0-5)
   55fb   ad                PLO 13              ; R13.0 = piece index base
                        
   55fc   88                GLO 8               ; Get piece again
   55fd   fa 08             ANI $08             ; Check color bit
   55ff   c2 56 06          LBZ HASH_INIT_WHITE
                            ; Black piece - add 6 to index
   5602   8d                GLO 13
   5603   fc 06             ADI 6
   5605   ad                PLO 13
   5606                 HASH_INIT_WHITE:
                        
                            ; Now compute square index (0-63 from 0x88)
                            ; sq64 = (sq88 >> 4) * 8 + (sq88 & 7) = rank*8 + file
   5606   89                GLO 9               ; 0x88 square
   5607   fa 07             ANI $07             ; D = file (0-7)
   5609   a8                PLO 8               ; R8.0 = file
   560a   89                GLO 9
   560b   fa 70             ANI $70             ; D = rank * 16 (masked)
   560d   f6                SHR                 ; D = rank * 8
   560e   52                STR 2               ; Save rank*8
   560f   88                GLO 8               ; D = file
   5610   f4                ADD                 ; D = rank*8 + file = sq64
   5611   a8                PLO 8               ; R8.0 = sq64 (0-63)
                        
                            ; Compute Zobrist table offset:
                            ; offset = piece_index * 128 + sq64 * 2
                            ; R13.0 = piece_index (0-11)
                            ; R8.0 = sq64 (0-63)
                        
                            ; First: piece_index * 128 = piece_index << 7
                            ; Since piece_index is 0-11, result fits in 16 bits
   5612   8d                GLO 13              ; piece_index (0-11)
   5613   fe                SHL                 ; x2
   5614   fe                SHL                 ; x4
   5615   fe                SHL                 ; x8
   5616   fe                SHL                 ; x16
   5617   fe                SHL                 ; x32
   5618   fe                SHL                 ; x64
   5619   b8                PHI 8               ; R8.1 = (piece_index * 64) = high part of offset
   561a   f8 00             LDI 0
   561c   c7                LSNF                ; Skip if no carry from last SHL
   561d   f8 01             LDI 1               ; Carry into high byte
                            ; Actually, piece_index * 128: need one more shift
                            ; Let me reconsider: piece * 128 = piece << 7
                            ; For piece=11: 11 << 7 = 1408 = $580
                            ; High byte = piece >> 1, low byte = (piece & 1) << 7
                        
                            ; Restart: piece_index * 128
   561f   8d                GLO 13              ; piece_index (0-11)
   5620   f6                SHR                 ; D = piece_index >> 1
   5621   b8                PHI 8               ; R8.1 = high byte of piece*128
   5622   8d                GLO 13
   5623   fa 01             ANI $01             ; D = piece_index & 1
   5625   c2 56 2d          LBZ HASH_INIT_EVEN_PIECE
   5628   f8 80             LDI $80
   562a   c0 56 2f          LBR HASH_INIT_ADD_SQ
   562d                 HASH_INIT_EVEN_PIECE:
   562d   f8 00             LDI 0
   562f                 HASH_INIT_ADD_SQ:
                            ; D = low byte of piece*128 (0 or $80)
                            ; Now add sq64 * 2
   562f   ad                PLO 13              ; R13.0 = temp low
   5630   88                GLO 8               ; sq64
   5631   fe                SHL                 ; sq64 * 2
   5632   52                STR 2
   5633   8d                GLO 13
   5634   f4                ADD                 ; D = low + sq*2
   5635   ad                PLO 13              ; R13.0 = offset low
   5636   98                GHI 8               ; high byte of piece*128
   5637   7c 00             ADCI 0              ; add carry
   5639   bd                PHI 13              ; R13.1 = offset high
                        
                            ; Now add ZOBRIST_PIECE_SQ base address
   563a   8d                GLO 13
   563b   fc 88             ADI LOW(ZOBRIST_PIECE_SQ)
   563d   aa                PLO 10
   563e   9d                GHI 13
   563f   7c 58             ADCI HIGH(ZOBRIST_PIECE_SQ)
   5641   ba                PHI 10              ; R10 = address of Zobrist key
                        
                            ; XOR the 16-bit key into hash (R7)
   5642   4a                LDA 10              ; High byte of key
   5643   52                STR 2
   5644   97                GHI 7
   5645   f3                XOR
   5646   b7                PHI 7               ; hash_hi ^= key_hi
   5647   0a                LDN 10              ; Low byte of key
   5648   52                STR 2
   5649   87                GLO 7
   564a   f3                XOR
   564b   a7                PLO 7               ; hash_lo ^= key_lo
                        
   564c                 HASH_INIT_NEXT_SQ:
                            ; Next square
   564c   19                INC 9               ; R9.0++
   564d   89                GLO 9
   564e   fb 80             XRI $80             ; Check if we've passed square $7F
   5650   ca 55 e7          LBNZ HASH_INIT_LOOP
                        
                            ; Done with pieces. Now XOR side to move.
   5653   68 ca 60 80       RLDI 10, GAME_STATE
   5657   0a                LDN 10              ; D = side to move (0=white, 8=black)
   5658   c2 56 69          LBZ HASH_SIDE_DONE
                            ; Black to move - XOR side key
   565b   68 ca 5e 88       RLDI 10, ZOBRIST_SIDE
   565f   4a                LDA 10
   5660   52                STR 2
   5661   97                GHI 7
   5662   f3                XOR
   5663   b7                PHI 7
   5664   0a                LDN 10
   5665   52                STR 2
   5666   87                GLO 7
   5667   f3                XOR
   5668   a7                PLO 7
   5669                 HASH_SIDE_DONE:
                        
                            ; XOR castling rights
                            ; Castling is at GAME_STATE + STATE_CASTLING ($6081)
   5669   68 ca 60 81       RLDI 10, GAME_STATE + STATE_CASTLING
   566d   0a                LDN 10              ; D = castling rights
   566e   a9                PLO 9               ; R9.0 = castling bits
                        
                            ; Check each castling bit
                            ; White kingside (bit 0)
   566f   89                GLO 9
   5670   fa 01             ANI CASTLE_WK
   5672   c2 56 78          LBZ HASH_NO_WK
   5675   d4 56 bf          CALL HASH_XOR_CASTLE_0
   5678                 HASH_NO_WK:
                            ; White queenside (bit 1)
   5678   89                GLO 9
   5679   fa 02             ANI CASTLE_WQ
   567b   c2 56 81          LBZ HASH_NO_WQ
   567e   d4 56 c6          CALL HASH_XOR_CASTLE_1
   5681                 HASH_NO_WQ:
                            ; Black kingside (bit 2)
   5681   89                GLO 9
   5682   fa 04             ANI CASTLE_BK
   5684   c2 56 8a          LBZ HASH_NO_BK
   5687   d4 56 cf          CALL HASH_XOR_CASTLE_2
   568a                 HASH_NO_BK:
                            ; Black queenside (bit 3)
   568a   89                GLO 9
   568b   fa 08             ANI CASTLE_BQ
   568d   c2 56 93          LBZ HASH_NO_BQ
   5690   d4 56 da          CALL HASH_XOR_CASTLE_3
   5693                 HASH_NO_BQ:
                        
                            ; XOR en passant file if set
   5693   68 ca 60 80       RLDI 10, GAME_STATE
   5697   1a                INC 10
   5698   1a                INC 10              ; Point to EP square
   5699   0a                LDN 10              ; D = EP square ($FF if none)
   569a   fb ff             XRI $FF
   569c   c2 56 b5          LBZ HASH_NO_EP      ; No EP square
                            ; Have EP - get file (bits 0-2 of 0x88 square)
   569f   0a                LDN 10
   56a0   fa 07             ANI $07             ; D = file (0-7)
   56a2   fe                SHL                 ; D = file * 2 (offset into ZOBRIST_EP)
   56a3   fc 92             ADI LOW(ZOBRIST_EP)
   56a5   aa                PLO 10
   56a6   f8 5e             LDI HIGH(ZOBRIST_EP)
   56a8   7c 00             ADCI 0
   56aa   ba                PHI 10              ; R10 = address of EP file key
   56ab   4a                LDA 10
   56ac   52                STR 2
   56ad   97                GHI 7
   56ae   f3                XOR
   56af   b7                PHI 7
   56b0   0a                LDN 10
   56b1   52                STR 2
   56b2   87                GLO 7
   56b3   f3                XOR
   56b4   a7                PLO 7
   56b5                 HASH_NO_EP:
                        
                            ; Store final hash
   56b5   68 ca 64 b9       RLDI 10, HASH_HI
   56b9   97                GHI 7
   56ba   5a                STR 10
   56bb   1a                INC 10
   56bc   87                GLO 7
   56bd   5a                STR 10
                        
   56be   d5                RETN
                        
                        ; Helper functions to XOR castling keys (avoids code duplication)
   56bf                 HASH_XOR_CASTLE_0:
   56bf   68 ca 5e 8a       RLDI 10, ZOBRIST_CASTLE
   56c3   c0 56 e4          LBR HASH_XOR_CASTLE_DO
   56c6                 HASH_XOR_CASTLE_1:
   56c6   68 ca 5e 8a       RLDI 10, ZOBRIST_CASTLE
   56ca   1a                INC 10
   56cb   1a                INC 10
   56cc   c0 56 e4          LBR HASH_XOR_CASTLE_DO
   56cf                 HASH_XOR_CASTLE_2:
   56cf   68 ca 5e 8a       RLDI 10, ZOBRIST_CASTLE
   56d3   1a                INC 10
   56d4   1a                INC 10
   56d5   1a                INC 10
   56d6   1a                INC 10
   56d7   c0 56 e4          LBR HASH_XOR_CASTLE_DO
   56da                 HASH_XOR_CASTLE_3:
   56da   68 ca 5e 8a       RLDI 10, ZOBRIST_CASTLE
   56de   1a                INC 10
   56df   1a                INC 10
   56e0   1a                INC 10
   56e1   1a                INC 10
   56e2   1a                INC 10
   56e3   1a                INC 10
   56e4                 HASH_XOR_CASTLE_DO:
   56e4   4a                LDA 10
   56e5   52                STR 2
   56e6   97                GHI 7
   56e7   f3                XOR
   56e8   b7                PHI 7
   56e9   0a                LDN 10
   56ea   52                STR 2
   56eb   87                GLO 7
   56ec   f3                XOR
   56ed   a7                PLO 7
   56ee   d5                RETN
                        
                        ; ==============================================================================
                        ; TT_CLEAR - Clear all transposition table entries
                        ; ==============================================================================
                        ; Sets all TT entries to flag=TT_FLAG_NONE (0)
                        ; Should be called at start of new game or new position.
                        ;
                        ; Uses: R9 (counter), R10 (pointer)
                        ; ==============================================================================
   56ef                 TT_CLEAR:
   56ef   68 ca 68 00       RLDI 10, TT_TABLE
                        
                            ; Clear 256 entries × 8 bytes = 2048 bytes
                            ; Use R9 as 16-bit counter
   56f3   68 c9 08 00       RLDI 9, TT_ENTRIES * TT_ENTRY_SIZE
                        
   56f7   f8 00             LDI 0               ; Value to write
   56f9                 TT_CLEAR_LOOP:
   56f9   5a                STR 10
   56fa   1a                INC 10
   56fb   29                DEC 9
   56fc   99                GHI 9
   56fd   ca 56 f9          LBNZ TT_CLEAR_LOOP
   5700   89                GLO 9
   5701   ca 56 f9          LBNZ TT_CLEAR_LOOP
                        
   5704   d5                RETN
                        
                        ; ==============================================================================
                        ; TT_PROBE - Look up current position in transposition table
                        ; ==============================================================================
                        ; Checks if current position (HASH_HI/LO) exists in TT.
                        ; If found and depth >= required, copies entry data to TT_* variables.
                        ;
                        ; Input:  D = required depth
                        ; Output: D = 1 if usable hit, 0 if miss
                        ;         If hit: TT_SCORE, TT_DEPTH, TT_FLAG, TT_MOVE populated
                        ;
                        ; Uses: R7 (hash), R8 (required depth), R10 (pointer)
                        ; ==============================================================================
   5705                 TT_PROBE:
   5705   a8                PLO 8               ; R8.0 = required depth
                        
   5706   68 c9 64 1d       RLDI 9, TRACE_WHERE
   570a   f8 b1             LDI $B1
   570c   59                STR 9              ; tracer: in TT_PROBE
                        
                            ; Clear TT_MOVE (prevents stale data if hash misses)
   570d   68 c9 64 c0       RLDI 9, TT_MOVE_HI
   5711   f8 00             LDI 0
   5713   59                STR 9
   5714   19                INC 9
   5715   59                STR 9               ; TT_MOVE_HI/LO = 0
                        
                            ; Load current hash
   5716   68 ca 64 b9       RLDI 10, HASH_HI
   571a   4a                LDA 10
   571b   b7                PHI 7
   571c   0a                LDN 10
   571d   a7                PLO 7               ; R7 = current hash
                        
                            ; Calculate TT entry address: TT_TABLE + (index * 8)
                            ; XOR-fold indexing (2026-05-15): index = (hash_hi XOR hash_lo) & $FF.
   571e   97                GHI 7               ; hash_hi
   571f   52                STR 2
   5720   87                GLO 7               ; hash_lo
   5721   f3                XOR                 ; D = hash_hi XOR hash_lo
   5722   fa ff             ANI TT_INDEX_MASK   ; Mask to table size
   5724   fe                SHL                 ; x2, carry into DF
   5725   aa                PLO 10
   5726   f8 00             LDI 0
   5728   7e                SHLC                ; carry into D
   5729   ba                PHI 10              ; R10.1 = high so far
   572a   8a                GLO 10
   572b   fe                SHL                 ; x4
   572c   aa                PLO 10
   572d   9a                GHI 10
   572e   7e                SHLC
   572f   ba                PHI 10
   5730   8a                GLO 10
   5731   fe                SHL                 ; x8
   5732   aa                PLO 10
   5733   9a                GHI 10
   5734   7e                SHLC
   5735   ba                PHI 10              ; R10 = index * 8
                        
                            ; Add TT_TABLE base
   5736   8a                GLO 10
   5737   fc 00             ADI LOW(TT_TABLE)
   5739   aa                PLO 10
   573a   9a                GHI 10
   573b   7c 68             ADCI HIGH(TT_TABLE)
   573d   ba                PHI 10              ; R10 = TT entry address
                        
                            ; Check if entry matches (compare stored hash with current)
   573e   4a                LDA 10              ; Entry hash_hi
   573f   52                STR 2
   5740   97                GHI 7
   5741   f3                XOR
   5742   ca 57 9b          LBNZ TT_PROBE_MISS
   5745   4a                LDA 10              ; Entry hash_lo
   5746   52                STR 2
   5747   87                GLO 7
   5748   f3                XOR
   5749   ca 57 9b          LBNZ TT_PROBE_MISS
                        
                            ; Hash matches! Save move for ordering (even if depth insufficient)
                            ; R10 at offset 2 (score_hi). Move is at offset 6-7.
   574c   1a                INC 10              ; → 3
   574d   1a                INC 10              ; → 4 (depth)
   574e   1a                INC 10              ; → 5 (flag)
   574f   1a                INC 10              ; → 6 (move_hi)
   5750   4a                LDA 10              ; D = move_hi, R10 → 7
   5751   73                STXD                ; push move_hi
   5752   0a                LDN 10              ; D = move_lo
   5753   73                STXD                ; push move_lo
                        
                            ; Write to TT_MOVE_HI/LO
   5754   68 c9 64 c0       RLDI 9, TT_MOVE_HI
   5758   60                IRX
   5759   72                LDXA                ; D = move_lo
   575a   19                INC 9
   575b   59                STR 9               ; TT_MOVE_LO = move_lo
   575c   29                DEC 9
   575d   f0                LDX                 ; D = move_hi
   575e   59                STR 9               ; TT_MOVE_HI = move_hi
                        
                            ; Navigate back to depth (offset 4)
   575f   2a                DEC 10              ; → 6
   5760   2a                DEC 10              ; → 5
   5761   2a                DEC 10              ; → 4 (depth)
                        
                            ; Check depth
   5762   0a                LDN 10              ; Entry depth
   5763   52                STR 2
   5764   88                GLO 8               ; Required depth
   5765   f5                SD                  ; D = entry_depth - required_depth
   5766   cb 57 9b          LBNF TT_PROBE_MISS  ; Borrow → depth insufficient (but TT_MOVE saved!)
                        
                            ; --- side-bit verification (2026-07-15): a 16-bit hash match can be a
                            ; DIFFERENT position (proven: loss8's +2341 = a white-to-move entry
                            ; served to a black-to-move node = sign inversion). Reject the SCORE on
                            ; side mismatch; the ordering move above is already saved (benign — a
                            ; wrong-position move matches nothing in the generated list).
   5769   1a                INC 10              ; → 5 (flag)
   576a   0a                LDN 10              ; D = entry flag (bit 3 = storing side)
   576b   52                STR 2
   576c   8c                GLO 12              ; current side to move ($00/$08)
   576d   f3                XOR
   576e   fa 08             ANI $08
   5770   ca 57 9b          LBNZ TT_PROBE_MISS  ; cross-side entry -> treat as miss
   5773   2a                DEC 10              ; → 4 (depth), as the flow below expects
                        
                            ; Usable hit! Copy entry data to TT_* variables
                            ; Back up to start of entry
   5774   2a                DEC 10
   5775   2a                DEC 10
   5776   2a                DEC 10
   5777   2a                DEC 10              ; R10 at entry start
                        
                            ; Copy to TT result variables
   5778   68 c9 64 bc       RLDI 9, TT_SCORE_HI
                        
   577c   1a                INC 10
   577d   1a                INC 10              ; Skip hash verification bytes
   577e   4a                LDA 10              ; score_hi
   577f   59                STR 9
   5780   19                INC 9
   5781   4a                LDA 10              ; score_lo
   5782   59                STR 9
   5783   19                INC 9
   5784   4a                LDA 10              ; depth
   5785   59                STR 9
   5786   19                INC 9
   5787   4a                LDA 10              ; flag
   5788   fa 07             ANI $07             ; strip the side bit — consumers compare bound types
   578a   59                STR 9
   578b   19                INC 9
   578c   4a                LDA 10              ; move_hi
   578d   59                STR 9
   578e   19                INC 9
   578f   0a                LDN 10              ; move_lo
   5790   59                STR 9
                        
                            ; Set TT_HIT = 1
   5791   68 ca 64 bb       RLDI 10, TT_HIT
   5795   f8 01             LDI 1
   5797   5a                STR 10
                        
   5798   f8 01             LDI 1               ; Return hit
   579a   d5                RETN
                        
   579b                 TT_PROBE_MISS:
                            ; Set TT_HIT = 0
   579b   68 ca 64 bb       RLDI 10, TT_HIT
   579f   f8 00             LDI 0
   57a1   5a                STR 10
                        
   57a2   f8 00             LDI 0               ; Return miss
   57a4   d5                RETN
                        
                        ; ==============================================================================
                        ; TT_STORE - Store position result in transposition table
                        ; ==============================================================================
                        ; Stores current position with score, depth, flag, and best move.
                        ; Always replaces existing entry (replace-always scheme).
                        ;
                        ; Input:  Stack contains (push order): score_hi, score_lo, depth, flag
                        ;         BEST_MOVE contains best move
                        ; Actually, let's use memory variables for simplicity:
                        ;         SCORE_HI/LO = score to store
                        ;         D = depth
                        ;         R8.0 = flag
                        ;
                        ; Uses: R7 (hash), R9 (temp), R10 (pointer)
                        ; ==============================================================================
   57a5                 TT_STORE:
                            ; Save depth and flag
   57a5   73                STXD                ; Push depth
   57a6   88                GLO 8
   57a7   73                STXD                ; Push flag
                        
   57a8   68 ca 64 1d       RLDI 10, TRACE_WHERE
   57ac   f8 b2             LDI $B2
   57ae   5a                STR 10              ; tracer: in TT_STORE
                        
                            ; Load current hash
   57af   68 ca 64 b9       RLDI 10, HASH_HI
   57b3   4a                LDA 10
   57b4   b7                PHI 7
   57b5   0a                LDN 10
   57b6   a7                PLO 7               ; R7 = current hash
                        
                            ; Calculate TT entry address: TT_TABLE + (index * 8) — XOR-fold (must match TT_PROBE)
   57b7   97                GHI 7               ; hash_hi
   57b8   52                STR 2
   57b9   87                GLO 7               ; hash_lo
   57ba   f3                XOR                 ; D = hash_hi XOR hash_lo
   57bb   fa ff             ANI TT_INDEX_MASK
   57bd   fe                SHL                 ; x2, carry into DF
   57be   aa                PLO 10
   57bf   f8 00             LDI 0
   57c1   7e                SHLC
   57c2   ba                PHI 10
   57c3   8a                GLO 10
   57c4   fe                SHL                 ; x4
   57c5   aa                PLO 10
   57c6   9a                GHI 10
   57c7   7e                SHLC
   57c8   ba                PHI 10
   57c9   8a                GLO 10
   57ca   fe                SHL                 ; x8
   57cb   aa                PLO 10
   57cc   9a                GHI 10
   57cd   7e                SHLC
   57ce   ba                PHI 10              ; R10 = index * 8
                        
                            ; Add TT_TABLE base
   57cf   8a                GLO 10
   57d0   fc 00             ADI LOW(TT_TABLE)
   57d2   aa                PLO 10
   57d3   9a                GHI 10
   57d4   7c 68             ADCI HIGH(TT_TABLE)
   57d6   ba                PHI 10              ; R10 = TT entry address
                        
                            ; Write entry
   57d7   97                GHI 7               ; hash_hi
   57d8   5a                STR 10
   57d9   1a                INC 10
   57da   87                GLO 7               ; hash_lo
   57db   5a                STR 10
   57dc   1a                INC 10
                        
                            ; Score from SCORE_HI/LO
   57dd   68 c9 64 46       RLDI 9, SCORE_HI
   57e1   49                LDA 9               ; score_hi
   57e2   5a                STR 10
   57e3   1a                INC 10
   57e4   09                LDN 9               ; score_lo
   57e5   5a                STR 10
   57e6   1a                INC 10
                        
                            ; Depth and flag from stack
   57e7   60                IRX
   57e8   72                LDXA                ; flag
   57e9   a8                PLO 8               ; Save temporarily
   57ea   f0                LDX                 ; depth
   57eb   5a                STR 10
   57ec   1a                INC 10
                            ; --- side-bit (2026-07-15, the $1B81 collision fix): fold the storing
                            ; side into flag bit 3 so a 16-bit false hit can't cross perspectives.
   57ed   8c                GLO 12
   57ee   fa 08             ANI $08
   57f0   52                STR 2               ; M(2) = side bit (spent stack slot, safe scratch)
   57f1   88                GLO 8               ; flag
   57f2   f1                OR                  ; flag | side
   57f3   5a                STR 10
   57f4   1a                INC 10
                        
                            ; Best move from NODE_BEST_MOVE[ply]
   57f5   68 c9 64 48       RLDI 9, CURRENT_PLY
   57f9   09                LDN 9               ; D = ply
   57fa   fe                SHL                 ; D = ply * 2
   57fb   a9                PLO 9               ; R9.0 = offset (NODE_BEST_MOVE base = $6700, low = $00)
   57fc   f8 67             LDI HIGH(NODE_BEST_MOVE)
   57fe   b9                PHI 9               ; R9 = $6700 + ply*2
   57ff   49                LDA 9               ; from
   5800   5a                STR 10
   5801   1a                INC 10
   5802   09                LDN 9               ; to
   5803   5a                STR 10
                        
   5804   d5                RETN
                        
                        ; ==============================================================================
                        ; HASH_XOR_PIECE_SQ - XOR piece-square key into current hash
                        ; ==============================================================================
                        ; Used for incremental hash updates in MAKE_MOVE/UNMAKE_MOVE.
                        ;
                        ; Input:  R8.0 = piece (1-6 white, 9-14 black, or EMPTY=0 for no-op)
                        ;         R8.1 = square (0x88 format)
                        ; Output: HASH_HI/LO updated
                        ; Uses:   R7, R9, R10, R11, R13
                        ; ==============================================================================
   5805                 HASH_XOR_PIECE_SQ:
                            ; Skip if piece is EMPTY
   5805   88                GLO 8
   5806   c2 58 67          LBZ HXPS_DONE
                        
                            ; Load current hash into R7
   5809   68 ca 64 b9       RLDI 10, HASH_HI
   580d   4a                LDA 10
   580e   b7                PHI 7
   580f   0a                LDN 10
   5810   a7                PLO 7               ; R7 = current hash
                        
                            ; Compute piece index (0-11)
                            ; piece_index = (piece & 7) - 1 for white, + 6 for black
   5811   88                GLO 8               ; piece
   5812   fa 07             ANI $07             ; piece type (1-6)
   5814   ff 01             SMI 1               ; piece_type - 1 (0-5)
   5816   ad                PLO 13              ; R13.0 = base index
                        
   5817   88                GLO 8               ; piece again
   5818   fa 08             ANI $08             ; color bit
   581a   c2 58 21          LBZ HXPS_WHITE
                            ; Black - add 6
   581d   8d                GLO 13
   581e   fc 06             ADI 6
   5820   ad                PLO 13
   5821                 HXPS_WHITE:
                        
                            ; Compute square index (0-63 from 0x88)
                            ; sq64 = (sq88 >> 4) * 8 + (sq88 & 7)
   5821   98                GHI 8               ; 0x88 square
   5822   fa 07             ANI $07             ; file
   5824   a9                PLO 9               ; R9.0 = file
   5825   98                GHI 8
   5826   fa 70             ANI $70             ; rank * 16
   5828   f6                SHR                 ; rank * 8
   5829   ab                PLO 11              ; R11.0 = rank*8 (use R11, NOT R7 - R7 has hash!)
   582a   89                GLO 9               ; file
   582b   52                STR 2               ; temp store on stack
   582c   8b                GLO 11              ; rank*8
   582d   f4                ADD                 ; rank*8 + file = sq64
   582e   a9                PLO 9               ; R9.0 = sq64
                        
                            ; Compute Zobrist offset: piece_index * 128 + sq64 * 2
                            ; piece * 128: high = piece >> 1, low = (piece & 1) << 7
   582f   8d                GLO 13              ; piece_index
   5830   f6                SHR                 ; piece >> 1
   5831   bd                PHI 13              ; R13.1 = high byte of piece*128
   5832   8d                GLO 13
   5833   fe                SHL                 ; Restore, then check bit 0
   5834   f6                SHR                 ; Back to original
   5835   fa 01             ANI $01
   5837   c2 58 3f          LBZ HXPS_EVEN
   583a   f8 80             LDI $80
   583c   c0 58 41          LBR HXPS_ADD_SQ
   583f                 HXPS_EVEN:
   583f   f8 00             LDI 0
   5841                 HXPS_ADD_SQ:
                            ; D = low byte of piece*128 (0 or $80)
   5841   aa                PLO 10              ; R10.0 = temp low
   5842   89                GLO 9               ; sq64
   5843   fe                SHL                 ; sq64 * 2
   5844   52                STR 2
   5845   8a                GLO 10
   5846   f4                ADD                 ; low + sq*2
   5847   aa                PLO 10
   5848   9d                GHI 13              ; high of piece*128
   5849   7c 00             ADCI 0
   584b   ba                PHI 10              ; R10 = offset
                        
                            ; Add ZOBRIST_PIECE_SQ base
   584c   8a                GLO 10
   584d   fc 88             ADI LOW(ZOBRIST_PIECE_SQ)
   584f   aa                PLO 10
   5850   9a                GHI 10
   5851   7c 58             ADCI HIGH(ZOBRIST_PIECE_SQ)
   5853   ba                PHI 10              ; R10 = key address
                        
                            ; XOR key into hash
   5854   4a                LDA 10              ; key_hi
   5855   52                STR 2
   5856   97                GHI 7
   5857   f3                XOR
   5858   b7                PHI 7
   5859   0a                LDN 10              ; key_lo
   585a   52                STR 2
