   142b   8b                GLO 11
   142c   f4                ADD
   142d   ab                PLO 11
   142e   9b                GHI 11
   142f   7c 00             ADCI 0
   1431   bb                PHI 11              ; R11 = &KING_CENTER_TABLE[index]
   1432   0b                LDN 11              ; D = table value (-30 to +30)
   1433   fe                SHL                 ; D * 2
   1434   fe                SHL                 ; D * 4 (-120 to +120)
                            ; Sign-extend to 16 bits into R7
   1435   a7                PLO 7
