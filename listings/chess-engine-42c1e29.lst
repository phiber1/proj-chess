   0c49   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0c4d   09                LDN 9
   0c4e   58                STR 8               ; BOARD[cap_sq] = captured piece
                        
                            ; For EP: clear BOARD[to] (cap_sq != to)
