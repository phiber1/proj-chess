   0adb   a8                PLO 8               ; R8.0 = rook piece
   0adc   09                LDN 9               ; D = to square
   0add   fc 01             ADI 1                ; D = to + 1 (rook's old square)
   0adf   b8                PHI 8               ; R8.1 = old rook square
   0ae0   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
