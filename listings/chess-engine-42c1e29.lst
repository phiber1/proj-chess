   176f                 EG_EDGE_DONE:
                        
                            ; ==================================================================
                            ; Check bonus: if side-to-move is in check, credit the attacker.
                            ; Score is white-relative, so white-in-check → R9 -= CHECK_BONUS;
                            ; black-in-check → R9 += CHECK_BONUS.
                            ; IS_IN_CHECK preserves R11/R12; we save R9 ourselves.
                            ; ==================================================================
   176f   89                GLO 9
   1770   73                STXD
   1771   99                GHI 9
   1772   73                STXD
                        
   1773   d4 01 8e          CALL IS_IN_CHECK        ; uses R12 (side to move); D = 1 if in check
   1776   a8                PLO 8                   ; R8.0 = result
                        
   1777   60                IRX
   1778   72                LDXA
   1779   b9                PHI 9
   177a   f0                LDX
   177b   a9                PLO 9                   ; R9 restored
                        
   177c   88                GLO 8
   177d   c2 17 9b          LBZ CHECK_BONUS_DONE    ; not in check, skip
                        
   1780   8c                GLO 12                  ; side to move: WHITE=0, BLACK=8
   1781   c2 17 91          LBZ CHECK_BONUS_SUB     ; white to move and white in check → penalty
                        
                            ; Black to move and black in check → bonus to white
   1784   f8 28             LDI CHECK_BONUS
   1786   52                STR 2
   1787   89                GLO 9
   1788   f4                ADD
   1789   a9                PLO 9
   178a   99                GHI 9
   178b   7c 00             ADCI 0
