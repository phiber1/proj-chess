   221f   82                GLO 2
   2220   fc 0e             ADI 14              ; Calculate offset to alpha_hi
   2222   aa                PLO 10
   2223   92                GHI 2
   2224   7c 00             ADCI 0
   2226   ba                PHI 10              ; R10 = address of alpha_hi on stack
   2227   0a                LDN 10              ; D = alpha_hi
   2228   b7                PHI 7               ; R7.1 = alpha_hi
   2229   2a                DEC 10              ; Point to alpha_lo (R2+11)
   222a   0a                LDN 10              ; D = alpha_lo
   222b   a7                PLO 7               ; R7 = parent's alpha (big-endian)
                        
