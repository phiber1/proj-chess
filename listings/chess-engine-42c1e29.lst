                            ; R10.0 = moving piece from BOARD[MOVE_TO]
   0a91   68 c9 64 03       RLDI 9, MOVE_TO
   0a95   09                LDN 9               ; D = to square
   0a96   a8                PLO 8
   0a97   f8 60             LDI HIGH(BOARD)
   0a99   b8                PHI 8               ; R8 = &BOARD[to]
   0a9a   08                LDN 8               ; D = moving piece (king)
   0a9b   aa                PLO 10              ; R10.0 = moving piece
                            ; R10.1 = captured piece from UNDO_CAPTURED
   0a9c   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0aa0   09                LDN 9               ; D = captured piece
   0aa1   ba                PHI 10              ; R10.1 = captured piece
                        
