                        ; ==============================================================================
                        ; GEN_KING - UNROLLED VERSION with castling (no stack math, no loops)
                        ; ==============================================================================
                        ; R11.1 has from square on entry (set before dispatch, survives CALLs)
                        ; Uses ADI with immediate offsets - no ADD/stack operations
                        ; King offsets: N=$10, NE=$11, E=$01, SE=$F1, S=$F0, SW=$EF, W=$FF, NW=$0F
                        ; ==============================================================================
   08f4                 GEN_KING:
                            ; --- Direction 1: N (+$10) ---
   08f4   9b                GHI 11
   08f5   fc 10             ADI $10
   08f7   ab                PLO 11
   08f8   fa 88             ANI $88
   08fa   ca 09 0c          LBNZ GEN_KG_DIR2
   08fd   d4 03 65          CALL CHECK_TARGET_SQUARE
   0900   c2 09 0c          LBZ GEN_KG_DIR2
   0903   9b                GHI 11
   0904   bd                PHI 13
   0905   8b                GLO 11
   0906   ad                PLO 13
   0907   f8 00             LDI MOVE_NORMAL
   0909   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   090c                 GEN_KG_DIR2:
                            ; --- Direction 2: NE (+$11) ---
   090c   9b                GHI 11
   090d   fc 11             ADI $11
   090f   ab                PLO 11
   0910   fa 88             ANI $88
   0912   ca 09 24          LBNZ GEN_KG_DIR3
   0915   d4 03 65          CALL CHECK_TARGET_SQUARE
   0918   c2 09 24          LBZ GEN_KG_DIR3
   091b   9b                GHI 11
   091c   bd                PHI 13
   091d   8b                GLO 11
   091e   ad                PLO 13
   091f   f8 00             LDI MOVE_NORMAL
   0921   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   0924                 GEN_KG_DIR3:
                            ; --- Direction 3: E (+$01) ---
   0924   9b                GHI 11
   0925   fc 01             ADI $01
   0927   ab                PLO 11
   0928   fa 88             ANI $88
   092a   ca 09 3c          LBNZ GEN_KG_DIR4
   092d   d4 03 65          CALL CHECK_TARGET_SQUARE
   0930   c2 09 3c          LBZ GEN_KG_DIR4
   0933   9b                GHI 11
   0934   bd                PHI 13
   0935   8b                GLO 11
   0936   ad                PLO 13
   0937   f8 00             LDI MOVE_NORMAL
   0939   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   093c                 GEN_KG_DIR4:
                            ; --- Direction 4: SE (+$F1 = -$0F) ---
   093c   9b                GHI 11
   093d   fc f1             ADI $F1
   093f   ab                PLO 11
   0940   fa 88             ANI $88
   0942   ca 09 54          LBNZ GEN_KG_DIR5
   0945   d4 03 65          CALL CHECK_TARGET_SQUARE
   0948   c2 09 54          LBZ GEN_KG_DIR5
   094b   9b                GHI 11
   094c   bd                PHI 13
   094d   8b                GLO 11
   094e   ad                PLO 13
   094f   f8 00             LDI MOVE_NORMAL
   0951   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   0954                 GEN_KG_DIR5:
                            ; --- Direction 5: S (+$F0 = -$10) ---
   0954   9b                GHI 11
   0955   fc f0             ADI $F0
   0957   ab                PLO 11
   0958   fa 88             ANI $88
   095a   ca 09 6c          LBNZ GEN_KG_DIR6
   095d   d4 03 65          CALL CHECK_TARGET_SQUARE
   0960   c2 09 6c          LBZ GEN_KG_DIR6
   0963   9b                GHI 11
   0964   bd                PHI 13
   0965   8b                GLO 11
   0966   ad                PLO 13
   0967   f8 00             LDI MOVE_NORMAL
   0969   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   096c                 GEN_KG_DIR6:
                            ; --- Direction 6: SW (+$EF = -$11) ---
   096c   9b                GHI 11
