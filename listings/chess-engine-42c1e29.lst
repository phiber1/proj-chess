   2297   88                GLO 8               ; low byte
   2298   fd 00             SDI 0               ; negate low
   229a   a8                PLO 8
   229b   98                GHI 8               ; high byte
   229c   7d 00             SDBI 0              ; negate high with borrow
   229e   b8                PHI 8               ; R8 = -alpha
                        
