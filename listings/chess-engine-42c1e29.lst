   1798   7f 00             SMBI 0
   179a   b9                PHI 9
                        
   179b                 CHECK_BONUS_DONE:
                        
   179b                 BKS_DONE:
                            ; DIAG stamp (2026-07-17 hang hunt): EVALUATE about to return.
   179b   68 ca 64 1d       RLDI 10, TRACE_WHERE
   179f   f8 e6             LDI $E6
   17a1   5a                STR 10              ; tracer: EVALUATE returning
   17a2   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; EVALUATE_MATERIAL - Material-only evaluation (fast version)
                        ; ------------------------------------------------------------------------------
                        ; Simplified evaluation for leaf nodes where speed is critical
                        ; Input:  A = board pointer
                        ; Output: R9 = material score (NOT R6 - R6 is SCRT linkage, off limits!)
                        ; ------------------------------------------------------------------------------
   17a3                 EVALUATE_MATERIAL:
                            ; Alias to main evaluate for now
                            ; Later can optimize this path
   17a3   c0 0e a7          LBR EVALUATE
                        
                        ; ------------------------------------------------------------------------------
                        ; KING_SAFETY - shield + enemy-queen-storm danger for one king (2026-06-11)
                        ; In:  R7.0 = king sq (0x88); R7.1 = enemy queen sq ($FF if none)
                        ;      R8.0 = friendly pawn code; R8.1 = shield ahead-offset (+$10 / $F0)
                        ; Out: D = penalty magnitude (0-250). Preserves R9. Uses R10,R11,R13. X=2.
                        ; ------------------------------------------------------------------------------
   17a6                 KING_SAFETY:
   17a6   e2                SEX 2
                        
   17a7   68 ca 64 1d       RLDI 10, TRACE_WHERE
   17ab   f8 e2             LDI $E2
   17ad   5a                STR 10              ; tracer: in KING_SAFETY (v2)
                            ; No enemy queen -> no king-safety penalty at all. Prevents penalizing an
                            ; actively centralized (shieldless) king in queenless endgames.
   17ae   97                GHI 7
   17af   fb ff             XRI $FF
   17b1   c2 18 49          LBZ KS_ZERO
                            ; center shield square = king + ahead-offset
   17b4   87                GLO 7
   17b5   52                STR 2
   17b6   98                GHI 8
   17b7   f4                ADD
   17b8   ad                PLO 13              ; R13.0 = center
   17b9   ff 01             SMI 1               ; D = center - 1 (first shield square)
   17bb   aa                PLO 10              ; R10.0 = shield square
   17bc   f8 00             LDI 0
   17be   bd                PHI 13              ; R13.1 = shield pawn count = 0
   17bf   f8 03             LDI 3
   17c1   ab                PLO 11              ; loop counter
   17c2                 KS_SH_LOOP:
   17c2   8a                GLO 10
   17c3   fa 88             ANI $88
   17c5   ca 17 d6          LBNZ KS_SH_NEXT     ; off board
   17c8   f8 60             LDI HIGH(BOARD)
   17ca   ba                PHI 10              ; R10 -> board[sq]
   17cb   0a                LDN 10
   17cc   52                STR 2
   17cd   88                GLO 8               ; friendly pawn code
   17ce   f3                XOR
   17cf   ca 17 d6          LBNZ KS_SH_NEXT     ; not our pawn
   17d2   9d                GHI 13
   17d3   fc 01             ADI 1
   17d5   bd                PHI 13              ; count++
   17d6                 KS_SH_NEXT:
   17d6   1a                INC 10              ; next shield square (center-1 -> center -> center+1)
   17d7   2b                DEC 11
   17d8   8b                GLO 11
   17d9   ca 17 c2          LBNZ KS_SH_LOOP
                            ; missing = 3 - count
   17dc   9d                GHI 13
   17dd   52                STR 2
   17de   f8 03             LDI 3
   17e0   f7                SM                  ; D = 3 - count
   17e1   ad                PLO 13              ; R13.0 = missing (0-3)
   17e2   fc e6             ADI LOW(SHIELD_PEN)
   17e4   aa                PLO 10
   17e5   f8 0d             LDI HIGH(SHIELD_PEN)
   17e7   7c 00             ADCI 0
   17e9   ba                PHI 10
   17ea   0a                LDN 10              ; D = SHIELD_PEN[missing]
   17eb   bb                PHI 11              ; R11.1 = penalty
                            ; storm only if shield cracked AND enemy queen within Chebyshev 2
   17ec   8d                GLO 13              ; missing
   17ed   c2 18 47          LBZ KS_RET          ; fully shielded -> no penalty
   17f0   97                GHI 7               ; enemy queen sq
   17f1   fb ff             XRI $FF
   17f3   c2 18 47          LBZ KS_RET          ; no enemy queen
                            ; chebyshev(enemy queen R7.1, our king R7.0)
   17f6   97                GHI 7
   17f7   fa 70             ANI $70
   17f9   f6                SHR
   17fa   f6                SHR
   17fb   f6                SHR
   17fc   f6                SHR                 ; q_rank
   17fd   ad                PLO 13
   17fe   87                GLO 7
   17ff   fa 70             ANI $70
   1801   f6                SHR
   1802   f6                SHR
   1803   f6                SHR
   1804   f6                SHR                 ; k_rank
   1805   52                STR 2
   1806   8d                GLO 13
   1807   f5                SD                  ; k_rank - q_rank
   1808   c3 18 0d          LBDF KS_RANK_OK
   180b   fd 00             SDI 0
   180d                 KS_RANK_OK:
   180d   bd                PHI 13              ; |rank diff|
   180e   97                GHI 7
   180f   fa 07             ANI $07             ; q_file
   1811   ad                PLO 13
   1812   87                GLO 7
   1813   fa 07             ANI $07             ; k_file
   1815   52                STR 2
   1816   8d                GLO 13
   1817   f5                SD                  ; k_file - q_file
   1818   c3 18 1d          LBDF KS_FILE_OK
   181b   fd 00             SDI 0
   181d                 KS_FILE_OK:
   181d   ad                PLO 13              ; |file diff|
   181e   9d                GHI 13              ; |rank diff|
   181f   52                STR 2
   1820   8d                GLO 13              ; |file diff|
   1821   f5                SD                  ; |rank| - |file|
   1822   c3 18 29          LBDF KS_USE_RANK
   1825   8d                GLO 13              ; max = file
   1826   c0 18 2a          LBR KS_HAVE_DIST
   1829                 KS_USE_RANK:
   1829   9d                GHI 13              ; max = rank
   182a                 KS_HAVE_DIST:
   182a   52                STR 2               ; M2 = dist
   182b   f8 03             LDI 3
   182d   f7                SM                  ; D = 3 - dist
   182e   c2 18 47          LBZ KS_RET          ; dist == 3 -> no storm
   1831   ad                PLO 13              ; R13.0 = 3 - dist
   1832   fa 80             ANI $80
   1834   ca 18 47          LBNZ KS_RET         ; dist > 3 -> no storm
   1837   8d                GLO 13
   1838   fc ea             ADI LOW(STORM_PEN)
   183a   aa                PLO 10
   183b   f8 0d             LDI HIGH(STORM_PEN)
   183d   7c 00             ADCI 0
   183f   ba                PHI 10
   1840   0a                LDN 10              ; D = STORM_PEN[3-dist]
   1841   ab                PLO 11              ; R11.0 = storm penalty (R11.1 still = shield)
                            ; (v2 defense-credit path REMOVED 2026-07-13 for the staging reclaim:
                            ; DEFENSE_CREDIT was zeroed 2026-06-17, so this block computed and
                            ; subtracted a constant 0 every eval — ~70 B dead by configuration.
                            ; git-revert this commit to restore the queen-home credit machinery.)
   1842                 KS_STORM_FULL:
   1842   8b                GLO 11              ; net (or full) storm
   1843   52                STR 2
   1844   9b                GHI 11              ; shield penalty
   1845   f4                ADD                 ; total = shield + net storm
   1846   bb                PHI 11
   1847                 KS_RET:
   1847   9b                GHI 11              ; D = total penalty
   1848   d5                RETN
   1849                 KS_ZERO:
   1849   f8 00             LDI 0
   184b   d5                RETN
                        
                        ; ------------------------------------------------------------------------------
                        ; QUEEN_MOBILITY - count empty squares the queen commands (8-direction ray walk).
                        ; The RIGHT instrument for queen activity (2026-06-17): rewards an active/safe queen
                        ; (high mobility), penalizes an idle OR self-caged queen (low mobility), and never
                        ; pays for a sac (a queen moving where it's captured has the SEARCH reject it, not
                        ; this term). Pure mobility -- no per-square attack check (too costly mid-game); the
                        ; search handles tactics. Symmetric (white adds, black subtracts) so a queen trade is
                        ; ~mobility-neutral UNLESS our queen is the less active one, in which case the term
                        ; correctly nudges us to trade it off.
                        ; In:  R7.0 = queen square (0x88; caller guarantees != $FF). Out: D = mobility 0..27.
                        ; Uses R8,R10,R11,R13. Preserves R9,R12. X=2 (mirrors KING_SAFETY).
                        ; ------------------------------------------------------------------------------
   184c                 QUEEN_MOBILITY:
   184c   e2                SEX 2
                        
   184d   68 ca 64 1d       RLDI 10, TRACE_WHERE
   1851   f8 e3             LDI $E3
   1853   5a                STR 10              ; tracer: in QUEEN_MOBILITY
   1854   f8 00             LDI 0
   1856   a8                PLO 8                   ; R8.0 = mobility = 0
   1857   68 ca 18 81       RLDI 10, QUEEN_DIRS     ; R10 -> 8-direction delta table
   185b   f8 08             LDI 8
   185d   ad                PLO 13                  ; R13.0 = directions remaining
   185e                 QM_DIR:
   185e   4a                LDA 10                  ; D = delta, R10++
   185f   b8                PHI 8                   ; R8.1 = delta
   1860   f8 60             LDI HIGH(BOARD)
   1862   bb                PHI 11
   1863   87                GLO 7
   1864   ab                PLO 11                  ; R11 = &BOARD[queen sq]
   1865                 QM_STEP:
   1865   8b                GLO 11
   1866   52                STR 2                   ; M(2) = current ray square (low byte)
   1867   98                GHI 8                   ; D = delta
   1868   f4                ADD                     ; D = square + delta
   1869   ab                PLO 11                  ; R11.0 = next ray square
   186a   fa 88             ANI $88
   186c   ca 18 7a          LBNZ QM_NEXT            ; off board -> end this ray
   186f   0b                LDN 11                  ; D = BOARD[next square]
   1870   ca 18 7a          LBNZ QM_NEXT            ; occupied -> blocked, end this ray
   1873   88                GLO 8
   1874   fc 01             ADI 1
   1876   a8                PLO 8                   ; empty -> mobility++
   1877   c0 18 65          LBR QM_STEP
   187a                 QM_NEXT:
   187a   2d                DEC 13
   187b   8d                GLO 13
   187c   ca 18 5e          LBNZ QM_DIR
   187f   88                GLO 8                   ; D = mobility count
   1880   d5                RETN
   1881                 QUEEN_DIRS:
   1881   f0 10 01 ff       DB DIR_N, DIR_S, DIR_E, DIR_W, DIR_NE, DIR_NW, DIR_SE, DIR_SW
   1885   f1 ef 11 0f   
                        
                        ; ==============================================================================
                        ; End of Evaluation
                        ; (EVAL_WITH_PST/EVAL_PST_SCAN/EVAL_PST_NEXT stub family removed 2026-06-04 —
                        ;  zero call-sites; reclaimed for SEE. EVALUATE_MATERIAL kept, 1 live caller.)
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Piece-Square Tables
                        ; ==============================================================================
                        ; Positional bonuses based on piece placement
                        ; Values in centipawns (signed 8-bit: -128 to +127)
                        ;
                        ; Tables are from White's perspective (flip for Black)
                        ; Total size: 6 tables x 64 squares = 384 bytes
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; PAWN PST - Encourage central pawns and advancement
                        ; ------------------------------------------------------------------------------
                        ; Index 0-7 = Rank 1 (a1-h1), Index 56-63 = Rank 8 (a8-h8)
                        ; For White: index = rank*8 + file (rank 0 = Rank 1)
                        ; For Black: index XOR $38 flips rank (Black's Rank 8 maps to Rank 1 values)
                        ; ------------------------------------------------------------------------------
   1889                 PST_PAWN:
                            ; Rank 1 (index 0-7) - pawns never here
   1889   00 00 00 00       DB  0,  0,  0,  0,  0,  0,  0,  0
   188d   00 00 00 00   
                            ; Rank 2 (index 8-15) - starting position
   1891   05 0a 0a ec       DB  5, 10, 10,-20,-20, 10, 10,  5
   1895   ec 0a 0a 05   
                            ; Rank 3 (index 16-23)
   1899   05 fb f6 00       DB  5, -5,-10,  0,  0,-10, -5,  5
   189d   00 f6 fb 05   
                            ; Rank 4 (index 24-31) - center control
   18a1   00 00 00 14       DB  0,  0,  0, 20, 20,  0,  0,  0
   18a5   14 00 00 00   
                            ; Rank 5 (index 32-39)
   18a9   05 05 0a 19       DB  5,  5, 10, 25, 25, 10,  5,  5
   18ad   19 0a 05 05   
                            ; Rank 6 (index 40-47)
   18b1   0a 0a 14 1e       DB 10, 10, 20, 30, 30, 20, 10, 10
   18b5   1e 14 0a 0a   
                            ; Rank 7 (index 48-55) - about to promote!
   18b9   32 32 32 32       DB 50, 50, 50, 50, 50, 50, 50, 50
   18bd   32 32 32 32   
                            ; Rank 8 (index 56-63) - promotion rank
   18c1   00 00 00 00       DB  0,  0,  0,  0,  0,  0,  0,  0
   18c5   00 00 00 00   
                        
                        ; ------------------------------------------------------------------------------
                        ; KNIGHT PST - Knights love the center, hate the rim
                        ; ------------------------------------------------------------------------------
   18c9                 PST_KNIGHT:
                            ; Rank 1
   18c9   ce d8 e2 e2       DB -50,-40,-30,-30,-30,-30,-40,-50
   18cd   e2 e2 d8 ce   
                            ; Rank 2
   18d1   d8 ec 00 05       DB -40,-20,  0,  5,  5,  0,-20,-40
   18d5   05 00 ec d8   
                            ; Rank 3
   18d9   e2 05 0a 0f       DB -30,  5, 10, 15, 15, 10,  5,-30
   18dd   0f 0a 05 e2   
                            ; Rank 4
   18e1   e2 00 0f 14       DB -30,  0, 15, 20, 20, 15,  0,-30
   18e5   14 0f 00 e2   
                            ; Rank 5
   18e9   e2 05 0f 14       DB -30,  5, 15, 20, 20, 15,  5,-30
   18ed   14 0f 05 e2   
                            ; Rank 6
   18f1   e2 00 0a 0f       DB -30,  0, 10, 15, 15, 10,  0,-30
   18f5   0f 0a 00 e2   
                            ; Rank 7
   18f9   d8 ec 00 00       DB -40,-20,  0,  0,  0,  0,-20,-40
   18fd   00 00 ec d8   
                            ; Rank 8
   1901   ce d8 e2 e2       DB -50,-40,-30,-30,-30,-30,-40,-50
   1905   e2 e2 d8 ce   
                        
                        ; ------------------------------------------------------------------------------
                        ; BISHOP PST - Avoid corners, prefer long diagonals
                        ; ------------------------------------------------------------------------------
   1909                 PST_BISHOP:
                            ; Rank 1 - penalize undeveloped bishops on c1/f1
   1909   ec f6 f1 f6       DB -20,-10,-15,-10,-10,-15,-10,-20
   190d   f6 f1 f6 ec   
                            ; Rank 2
   1911   f6 05 00 00       DB -10,  5,  0,  0,  0,  0,  5,-10
   1915   00 00 05 f6   
                            ; Rank 3
   1919   f6 0a 0a 0a       DB -10, 10, 10, 10, 10, 10, 10,-10
   191d   0a 0a 0a f6   
                            ; Rank 4
   1921   f6 00 0a 0a       DB -10,  0, 10, 10, 10, 10,  0,-10
   1925   0a 0a 00 f6   
                            ; Rank 5
   1929   f6 05 05 0a       DB -10,  5,  5, 10, 10,  5,  5,-10
   192d   0a 05 05 f6   
                            ; Rank 6
   1931   f6 00 05 0a       DB -10,  0,  5, 10, 10,  5,  0,-10
   1935   0a 05 00 f6   
                            ; Rank 7
   1939   f6 00 00 00       DB -10,  0,  0,  0,  0,  0,  0,-10
   193d   00 00 00 f6   
                            ; Rank 8
   1941   ec f6 f6 f6       DB -20,-10,-10,-10,-10,-10,-10,-20
   1945   f6 f6 f6 ec   
                        
                        ; ------------------------------------------------------------------------------
                        ; ROOK PST - 7th rank is golden, open files later
                        ; ------------------------------------------------------------------------------
   1949                 PST_ROOK:
                            ; Rank 1 - penalize undeveloped corner rooks, prefer central
   1949   f1 00 00 05       DB -15,  0,  0,  5,  5,  0,  0,-15
   194d   05 00 00 f1   
                            ; Rank 2
   1951   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   1955   00 00 00 fb   
                            ; Rank 3
   1959   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   195d   00 00 00 fb   
                            ; Rank 4
   1961   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   1965   00 00 00 fb   
                            ; Rank 5
   1969   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   196d   00 00 00 fb   
                            ; Rank 6
   1971   fb 00 00 00       DB -5,  0,  0,  0,  0,  0,  0, -5
   1975   00 00 00 fb   
                            ; Rank 7 - "pig" on 7th rank
   1979   05 0a 0a 0a       DB  5, 10, 10, 10, 10, 10, 10,  5
   197d   0a 0a 0a 05   
                            ; Rank 8
   1981   00 00 00 00       DB  0,  0,  0,  0,  0,  0,  0,  0
   1985   00 00 00 00   
                        
                        ; ------------------------------------------------------------------------------
                        ; QUEEN PST - Slight preference for center, avoid early development
                        ; ------------------------------------------------------------------------------
   1989                 PST_QUEEN:
                            ; Rank 1 - starting position OK
   1989   ec f6 f6 fb       DB -20,-10,-10, -5, -5,-10,-10,-20
   198d   fb f6 f6 ec   
                            ; Rank 2
   1991   f6 00 05 00       DB -10,  0,  5,  0,  0,  0,  0,-10
   1995   00 00 00 f6   
                            ; Rank 3
   1999   f6 05 05 05       DB -10,  5,  5,  5,  5,  5,  0,-10
   199d   05 05 00 f6   
                            ; Rank 4
   19a1   00 00 05 05       DB   0,  0,  5,  5,  5,  5,  0, -5
   19a5   05 05 00 fb   
                            ; Rank 5
   19a9   fb 00 05 05       DB  -5,  0,  5,  5,  5,  5,  0, -5
   19ad   05 05 00 fb   
                            ; Rank 6
   19b1   f6 00 05 05       DB -10,  0,  5,  5,  5,  5,  0,-10
   19b5   05 05 00 f6   
                            ; Rank 7 - penalize edge squares in enemy territory
   19b9   ec f6 00 00       DB -20,-10,  0,  0,  0,  0,-10,-20
   19bd   00 00 f6 ec   
                            ; Rank 8 - heavy penalty for deep queen raids
   19c1   e2 ec ec f6       DB -30,-20,-20,-10,-10,-20,-20,-30
   19c5   f6 ec ec e2   
                        
                        ; ------------------------------------------------------------------------------
                        ; KING PST (Middlegame) - Castle! Stay safe on the side
                        ; ------------------------------------------------------------------------------
   19c9                 PST_KING:
                            ; Rank 1 - castled king is safest (b1/g1 kingside, c1 queenside)
   19c9   14 3c 28 ec       DB  20, 60, 40,-20,-20, 10, 60, 20
   19cd   ec 0a 3c 14   
                            ; Rank 2 - behind pawn shelter OK
   19d1   14 14 f6 e2       DB  20, 20,-10,-30,-30,-10, 20, 20
   19d5   e2 f6 14 14   
                            ; Rank 3
   19d9   f6 ec ec ec       DB -10,-20,-20,-20,-20,-20,-20,-10
   19dd   ec ec ec f6   
                            ; Rank 4
   19e1   ec e2 e2 d8       DB -20,-30,-30,-40,-40,-30,-30,-20
   19e5   d8 e2 e2 ec   
                            ; Rank 5
   19e9   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   19ed   ce d8 d8 e2   
                            ; Rank 6
   19f1   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   19f5   ce d8 d8 e2   
                            ; Rank 7
   19f9   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   19fd   ce d8 d8 e2   
                            ; Rank 8
   1a01   e2 d8 d8 ce       DB -30,-40,-40,-50,-50,-40,-40,-30
   1a05   ce d8 d8 e2   
                        
                        ; ==============================================================================
                        ; PST Table Address Lookup
                        ; ==============================================================================
                        ; Index by piece type (1-6) to get table address
   1a09                 PST_TABLE_LO:
   1a09   00                DB 0                    ; 0 = empty (unused)
   1a0a   89                DB LOW(PST_PAWN)        ; 1 = pawn
   1a0b   c9                DB LOW(PST_KNIGHT)      ; 2 = knight
   1a0c   09                DB LOW(PST_BISHOP)      ; 3 = bishop
   1a0d   49                DB LOW(PST_ROOK)        ; 4 = rook
   1a0e   89                DB LOW(PST_QUEEN)       ; 5 = queen
   1a0f   c9                DB LOW(PST_KING)        ; 6 = king
                        
   1a10                 PST_TABLE_HI:
   1a10   00                DB 0
   1a11   18                DB HIGH(PST_PAWN)
   1a12   18                DB HIGH(PST_KNIGHT)
   1a13   19                DB HIGH(PST_BISHOP)
   1a14   19                DB HIGH(PST_ROOK)
   1a15   19                DB HIGH(PST_QUEEN)
   1a16   19                DB HIGH(PST_KING)
                        
                        ; ==============================================================================
                        ; EVAL_PST - Add piece-square table bonuses to score
                        ; ==============================================================================
                        ; Input:  6 = current score (material)
                        ; Output: 6 = score + PST bonuses
                        ; Uses:   A, D, E, F
                        ;
                        ; Algorithm:
                        ;   For each piece on board:
                        ;     1. Get piece type and color
                        ;     2. Convert 0x88 square to 0-63 index
                        ;     3. For black pieces, flip the rank (mirror vertically)
                        ;     4. Look up PST value
                        ;     5. Add (white) or subtract (black) from score
                        ; ==============================================================================
   1a17                 EVAL_PST:
                            ; Ensure X=2 for all stack operations
   1a17   e2                SEX 2
                        
                            ; Save score (R9 is score accumulator, NOT R6 which is SCRT linkage!)
   1a18   89                GLO 9
   1a19   73                STXD
   1a1a   99                GHI 9
   1a1b   73                STXD
                        
                            ; Save R15 (used by caller for move count in quiescence search)
   1a1c   8f                GLO 15
   1a1d   73                STXD
   1a1e   9f                GHI 15
   1a1f   73                STXD
                        
                            ; Initialize PST accumulator
   1a20   f8 00             LDI 0
   1a22   b7                PHI 7
   1a23   a7                PLO 7               ; 7 = 0
                        
                            ; Point to board
   1a24   68 ca 60 00       RLDI 10, BOARD
                        
                            ; Loop counter in memory (R14 is off-limits - BIOS uses it!)
   1a28   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1a2c   f8 00             LDI 0
   1a2e   58                STR 8               ; EVAL_TEMP1 = 0 (square index)
                        
   1a2f                 EVAL_PST_LOOP:
                            ; Check if valid square (load from memory)
   1a2f   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1a33   08                LDN 8               ; D = square index
   1a34   fa 88             ANI $88
   1a36   ca 1a ad          LBNZ EVAL_PST_NEXT_SQ
                        
                            ; Load piece
   1a39   0a                LDN 10
   1a3a   c2 1a ad          LBZ EVAL_PST_NEXT_SQ ; Empty square
                        
                            ; Save piece
   1a3d   af                PLO 15               ; F.0 = piece
                        
                            ; Get piece type
   1a3e   fa 07             ANI PIECE_MASK
   1a40   ad                PLO 13               ; D.0 = piece type (1-6)
                        
                            ; Get PST table address for this piece type
   1a41   68 cb 1a 09       RLDI 11, PST_TABLE_LO
   1a45   8d                GLO 13               ; Piece type
   1a46   52                STR 2
   1a47   8b                GLO 11
   1a48   f4                ADD
   1a49   ab                PLO 11
   1a4a   9b                GHI 11
   1a4b   7c 00             ADCI 0
   1a4d   bb                PHI 11               ; Propagate carry across page boundary
   1a4e   0b                LDN 11               ; D = low byte of PST address
   1a4f   bd                PHI 13               ; Save in D.1 temporarily
                        
   1a50   68 cb 1a 10       RLDI 11, PST_TABLE_HI
   1a54   8d                GLO 13               ; Piece type (still in D.0? No, need to reload)
   1a55   8f                GLO 15               ; Get piece back
   1a56   fa 07             ANI PIECE_MASK
   1a58   52                STR 2
   1a59   8b                GLO 11
   1a5a   f4                ADD
   1a5b   ab                PLO 11
   1a5c   0b                LDN 11               ; High byte of PST address
   1a5d   bb                PHI 11
   1a5e   9d                GHI 13               ; Low byte (saved earlier)
   1a5f   ab                PLO 11               ; B = PST table base for this piece
                        
                            ; Convert 0x88 square to 0-63 index
                            ; Index = (rank * 8) + file
                            ; For 0x88: rank = sq >> 4, file = sq & 7
                            ; Load square from memory (R14 is off-limits!)
   1a60   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1a64   08                LDN 8               ; D = square (0x88 format)
   1a65   73                STXD                ; Save square on stack for reuse
   1a66   fa 07             ANI $07             ; File (0-7)
   1a68   ad                PLO 13               ; D.0 = file
                        
   1a69   60                IRX
   1a6a   f0                LDX                 ; D = square again
   1a6b   fa 70             ANI $70             ; Rank * 16
   1a6d   f6                SHR                 ; Rank * 8
   1a6e   52                STR 2
   1a6f   8d                GLO 13
   1a70   f4                ADD                 ; Index = rank*8 + file
   1a71   ad                PLO 13               ; D.0 = 0-63 index
                        
                            ; For black pieces, flip the index (mirror board)
                            ; New index = 63 - index = (7-rank)*8 + (7-file)
                            ; Simpler: XOR with $38 flips rank (keeps file same within rank)
   1a72   8f                GLO 15               ; Get piece
   1a73   fa 08             ANI COLOR_MASK
   1a75   c2 1a 7c          LBZ EVAL_PST_WHITE   ; long branch: insertion shifted page boundary
                        
                            ; Black piece - flip rank
   1a78   8d                GLO 13
   1a79   fb 38             XRI $38             ; Flip rank bits
   1a7b   ad                PLO 13
                        
   1a7c                 EVAL_PST_WHITE:
                            ; Look up PST value
   1a7c   8d                GLO 13               ; Index
   1a7d   52                STR 2
   1a7e   8b                GLO 11
   1a7f   f4                ADD
   1a80   ab                PLO 11
   1a81   9b                GHI 11
   1a82   7c 00             ADCI 0
   1a84   bb                PHI 11
   1a85   0b                LDN 11               ; D = PST value (signed 8-bit)
                        
                            ; Extend sign to 16-bit
   1a86   ad                PLO 13               ; D.0 = PST value
   1a87   fa 80             ANI $80             ; Check sign bit
   1a89   c2 1a 92          LBZ EVAL_PST_POSITIVE
   1a8c   f8 ff             LDI $FF
   1a8e   bd                PHI 13               ; D = sign-extended negative
   1a8f   c0 1a 95          LBR EVAL_PST_ADD
                        
   1a92                 EVAL_PST_POSITIVE:
   1a92   f8 00             LDI 0
   1a94   bd                PHI 13               ; D = sign-extended positive
                        
   1a95                 EVAL_PST_ADD:
                            ; Add or subtract based on color
   1a95   8f                GLO 15               ; Get piece
   1a96   fa 08             ANI COLOR_MASK
   1a98   c2 1a a3          LBZ EVAL_PST_ADD_WHITE
                        
                            ; Black - subtract from accumulator (7 = 7 - D)
                            ; Actually: negate D, then add
   1a9b   8d                GLO 13
   1a9c   fd 00             SDI 0               ; D.0 = -D.0
   1a9e   ad                PLO 13
   1a9f   9d                GHI 13
   1aa0   7d 00             SDBI 0              ; D.1 = -D.1 - borrow
   1aa2   bd                PHI 13
                        
   1aa3                 EVAL_PST_ADD_WHITE:
                            ; Add D to accumulator (7)
   1aa3   8d                GLO 13
   1aa4   52                STR 2
   1aa5   87                GLO 7
   1aa6   f4                ADD
   1aa7   a7                PLO 7
                        
   1aa8   9d                GHI 13
   1aa9   52                STR 2
   1aaa   97                GHI 7
   1aab   74                ADC
   1aac   b7                PHI 7
                        
   1aad                 EVAL_PST_NEXT_SQ:
   1aad   1a                INC 10               ; Next board position
                            ; Increment square index in memory (R14 is off-limits!)
   1aae   68 c8 64 40       RLDI 8, EVAL_TEMP1
   1ab2   08                LDN 8               ; D = square index
   1ab3   fc 01             ADI 1               ; Increment
   1ab5   58                STR 8               ; Store back
   1ab6   fb 80             XRI $80             ; Done when index = 128
   1ab8   ca 1a 2f          LBNZ EVAL_PST_LOOP
                        
                            ; Add PST accumulator to score
                            ; Restore R15 first (LIFO - it was pushed last)
   1abb   60                IRX
   1abc   72                LDXA
   1abd   bf                PHI 15
   1abe   f0                LDX
   1abf   af                PLO 15
                        
                            ; Now restore material score (R9)
   1ac0   60                IRX
   1ac1   72                LDXA
   1ac2   b9                PHI 9
   1ac3   f0                LDX
   1ac4   a9                PLO 9
                        
                            ; R9 = R9 + R7
   1ac5   87                GLO 7
   1ac6   52                STR 2
   1ac7   89                GLO 9
   1ac8   f4                ADD
   1ac9   a9                PLO 9
                        
   1aca   97                GHI 7
   1acb   52                STR 2
   1acc   99                GHI 9
   1acd   74                ADC
   1ace   b9                PHI 9
                        
   1acf   d5                RETN
                        
                        ; ==============================================================================
                        ; End of Piece-Square Tables
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Endgame Heuristics
                        ; ==============================================================================
                        ; Special evaluation bonuses for endgame positions:
                        ; 1. King centralization when material is low
                        ; 2. Drive enemy king to edge/corner in winning positions
                        ; 3. Passed pawn bonus
                        ; ==============================================================================
                        
                        ; Endgame threshold (in centipawns of total material)
                        ; Below this, we're in the endgame
                        ; Roughly: 2 rooks + 2 minor = 2*500 + 2*325 = 1650
   0068                 ENDGAME_THRESHOLD_LO    EQU $68     ; 1640 = $0668
   0006                 ENDGAME_THRESHOLD_HI    EQU $06
                        
                        ; King centralization table (bonus for king being in center during endgame)
                        ; Higher values in center, lower on edges
   1ad0                 KING_CENTER_TABLE:
                            ; Rank 8
   1ad0   e2 ec f6 00       DB -30,-20,-10,  0,  0,-10,-20,-30
   1ad4   00 f6 ec e2   
                            ; Rank 7
   1ad8   ec f6 00 0a       DB -20,-10,  0, 10, 10,  0,-10,-20
   1adc   0a 00 f6 ec   
                            ; Rank 6
   1ae0   f6 00 0a 14       DB -10,  0, 10, 20, 20, 10,  0,-10
   1ae4   14 0a 00 f6   
                            ; Rank 5
   1ae8   00 0a 14 1e       DB   0, 10, 20, 30, 30, 20, 10,  0
   1aec   1e 14 0a 00   
                            ; Rank 4
   1af0   00 0a 14 1e       DB   0, 10, 20, 30, 30, 20, 10,  0
   1af4   1e 14 0a 00   
                            ; Rank 3
   1af8   f6 00 0a 14       DB -10,  0, 10, 20, 20, 10,  0,-10
   1afc   14 0a 00 f6   
                            ; Rank 2
   1b00   ec f6 00 0a       DB -20,-10,  0, 10, 10,  0,-10,-20
   1b04   0a 00 f6 ec   
                            ; Rank 1
   1b08   e2 ec f6 00       DB -30,-20,-10,  0,  0,-10,-20,-30
   1b0c   00 f6 ec e2   
                        
                        ; King to edge table (bonus for enemy king on edge/corner — drive-to-mate)
                        ; Use this when we're winning to drive enemy king to corner.
                        ; Higher values at edges/corners, lower in center.
                        ; Retuned 2026-06-15: steepened ~1.5x toward corners (proven mate-shuffle:
                        ; R+Q+5P vs lone K dawdled ~22 moves, eval flat — the edge gradient was too
                        ; shallow to actively squeeze the enemy king to a corner). Max 90, SHL'd to
                        ; 180cp at the corner (still <256, no byte overflow). Zero new bytes.
   1b10                 KING_EDGE_TABLE:
                            ; Rank 8
   1b10   5a 4b 3c 2d       DB  90, 75, 60, 45, 45, 60, 75, 90
   1b14   2d 3c 4b 5a   
                            ; Rank 7
   1b18   4b 3c 2d 1e       DB  75, 60, 45, 30, 30, 45, 60, 75
   1b1c   1e 2d 3c 4b   
                            ; Rank 6
   1b20   3c 2d 1e 0f       DB  60, 45, 30, 15, 15, 30, 45, 60
   1b24   0f 1e 2d 3c   
                            ; Rank 5
   1b28   2d 1e 0f 00       DB  45, 30, 15,  0,  0, 15, 30, 45
   1b2c   00 0f 1e 2d   
                            ; Rank 4
   1b30   2d 1e 0f 00       DB  45, 30, 15,  0,  0, 15, 30, 45
   1b34   00 0f 1e 2d   
                            ; Rank 3
   1b38   3c 2d 1e 0f       DB  60, 45, 30, 15, 15, 30, 45, 60
   1b3c   0f 1e 2d 3c   
                            ; Rank 2
   1b40   4b 3c 2d 1e       DB  75, 60, 45, 30, 30, 45, 60, 75
   1b44   1e 2d 3c 4b   
                            ; Rank 1
   1b48   5a 4b 3c 2d       DB  90, 75, 60, 45, 45, 60, 75, 90
   1b4c   2d 3c 4b 5a   
                        
                        ; ------------------------------------------------------------------------------
                        ; KING_PROX_BONUS - friendly-king-to-enemy-king proximity, indexed by Chebyshev
                        ; distance (0-7). The missing mating ingredient: edging the enemy king alone
                        ; never mates — the winning side's king must march up to support. Small-distance
                        ; = high bonus gives the shallow search a downhill gradient to walk the king in.
                        ; Kings can never be adjacent (dist<2 illegal), so 2 = closest = max pull.
                        ; ------------------------------------------------------------------------------
                        ; Retuned 2026-06-15: ~4x stronger (was 0,0,40,32,24,16,8,0 = 8cp/step).
                        ; PROVEN bottleneck: in the R+Q+5P vs K mate the winning king refused to march
                        ; (g1<->h1<->f1 shuffle for ~11 moves) because closing toward the enemy king
                        ; netted only +8cp — tied with shuffling, so the engine wouldn't commit. The
                        ; mate appeared the instant the king finally reached the enemy. Now ~30-35cp/
                        ; step so each marching step clearly beats a wait move. Max 150 < passer/runner
                        ; bonuses (250-600) so this never pulls the king off a passer in a K+P race.
   1b50                 KING_PROX_BONUS:
   1b50   00 00 96 73       DB   0,  0,150,115, 80, 50, 25,  0   ; dist 0..7 (~30-35cp/step march)
   1b54   50 32 19 00   
                        
                        ; ==============================================================================
                        ; EVAL_ENDGAME - Add endgame-specific bonuses
                        ; ==============================================================================
                        ; Input:  6 = current score (material + PST)
                        ;         7 = total material on board (calculated externally, or we calculate)
                        ; Output: 6 = score with endgame bonuses
                        ; Uses:   A, B, D, E, F
                        ;
                        ; Logic:
                        ;   1. Check if we're in endgame (material below threshold)
                        ;   2. If endgame:
                        ;      - Add king centralization bonus for friendly king
                        ;      - If winning significantly, add enemy king edge bonus
                        ; ==============================================================================
                        ; (EVAL_ENDGAME + CALC_TOTAL_MATERIAL REMOVED 2026-07-15 — symmetry audit)
                        ; Both had ZERO call sites (the 'removed king-drive'); the live endgame king
                        ; logic is in evaluate.asm's pc<12 block. The dead code ALSO contained
                        ; side-to-move-relative sign bugs (mover's centralization credited to white;
                        ; winning gate read raw R9) — deleted rather than fixed. git-revert restores.
                        ; KING_CENTER_TABLE / KING_EDGE_TABLE below remain LIVE (evaluate.asm uses them).
                        ; ==============================================================================
                        
                        
                        ; ==============================================================================
                        ; End of Endgame Heuristics
                        ; ==============================================================================
                        ; ==============================================================================
                        ; RCA 1802/1806 Chess Engine - Negamax Search with Alpha-Beta Pruning
                        ; ==============================================================================
                        ; Core search algorithm
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; Register Usage During Search
                        ; ------------------------------------------------------------------------------
                        ; 0:  Reserved for interrupts/DMA
                        ; 1:  Reserved for interrupt PC
                        ; 2:  Stack pointer (X register) - CRITICAL
                        ; 3:  Program counter (P register) - CRITICAL
                        ; 4:  SCALL routine pointer (BIOS SCRT)
                        ; 5:  SRET routine pointer (BIOS SCRT) - DO NOT USE FOR DATA!
                        ; 6:  SCRT linkage register - DO NOT USE FOR DATA! (corrupted by every CALL)
                        ; 7:  Temp for alpha/beta operations (beta loaded from memory when needed)
                        ; 8:  Best score accumulator
                        ; 9:  Move list pointer / score return value
                        ; A:  Board state pointer (set before search)
                        ; B:  Current move being evaluated
                        ; C:  Color/side to move (0 for white, 8 for black - matches COLOR_MASK)
                        ; D:  Temp/scratch register 1
                        ; E:  Temp/scratch register 2 (move counter)
                        ; F:  Temp/scratch register 3
                        ; NOTE: Alpha/beta stored in memory at ALPHA_HI/LO, BETA_HI/LO (big-endian)
                        ; NOTE: Search depth stored in memory at SEARCH_DEPTH (not in a register)
                        ; ------------------------------------------------------------------------------
                        
                        ; Memory locations for search state - defined in board.asm:
                        ;   BEST_MOVE, NODES_SEARCHED, SEARCH_DEPTH, QS_*, EVAL_SQ_INDEX, KILLER_MOVES
                        ;   ALPHA_HI/LO, BETA_HI/LO, SCORE_HI/LO (big-endian: high byte at lower address)
                        ; All engine variables consolidated at $6400+ region
                        
                        ; ------------------------------------------------------------------------------
                        ; NEGAMAX - Main recursive search function
                        ; ------------------------------------------------------------------------------
                        ; Input:  SEARCH_DEPTH = depth remaining in memory (0 = leaf node, evaluate)
                        ;         ALPHA_HI/LO = alpha (lower bound) in memory (big-endian)
                        ;         BETA_HI/LO = beta (upper bound) in memory (big-endian)
                        ;         C = color (0 for white, 8 for black - matches COLOR_MASK)
                        ;         A = board state pointer
                        ; Output: R9 = score from current position
                        ;         BEST_MOVE = best move found (if at root)
                        ; Uses:   All registers 7-F, stack
                        ; NOTE:   R6 is SCRT linkage register - never used for data!
                        ; ------------------------------------------------------------------------------
   1b58                 NEGAMAX:
                            ; Ensure X=2 for stack operations
   1b58   e2                SEX 2
                        
                            ; DIAG stamp (2026-07-17 hang hunt): covers prologue window
                            ; (stack-check/ply-assert/SAVE_PLY_STATE) before the $A1 node stamp.
   1b59   68 ca 64 1d       RLDI 10, TRACE_WHERE
   1b5d   f8 a0             LDI $A0
   1b5f   5a                STR 10              ; tracer: NEGAMAX prologue (R10 reloaded below)
                        
                            ; Stack overflow detection (added 2026-05-12). MOVE_LIST at $7800-$7A7F
                            ; sits directly below stack guard $7B00. If recursion pushes R2 below
                            ; $7B00, MOVE_LIST gets silently corrupted — the suspected cause of the
                            ; 2026-05-11 g8h7 illegal-move output. Flag is checked + emitted as
                            ; UCI info string at each IDS iteration boundary.
   1b60   d4 00 87          CALL CHECK_STACK_OVERFLOW
                        
                            ; -----------------------------------------------
                            ; PLY LIMIT CHECK: Prevent array overflow
                            ; -----------------------------------------------
                            ; If CURRENT_PLY >= MAX_PLY (8), return static eval
   1b63   68 ca 64 48       RLDI 10, CURRENT_PLY
   1b67   0a                LDN 10              ; D = current ply
   1b68   ff 08             SMI 8               ; D = ply - MAX_PLY
   1b6a   cb 1b 7f          LBNF NEGAMAX_PLY_OK ; ply < 8, continue
                        
                            ; Ply limit reached - return static evaluation
   1b6d   d4 0e a7          CALL EVALUATE
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   1b70   8c                GLO 12
   1b71   fa 08             ANI $08
   1b73   c2 1b 7e          LBZ NEGAMAX_PLY_RET
   1b76   89                GLO 9               ; low byte
   1b77   fd 00             SDI 0               ; negate low
   1b79   a9                PLO 9
   1b7a   99                GHI 9               ; high byte
   1b7b   7d 00             SDBI 0              ; negate high with borrow
   1b7d   b9                PHI 9
   1b7e                 NEGAMAX_PLY_RET:
   1b7e   d5                RETN
                        
   1b7f                 NEGAMAX_PLY_OK:
                            ; Save context to ply-indexed state array (no stack manipulation!)
   1b7f   d4 00 18          CALL SAVE_PLY_STATE
                        
   1b82   68 ca 64 1d       RLDI 10, TRACE_WHERE
   1b86   f8 a1             LDI $A1
   1b88   5a                STR 10              ; tracer: in NEGAMAX node
                        
                            ; -- TT node flag: default ALPHA (upper bound) --
   1b89   68 ca 64 48       RLDI 10, CURRENT_PLY
   1b8d   0a                LDN 10
   1b8e   fc d2             ADI LOW(NODE_TT_FLAGS)
   1b90   aa                PLO 10
   1b91   f8 64             LDI HIGH(NODE_TT_FLAGS)
   1b93   ba                PHI 10
   1b94   f8 02             LDI TT_FLAG_ALPHA
   1b96   5a                STR 10
                        
                            ; Increment node counter (for statistics)
   1b97   d4 2a 21          CALL INC_NODE_COUNT
                        
                            ; -----------------------------------------------
                            ; RTC TIME TRACKING: Always update elapsed time
                            ; -----------------------------------------------
                            ; Read RTC on every node so elapsed time is accurate.
                            ; Only check abort flag and enforce budget during d3+.
                        
                            ; --- RTC elapsed time check ---
                            ; Read current seconds from DS12887 (binary mode)
   1b9a   f8 80             LDI $80                     ; Seconds register
   1b9c   52                STR 2
   1b9d   62                OUT 2                       ; Select register, R2++
   1b9e   22                DEC 2                       ; Restore R2
   1b9f   6b                INP 3                       ; D = current_secs, M(R2) = current_secs
   1ba0   a7                PLO 7                       ; R7.0 = current_secs (R7 saved by SAVE_PLY_STATE)
                        
                            ; Load prev_secs, save for delta computation
   1ba1   68 cd 64 ca       RLDI 13, SEARCH_PREV_SECS
   1ba5   0d                LDN 13                      ; D = prev_secs
   1ba6   b7                PHI 7                       ; R7.1 = prev_secs
                        
                            ; Update prev = current
   1ba7   87                GLO 7                       ; D = current_secs
   1ba8   5d                STR 13                      ; SEARCH_PREV_SECS = current_secs
                        
                            ; Compute delta = current - prev
   1ba9   97                GHI 7                       ; D = prev_secs
   1baa   52                STR 2                       ; M(R2) = prev_secs
   1bab   87                GLO 7                       ; D = current_secs
   1bac   f7                SM                          ; D = current - prev (SM = D - M(R(X)))
   1bad   c3 1b b2          LBDF RTC_DELTA_POS          ; DF=1: no borrow, delta >= 0
   1bb0   fc 3c             ADI 60                      ; Wrapped past 59→0: add 60
   1bb2                 RTC_DELTA_POS:
                            ; D = delta seconds (typically 0 or 1)
                        
                            ; Add delta to elapsed counter
   1bb2   52                STR 2                       ; M(R2) = delta
   1bb3   68 cd 64 cb       RLDI 13, SEARCH_ELAPSED
   1bb7   0d                LDN 13                      ; D = elapsed so far
   1bb8   f4                ADD                         ; D = elapsed + delta
   1bb9   cb 1b be          LBNF RTC_NO_SAT             ; DF=0: no carry, fits in 8 bits
   1bbc   f8 ff             LDI 255                     ; Saturate at 255
   1bbe                 RTC_NO_SAT:
   1bbe   5d                STR 13                      ; SEARCH_ELAPSED = updated value
                        
                            ; -----------------------------------------------
                            ; ABORT CHECK: Only enforce budget during d3+
                            ; -----------------------------------------------
                            ; Depth 1-2 always complete; only abort d3+ if over budget
   1bbf   68 cd 64 c5       RLDI 13, CURRENT_MAX_DEPTH
   1bc3   0d                LDN 13                      ; D = current iteration depth
   1bc4   ff 03             SMI 3
   1bc6   cb 1b ea          LBNF NEGAMAX_BUDGET_OK      ; depth < 3, skip abort check
                        
                            ; --- Abort flag check (propagate up recursion during d3) ---
   1bc9   68 cd 64 c4       RLDI 13, SEARCH_ABORTED
   1bcd   0d                LDN 13
   1bce   ca 1b e2          LBNZ NEGAMAX_ABORT_RETURN   ; Already aborted, bail out
                        
                            ; Check: elapsed >= 180 seconds?
   1bd1   68 cd 64 cb       RLDI 13, SEARCH_ELAPSED
   1bd5   0d                LDN 13                      ; Reload elapsed (clobbered above)
   1bd6   ff b4             SMI 180                     ; D = elapsed - 180 (budget bumped 2026-04-23)
   1bd8   cb 1b ea          LBNF NEGAMAX_BUDGET_OK      ; DF=0: elapsed < 180, continue
                        
                            ; Time exceeded — set abort flag
   1bdb   68 cd 64 c4       RLDI 13, SEARCH_ABORTED
   1bdf   f8 01             LDI 1
   1be1   5d                STR 13
                        
   1be2                 NEGAMAX_ABORT_RETURN:
                            ; Restore ply state and return dummy score
   1be2   d4 00 54          CALL RESTORE_PLY_STATE
   1be5   f8 00             LDI 0
   1be7   b9                PHI 9
   1be8   a9                PLO 9                       ; R9 = 0 (score irrelevant, will be discarded)
   1be9   d5                RETN
                        
   1bea                 NEGAMAX_BUDGET_OK:
                        
                            ; -----------------------------------------------
                            ; FIFTY-MOVE RULE: Check for draw
                            ; -----------------------------------------------
                            ; If halfmove clock >= 100, position is a draw
   1bea   68 cd 60 83       RLDI 13, GAME_STATE + STATE_HALFMOVE
   1bee   0d                LDN 13               ; D = halfmove clock
   1bef   ff 64             SMI 100             ; D = halfmove - 100
   1bf1   cb 1c 0d          LBNF NEGAMAX_NOT_FIFTY ; If < 100, continue normally (long branch - crosses page)
                        
                            ; Draw return — shared by fifty-move rule and repetition detection
   1bf4                 RETURN_DRAW:
   1bf4   f8 00             LDI 0
   1bf6   b9                PHI 9
   1bf7   a9                PLO 9               ; R9 = 0 (draw score) - R6 is SCRT linkage!
                            ; Save score to SCORE_HI/LO BEFORE restore (RESTORE clobbers R9!)
   1bf8   68 ca 64 46       RLDI 10, SCORE_HI
   1bfc   99                GHI 9
   1bfd   5a                STR 10
   1bfe   1a                INC 10
   1bff   89                GLO 9
   1c00   5a                STR 10              ; SCORE_HI/LO = 0 (draw)
   1c01   d4 00 54          CALL RESTORE_PLY_STATE
                            ; Reload R9 from SCORE_HI/LO AFTER restore
   1c04   68 ca 64 46       RLDI 10, SCORE_HI
   1c08   4a                LDA 10
   1c09   b9                PHI 9
   1c0a   0a                LDN 10
   1c0b   a9                PLO 9               ; R9 = draw score (0)
   1c0c   d5                RETN
                        
   1c0d                 NEGAMAX_NOT_FIFTY:
                            ; -----------------------------------------------
                            ; REPETITION DETECTION: Check game position history
                            ; -----------------------------------------------
                            ; Skip at root (ply 0) — root position is the last HASH_HIST
                            ; entry and would always match itself.
   1c0d   68 ca 64 48       RLDI 10, CURRENT_PLY
   1c11   0a                LDN 10
   1c12   c2 1c 4b          LBZ REP_NO_MATCH
                        
                            ; Skip if halfmove clock < 4 — after pawn moves or captures,
                            ; repetition is impossible. Scanning the full hash history with
                            ; 16-bit hashes causes false collisions (~5% with 80+ entries),
                            ; which makes the engine return draw (0) for promotion lines.
   1c15   68 ca 60 83       RLDI 10, GAME_STATE + STATE_HALFMOVE
   1c19   0a                LDN 10              ; D = halfmove clock
   1c1a   ff 04             SMI 4
   1c1c   cb 1c 4b          LBNF REP_NO_MATCH   ; halfmove < 4, can't be repetition
                        
                            ; Load current hash into R8
   1c1f   68 ca 64 b9       RLDI 10, HASH_HI
   1c23   4a                LDA 10              ; D = HASH_HI
   1c24   b8                PHI 8
   1c25   0a                LDN 10              ; D = HASH_LO
   1c26   a8                PLO 8               ; R8 = current position hash
                        
                            ; Load history count
   1c27   68 cd 64 eb       RLDI 13, HASH_HIST_COUNT
   1c2b   0d                LDN 13
   1c2c   c2 1c 4b          LBZ REP_NO_MATCH    ; Empty history
   1c2f   ab                PLO 11              ; R11.0 = loop counter
                        
   1c30   68 c9 65 00       RLDI 9, HASH_HIST   ; R9 → first entry
                        
   1c34                 REP_CHECK_LOOP:
                            ; Compare hi byte
   1c34   49                LDA 9               ; D = hist[i].hi, R9→lo byte
   1c35   52                STR 2               ; temp at M(R2)
   1c36   98                GHI 8               ; D = current.hi
   1c37   f3                XOR                 ; compare
   1c38   ca 1c 45          LBNZ REP_SKIP_LO   ; Hi mismatch
                        
                            ; Hi matched — compare lo byte
   1c3b   49                LDA 9               ; D = hist[i].lo, R9→next entry
   1c3c   52                STR 2
   1c3d   88                GLO 8               ; D = current.lo
   1c3e   f3                XOR
   1c3f   c2 1b f4          LBZ RETURN_DRAW     ; MATCH! Return draw (shared code)
   1c42   c0 1c 46          LBR REP_DEC         ; Mismatch, R9 already past both bytes
                        
   1c45                 REP_SKIP_LO:
   1c45   19                INC 9               ; Skip lo byte
                        
   1c46                 REP_DEC:
   1c46   2b                DEC 11
   1c47   8b                GLO 11
   1c48   ca 1c 34          LBNZ REP_CHECK_LOOP
                        
   1c4b                 REP_NO_MATCH:
                            ; -----------------------------------------------
                            ; Snapshot CHECK_EXT_FLAG → NODE_IN_CHECK[CURRENT_PLY]
                            ; -----------------------------------------------
                            ; CHECK_EXT_FLAG was just set by parent's move-loop iteration to
                            ; indicate "did my (parent's) move give check to opponent (us)". We
                            ; capture it here at NEGAMAX entry — before our own move loop starts
                            ; overwriting it — so downstream pruning code (LMP especially) can
                            ; tell whether THIS node is in check.
                            ;
                            ; Cost: ~10 instructions per node call. Negligible relative to per-
                            ; node search cost (~30K instructions median).
   1c4b   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   1c4f   0a                LDN 10              ; D = current check flag (from parent)
   1c50   ad                PLO 13              ; R13.0 = check flag (temp)
   1c51   68 ca 64 48       RLDI 10, CURRENT_PLY
   1c55   0a                LDN 10              ; D = ply
   1c56   fc 42             ADI LOW(NODE_IN_CHECK)
   1c58   aa                PLO 10
   1c59   f8 67             LDI HIGH(NODE_IN_CHECK)
   1c5b   7c 00             ADCI 0
   1c5d   ba                PHI 10              ; R10 = NODE_IN_CHECK + ply
   1c5e   8d                GLO 13              ; D = saved check flag
   1c5f   5a                STR 10              ; NODE_IN_CHECK[ply] = check flag
                        
                            ; -----------------------------------------------
                            ; Transposition Table Probe
                            ; -----------------------------------------------
                            ; Hash is updated incrementally in MAKE/UNMAKE_MOVE,
                            ; so TT works correctly at all nodes.
                            ;
                            ; Skip TT at root (ply 0): TT_STORE saves the root's BEST_MOVE
                            ; globally, so non-root TT entries have stale/sentinel move data.
                            ; Root must always search fully to guarantee a valid BEST_MOVE.
   1c60   68 ca 64 48       RLDI 10, CURRENT_PLY
   1c64   0a                LDN 10              ; D = current ply
   1c65   c2 1c a6          LBZ NEGAMAX_TT_MISS ; Root: always search fully
                        
                            ; Load current search depth for comparison
   1c68   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   1c6c   0d                LDN 13              ; D = depth low byte (SEARCH_DEPTH+1 = low byte)
   1c6d   d4 57 05          CALL TT_PROBE       ; D = required depth, returns D = 1 if hit
   1c70   c2 1c a6          LBZ NEGAMAX_TT_MISS ; No hit, continue with search
                        
                            ; TT hit - check if it's usable (EXACT bound)
   1c73   68 ca 64 bf       RLDI 10, TT_FLAG
   1c77   0a                LDN 10              ; D = TT flag
   1c78   fb 01             XRI TT_FLAG_EXACT
   1c7a   ca 1c a6          LBNZ NEGAMAX_TT_MISS    ; Not exact, can't use directly (for now)
                        
                            ; EXACT hit at non-root node - use the stored score
                            ; (Root is excluded above, so no BEST_MOVE copy needed)
                        
                            ; Get the score and save to SCORE_HI/LO BEFORE restore
                            ; (RESTORE_PLY_STATE clobbers R9!)
                            ; CRITICAL: Reject mate scores from TT to prevent hash collision
                            ; causing stalemate/checkmate misidentification (16-bit hash limit)
   1c7d   68 ca 64 bc       RLDI 10, TT_SCORE_HI
   1c81   0a                LDN 10              ; D = score_hi
   1c82   fb 7f             XRI $7F
   1c84   c2 1c a6          LBZ NEGAMAX_TT_MISS ; Positive mate score → re-search to verify
   1c87   0a                LDN 10              ; D = score_hi (reload)
   1c88   fb 80             XRI $80
   1c8a   c2 1c a6          LBZ NEGAMAX_TT_MISS ; Negative mate score → re-search to verify
   1c8d   4a                LDA 10              ; D = score_hi, R10 → score_lo
   1c8e   b9                PHI 9
   1c8f   0a                LDN 10              ; score_lo
   1c90   a9                PLO 9               ; R9 = stored score
                            ; Save to SCORE_HI/LO so it survives RESTORE
   1c91   68 ca 64 46       RLDI 10, SCORE_HI
   1c95   99                GHI 9
   1c96   5a                STR 10
   1c97   1a                INC 10
   1c98   89                GLO 9
   1c99   5a                STR 10              ; SCORE_HI/LO = TT score
   1c9a   d4 00 54          CALL RESTORE_PLY_STATE
                            ; Reload R9 from SCORE_HI/LO AFTER restore
   1c9d   68 ca 64 46       RLDI 10, SCORE_HI
   1ca1   4a                LDA 10
   1ca2   b9                PHI 9
   1ca3   0a                LDN 10
   1ca4   a9                PLO 9               ; R9 = TT score (preserved through restore)
   1ca5   d5                RETN                ; Return TT score
                        
   1ca6                 NEGAMAX_TT_MISS:
                            ; -----------------------------------------------
                            ; Check if we're at a leaf node (depth == 0)
                            ; -----------------------------------------------
                            ; Load depth from memory (SEARCH_DEPTH)
   1ca6   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   1caa   4d                LDA 13              ; D = depth high byte
   1cab   ca 1c b5          LBNZ NEGAMAX_CONTINUE
   1cae   0d                LDN 13              ; D = depth low byte
   1caf   ca 1c b5          LBNZ NEGAMAX_CONTINUE
                            ; Depth is 0, evaluate leaf node
   1cb2   c0 25 2a          LBR NEGAMAX_LEAF
                        
   1cb5                 NEGAMAX_CONTINUE:
                            ; ===============================================
                            ; NULL MOVE PRUNING CHECK
                            ; ===============================================
                            ; If position is so strong that passing still beats beta, prune.
                            ; Conditions: depth >= 3, not in check, NULL_MOVE_OK, ply > 0
                        
                            ; Condition 1: depth >= 3?
   1cb5   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   1cb9   0a                LDN 10              ; D = depth low byte
   1cba   ff 03             SMI 3               ; D = depth - 3
   1cbc   cb 1d d3          LBNF NMP_SKIP       ; depth < 3, skip null move
                        
                            ; Condition 2: ply > 0? (don't do at root)
   1cbf   68 ca 64 48       RLDI 10, CURRENT_PLY
   1cc3   0a                LDN 10              ; D = current ply
   1cc4   c2 1d d3          LBZ NMP_SKIP        ; ply == 0, skip null move
                        
                            ; Condition 3: NULL_MOVE_OK?
   1cc7   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   1ccb   0a                LDN 10
   1ccc   c2 1d d3          LBZ NMP_SKIP        ; null move not allowed (already did one)
                        
                            ; Condition 4: NOT in check? (already verified above for non-CE path)
   1ccf   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if in check, 0 if safe
   1cd2   ca 1d d3          LBNZ NMP_SKIP       ; in check, can't pass
                        
                            ; --- All conditions met, try null move ---
                        
                            ; Disable null move for child (prevent consecutive)
   1cd5   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   1cd9   f8 00             LDI 0
   1cdb   5a                STR 10              ; NULL_MOVE_OK = 0
                        
                            ; Save depth to stack
   1cdc   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   1ce0   4d                LDA 13              ; depth_hi
   1ce1   73                STXD
   1ce2   0d                LDN 13              ; depth_lo
   1ce3   73                STXD
                        
                            ; Save alpha/beta to stack
   1ce4   68 cd 64 42       RLDI 13, ALPHA_HI
   1ce8   4d                LDA 13              ; alpha_hi
   1ce9   73                STXD
   1cea   0d                LDN 13              ; alpha_lo
   1ceb   73                STXD
   1cec   68 cd 64 44       RLDI 13, BETA_HI
   1cf0   4d                LDA 13              ; beta_hi
   1cf1   73                STXD
   1cf2   0d                LDN 13              ; beta_lo
   1cf3   73                STXD
                        
                            ; Make null move (toggle side, update hash, clear EP)
   1cf4   d4 0d a7          CALL NULL_MAKE_MOVE
                        
                            ; Set child depth = depth - 3 (R=2 reduction + normal -1)
                            ; Peek depth from stack (at R2+5, R2+6)
   1cf7   82                GLO 2
   1cf8   fc 06             ADI 6
   1cfa   aa                PLO 10
   1cfb   92                GHI 2
   1cfc   7c 00             ADCI 0
   1cfe   ba                PHI 10              ; R10 = &depth_hi on stack
   1cff   0a                LDN 10              ; depth_hi
   1d00   b7                PHI 7               ; R7.1 = depth_hi
   1d01   2a                DEC 10
   1d02   0a                LDN 10              ; depth_lo
   1d03   ff 03             SMI 3               ; depth_lo - 3
   1d05   a7                PLO 7
   1d06   97                GHI 7
   1d07   7f 00             SMBI 0              ; depth_hi - borrow
   1d09   b7                PHI 7               ; R7 = depth - 3
                        
                            ; Store child depth to memory
   1d0a   68 ca 64 16       RLDI 10, SEARCH_DEPTH
   1d0e   97                GHI 7
   1d0f   5a                STR 10
   1d10   1a                INC 10
   1d11   87                GLO 7
   1d12   5a                STR 10              ; SEARCH_DEPTH = depth - 3
                        
                            ; Set child alpha = -beta (zero window)
                            ; Peek beta from stack (at R2+1, R2+2)
   1d13   82                GLO 2
   1d14   fc 02             ADI 2
   1d16   aa                PLO 10
   1d17   92                GHI 2
   1d18   7c 00             ADCI 0
   1d1a   ba                PHI 10              ; R10 = &beta_hi on stack
   1d1b   0a                LDN 10              ; beta_hi
   1d1c   b7                PHI 7
   1d1d   2a                DEC 10
   1d1e   0a                LDN 10              ; beta_lo
   1d1f   a7                PLO 7               ; R7 = beta
                        
                            ; Negate R7 (beta) → R8 = -beta (child alpha)
   1d20   87                GLO 7               ; low byte
   1d21   fd 00             SDI 0               ; negate low
   1d23   a8                PLO 8
   1d24   97                GHI 7               ; high byte
   1d25   7d 00             SDBI 0              ; negate high with borrow
   1d27   b8                PHI 8               ; R8 = -beta
                        
                            ; Store as new alpha
   1d28   68 ca 64 42       RLDI 10, ALPHA_HI
   1d2c   98                GHI 8
   1d2d   5a                STR 10
   1d2e   1a                INC 10
   1d2f   88                GLO 8
   1d30   5a                STR 10              ; ALPHA = -beta
                        
                            ; Set child beta = -beta + 1 (zero window)
   1d31   88                GLO 8
   1d32   fc 01             ADI 1
   1d34   a8                PLO 8
   1d35   98                GHI 8
   1d36   7c 00             ADCI 0
   1d38   b8                PHI 8               ; R8 = -beta + 1
                        
   1d39   68 ca 64 44       RLDI 10, BETA_HI
   1d3d   98                GHI 8
   1d3e   5a                STR 10
   1d3f   1a                INC 10
   1d40   88                GLO 8
   1d41   5a                STR 10              ; BETA = -beta + 1
                        
                            ; Toggle color for child
   1d42   8c                GLO 12
   1d43   fb 08             XRI $08
   1d45   ac                PLO 12
                        
                            ; Increment ply
   1d46   68 ca 64 48       RLDI 10, CURRENT_PLY
   1d4a   0a                LDN 10
   1d4b   fc 01             ADI 1
   1d4d   5a                STR 10              ; CURRENT_PLY++
                        
                            ; Recursive call
   1d4e   d4 1b 58          CALL NEGAMAX
                            ; R9 = score
                        
                            ; Decrement ply
   1d51   68 ca 64 48       RLDI 10, CURRENT_PLY
   1d55   0a                LDN 10
   1d56   ff 01             SMI 1
   1d58   5a                STR 10              ; CURRENT_PLY--
                        
                            ; Toggle color back
   1d59   8c                GLO 12
   1d5a   fb 08             XRI $08
   1d5c   ac                PLO 12
                        
                            ; Negate R9 (score = -score)
   1d5d   89                GLO 9               ; low byte
   1d5e   fd 00             SDI 0               ; negate low
   1d60   a9                PLO 9
   1d61   99                GHI 9               ; high byte
   1d62   7d 00             SDBI 0              ; negate high with borrow
   1d64   b9                PHI 9
                        
                            ; Unmake null move (toggle side back, restore EP, update hash)
   1d65   d4 0d c6          CALL NULL_UNMAKE_MOVE
                        
                            ; Re-enable null move for this level
   1d68   68 ca 64 a7       RLDI 10, NULL_MOVE_OK
   1d6c   f8 01             LDI 1
   1d6e   5a                STR 10              ; NULL_MOVE_OK = 1
                        
                            ; Pop beta from stack into R7
   1d6f   60                IRX
   1d70   72                LDXA                ; beta_lo
   1d71   a7                PLO 7
   1d72   f0                LDX                 ; beta_hi (R2 now at beta_hi slot)
   1d73   b7                PHI 7               ; R7 = original beta
                        
                            ; Pop alpha from stack into R8
   1d74   60                IRX
   1d75   72                LDXA                ; alpha_lo
   1d76   a8                PLO 8
   1d77   f0                LDX                 ; alpha_hi
   1d78   b8                PHI 8               ; R8 = original alpha
                        
                            ; Pop depth from stack and restore to memory
   1d79   60                IRX
   1d7a   72                LDXA                ; depth_lo
   1d7b   ad                PLO 13
   1d7c   f0                LDX                 ; depth_hi
   1d7d   bd                PHI 13              ; R13 = original depth
                        
   1d7e   68 ca 64 16       RLDI 10, SEARCH_DEPTH
   1d82   9d                GHI 13
   1d83   5a                STR 10
   1d84   1a                INC 10
   1d85   8d                GLO 13
   1d86   5a                STR 10              ; SEARCH_DEPTH restored
                            ; R7 = original beta, R8 = original alpha (for NMP_NO_CUTOFF path)
                        
                            ; Compare: score (R9) >= beta (R7)? If so, prune!
                            ; Signed 16-bit comparison
                        
   1d87   68 ca 64 49       RLDI 10, COMPARE_TEMP
   1d8b   ea                SEX 10
                        
                            ; Check if signs differ
   1d8c   99                GHI 9               ; score_hi
   1d8d   5a                STR 10
   1d8e   97                GHI 7               ; beta_hi
   1d8f   f3                XOR
   1d90   fa 80             ANI $80             ; Check sign bit difference
   1d92   e2                SEX 2
   1d93   ca 1d a6          LBNZ NMP_CHECK_SIGN
                        
                            ; Same sign: score >= beta if (score - beta) has no borrow
   1d96   ea                SEX 10
   1d97   87                GLO 7               ; beta_lo
   1d98   5a                STR 10
   1d99   89                GLO 9               ; score_lo
   1d9a   f7                SM                  ; score_lo - beta_lo
   1d9b   97                GHI 7               ; beta_hi
   1d9c   5a                STR 10
   1d9d   99                GHI 9               ; score_hi
   1d9e   77                SMB                 ; score_hi - beta_hi - borrow
   1d9f   e2                SEX 2
   1da0   cb 1d c1          LBNF NMP_NO_CUTOFF  ; Borrow set = score < beta
   1da3   c0 1d ac          LBR NMP_CUTOFF      ; No borrow = score >= beta
                        
   1da6                 NMP_CHECK_SIGN:
                            ; Different signs: positive >= negative always
                            ; If score positive (hi bit 0) and beta negative (hi bit 1): score >= beta
   1da6   99                GHI 9               ; score_hi
   1da7   fa 80             ANI $80
   1da9   ca 1d c1          LBNZ NMP_NO_CUTOFF  ; score negative, beta positive: score < beta
                            ; score positive, beta negative: score >= beta
                            ; Fall through to cutoff
                        
   1dac                 NMP_CUTOFF:
                            ; Null move cutoff! Return beta
                            ; Save beta to SCORE memory (same pattern as NEGAMAX_RETURN)
   1dac   68 ca 64 46       RLDI 10, SCORE_HI
   1db0   97                GHI 7               ; beta_hi
   1db1   5a                STR 10
   1db2   1a                INC 10
   1db3   87                GLO 7               ; beta_lo
   1db4   5a                STR 10              ; SCORE = beta
                        
   1db5   d4 00 54          CALL RESTORE_PLY_STATE
                        
                            ; Load return value from SCORE memory into R9 (after restore)
   1db8   68 ca 64 46       RLDI 10, SCORE_HI
   1dbc   4a                LDA 10              ; SCORE_HI
   1dbd   b9                PHI 9
   1dbe   0a                LDN 10              ; SCORE_LO
   1dbf   a9                PLO 9               ; R9 = beta
                        
   1dc0   d5                RETN
                        
   1dc1                 NMP_NO_CUTOFF:
                            ; Null move didn't cause cutoff - restore alpha/beta to memory
                            ; R8 = original alpha, R7 = original beta
   1dc1   68 ca 64 42       RLDI 10, ALPHA_HI
   1dc5   98                GHI 8
   1dc6   5a                STR 10
   1dc7   1a                INC 10
   1dc8   88                GLO 8
   1dc9   5a                STR 10              ; ALPHA = original alpha
                        
   1dca   68 ca 64 44       RLDI 10, BETA_HI
   1dce   97                GHI 7
   1dcf   5a                STR 10
   1dd0   1a                INC 10
   1dd1   87                GLO 7
   1dd2   5a                STR 10              ; BETA = original beta
                            ; Fall through to normal move generation
                        
   1dd3                 NMP_SKIP:
                            ; -----------------------------------------------
                            ; REVERSE FUTILITY PRUNING (RFP) - DISABLED
                            ; -----------------------------------------------
                            ; RFP margins (150/300cp) are too aggressive for material+PST eval.
                            ; The coarse eval causes search collapse when any PV child finds
                            ; tactical improvement: beta drops and RFP prunes all siblings.
                            ; R7 beta-reload fix (below) is preserved for future re-enable.
                            ;
                            ; Conditions: depth <= 2, ply > 0, not in check
                        
                            ; Condition 1: depth <= 2?
   1dd3   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   1dd7   0a                LDN 10              ; D = depth low byte
   1dd8   ff 03             SMI 3               ; D = depth - 3
   1dda   c3 1e 5b          LBDF RFP_SKIP       ; depth >= 3, skip RFP
                        
                            ; Condition 2: ply > 0? (don't prune at root)
   1ddd   68 ca 64 48       RLDI 10, CURRENT_PLY
   1de1   0a                LDN 10              ; D = current ply
   1de2   c2 1e 5b          LBZ RFP_SKIP        ; ply == 0, skip
                        
                            ; Condition 3: not in check?
   1de5   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if in check, 0 if safe
   1de8   ca 1e 5b          LBNZ RFP_SKIP       ; in check, can't prune
                        
                            ; --- All conditions met ---
                            ; Get static eval
   1deb   d4 0e a7          CALL EVALUATE
                            ; R9 = score from white's perspective
                        
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   1dee   8c                GLO 12
   1def   fa 08             ANI $08
   1df1   c2 1d fc          LBZ RFP_NO_NEG
   1df4   89                GLO 9               ; low byte
   1df5   fd 00             SDI 0               ; negate low
   1df7   a9                PLO 9
   1df8   99                GHI 9               ; high byte
   1df9   7d 00             SDBI 0              ; negate high with borrow
   1dfb   b9                PHI 9
   1dfc                 RFP_NO_NEG:
                        
                            ; Save eval in SCORE_HI/LO (for return value if we prune)
   1dfc   68 ca 64 46       RLDI 10, SCORE_HI
   1e00   99                GHI 9
   1e01   5a                STR 10
   1e02   1a                INC 10
   1e03   89                GLO 9
   1e04   5a                STR 10              ; SCORE_HI/LO = eval
                        
                            ; Select margin based on depth
                            ; Load depth again
   1e05   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   1e09   0a                LDN 10              ; D = depth (1 or 2)
   1e0a   ff 02             SMI 2
   1e0c   cb 1e 1a          LBNF RFP_DEPTH1     ; depth < 2, so depth == 1
                        
                            ; Depth 2: subtract 300cp margin
   1e0f   89                GLO 9
   1e10   ff 2c             SMI RFP_MARGIN_D2_LO
   1e12   a9                PLO 9
   1e13   99                GHI 9
   1e14   7f 01             SMBI RFP_MARGIN_D2_HI
   1e16   b9                PHI 9
   1e17   c0 1e 22          LBR RFP_COMPARE
                        
   1e1a                 RFP_DEPTH1:
                            ; Depth 1: subtract 150cp margin
   1e1a   89                GLO 9
   1e1b   ff 96             SMI RFP_MARGIN_D1_LO
   1e1d   a9                PLO 9
   1e1e   99                GHI 9
   1e1f   7f 00             SMBI RFP_MARGIN_D1_HI
   1e21   b9                PHI 9
                        
   1e22                 RFP_COMPARE:
                            ; R9 = eval - margin
                            ; Compare: (eval - margin) >= beta (R7)?
                            ; Signed 16-bit comparison using same pattern as NMP
                        
                            ; Load beta from memory into R7
                            ; (R7 was clobbered by time tracking code at NEGAMAX entry!)
   1e22   68 ca 64 44       RLDI 10, BETA_HI
   1e26   4a                LDA 10              ; D = beta_hi
   1e27   b7                PHI 7
   1e28   0a                LDN 10              ; D = beta_lo
   1e29   a7                PLO 7               ; R7 = beta
                        
   1e2a   68 ca 64 49       RLDI 10, COMPARE_TEMP
   1e2e   ea                SEX 10
                        
                            ; Check if signs differ
   1e2f   99                GHI 9               ; (eval-margin)_hi
   1e30   5a                STR 10
   1e31   97                GHI 7               ; beta_hi
   1e32   f3                XOR
   1e33   fa 80             ANI $80             ; Check sign bit difference
   1e35   e2                SEX 2
   1e36   ca 1e 49          LBNZ RFP_CHECK_SIGN
                        
                            ; Same sign: (eval-margin) >= beta if no borrow
   1e39   ea                SEX 10
   1e3a   87                GLO 7               ; beta_lo
   1e3b   5a                STR 10
   1e3c   89                GLO 9               ; (eval-margin)_lo
   1e3d   f7                SM                  ; (eval-margin)_lo - beta_lo
   1e3e   97                GHI 7               ; beta_hi
   1e3f   5a                STR 10
   1e40   99                GHI 9               ; (eval-margin)_hi
   1e41   77                SMB                 ; (eval-margin)_hi - beta_hi - borrow
   1e42   e2                SEX 2
   1e43   cb 1e 5b          LBNF RFP_SKIP       ; Borrow = eval-margin < beta, don't prune
   1e46   c0 1e 4f          LBR RFP_PRUNE       ; No borrow = eval-margin >= beta, prune!
                        
   1e49                 RFP_CHECK_SIGN:
                            ; Different signs: positive >= negative always
   1e49   99                GHI 9               ; (eval-margin)_hi
   1e4a   fa 80             ANI $80
   1e4c   ca 1e 5b          LBNZ RFP_SKIP       ; eval-margin negative, beta positive: don't prune
                            ; eval-margin positive, beta negative: prune
                            ; Fall through to RFP_PRUNE
                        
   1e4f                 RFP_PRUNE:
                            ; Return eval (saved in SCORE_HI/LO)
   1e4f   d4 00 54          CALL RESTORE_PLY_STATE
                            ; Reload R9 from SCORE_HI/LO after restore
   1e52   68 ca 64 46       RLDI 10, SCORE_HI
   1e56   4a                LDA 10
   1e57   b9                PHI 9
   1e58   0a                LDN 10
   1e59   a9                PLO 9               ; R9 = eval score
   1e5a   d5                RETN
                        
   1e5b                 RFP_SKIP:
                            ; -----------------------------------------------
                            ; Generate moves for current position
                            ; -----------------------------------------------
                            ; Use ply-indexed move list to avoid overwrites during recursion!
                            ; Each ply gets 128 bytes (64 moves): PLY 0 at $6200, PLY 1 at $6280, etc.
                            ; ply × 128 overflows 8 bits for ply >= 2, so use 16-bit math:
                            ;   offset_hi = ply >> 1, offset_lo = (ply & 1) << 7
                        
   1e5b   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e5f   0a                LDN 10              ; D = current ply (0-4 with d=5)
                        
                            ; Calculate high byte: HIGH(MOVE_LIST) + (ply >> 1)
   1e60   f6                SHR                 ; D = ply >> 1 (0 or 1)
   1e61   fc 78             ADI HIGH(MOVE_LIST) ; D = $78 + (ply >> 1)
   1e63   b9                PHI 9               ; R9.1 = high byte
                        
                            ; Calculate low byte: (ply & 1) << 7 = $00 or $80
   1e64   0a                LDN 10              ; D = ply (reload)
   1e65   fa 01             ANI $01             ; D = ply & 1
   1e67   c2 1e 6f          LBZ NEGAMAX_PLY_EVEN
   1e6a   f8 80             LDI $80             ; Odd ply: low byte = $80
   1e6c   c0 1e 71          LBR NEGAMAX_PLY_DONE
   1e6f                 NEGAMAX_PLY_EVEN:
   1e6f   f8 00             LDI $00             ; Even ply: low byte = $00
   1e71                 NEGAMAX_PLY_DONE:
   1e71   a9                PLO 9               ; R9 = ply-indexed move list
                        
   1e72   d4 04 d7          CALL GENERATE_MOVES
                            ; Returns: D = move count
                            ; NOTE: R9 now points PAST the end of the move list!
                        
                            ; Save move count to ply-indexed memory (NOT the stack — see LOOP_MOVE_CNT).
                            ; D = count from GENERATE_MOVES; R11 is movegen scratch (dead on return).
   1e75   ab                PLO 11             ; stash count in R11.0
   1e76   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e7a   0a                LDN 10             ; D = ply
   1e7b   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1e7d   aa                PLO 10
   1e7e   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1e80   ba                PHI 10             ; R10 = &LOOP_MOVE_CNT[ply]
   1e81   8b                GLO 11             ; D = count
   1e82   5a                STR 10             ; LOOP_MOVE_CNT[ply] = count
                        
                            ; Reset R9 to START of ply-indexed move list (128 bytes per ply)
   1e83   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e87   0a                LDN 10              ; D = current ply
                        
                            ; Calculate high byte: HIGH(MOVE_LIST) + (ply >> 1)
   1e88   f6                SHR                 ; D = ply >> 1
   1e89   fc 78             ADI HIGH(MOVE_LIST)
   1e8b   b9                PHI 9
                        
                            ; Calculate low byte: (ply & 1) << 7
   1e8c   0a                LDN 10              ; D = ply (reload)
   1e8d   fa 01             ANI $01
   1e8f   c2 1e 97          LBZ NEGAMAX_RESET_EVEN
   1e92   f8 80             LDI $80
   1e94   c0 1e 99          LBR NEGAMAX_RESET_DONE
   1e97                 NEGAMAX_RESET_EVEN:
   1e97   f8 00             LDI $00
   1e99                 NEGAMAX_RESET_DONE:
   1e99   a9                PLO 9               ; R9 = ply-indexed move list start
                        
                            ; -----------------------------------------------
                            ; Apply killer move ordering (search killers first)
                            ; Apply at plies 0-4: with d=5 search now active, plies 3 and 4 are
                            ; non-leaves with rich subtrees where alpha-beta cutoffs from a
                            ; well-ordered list save exponentially more work. Skip only at ply >= 5
                            ; (where remaining depth is too shallow for ordering to pay off).
                            ; -----------------------------------------------
   1e9a   68 ca 64 48       RLDI 10, CURRENT_PLY
   1e9e   0a                LDN 10              ; D = current ply
   1e9f   ff 05             SMI 5               ; Check if ply >= 5
   1ea1   c3 1e b3          LBDF NEGAMAX_SKIP_KILLER  ; Skip if ply >= 5
                        
   1ea4   68 ca 64 48       RLDI 10, CURRENT_PLY
   1ea8   0a                LDN 10              ; D = ply
   1ea9   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1eab   aa                PLO 10
   1eac   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1eae   ba                PHI 10              ; R10 = &LOOP_MOVE_CNT[ply]
   1eaf   0a                LDN 10              ; D = move count (read from memory)
   1eb0   d4 28 de          CALL ORDER_KILLER_MOVES
                        
   1eb3                 NEGAMAX_SKIP_KILLER:
                            ; -----------------------------------------------
                            ; Order captures first (MVV-LVA preparation)
                            ; Apply at plies 0-4 (same rationale as killers above).
                            ; -----------------------------------------------
   1eb3   68 ca 64 48       RLDI 10, CURRENT_PLY
   1eb7   0a                LDN 10              ; D = current ply
   1eb8   ff 05             SMI 5               ; Check if ply >= 5
   1eba   c3 1e cc          LBDF NEGAMAX_SKIP_CAPTURE_ORDER  ; Skip if ply >= 5
                        
   1ebd   68 ca 64 48       RLDI 10, CURRENT_PLY
   1ec1   0a                LDN 10              ; D = ply
   1ec2   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1ec4   aa                PLO 10
   1ec5   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1ec7   ba                PHI 10              ; R10 = &LOOP_MOVE_CNT[ply]
   1ec8   0a                LDN 10              ; D = move count (read from memory)
   1ec9   d4 29 a9          CALL ORDER_CAPTURES_FIRST
                        
   1ecc                 NEGAMAX_SKIP_CAPTURE_ORDER:
                            ; -----------------------------------------------
                            ; Order TT/PV move first (highest-priority ordering hint)
                            ; At ply >= 1: TT_PROBE has populated TT_MOVE_HI/LO (or left empty zeros).
                            ; At root: ITER_BEST_FROM/TO holds the principal-variation move from the
                            ; prior iterative-deepening iteration. Copy it into TT_MOVE_HI/LO so the
                            ; existing ORDER_TT_MOVE puts it at the front. This PV-move-first
                            ; ordering is essentially free (no extra search; the move is already
                            ; computed) and typically halves node counts at the next depth via
                            ; immediate alpha-beta cutoffs.
                            ; ITER_BEST is initialized to $FF/$FF in SEARCH_POSITION; only valid
                            ; after at least one successful iteration completes.
                            ; -----------------------------------------------
   1ecc   68 ca 64 48       RLDI 10, CURRENT_PLY
   1ed0   0a                LDN 10              ; D = current ply
   1ed1   ca 1e ef          LBNZ NEGAMAX_TT_ORDER_CALL  ; ply >= 1: TT_PROBE has populated TT_MOVE
                        
                            ; Root: copy ITER_BEST into TT_MOVE if valid, else skip ordering pass.
   1ed4   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   1ed8   0a                LDN 10
   1ed9   fb ff             XRI $FF
   1edb   c2 1e ef          LBZ NEGAMAX_SKIP_TT_ORDER   ; first iteration: no PV — skip
                        
   1ede   68 ca 64 c2       RLDI 10, ITER_BEST_FROM
   1ee2   4a                LDA 10                      ; D = ITER_BEST_FROM, R10 -> ITER_BEST_TO
   1ee3   bd                PHI 13
   1ee4   0a                LDN 10                      ; D = ITER_BEST_TO
   1ee5   ad                PLO 13
   1ee6   68 ca 64 c0       RLDI 10, TT_MOVE_HI
   1eea   9d                GHI 13
   1eeb   5a                STR 10                      ; TT_MOVE_HI = ITER_BEST_FROM
   1eec   1a                INC 10
   1eed   8d                GLO 13
   1eee   5a                STR 10                      ; TT_MOVE_LO = ITER_BEST_TO
                        
   1eef                 NEGAMAX_TT_ORDER_CALL:
                            ; (move-count peek removed: ORDER_TT_MOVE below is disabled, so nothing
                            ;  consumed it. When re-enabled, read LOOP_MOVE_CNT[ply] into D first.)
                            ; --- ORDER_TT_MOVE disabled 2026-05-13 pending 32-bit TT hash widening ---
                            ; The byte-order fix in ORDER_TT_MOVE (commit 8aa04e6) is correct, but
                            ; enabling it surfaced a regression: with TT keyed on only 16 hash bits,
                            ; collisions are frequent (2^16 = 65k positions per slot). A TT_MOVE
                            ; from a colliding position gets promoted to the front of the move list
                            ; for the WRONG position; alpha-beta commits to that move's search line;
                            ; depth-limited search can't refute it. Observed concretely 2026-05-13:
                            ; engine chose Qg4-g7-h8 (queen sac into rook taking + queen recapture)
                            ; with ordering enabled; chose sensible Qg4-c8 with ordering disabled.
                            ; Killer ordering above is safe (not hash-keyed; per-ply table only).
                            ; Re-enable this CALL when TT_HASH is widened to 32 bits.
                            ; CALL ORDER_TT_MOVE
                        
   1eef                 NEGAMAX_SKIP_TT_ORDER:
                        
                            ; -----------------------------------------------
                            ; Initialize best score to -INFINITY in memory
                            ; -----------------------------------------------
                            ; Using memory avoids register clobbering bugs!
   1eef   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   1ef3   f8 80             LDI $80
   1ef5   5a                STR 10              ; BEST_SCORE_HI = $80
   1ef6   1a                INC 10
   1ef7   f8 01             LDI $01
   1ef9   5a                STR 10              ; BEST_SCORE_LO = $01 (best = $8001 = -32767, safe to negate)
                        
                            ; -----------------------------------------------
                            ; Initialize node best move to 0/0 (no move yet)
                            ; -----------------------------------------------
   1efa   68 ca 64 48       RLDI 10, CURRENT_PLY
   1efe   0a                LDN 10              ; D = ply
   1eff   fe                SHL                 ; D = ply * 2
   1f00   aa                PLO 10
   1f01   f8 67             LDI HIGH(NODE_BEST_MOVE)
   1f03   ba                PHI 10              ; R10 = &NODE_BEST_MOVE[ply]
   1f04   f8 00             LDI 0
   1f06   5a                STR 10              ; from = 0
   1f07   1a                INC 10
   1f08   5a                STR 10              ; to = 0
                        
                            ; -----------------------------------------------
                            ; Futility Pruning Setup (depth 1 only)
                            ; -----------------------------------------------
                            ; Clear futility flag for THIS ply (per-ply table prevents recursion corruption)
   1f09   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f0d   0a                LDN 10              ; D = ply
   1f0e   fe                SHL
   1f0f   fe                SHL                 ; D = ply * 4
   1f10   fc 22             ADI LOW(FUTILITY_TABLE)
   1f12   aa                PLO 10
   1f13   f8 67             LDI HIGH(FUTILITY_TABLE)
   1f15   7c 00             ADCI 0
   1f17   ba                PHI 10              ; R10 = &FUTILITY_TABLE[ply*4] (flag byte)
   1f18   f8 00             LDI 0
   1f1a   5a                STR 10              ; flag = 0 (disabled by default)
                        
                            ; Check if depth == 1 (frontier node)
   1f1b   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   1f1f   4d                LDA 13              ; D = depth high byte
   1f20   ca 1f 77          LBNZ NEGAMAX_SKIP_FUTILITY  ; depth > 255, skip
   1f23   0d                LDN 13              ; D = depth low byte
   1f24   fb 01             XRI 1               ; Check if depth == 1
   1f26   ca 1f 77          LBNZ NEGAMAX_SKIP_FUTILITY  ; Not depth 1, skip
                        
                            ; Don't enable futility at root — must always search all root moves
   1f29   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f2d   0a                LDN 10              ; D = current ply
   1f2e   c2 1f 77          LBZ NEGAMAX_SKIP_FUTILITY  ; ply == 0, skip
                        
                            ; Check guard: don't enable futility if side is in check
                            ; (escape moves must not be pruned — mirrors RFP guard at line 563)
   1f31   d4 01 8e          CALL IS_IN_CHECK    ; R12 = our color; D = 1 if in check
   1f34   ca 1f 77          LBNZ NEGAMAX_SKIP_FUTILITY  ; in check, skip futility
                        
                            ; Depth == 1: Cache static eval for futility pruning (per-ply table)
   1f37   d4 0e a7          CALL EVALUATE       ; Returns score in R9 (white perspective)
                            ; Negate R9 if black to move (white-perspective → side-to-move)
   1f3a   8c                GLO 12
   1f3b   fa 08             ANI $08
   1f3d   c2 1f 48          LBZ FUTILITY_NO_NEG
   1f40   89                GLO 9               ; low byte
   1f41   fd 00             SDI 0               ; negate low
   1f43   a9                PLO 9
   1f44   99                GHI 9               ; high byte
   1f45   7d 00             SDBI 0              ; negate high with borrow
   1f47   b9                PHI 9
   1f48                 FUTILITY_NO_NEG:
                            ; Store flag + eval in FUTILITY_TABLE[ply*4]: [flag][eval_hi][eval_lo]
   1f48   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f4c   0a                LDN 10              ; D = ply
   1f4d   fe                SHL
   1f4e   fe                SHL                 ; D = ply * 4
   1f4f   fc 22             ADI LOW(FUTILITY_TABLE)
   1f51   aa                PLO 10
   1f52   f8 67             LDI HIGH(FUTILITY_TABLE)
   1f54   7c 00             ADCI 0
   1f56   ba                PHI 10              ; R10 = &FUTILITY_TABLE[ply*4]
   1f57   f8 01             LDI 1               ; DEBUG: flag=1 (futility active, negate LBR'd = unsigned eval like bd6e4b5)
   1f59   5a                STR 10              ; flag = 1 (futility enabled)
   1f5a   1a                INC 10
   1f5b   99                GHI 9
   1f5c   5a                STR 10              ; eval_hi
   1f5d   1a                INC 10
   1f5e   89                GLO 9
   1f5f   5a                STR 10              ; eval_lo
                        
                            ; FIX: EVALUATE clobbered R9 (move list pointer) with eval score.
                            ; Re-initialize R9 to move list start for this ply.
   1f60   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f64   0a                LDN 10              ; D = current ply
   1f65   f6                SHR                 ; D = ply >> 1
   1f66   fc 78             ADI HIGH(MOVE_LIST)
   1f68   b9                PHI 9               ; R9.1 = HIGH(MOVE_LIST) + (ply >> 1)
   1f69   0a                LDN 10              ; D = ply (reload)
   1f6a   fa 01             ANI $01
   1f6c   c2 1f 74          LBZ NEGAMAX_FUTILITY_R9_EVEN
   1f6f   f8 80             LDI $80
   1f71   c0 1f 76          LBR NEGAMAX_FUTILITY_R9_DONE
   1f74                 NEGAMAX_FUTILITY_R9_EVEN:
   1f74   f8 00             LDI $00
   1f76                 NEGAMAX_FUTILITY_R9_DONE:
   1f76   a9                PLO 9               ; R9 = ply-indexed move list start
                        
   1f77                 NEGAMAX_SKIP_FUTILITY:
                        
                            ; Initialize LMR move counter to 0
   1f77   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   1f7b   f8 00             LDI 0
   1f7d   5a                STR 10              ; LMR_MOVE_INDEX = 0
                        
                            ; Check if there are any legal moves
   1f7e   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f82   0a                LDN 10              ; D = ply
   1f83   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1f85   aa                PLO 10
   1f86   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1f88   ba                PHI 10              ; R10 = &LOOP_MOVE_CNT[ply]
   1f89   0a                LDN 10              ; D = move count (read from memory)
   1f8a   ca 1f 90          LBNZ NEGAMAX_HAS_MOVES  ; Long branch (may cross page boundary)
                            ; No legal moves - checkmate or stalemate
   1f8d   c0 25 49          LBR NEGAMAX_NO_MOVES
                        
   1f90                 NEGAMAX_HAS_MOVES:
   1f90                 NEGAMAX_MOVE_LOOP:
                            ; -----------------------------------------------
                            ; Loop through all moves
                            ; -----------------------------------------------
                            ; Read move count from ply-indexed memory
   1f90   68 ca 64 48       RLDI 10, CURRENT_PLY
   1f94   0a                LDN 10             ; D = ply
   1f95   fc ef             ADI LOW(LOOP_MOVE_CNT)
   1f97   aa                PLO 10
   1f98   f8 64             LDI HIGH(LOOP_MOVE_CNT)
   1f9a   ba                PHI 10             ; R10 = &LOOP_MOVE_CNT[ply]
   1f9b   0a                LDN 10             ; D = move count (read from memory)
   1f9c   c2 24 f8          LBZ NEGAMAX_RETURN  ; No moves left
                        
                            ; Get next move from list (big-endian: high byte first)
   1f9f   49                LDA 9              ; Load high byte of move
   1fa0   b8                PHI 8
   1fa1   49                LDA 9              ; Load low byte of move
   1fa2   a8                PLO 8              ; R8 = current move (16-bit encoded)
                        
                            ; Save R9 (move pointer) to ply-indexed memory (not stack!)
                            ; This avoids stack alignment bugs across the large move loop
   1fa3   68 ca 64 48       RLDI 10, CURRENT_PLY
   1fa7   0a                LDN 10              ; D = ply
   1fa8   fe                SHL                 ; D = ply * 2
   1fa9   fc db             ADI LOW(LOOP_MOVE_PTR)
   1fab   aa                PLO 10
   1fac   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   1fae   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   1faf   99                GHI 9
   1fb0   5a                STR 10              ; Save R9.hi
   1fb1   1a                INC 10
   1fb2   89                GLO 9
   1fb3   5a                STR 10              ; Save R9.lo
                        
                            ; Decode move: R8 → R13 (from/to)
   1fb4   d4 03 c7          CALL DECODE_MOVE_16BIT
                            ; R13.1 = from square, R13.0 = to square
                        
                            ; Store to MOVE_FROM/MOVE_TO for MAKE_MOVE
   1fb7   68 ca 64 02       RLDI 10, MOVE_FROM
   1fbb   9d                GHI 13              ; from
   1fbc   5a                STR 10
   1fbd   1a                INC 10
   1fbe   8d                GLO 13              ; to
   1fbf   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; Set LMR_IS_CAPTURE flag based on target square
                            ; -----------------------------------------------
                            ; R13.0 still has 'to' square from DECODE_MOVE_16BIT
   1fc0   f8 60             LDI HIGH(BOARD)
   1fc2   ba                PHI 10
   1fc3   8d                GLO 13              ; D = to square
   1fc4   aa                PLO 10              ; R10 = BOARD + to_square
   1fc5   0a                LDN 10              ; D = piece at target (0 if empty)
   1fc6   a7                PLO 7               ; Save piece in R7.0 (temp)
   1fc7   68 ca 64 a5       RLDI 10, LMR_IS_CAPTURE
   1fcb   87                GLO 7               ; Restore piece
   1fcc   c2 1f d4          LBZ LMR_NOT_CAPTURE
   1fcf   f8 01             LDI 1               ; Non-empty = capture
   1fd1   c0 1f d6          LBR LMR_CAPTURE_DONE
   1fd4                 LMR_NOT_CAPTURE:
   1fd4   f8 00             LDI 0               ; Empty = not capture
   1fd6                 LMR_CAPTURE_DONE:
   1fd6   5a                STR 10              ; Store flag
                        
                            ; -----------------------------------------------
                            ; Castling Legality (moved from movegen for performance)
                            ; Only runs when the search actually tries a castling move,
                            ; not at every node during move generation.
                            ; -----------------------------------------------
   1fd7   68 ca 64 05       RLDI 10, DECODED_FLAGS
   1fdb   0a                LDN 10
   1fdc   fb 01             XRI MOVE_CASTLE         ; Zero if castling
   1fde   ca 20 10          LBNZ NM_NOT_CASTLE
                        
                            ; Castling — check king not in check (can't castle out of check)
   1fe1   68 ca 64 02       RLDI 10, MOVE_FROM
   1fe5   0a                LDN 10                  ; D = from (king square)
   1fe6   ab                PLO 11                  ; R11.0 = king square
   1fe7   d4 01 a4          CALL IS_SQUARE_ATTACKED ; D = 1 if in check
   1fea   ca 1f fd          LBNZ NM_CASTLE_ILLEGAL
                        
                            ; Check transit square not attacked (can't castle through check)
                            ; Transit = (from + to) / 2
   1fed   68 ca 64 02       RLDI 10, MOVE_FROM
   1ff1   4a                LDA 10                  ; D = from, R10 -> MOVE_TO
   1ff2   52                STR 2                   ; M[R2] = from
   1ff3   0a                LDN 10                  ; D = to
   1ff4   f4                ADD                     ; D = from + to
   1ff5   f6                SHR                     ; D = transit square
   1ff6   ab                PLO 11                  ; R11.0 = transit
   1ff7   d4 01 a4          CALL IS_SQUARE_ATTACKED
   1ffa   c2 20 10          LBZ NM_NOT_CASTLE       ; Transit safe, proceed
                        
   1ffd                 NM_CASTLE_ILLEGAL:
                            ; Restore R9 from ply-indexed memory
   1ffd   68 ca 64 48       RLDI 10, CURRENT_PLY
   2001   0a                LDN 10
   2002   fe                SHL
   2003   fc db             ADI LOW(LOOP_MOVE_PTR)
   2005   aa                PLO 10
   2006   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   2008   ba                PHI 10
   2009   4a                LDA 10
   200a   b9                PHI 9
   200b   0a                LDN 10
   200c   a9                PLO 9
   200d   c0 24 c8          LBR NEGAMAX_NEXT_MOVE
                        
   2010                 NM_NOT_CASTLE:
                        
                            ; -----------------------------------------------
                            ; Futility Pruning Check (per-ply, depth 1 quiet moves)
                            ; -----------------------------------------------
                        
                            ; Check: is futility pruning enabled for this ply? (per-ply table)
   2010   68 ca 64 48       RLDI 10, CURRENT_PLY
   2014   0a                LDN 10              ; D = ply
   2015   fe                SHL
   2016   fe                SHL                 ; D = ply * 4
   2017   fc 22             ADI LOW(FUTILITY_TABLE)
   2019   aa                PLO 10
   201a   f8 67             LDI HIGH(FUTILITY_TABLE)
   201c   7c 00             ADCI 0
   201e   ba                PHI 10              ; R10 = &FUTILITY_TABLE[ply*4]
   201f   4a                LDA 10              ; D = flag, R10 → eval_hi
   2020   c2 20 69          LBZ NEGAMAX_NOT_FUTILE  ; Flag=0, skip futility
                            ; Pre-load static eval while R10 is positioned
   2023   4a                LDA 10              ; D = eval_hi, R10 → eval_lo
   2024   bb                PHI 11
   2025   0a                LDN 10              ; D = eval_lo
   2026   ab                PLO 11              ; R11 = static eval (from per-ply table)
                        
                            ; Check if move is a capture (target square non-empty)
   2027   68 ca 64 03       RLDI 10, MOVE_TO
   202b   0a                LDN 10              ; D = to square
   202c   aa                PLO 10              ; R10.0 = to square
   202d   f8 60             LDI HIGH(BOARD)
   202f   ba                PHI 10              ; R10 = BOARD + to_square
   2030   0a                LDN 10              ; D = piece at target
   2031   ca 20 69          LBNZ NEGAMAX_NOT_FUTILE  ; Non-empty = capture, don't prune
                        
                            ; Check if move is a promotion (never prune — changes material)
   2034   68 ca 64 05       RLDI 10, DECODED_FLAGS
   2038   0a                LDN 10              ; D = move flags
   2039   fb 03             XRI MOVE_PROMOTION  ; Zero if promotion
   203b   c2 20 69          LBZ NEGAMAX_NOT_FUTILE  ; Promotion, don't prune
                        
                            ; Add FUTILITY_MARGIN (150 = $0096)
   203e   8b                GLO 11
   203f   fc 96             ADI FUTILITY_MARGIN_D1_LO  ; Add low byte
   2041   ab                PLO 11
   2042   9b                GHI 11
   2043   7c 00             ADCI FUTILITY_MARGIN_D1_HI ; Add high byte with carry
   2045   bb                PHI 11              ; R11 = static_eval + margin
                        
                            ; Safety: don't prune if no move has been searched yet (BEST_SCORE
                            ; is still sentinel $8001). Otherwise all quiet moves get pruned,
                            ; BEST_SCORE stays at sentinel, and the engine detects false checkmate.
   2046   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   204a   0a                LDN 10              ; D = BEST_SCORE_HI
   204b   fb 80             XRI $80             ; Zero if still sentinel high byte
   204d   c2 20 69          LBZ NEGAMAX_NOT_FUTILE  ; Sentinel → must search this move
                        
                            ; Futility: prune if static_eval + margin < 0 (losing by more than margin)
   2050   9b                GHI 11              ; (eval+margin) high byte
   2051   fa 80             ANI $80             ; Check sign bit
   2053   c2 20 69          LBZ NEGAMAX_NOT_FUTILE  ; Sign bit clear = positive, don't prune
                        
                            ; Futile! Skip this move
                            ; Restore R9 from ply-indexed memory
   2056   68 ca 64 48       RLDI 10, CURRENT_PLY
   205a   0a                LDN 10              ; D = ply
   205b   fe                SHL                 ; D = ply * 2
   205c   fc db             ADI LOW(LOOP_MOVE_PTR)
   205e   aa                PLO 10
   205f   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   2061   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   2062   4a                LDA 10
   2063   b9                PHI 9               ; R9.hi
   2064   0a                LDN 10
   2065   a9                PLO 9               ; R9 = move list pointer restored
                        
                            ; Jump to decrement move count and continue loop
   2066   c0 24 c8          LBR NEGAMAX_NEXT_MOVE
                        
   2069                 NEGAMAX_NOT_FUTILE:
                        
                            ; -----------------------------------------------
                            ; Late Move Pruning (LMP) — at low depth, after first N quiet moves
                            ; have been searched, skip remaining quiet moves entirely. Empirical
                            ; literature: 20-40% node reduction at low depths with low risk.
                            ; Conditions (all must hold to prune):
                            ;   1. CURRENT_PLY > 0      — never prune at root (highest cost of error)
                            ;   2. NODE_IN_CHECK == 0   — never prune when we're in check (legal
                            ;                             escape moves can be late in ordering, and
                            ;                             pruning them = false mate detection)
                            ;   3. SEARCH_DEPTH <= 2    — only at low depths (small subtrees)
                            ;   4. LMR_MOVE_INDEX >= 8  — first 8 moves search normally
                            ;   5. LMR_IS_CAPTURE == 0  — never prune captures
                            ;   6. DECODED_FLAGS != MOVE_PROMOTION
                            ; The in-check guard (cond 2) was added 2026-05-05 after the move-21
                            ; replay surfaced a false +32766 mate at d=1/2/3: opponent in check
                            ; from our Qh5+, with many illegal pseudo-legal moves filling indices
                            ; 0-7, leaving the legal escapes (Ng6, gxh6) at index 9+ where LMP
                            ; pruned them, causing NEGAMAX_NO_MOVES to fire and report mate.
                            ; -----------------------------------------------
                        
                            ; Cond 1: ply > 0?
   2069   68 ca 64 48       RLDI 10, CURRENT_PLY
   206d   0a                LDN 10
   206e   c2 20 a6          LBZ NEGAMAX_LMP_DONE        ; root: never prune
                        
                            ; Cond 2: not in check at this node?
   2071   fc 42             ADI LOW(NODE_IN_CHECK)
   2073   aa                PLO 10
   2074   f8 67             LDI HIGH(NODE_IN_CHECK)
   2076   7c 00             ADCI 0
   2078   ba                PHI 10                      ; R10 = NODE_IN_CHECK + ply
   2079   0a                LDN 10                      ; D = node-in-check flag
   207a   ca 20 a6          LBNZ NEGAMAX_LMP_DONE       ; in check: skip LMP (legal escapes may be late)
                        
                            ; Cond 3: depth <= 2?
   207d   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   2081   0a                LDN 10
   2082   ff 03             SMI 3
   2084   c3 20 a6          LBDF NEGAMAX_LMP_DONE       ; depth >= 3: skip LMP
                        
                            ; Cond 4: index >= 8?
   2087   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   208b   0a                LDN 10
   208c   ff 08             SMI 8
   208e   cb 20 a6          LBNF NEGAMAX_LMP_DONE       ; index < 8: search normally
                        
                            ; Cond 5: not a capture?
   2091   68 ca 64 a5       RLDI 10, LMR_IS_CAPTURE
   2095   0a                LDN 10
   2096   ca 20 a6          LBNZ NEGAMAX_LMP_DONE       ; capture: search normally
                        
                            ; Cond 6: not a promotion?
   2099   68 ca 64 05       RLDI 10, DECODED_FLAGS
   209d   0a                LDN 10
   209e   fb 03             XRI MOVE_PROMOTION
   20a0   c2 20 a6          LBZ NEGAMAX_LMP_DONE        ; promotion: search normally
                        
                            ; All conditions met — skip this move (LMP prune)
   20a3   c0 24 c8          LBR NEGAMAX_NEXT_MOVE
                        
   20a6                 NEGAMAX_LMP_DONE:
                        
                            ; Set UNDO_PROMOTION based on move flags
                            ; Must be done before MAKE_MOVE so promotions work correctly
   20a6   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   20aa   68 cd 64 05       RLDI 13, DECODED_FLAGS
   20ae   0d                LDN 13              ; D = flags
   20af   fb 03             XRI MOVE_PROMOTION  ; == $03?
   20b1   ca 20 b9          LBNZ NM_NOT_PROMO
   20b4   f8 05             LDI QUEEN_TYPE      ; Promote to queen ($05)
   20b6   c0 20 bb          LBR NM_SET_PROMO
   20b9                 NM_NOT_PROMO:
   20b9   f8 00             LDI 0               ; Not a promotion
   20bb                 NM_SET_PROMO:
   20bb   5a                STR 10              ; UNDO_PROMOTION = QUEEN_TYPE or 0
                        
                            ; Make the move on the board
   20bc   d4 09 bb          CALL MAKE_MOVE
                        
                            ; -----------------------------------------------
                            ; LEGALITY CHECK: Does this move leave our king in check?
                            ; MAKE_MOVE does NOT toggle R12 - only SIDE in memory.
                            ; R12 still contains our color (the side that just moved).
                            ; -----------------------------------------------
   20bf   d4 01 8e          CALL IS_IN_CHECK
                            ; D = 1 if our king is in check (illegal move), 0 if safe
                        
                            ; If in check, this move is illegal - unmake and skip
   20c2   c2 20 db          LBZ NEGAMAX_MOVE_LEGAL  ; D=0 means not in check, move is legal
                        
                            ; ILLEGAL MOVE: Our king is in check after this move
   20c5   d4 0c 2e          CALL UNMAKE_MOVE
                        
                            ; R12 stays as our color (UNMAKE_MOVE doesn't toggle R12)
                        
                            ; Restore R9 from ply-indexed memory and skip to next move
   20c8   68 ca 64 48       RLDI 10, CURRENT_PLY
   20cc   0a                LDN 10              ; D = ply
   20cd   fe                SHL                 ; D = ply * 2
   20ce   fc db             ADI LOW(LOOP_MOVE_PTR)
   20d0   aa                PLO 10
   20d1   f8 64             LDI HIGH(LOOP_MOVE_PTR)
   20d3   ba                PHI 10              ; R10 = LOOP_MOVE_PTR + ply*2
   20d4   4a                LDA 10
   20d5   b9                PHI 9               ; R9.hi
   20d6   0a                LDN 10
   20d7   a9                PLO 9               ; R9 = move list pointer restored
                        
   20d8   c0 24 c8          LBR NEGAMAX_NEXT_MOVE   ; Skip this illegal move
                        
   20db                 NEGAMAX_MOVE_LEGAL:
                            ; --- Check extension: does this move give check? ---
   20db   8c                GLO 12
   20dc   fb 08             XRI 8
   20de   ac                PLO 12              ; R12 = opponent's color
   20df   d4 01 8e          CALL IS_IN_CHECK    ; Check opponent's king
                            ; D = 1 if giving check (RLDI does NOT clobber D)
   20e2   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   20e6   5a                STR 10              ; Save result (0 or 1)
   20e7   8c                GLO 12
   20e8   fb 08             XRI 8
   20ea   ac                PLO 12              ; R12 = our color restored
                        
                            ; -----------------------------------------------
                            ; LMR Check: Should we reduce this move's search?
                            ; -----------------------------------------------
                            ; Clear LMR_REDUCED flag first
   20eb   68 ca 64 a4       RLDI 10, LMR_REDUCED
   20ef   f8 00             LDI 0
   20f1   5a                STR 10              ; LMR_REDUCED = 0 (default)
                        
                            ; Condition 1: LMR_MOVE_INDEX >= 4?
   20f2   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   20f6   0a                LDN 10              ; D = moves searched so far
   20f7   ff 04             SMI 4               ; D = index - 4
   20f9   cb 21 1f          LBNF LMR_SKIP       ; < 4, skip LMR
                        
                            ; Condition 2: SEARCH_DEPTH >= 3?
   20fc   68 ca 64 17       RLDI 10, SEARCH_DEPTH + 1
   2100   0a                LDN 10              ; D = depth low byte
   2101   ff 03             SMI 3               ; D = depth - 3
   2103   cb 21 1f          LBNF LMR_SKIP       ; < 3, skip LMR
                        
                            ; Condition 3: Not a capture?
   2106   68 ca 64 a5       RLDI 10, LMR_IS_CAPTURE
   210a   0a                LDN 10              ; D = capture flag
   210b   ca 21 1f          LBNZ LMR_SKIP       ; Is capture, skip LMR
                        
                            ; Condition 4: Not a promotion? (promotions change material, never reduce)
   210e   68 ca 64 05       RLDI 10, DECODED_FLAGS
   2112   0a                LDN 10              ; D = move flags
   2113   fb 03             XRI MOVE_PROMOTION  ; Zero if promotion
   2115   c2 21 1f          LBZ LMR_SKIP        ; Promotion, skip LMR
                        
                            ; All conditions met - set LMR_REDUCED = 1
   2118   68 ca 64 a4       RLDI 10, LMR_REDUCED
   211c   f8 01             LDI 1
   211e   5a                STR 10              ; LMR_REDUCED = 1
                        
   211f                 LMR_SKIP:
                        
                            ; -----------------------------------------------
                            ; Save depth to stack and decrement for recursive call
                            ; (PUSH ORDER: R9/R8, depth, alpha/beta, UNDO_* - pop in reverse!)
                            ; -----------------------------------------------
                            ; First, save current depth to stack for later restore
   211f   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   2123   4d                LDA 13              ; D = depth high
   2124   73                STXD
   2125   0d                LDN 13              ; D = depth low
   2126   73                STXD                ; Stack now has: ... [depth_hi] [depth_lo]
                        
                            ; Now decrement depth in memory
   2127   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   212b   0d                LDN 13              ; D = depth low
   212c   ff 01             SMI 1
   212e   5d                STR 13              ; Store decremented low byte
   212f   2d                DEC 13              ; Point to high byte
   2130   0d                LDN 13              ; D = depth high
   2131   7f 00             SMBI 0              ; Subtract borrow
   2133   5d                STR 13              ; Store decremented high byte
                        
                            ; -----------------------------------------------
                            ; LMR: Extra depth decrement if flag is set
                            ; -----------------------------------------------
   2134   68 ca 64 a4       RLDI 10, LMR_REDUCED
   2138   0a                LDN 10              ; D = LMR_REDUCED flag
   2139   c2 21 49          LBZ LMR_NO_EXTRA_DEC ; Not reduced, skip extra decrement
                        
                            ; LMR applies - decrement depth by 1 MORE (depth now = original - 2)
   213c   68 cd 64 17       RLDI 13, SEARCH_DEPTH + 1
   2140   0d                LDN 13              ; D = depth low
   2141   ff 01             SMI 1
   2143   5d                STR 13              ; depth_lo--
   2144   2d                DEC 13              ; Point to high byte
   2145   0d                LDN 13              ; D = depth high
   2146   7f 00             SMBI 0              ; Subtract borrow
   2148   5d                STR 13              ; depth_hi-- (with borrow)
                        
   2149                 LMR_NO_EXTRA_DEC:
                            ; -----------------------------------------------
                            ; Check extension: if move gives check AND depth is
                            ; at the horizon (depth <= 0 after decrement), undo
                            ; the decrement so checking move stays in main search
                            ; where checkmate can be detected (QS can't detect it)
                            ; -----------------------------------------------
   2149   68 ca 64 da       RLDI 10, CHECK_EXT_FLAG
   214d   0a                LDN 10              ; D = check flag
   214e   c2 21 6a          LBZ CE_DONE         ; Not giving check, skip
                        
                            ; Ply guard: don't extend if ply >= 4 (child would be ply 5).
                            ; With MAX_PLY=8 and MOVE_LIST sized for 5 plies + QS scratch beyond,
                            ; ply 4 extending to 5 stays within bounds.
   2151   68 ca 64 48       RLDI 10, CURRENT_PLY
   2155   0a                LDN 10              ; D = current ply
   2156   ff 04             SMI 4
   2158   c3 21 6a          LBDF CE_DONE        ; ply >= 4, skip extension
                        
                            ; Only extend at horizon: depth <= 0 after decrement
   215b   68 cd 64 16       RLDI 13, SEARCH_DEPTH
   215f   4d                LDA 13              ; D = depth_hi
   2160   ca 21 6a          LBNZ CE_DONE        ; depth_hi != 0, not at horizon
   2163   0d                LDN 13              ; D = depth_lo
   2164   ca 21 6a          LBNZ CE_DONE        ; depth_lo != 0, not at horizon
                        
                            ; Depth is 0 — about to drop to QS. Undo decrement (+1)
   2167   f8 01             LDI 1
   2169   5d                STR 13              ; depth_lo = 1
                            ; depth_hi stays 0 (already confirmed)
                        
   216a                 CE_DONE:
                            ; -----------------------------------------------
                            ; Negate and swap alpha/beta (memory-based - R6 is SCRT linkage!)
                            ; -----------------------------------------------
                            ; For negamax: score = -negamax(depth-1, -beta, -alpha, -color)
                        
                            ; Save current alpha and beta from memory to stack
                            ; Load alpha from memory (big-endian: HI at lower address)
   216a   68 cd 64 42       RLDI 13, ALPHA_HI
   216e   4d                LDA 13              ; D = alpha_hi
   216f   73                STXD
   2170   0d                LDN 13              ; D = alpha_lo
   2171   73                STXD
                            ; Load beta from memory (big-endian: HI at lower address)
   2172   68 cd 64 44       RLDI 13, BETA_HI
   2176   4d                LDA 13              ; D = beta_hi
   2177   73                STXD
   2178   0d                LDN 13              ; D = beta_lo
   2179   73                STXD
                            ; Stack now has: [beta_lo][beta_hi][alpha_lo][alpha_hi][depth]...
                        
                            ; -----------------------------------------------
                            ; Save UNDO_* to stack (7 bytes) for recursive safety
                            ; Child calls will overwrite UNDO_*, so we must save it
                            ; Push LAST so it gets popped FIRST (LIFO order!)
                            ; -----------------------------------------------
   217a   68 ca 64 08       RLDI 10, UNDO_CAPTURED
   217e   4a                LDA 10              ; UNDO_CAPTURED
   217f   73                STXD
   2180   4a                LDA 10              ; UNDO_FROM
   2181   73                STXD
   2182   4a                LDA 10              ; UNDO_TO
   2183   73                STXD
   2184   4a                LDA 10              ; UNDO_CASTLING
   2185   73                STXD
   2186   4a                LDA 10              ; UNDO_EP
   2187   73                STXD
   2188   0a                LDN 10              ; UNDO_HALFMOVE
   2189   73                STXD
                            ; UNDO_PROMOTION is at $6404 (not contiguous)
   218a   68 ca 64 04       RLDI 10, UNDO_PROMOTION
   218e   0a                LDN 10              ; UNDO_PROMOTION
   218f   73                STXD
                            ; UNDO_CAP_SQ is at $64FF (not contiguous)
   2190   68 ca 64 ff       RLDI 10, UNDO_CAP_SQ
   2194   0a                LDN 10              ; UNDO_CAP_SQ
   2195   73                STXD
                        
                            ; -----------------------------------------------
                            ; Save BEST_SCORE to stack (2 bytes) for recursive safety
                            ; Child calls will reinitialize BEST_SCORE to -infinity!
                            ; -----------------------------------------------
   2196   68 ca 64 0e       RLDI 10, BEST_SCORE_HI
   219a   4a                LDA 10              ; BEST_SCORE_HI
   219b   73                STXD
   219c   0a                LDN 10              ; BEST_SCORE_LO
   219d   73                STXD
                            ; Stack now has: [BEST_SCORE][UNDO_CAP_SQ][UNDO_*][beta][alpha][depth][R9]...
                        
                            ; Negate beta from memory → R7 = -beta (new alpha)
                            ; Read low byte first for borrow propagation, then high byte
   219e   68 cd 64 45       RLDI 13, BETA_LO
   21a2   0d                LDN 13              ; low byte (BETA_LO at higher address)
   21a3   fd 00             SDI 0               ; negate low
   21a5   a7                PLO 7
   21a6   2d                DEC 13              ; → BETA_HI (lower address)
   21a7   0d                LDN 13              ; high byte
   21a8   7d 00             SDBI 0              ; negate high with borrow
   21aa   b7                PHI 7               ; R7 = -beta
                        
                            ; Negate alpha from memory → R8 = -alpha (new beta)
   21ab   68 cd 64 43       RLDI 13, ALPHA_LO
   21af   0d                LDN 13              ; low byte (ALPHA_LO at higher address)
   21b0   fd 00             SDI 0               ; negate low
   21b2   a8                PLO 8
   21b3   2d                DEC 13              ; → ALPHA_HI (lower address)
   21b4   0d                LDN 13              ; high byte
   21b5   7d 00             SDBI 0              ; negate high with borrow
   21b7   b8                PHI 8               ; R8 = -alpha
                        
                            ; Now swap: new_alpha = -beta (in R7), new_beta = -alpha (in R8)
                            ; Store to memory (big-endian: high byte at lower address)
   21b8   68 cd 64 42       RLDI 13, ALPHA_HI
   21bc   97                GHI 7
   21bd   5d                STR 13              ; ALPHA_HI = -beta high
   21be   1d                INC 13
   21bf   87                GLO 7
   21c0   5d                STR 13              ; ALPHA_LO = -beta low
                        
   21c1   68 cd 64 44       RLDI 13, BETA_HI
   21c5   98                GHI 8
   21c6   5d                STR 13              ; BETA_HI = -alpha high
   21c7   1d                INC 13
   21c8   88                GLO 8
   21c9   5d                STR 13              ; BETA_LO = -alpha low
                        
                            ; Toggle color (C): 0=white, 8=black (matches COLOR_MASK)
   21ca   8c                GLO 12
   21cb   fb 08             XRI $08             ; Toggle between 0 and 8
   21cd   ac                PLO 12
                        
                            ; Increment ply counter before recursion
   21ce   68 ca 64 48       RLDI 10, CURRENT_PLY
   21d2   0a                LDN 10
   21d3   fc 01             ADI 1
   21d5   5a                STR 10              ; CURRENT_PLY++
                        
                            ; -----------------------------------------------
                            ; Push LMR state to stack (overwritten by recursive call)
                            ; -----------------------------------------------
                            ; Push LMR_MOVE_INDEX first (popped last)
   21d6   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   21da   0a                LDN 10              ; D = LMR_MOVE_INDEX
   21db   73                STXD                ; Push to stack
                            ; Push LMR_REDUCED second (popped first)
   21dc   68 ca 64 a4       RLDI 10, LMR_REDUCED
   21e0   0a                LDN 10              ; D = LMR_REDUCED flag
   21e1   73                STXD                ; Push to stack
                        
                            ; -----------------------------------------------
                            ; Recursive call to NEGAMAX
                            ; -----------------------------------------------
   21e2   d4 1b 58          CALL NEGAMAX
                            ; Returns score in R9 (R6 is SCRT linkage - off limits!)
                        
                            ; DIAG stamp (2026-07-17 hang hunt): post-child bookkeeping window
                            ; (LMR pops, score negate, alpha/beta, killer store, next-move fetch).
   21e5   68 ca 64 1d       RLDI 10, TRACE_WHERE
   21e9   f8 a2             LDI $A2
   21eb   5a                STR 10              ; tracer: back from child (R10 reloaded below)
                        
                            ; -----------------------------------------------
                            ; Pop LMR state (reverse order)
                            ; -----------------------------------------------
                            ; Pop LMR_REDUCED and save to LMR_OUTER
   21ec   60                IRX
   21ed   f0                LDX                 ; D = saved LMR_REDUCED (R2 stays at this slot)
   21ee   a7                PLO 7               ; Save in R7.0 (temp)
   21ef   68 ca 64 a6       RLDI 10, LMR_OUTER
   21f3   87                GLO 7               ; Restore LMR_REDUCED value
   21f4   5a                STR 10              ; LMR_OUTER = saved LMR_REDUCED
                            ; Pop LMR_MOVE_INDEX and restore to memory
   21f5   60                IRX
   21f6   f0                LDX                 ; D = saved LMR_MOVE_INDEX
   21f7   a7                PLO 7               ; Temp in R7.0
   21f8   68 ca 64 a3       RLDI 10, LMR_MOVE_INDEX
   21fc   87                GLO 7
   21fd   5a                STR 10              ; LMR_MOVE_INDEX restored
                        
                            ; Decrement ply counter after recursion
   21fe   68 ca 64 48       RLDI 10, CURRENT_PLY
   2202   0a                LDN 10
   2203   ff 01             SMI 1
   2205   5a                STR 10              ; CURRENT_PLY--
                        
                            ; Negate R9 (score = -score)
   2206   89                GLO 9               ; low byte
   2207   fd 00             SDI 0               ; negate low
   2209   a9                PLO 9
   220a   99                GHI 9               ; high byte
   220b   7d 00             SDBI 0              ; negate high with borrow
   220d   b9                PHI 9
                        
                            ; Save negated score to SCORE_HI/LO (R9 clobbered by stack pops)
   220e   68 ca 64 46       RLDI 10, SCORE_HI
   2212   99                GHI 9               ; high byte → SCORE_HI (lower address)
   2213   5a                STR 10
   2214   1a                INC 10
   2215   89                GLO 9               ; low byte → SCORE_LO (higher address)
   2216   5a                STR 10
                        
                            ; -----------------------------------------------
                            ; LMR Re-search Check: Did reduced search beat alpha?
                            ; -----------------------------------------------
                            ; Read LMR_OUTER from memory (LMR_REDUCED was cleared by recursive call)
   2217   68 ca 64 a6       RLDI 10, LMR_OUTER
   221b   0a                LDN 10              ; D = LMR_OUTER flag
   221c   c2 22 f3          LBZ LMR_NO_RESEARCH ; Not reduced, skip re-search check
                        
