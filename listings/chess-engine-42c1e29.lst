   146b   f4                ADD                 ; R9.0 + bonus
   146c   a9                PLO 9
   146d   99                GHI 9
   146e   7c 00             ADCI 0
   1470   b9                PHI 9               ; R9 += white pawn bonus
   1471                 EG_NO_W_ADV:
                        
                            ; Black advanced pawn bonus (accumulated)
                            ; No conversion-phase scaling on opponent pawns: we want full sensitivity
                            ; to enemy promotion threats even when we've lost our queen.
   1471   68 cb 64 fe       RLDI 11, ADV_PAWN_B
   1475   0b                LDN 11
   1476   c2 14 81          LBZ EG_NO_B_ADV     ; none, skip
   1479   52                STR 2               ; save bonus on stack
