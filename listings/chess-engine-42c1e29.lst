   0780   c0 05 2b          LBR GEN_SKIP_SQUARE
                        
                        ; ==============================================================================
                        ; GEN_BISHOP, GEN_ROOK, GEN_QUEEN - Use direction-specific sliding functions
                        ; ==============================================================================
   0783                 GEN_BISHOP:
   0783   d4 07 e3          CALL GEN_SLIDE_NE
   0786   d4 08 cd          CALL GEN_SLIDE_NW
   0789   d4 08 31          CALL GEN_SLIDE_SE
   078c   d4 08 7f          CALL GEN_SLIDE_SW
   078f   c0 05 2b          LBR GEN_SKIP_SQUARE
                        
   0792                 GEN_ROOK:
   0792   d4 07 bc          CALL GEN_SLIDE_N
   0795   d4 08 58          CALL GEN_SLIDE_S
   0798   d4 08 0a          CALL GEN_SLIDE_E
   079b   d4 08 a6          CALL GEN_SLIDE_W
   079e   c0 05 2b          LBR GEN_SKIP_SQUARE
                        
   07a1                 GEN_QUEEN:
   07a1   d4 07 bc          CALL GEN_SLIDE_N
   07a4   d4 07 e3          CALL GEN_SLIDE_NE
   07a7   d4 08 0a          CALL GEN_SLIDE_E
   07aa   d4 08 31          CALL GEN_SLIDE_SE
   07ad   d4 08 58          CALL GEN_SLIDE_S
   07b0   d4 08 7f          CALL GEN_SLIDE_SW
   07b3   d4 08 a6          CALL GEN_SLIDE_W
   07b6   d4 08 cd          CALL GEN_SLIDE_NW
   07b9   c0 05 2b          LBR GEN_SKIP_SQUARE
                        
                        ; ==============================================================================
                        ; GEN_SLIDE_* - Direction-specific sliding (no stack math)
                        ; ==============================================================================
                        ; Each function handles one direction with hardcoded ADI
                        ; R11.1 = from square (survives CALLs), R7.0 = current position
                        ; Direction offsets: N=$10, NE=$11, E=$01, SE=$F1, S=$F0, SW=$EF, W=$FF, NW=$0F
                        ; ==============================================================================
                        
                        ; --- GEN_SLIDE_N: North (+$10) ---
   07bc                 GEN_SLIDE_N:
   07bc   9b                GHI 11
   07bd   a7                PLO 7               ; R7.0 = current position = from
   07be                 GEN_SLIDE_N_LOOP:
   07be   87                GLO 7
   07bf   fc 10             ADI $10             ; next = current + $10
   07c1   a7                PLO 7               ; R7.0 = target
   07c2   fa 88             ANI $88
   07c4   ca 07 e2          LBNZ GEN_SLIDE_N_RET
   07c7   87                GLO 7               ; Get target back (ANI destroyed D)
   07c8   ab                PLO 11              ; R11.0 = target (for CHECK_TARGET_SQUARE)
   07c9   d4 03 65          CALL CHECK_TARGET_SQUARE
   07cc   ab                PLO 11              ; Save result to R11.0 (R8 clobbered by ADD_MOVE_ENCODED)
   07cd   c2 07 e2          LBZ GEN_SLIDE_N_RET
   07d0   9b                GHI 11
   07d1   bd                PHI 13
   07d2   87                GLO 7
   07d3   ad                PLO 13
   07d4   f8 00             LDI MOVE_NORMAL
   07d6   d4 03 e9          CALL ADD_MOVE_ENCODED
   07d9   8b                GLO 11              ; Get result from R11.0
   07da   fb 02             XRI 2
   07dc   c2 07 e2          LBZ GEN_SLIDE_N_RET  ; Capture, stop
   07df   c0 07 be          LBR GEN_SLIDE_N_LOOP
   07e2                 GEN_SLIDE_N_RET:
   07e2   d5                RETN
                        
                        ; --- GEN_SLIDE_NE: Northeast (+$11) ---
   07e3                 GEN_SLIDE_NE:
   07e3   9b                GHI 11
   07e4   a7                PLO 7
   07e5                 GEN_SLIDE_NE_LOOP:
   07e5   87                GLO 7
   07e6   fc 11             ADI $11
   07e8   a7                PLO 7
   07e9   fa 88             ANI $88
   07eb   ca 08 09          LBNZ GEN_SLIDE_NE_RET
   07ee   87                GLO 7
   07ef   ab                PLO 11
   07f0   d4 03 65          CALL CHECK_TARGET_SQUARE
   07f3   ab                PLO 11              ; Save result to R11.0
   07f4   c2 08 09          LBZ GEN_SLIDE_NE_RET
   07f7   9b                GHI 11
   07f8   bd                PHI 13
   07f9   87                GLO 7
   07fa   ad                PLO 13
   07fb   f8 00             LDI MOVE_NORMAL
   07fd   d4 03 e9          CALL ADD_MOVE_ENCODED
   0800   8b                GLO 11              ; Get result from R11.0
   0801   fb 02             XRI 2
   0803   c2 08 09          LBZ GEN_SLIDE_NE_RET
   0806   c0 07 e5          LBR GEN_SLIDE_NE_LOOP
   0809                 GEN_SLIDE_NE_RET:
   0809   d5                RETN
                        
                        ; --- GEN_SLIDE_E: East (+$01) ---
   080a                 GEN_SLIDE_E:
   080a   9b                GHI 11
   080b   a7                PLO 7
   080c                 GEN_SLIDE_E_LOOP:
   080c   87                GLO 7
   080d   fc 01             ADI $01
   080f   a7                PLO 7
   0810   fa 88             ANI $88
   0812   ca 08 30          LBNZ GEN_SLIDE_E_RET
   0815   87                GLO 7
   0816   ab                PLO 11
   0817   d4 03 65          CALL CHECK_TARGET_SQUARE
   081a   ab                PLO 11              ; Save result to R11.0
   081b   c2 08 30          LBZ GEN_SLIDE_E_RET
   081e   9b                GHI 11
   081f   bd                PHI 13
   0820   87                GLO 7
   0821   ad                PLO 13
   0822   f8 00             LDI MOVE_NORMAL
   0824   d4 03 e9          CALL ADD_MOVE_ENCODED
   0827   8b                GLO 11              ; Get result from R11.0
   0828   fb 02             XRI 2
   082a   c2 08 30          LBZ GEN_SLIDE_E_RET
   082d   c0 08 0c          LBR GEN_SLIDE_E_LOOP
   0830                 GEN_SLIDE_E_RET:
   0830   d5                RETN
                        
                        ; --- GEN_SLIDE_SE: Southeast (+$F1 = -$0F) ---
   0831                 GEN_SLIDE_SE:
   0831   9b                GHI 11
