   0ae3   68 c9 64 0a       RLDI 9, UNDO_TO
   0ae7   09                LDN 9               ; D = to square
   0ae8   ff 01             SMI 1                ; D = to - 1 (rook's new square)
   0aea   b8                PHI 8               ; R8.1 = new rook square
   0aeb   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
   0aee   c0 0b 1e          LBR MM_CASTLE_DONE
                        
   0af1                 MM_CASTLE_QS:
                            ; Queenside: rook from to-2 (a-file) to to+1 (d-file)
   0af1   68 c9 64 0a       RLDI 9, UNDO_TO
   0af5   09                LDN 9               ; D = to square
                        
                            ; Read rook from BOARD[to-2]
   0af6   ff 02             SMI 2                ; D = to - 2
   0af8   a8                PLO 8
   0af9   f8 60             LDI HIGH(BOARD)
   0afb   b8                PHI 8               ; R8 = &BOARD[to-2]
   0afc   08                LDN 8               ; D = rook piece
   0afd   bd                PHI 13              ; R13.1 = rook piece (temp)
   0afe   f8 00             LDI EMPTY
   0b00   58                STR 8               ; Clear rook's old square (a1/a8)
                        
                            ; Place rook at BOARD[to+1]
   0b01   09                LDN 9               ; D = to square (reload from UNDO_TO)
   0b02   fc 01             ADI 1                ; D = to + 1
   0b04   a8                PLO 8
   0b05   f8 60             LDI HIGH(BOARD)
   0b07   b8                PHI 8               ; R8 = &BOARD[to+1]
   0b08   9d                GHI 13              ; D = rook piece
   0b09   58                STR 8               ; Place rook at d1/d8
                        
                            ; Hash: XOR out [rook, to-2]
   0b0a   9d                GHI 13              ; D = rook piece
   0b0b   a8                PLO 8               ; R8.0 = rook piece
   0b0c   09                LDN 9               ; D = to square
   0b0d   ff 02             SMI 2                ; D = to - 2 (rook's old square)
   0b0f   b8                PHI 8               ; R8.1 = old rook square
   0b10   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
                            ; Hash: XOR in [rook, to+1] (R8.0 preserved by HASH_XOR)
   0b13   68 c9 64 0a       RLDI 9, UNDO_TO
   0b17   09                LDN 9               ; D = to square
   0b18   fc 01             ADI 1                ; D = to + 1 (rook's new square)
   0b1a   b8                PHI 8               ; R8.1 = new rook square
   0b1b   d4 58 05          CALL HASH_XOR_PIECE_SQ
                        
   0b1e                 MM_CASTLE_DONE:
                            ; Reload R10 (clobbered by HASH_XOR_PIECE_SQ)
   0b1e   68 c9 64 0a       RLDI 9, UNDO_TO
   0b22   09                LDN 9               ; D = to square
   0b23   a8                PLO 8
   0b24   f8 60             LDI HIGH(BOARD)
   0b26   b8                PHI 8               ; R8 = &BOARD[to]
   0b27   08                LDN 8               ; D = king piece
   0b28   aa                PLO 10              ; R10.0 = moving piece
   0b29   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0b2d   09                LDN 9               ; D = captured piece
   0b2e   ba                PHI 10              ; R10.1 = captured piece
                            ; Fall through to MM_NOT_KING
                        
   0b2f                 MM_NOT_KING:
                            ; Clear the from square
   0b2f   68 c9 64 02       RLDI 9, MOVE_FROM
   0b33   09                LDN 9               ; D = from square
   0b34   a8                PLO 8
   0b35   f8 60             LDI HIGH(BOARD)
   0b37   b8                PHI 8               ; R8 = &BOARD[from]
   0b38   f8 00             LDI EMPTY
   0b3a   58                STR 8               ; Clear from square
                        
