   14c9   0a                LDN 10
   14ca   52                STR 2
   14cb   87                GLO 7
   14cc   f7                SM                      ; delta -= W_QUEEN_CNT  (D=delta, M=wq, SM=D-M)
   14cd   a7                PLO 7
   14ce   c2 14 db          LBZ OG_NOT              ; delta == 0 -> not outgunned
   14d1   fa 80             ANI $80
   14d3   ca 14 db          LBNZ OG_NOT             ; delta < 0 (white ahead) -> not outgunned
   14d6   f8 01             LDI 1
   14d8   c0 14 dd          LBR OG_STORE
   14db                 OG_NOT:
   14db   f8 00             LDI 0
   14dd                 OG_STORE:
