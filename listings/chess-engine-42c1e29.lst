   13aa                 EVAL_BR_DONE:
                        
                            ; ==================================================================
                            ; Endgame phase eval (king centralization, advanced pawn, passed pawn,
                            ; king-edge drive) — gated by EG_PIECE_COUNT threshold.
                            ; Tightened 2026-04-30 from <21 to <12: previously fired after only 9
                            ; captures (mid-middlegame), causing premature king-walking with d=5
                            ; search exposing inappropriate king-centralization variations. <12
                            ; requires 18 captures, true late-endgame territory where king activity
                            ; and pawn promotion drives are actually correct strategy.
                            ; ==================================================================
                        
   13aa   68 cb 64 ec       RLDI 11, EG_PIECE_COUNT
   13ae   0b                LDN 11              ; D = piece count
   13af   ff 0c             SMI 12              ; compare: count - 12
   13b1   c3 17 9b          LBDF BKS_DONE       ; DF=1 means count >= 12, not endgame, skip
                        
                            ; ==================================================================
                            ; Hopeless-material amplifier (re-added 2026-06-10, LOSING-side only).
                            ; Goal: end clearly-lost endgames via cutechess's -1500/10-move resign
                            ; adjudication instead of 100-move shuffles (which were averaging 2h/match
                            ; and choking the hang hunt). At this point R9 = material+PST+minor
                            ; positional, BEFORE the advanced/passed-pawn bonuses (applied below at
                            ; ADV_PAWN_W/B ~1271/1297) -- so R9 here is a stable preeg-like signal that
                            ; ignores the pawn-promotion inflation that lets ELPH misread lost K+P-vs-
                            ; K+B+P as ~0. Trigger: pc<=6 AND R9 <= -300 (down ~a minor in a sparse
                            ; endgame = lost) -> R9 -= 2000. Losing-side ONLY (winning-side amp caused
                            ; search volatility, see 5966070); never fires when winning or in the
                            ; opening (pc>=12 already skipped to BKS_DONE). Inert vs the hang (endgame
                            ; only). Only amps genuinely-lost leaves, so a saving line (R9 > -300) is
                            ; never over-resigned.
                            ; ==================================================================
   13b4   68 cb 64 ec       RLDI 11, EG_PIECE_COUNT
   13b8   0b                LDN 11
   13b9   ff 07             SMI 7               ; pc - 7; DF=1 if pc >= 7
   13bb   c3 13 d7          LBDF HM_AMP_DONE    ; pc > 6, skip amp
   13be   99                GHI 9
   13bf   fa 80             ANI $80
   13c1   c2 13 d7          LBZ HM_AMP_DONE     ; R9 >= 0 (not losing), skip
   13c4   89                GLO 9
   13c5   fc fa             ADI LOW(250)        ; R9 + 250 (DF = carry); -250 margin so down-a-clean-minor fires
   13c7   99                GHI 9
   13c8   7c 00             ADCI HIGH(250)      ; D = (R9 + 250) high byte
   13ca   fa 80             ANI $80
   13cc   c2 13 d7          LBZ HM_AMP_DONE     ; (R9 + 250) >= 0 -> R9 >= -250, not hopeless, skip
   13cf   89                GLO 9               ; hopeless: R9 -= 2000
   13d0   ff d0             SMI LOW(2000)
   13d2   a9                PLO 9
   13d3   99                GHI 9
   13d4   7f 07             SMBI HIGH(2000)
   13d6   b9                PHI 9
   13d7                 HM_AMP_DONE:
                        
                            ; === White king centralization ===
   13d7   68 ca 60 86       RLDI 10, GAME_STATE + STATE_W_KING_SQ
   13db   0a                LDN 10              ; D = white king 0x88 square
                            ; Convert 0x88 to 0-63 index
   13dc   ad                PLO 13              ; save square
   13dd   f6                SHR
   13de   f6                SHR
   13df   f6                SHR
   13e0   f6                SHR                 ; D = rank (0-7)
   13e1   fe                SHL
   13e2   fe                SHL
   13e3   fe                SHL                 ; D = rank * 8
   13e4   73                STXD                ; push rank*8
   13e5   8d                GLO 13
   13e6   fa 07             ANI $07             ; D = file (0-7)
   13e8   60                IRX
   13e9   f4                ADD                 ; D = rank*8 + file = index
   13ea   af                PLO 15              ; save white king index in R15.0
                            ; Look up centralization value
   13eb   52                STR 2               ; save index on stack
   13ec   68 cb 1a d0       RLDI 11, KING_CENTER_TABLE
   13f0   8b                GLO 11
   13f1   f4                ADD                 ; D = LOW(table) + index
   13f2   ab                PLO 11
   13f3   9b                GHI 11
   13f4   7c 00             ADCI 0
   13f6   bb                PHI 11              ; R11 = &KING_CENTER_TABLE[index]
   13f7   0b                LDN 11              ; D = table value (-30 to +30)
   13f8   fe                SHL                 ; D = value * 2
   13f9   fe                SHL                 ; D = value * 4 (-120 to +120)
                            ; Sign-extend to 16 bits and add to R9
   13fa   a7                PLO 7               ; R7.0 = bonus low byte
   13fb   fa 80             ANI $80             ; check sign
   13fd   c2 14 05          LBZ EG_W_POS
   1400   f8 ff             LDI $FF
