   0765   d4 03 e9          CALL ADD_MOVE_ENCODED
                        
   0768                 GEN_KN_DIR8:
                            ; --- Direction 8: SWW (+$EE = -$12) ---
   0768   9b                GHI 11
   0769   fc ee             ADI $EE
   076b   ab                PLO 11
   076c   fa 88             ANI $88
   076e   ca 07 80          LBNZ GEN_KN_DONE
   0771   d4 03 65          CALL CHECK_TARGET_SQUARE
   0774   c2 07 80          LBZ GEN_KN_DONE
   0777   9b                GHI 11
