                        ;       FROM handles rook moving away; TO handles rook being captured.
                        ; ------------------------------------------------------------------------------
   0c06                 MM_ROOK_HOME_CHECK:
   0c06   c2 0c 19          LBZ MMRHC_A1         ; $00 = a1 → white queenside
   0c09   fb 07             XRI $07
   0c0b   c2 0c 1e          LBZ MMRHC_H1         ; $07 = h1 → white kingside
   0c0e   fb 77             XRI $77
   0c10   c2 0c 23          LBZ MMRHC_A8         ; $70 = a8 → black queenside
   0c13   fb 07             XRI $07
   0c15   c2 0c 28          LBZ MMRHC_H8         ; $77 = h8 → black kingside
   0c18   d5                RETN                 ; No match, return
                        
   0c19                 MMRHC_A1:
   0c19   f8 02             LDI CASTLE_WQ        ; $02
   0c1b   c0 0c 2a          LBR MMRHC_CLEAR
                        
   0c1e                 MMRHC_H1:
   0c1e   f8 01             LDI CASTLE_WK        ; $01
   0c20   c0 0c 2a          LBR MMRHC_CLEAR
                        
   0c23                 MMRHC_A8:
   0c23   f8 08             LDI CASTLE_BQ        ; $08
   0c25   c0 0c 2a          LBR MMRHC_CLEAR
                        
   0c28                 MMRHC_H8:
   0c28   f8 04             LDI CASTLE_BK        ; $04
                        
   0c2a                 MMRHC_CLEAR:
   0c2a   d4 01 5c          CALL CLEAR_CASTLING_RIGHT
   0c2d   d5                RETN
                        
                        ; ==============================================================================
                        ; UNMAKE_MOVE - Reverse the last move
                        ; Input: Undo info from previous MAKE_MOVE
