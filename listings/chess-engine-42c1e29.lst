   0b43   18                INC 8               ; $6081 = STATE_CASTLING
   0b44   18                INC 8               ; $6082 = STATE_EP_SQUARE
                        
                            ; Check if moving piece is a pawn
   0b45   8a                GLO 10              ; D = moving piece
   0b46   fa 07             ANI PIECE_MASK      ; piece type
   0b48   fb 01             XRI PAWN_TYPE
   0b4a   ca 0b 82          LBNZ MM_EP_CLEAR    ; Not a pawn -> clear EP
                        
                            ; Pawn moved. Check rank difference = $20 (double push)
   0b4d   68 c9 64 09       RLDI 9, UNDO_FROM
   0b51   09                LDN 9               ; D = from
   0b52   fa 70             ANI $70             ; from rank
   0b54   ad                PLO 13              ; R13.0 = from rank
   0b55   68 c9 64 0a       RLDI 9, UNDO_TO
   0b59   09                LDN 9               ; D = to
   0b5a   fa 70             ANI $70             ; to rank
   0b5c   52                STR 2
   0b5d   8d                GLO 13              ; D = from rank
   0b5e   f7                SM                  ; D = from_rank - to_rank
                        
                            ; White double push: from_rank - to_rank = $E0 (-$20)
                            ; Black double push: from_rank - to_rank = $20
   0b5f   fb e0             XRI $E0
   0b61   c2 0b 6c          LBZ MM_EP_WHITE     ; White pawn double push
   0b64   fb c0             XRI $C0             ; XOR chain: $20 XOR $E0 = $C0, XOR $C0 = 0
   0b66   c2 0b 77          LBZ MM_EP_BLACK     ; Black pawn double push
   0b69   c0 0b 82          LBR MM_EP_CLEAR     ; Not a double push
                        
   0b6c                 MM_EP_WHITE:
                            ; EP square = to + DIR_N ($F0) = one rank above destination
   0b6c   68 c9 64 0a       RLDI 9, UNDO_TO
   0b70   09                LDN 9
   0b71   fc f0             ADI DIR_N           ; to - $10 (square pawn passed through)
   0b73   58                STR 8               ; STATE_EP_SQUARE = EP target
   0b74   c0 0b 85          LBR MM_EP_DONE
                        
   0b77                 MM_EP_BLACK:
                            ; EP square = to + DIR_S ($10) = one rank below destination
   0b77   68 c9 64 0a       RLDI 9, UNDO_TO
   0b7b   09                LDN 9
   0b7c   fc 10             ADI DIR_S           ; to + $10 (square pawn passed through)
   0b7e   58                STR 8               ; STATE_EP_SQUARE = EP target
   0b7f   c0 0b 85          LBR MM_EP_DONE
                        
   0b82                 MM_EP_CLEAR:
   0b82   f8 ff             LDI NO_EP
   0b84   58                STR 8
                        
   0b85                 MM_EP_DONE:
                        
                            ; ===========================================
                            ; FIFTY-MOVE RULE: Update halfmove clock
                            ; ===========================================
                            ; Reset to 0 if: capture or pawn move
                            ; Otherwise: increment
                            ; R10.0 = moving piece, R10.1 = captured piece
                        
   0b85   18                INC 8               ; Point to HALFMOVE
                        
                            ; Check if capture occurred (R10.1 != EMPTY)
   0b86   9a                GHI 10              ; Get captured piece
   0b87   ca 0b 99          LBNZ MM_RESET_HALFMOVE
                        
                            ; Check if pawn moved (piece type == PAWN_TYPE)
   0b8a   8a                GLO 10              ; Get moving piece
   0b8b   fa 07             ANI PIECE_MASK      ; Get piece type
   0b8d   fb 01             XRI PAWN_TYPE       ; Is it a pawn?
   0b8f   c2 0b 99          LBZ MM_RESET_HALFMOVE
                        
