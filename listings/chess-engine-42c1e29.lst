   083e   d4 03 65          CALL CHECK_TARGET_SQUARE
   0841   ab                PLO 11              ; Save result to R11.0
   0842   c2 08 57          LBZ GEN_SLIDE_SE_RET
   0845   9b                GHI 11
   0846   bd                PHI 13
   0847   87                GLO 7
   0848   ad                PLO 13
   0849   f8 00             LDI MOVE_NORMAL
   084b   d4 03 e9          CALL ADD_MOVE_ENCODED
   084e   8b                GLO 11              ; Get result from R11.0
