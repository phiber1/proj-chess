   0b93   fc 01             ADI 1               ; Increment
   0b95   58                STR 8               ; Store back
   0b96   c0 0b 9c          LBR MM_ROOK_CHECK
                        
   0b99                 MM_RESET_HALFMOVE:
                            ; Reset halfmove clock to 0
