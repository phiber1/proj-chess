   14a7   f4                ADD                     ; delta += B_QUEEN_CNT
   14a8   a7                PLO 7
   14a9   68 ca 64 b1       RLDI 10, EVAL_W_ROOK_F1
   14ad   0a                LDN 10
   14ae   fb ff             XRI $FF
   14b0   c2 14 b7          LBZ OG_W2               ; no white rook in slot 1
   14b3   87                GLO 7
   14b4   ff 01             SMI 1
   14b6   a7                PLO 7
   14b7                 OG_W2:
