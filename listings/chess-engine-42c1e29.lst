   0bc6   68 ca 64 0a       RLDI 10, UNDO_TO
   0bca   0a                LDN 10              ; D = to_square
   0bcb   fc 00             ADI LOW(BOARD)
   0bcd   aa                PLO 10
   0bce   f8 60             LDI HIGH(BOARD)
   0bd0   7c 00             ADCI 0
   0bd2   ba                PHI 10              ; R10 = &BOARD[to_square]
   0bd3   0a                LDN 10              ; D = moving piece
   0bd4   a8                PLO 8               ; R8.0 = moving piece
                        
