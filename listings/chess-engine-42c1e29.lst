   09b4                 GEN_KG_CASTLING:
                            ; Add castling moves (R11.1 still has king square)
   09b4   9b                GHI 11              ; D = king square for castling check
   09b5   d4 04 29          CALL GEN_CASTLING_MOVES
                        
   09b8   c0 05 2b          LBR GEN_SKIP_SQUARE
                        
                        
                        ; ==============================================================================
                        ; End of Move Generation (Fixed)
                        ; ==============================================================================
                        ; ==============================================================================
                        ; MAKE/UNMAKE MOVE MODULE
                        ; ==============================================================================
                        
                        ; ------------------------------------------------------------------------------
                        ; Undo information - defined in board.asm as EQUs in RAM ($6408-$640D)
                        ; UNDO_CAPTURED, UNDO_FROM, UNDO_TO, UNDO_CASTLING, UNDO_EP, UNDO_HALFMOVE
                        ; These MUST be in RAM (not ROM) for read/write access!
                        ; ------------------------------------------------------------------------------
                        
                        ; ==============================================================================
                        ; MAKE_MOVE - Apply move to the board
                        ; Input: MOVE_FROM, MOVE_TO contain the move
                        ; Output: Board updated, undo info saved, hash updated
                        ;         D = 0 if success
                        ; ==============================================================================
   09bb                 MAKE_MOVE:
                            ; DIAG stamp (2026-07-17 hang hunt).
   09bb   68 c8 64 1d       RLDI 8, TRACE_WHERE
   09bf   f8 a3             LDI $A3
   09c1   58                STR 8               ; tracer: in MAKE_MOVE (R8 reloaded below)
                        
                            ; Save undo information
   09c2   68 c8 64 09       RLDI 8, UNDO_FROM
                        
                            ; Save from square
   09c6   68 c9 64 02       RLDI 9, MOVE_FROM
   09ca   09                LDN 9
   09cb   58                STR 8
   09cc   18                INC 8
                            
                            ; Save to square
   09cd   19                INC 9
   09ce   09                LDN 9               ; MOVE_TO
   09cf   58                STR 8
   09d0   18                INC 8
                            
                            ; Save castling rights from GAME_STATE + STATE_CASTLING
   09d1   68 c9 60 81       RLDI 9, GAME_STATE + STATE_CASTLING
   09d5   09                LDN 9
   09d6   58                STR 8
   09d7   18                INC 8
                        
                            ; Save en passant square from GAME_STATE + STATE_EP_SQUARE
   09d8   19                INC 9
   09d9   09                LDN 9
   09da   58                STR 8
   09db   18                INC 8
                        
                            ; Save halfmove clock from GAME_STATE + STATE_HALFMOVE
   09dc   19                INC 9
   09dd   09                LDN 9
   09de   58                STR 8
                        
                            ; Get the piece being moved
   09df   68 c9 64 02       RLDI 9, MOVE_FROM
   09e3   09                LDN 9               ; D = from square index
   09e4   a8                PLO 8
   09e5   f8 60             LDI HIGH(BOARD)
   09e7   b8                PHI 8               ; R8 = &BOARD[from]
   09e8   08                LDN 8               ; D = piece at from square
   09e9   aa                PLO 10              ; Save moving piece in R10.0
                        
                            ; Get captured piece at destination
   09ea   68 c9 64 03       RLDI 9, MOVE_TO
   09ee   09                LDN 9               ; D = to square index
   09ef   a8                PLO 8
   09f0   f8 60             LDI HIGH(BOARD)
   09f2   b8                PHI 8               ; R8 = &BOARD[to]
   09f3   08                LDN 8               ; D = piece at to square (captured)
                            
                            ; Save captured piece
   09f4   ba                PHI 10              ; Save in R10.1
   09f5   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   09f9   9a                GHI 10
   09fa   59                STR 9
                        
                            ; Save capture square (default = to, changed by EP)
   09fb   68 c9 64 ff       RLDI 9, UNDO_CAP_SQ
   09ff   68 cd 64 0a       RLDI 13, UNDO_TO
   0a03   0d                LDN 13
   0a04   59                STR 9               ; UNDO_CAP_SQ = MOVE_TO (default)
                        
                            ; Place moving piece at destination
   0a05   8a                GLO 10              ; Get moving piece
   0a06   58                STR 8               ; Store at to square (R8 still points there)
                        
                            ; =========================================
                            ; EN PASSANT CAPTURE
                            ; =========================================
                            ; Detect: pawn moves to saved EP square, BOARD[to] was empty
                            ; R10.1 = captured piece at BOARD[to], R10.0 = moving piece
   0a07   9a                GHI 10              ; captured piece
   0a08   ca 0a 56          LBNZ MM_NOT_EP_CAP  ; Normal capture (piece at to) -> skip
                        
   0a0b   8a                GLO 10              ; moving piece
   0a0c   fa 07             ANI PIECE_MASK
   0a0e   fb 01             XRI PAWN_TYPE
   0a10   ca 0a 56          LBNZ MM_NOT_EP_CAP  ; Not a pawn -> skip
                        
                            ; Pawn moved to empty square. Check if to == saved EP square.
   0a13   68 c9 64 0c       RLDI 9, UNDO_EP     ; EP square from BEFORE this move
   0a17   09                LDN 9               ; D = saved EP square
   0a18   fb ff             XRI NO_EP
   0a1a   c2 0a 56          LBZ MM_NOT_EP_CAP   ; No EP was active ($FF) -> skip
   0a1d   68 c9 64 0c       RLDI 9, UNDO_EP
   0a21   09                LDN 9               ; D = EP square
   0a22   52                STR 2
   0a23   68 c9 64 0a       RLDI 9, UNDO_TO
   0a27   09                LDN 9               ; D = to square
   0a28   f3                XOR
   0a29   ca 0a 56          LBNZ MM_NOT_EP_CAP  ; to != EP -> not en passant
                        
                            ; EP CAPTURE! Captured pawn at (from_rank | to_file)
   0a2c   68 c9 64 09       RLDI 9, UNDO_FROM
   0a30   09                LDN 9
   0a31   fa 70             ANI $70             ; from rank
   0a33   ad                PLO 13
   0a34   68 c9 64 0a       RLDI 9, UNDO_TO
   0a38   09                LDN 9
   0a39   fa 07             ANI $07             ; to file
   0a3b   52                STR 2
   0a3c   8d                GLO 13
   0a3d   f1                OR                  ; D = captured square
   0a3e   a8                PLO 8
   0a3f   f8 60             LDI HIGH(BOARD)
   0a41   b8                PHI 8               ; R8 = &BOARD[cap_sq]
                        
                            ; Read and save the captured pawn
   0a42   08                LDN 8               ; D = enemy pawn
   0a43   ba                PHI 10              ; R10.1 = captured pawn (update from EMPTY)
   0a44   68 c9 64 08       RLDI 9, UNDO_CAPTURED
   0a48   9a                GHI 10
   0a49   59                STR 9               ; UNDO_CAPTURED = enemy pawn
                        
                            ; Save EP capture square
   0a4a   88                GLO 8               ; D = cap_sq (low byte of R8)
   0a4b   73                STXD                ; push to stack
   0a4c   68 c9 64 ff       RLDI 9, UNDO_CAP_SQ
   0a50   60                IRX
   0a51   f0                LDX                 ; D = cap_sq
